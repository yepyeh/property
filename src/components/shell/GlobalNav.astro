---
import BrandLink from "./BrandLink.astro";
import AccountMenu from "./AccountMenu.astro";

interface NavItem {
  key?: string;
  label: string;
  href: string;
  active?: boolean;
  count?: number;
}

export interface Props {
  primaryNav: NavItem[];
  viewer?: unknown;
  viewerLabel: string;
  viewerRoleLabel: string;
  viewerInitials: string;
  accountMenu: NavItem[];
  postHref: string;
  postLabel: string;
  darkModeLabel: string;
  lightModeLabel: string;
  signInLabel: string;
  createAccountLabel: string;
  logOutLabel: string;
}

const {
  primaryNav,
  viewer,
  viewerLabel,
  viewerRoleLabel,
  viewerInitials,
  accountMenu,
  postHref,
  postLabel,
  darkModeLabel,
  lightModeLabel,
  signInLabel,
  createAccountLabel,
  logOutLabel,
} = Astro.props;
---

<header class="header-shell glass-effect">
  <BrandLink />

  <div class="flex items-center gap-s">
    <nav class="hidden items-center gap-xs md:flex">
      {primaryNav.map((item) => (
        <a
          class:list={[
            "luxury-transition inline-flex min-h-10 items-center justify-center rounded-full border border-transparent px-s py-xs text-sm font-medium no-underline",
            item.active
              ? "border-base bg-card text-white"
              : "text-muted-ui hover:border-base hover:bg-card hover:text-white",
          ]}
          href={item.href}
        >
          <span>{item.label}</span>
          {item.count ? (
            <span class="ml-xs inline-flex h-5 min-w-5 items-center justify-center rounded-full bg-accent px-[0.34rem] text-[0.68rem] font-semibold text-accent-foreground">
              {item.count > 9 ? "9+" : item.count}
            </span>
          ) : null}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-xs">
      <a class="btn-primary" href={postHref}>{postLabel}</a>
      {viewer ? (
        <AccountMenu
          viewerLabel={viewerLabel}
          viewerRoleLabel={viewerRoleLabel}
          viewerInitials={viewerInitials}
          accountMenu={accountMenu}
          darkModeLabel={darkModeLabel}
          lightModeLabel={lightModeLabel}
          logOutLabel={logOutLabel}
        />
      ) : null}
    </div>
  </div>
</header>
