---
import BrandLink from "./BrandLink.astro";
import AccountMenu from "./AccountMenu.astro";

interface NavItem {
  key?: string;
  label: string;
  href: string;
  active?: boolean;
  count?: number;
}

interface LocaleOption {
  code: string;
  label: string;
  nativeLabel: string;
  href: string;
  current: boolean;
  suggested: boolean;
}

export interface Props {
  primaryNav: NavItem[];
  viewer?: unknown;
  viewerLabel: string;
  viewerRoleLabel: string;
  viewerInitials: string;
  accountMenu: NavItem[];
  localeMeta: { code: string; nativeLabel: string };
  localeOptions: LocaleOption[];
  localeLabel: string;
  suggestedLabel: string;
  darkModeLabel: string;
  lightModeLabel: string;
  signInLabel: string;
  createAccountLabel: string;
  accountLabel: string;
  navigationLabel: string;
  shortcutsLabel: string;
  logOutLabel: string;
}

const {
  primaryNav,
  viewer,
  viewerLabel,
  viewerRoleLabel,
  viewerInitials,
  accountMenu,
  localeMeta,
  localeOptions,
  localeLabel,
  suggestedLabel,
  darkModeLabel,
  lightModeLabel,
  signInLabel,
  createAccountLabel,
  accountLabel,
  navigationLabel,
  shortcutsLabel,
  logOutLabel,
} = Astro.props;
---

<header class="global-nav card">
  <BrandLink />

  <div class="nav-cluster">
    <nav class="nav-links">
      {primaryNav.map((item) => (
        <a class:list={["nav-link", "link-with-count", item.active && "active"]} href={item.href}>
          <span>{item.label}</span>
          {item.count ? <span class="count-badge">{item.count > 9 ? "9+" : item.count}</span> : null}
        </a>
      ))}
    </nav>

    <div class="utility-links">
      <details class="locale-menu">
        <summary class="locale-summary">
          <span class="locale-label">{localeLabel}</span>
          <strong>{localeMeta.nativeLabel}</strong>
          <span class="chevron">▾</span>
        </summary>
        <div class="locale-panel">
          {localeOptions.map((option) => (
            <a class:list={["locale-item", option.current && "active"]} href={option.href}>
              <span>
                {option.nativeLabel}
                {option.code !== "en" ? <small>{option.label}</small> : null}
              </span>
              {option.suggested ? <em>{suggestedLabel}</em> : null}
            </a>
          ))}
        </div>
      </details>

      <button
        class="theme-toggle"
        type="button"
        data-theme-toggle
      >
        <span class="theme-toggle-icon" data-theme-icon>◐</span>
        <span data-theme-label data-theme-dark-label={darkModeLabel} data-theme-light-label={lightModeLabel}>{darkModeLabel}</span>
      </button>
      {viewer ? (
        <AccountMenu
          viewerLabel={viewerLabel}
          viewerRoleLabel={viewerRoleLabel}
          viewerInitials={viewerInitials}
          accountMenu={accountMenu}
          accountLabel={accountLabel}
          navigationLabel={navigationLabel}
          shortcutsLabel={shortcutsLabel}
          logOutLabel={logOutLabel}
        />
      ) : (
        <>
          <a class="auth-link" href="/login">{signInLabel}</a>
          <a class="auth-link primary" href="/signup?role=buyer">{createAccountLabel}</a>
        </>
      )}
    </div>
  </div>
</header>
