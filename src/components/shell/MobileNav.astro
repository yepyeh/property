---
import { Bookmark, CircleUserRound, HousePlus, Search } from "lucide-react";

export interface Props {
  pathname: string;
  viewer?: { role?: string } | null;
  unreadCount: number;
  dashboardHref: string;
  listingsHref: string;
  savedHref: string;
  t: (key: string) => string;
}

const { pathname, viewer, unreadCount, dashboardHref, listingsHref, savedHref, t } = Astro.props;
---

<nav class="mobile-utility" aria-label="Mobile navigation">
  <a class:list={["mobile-link", pathname.startsWith("/listings") || pathname === "/" ? "active" : ""]} href="/listings/?intent=buy">
    <Search class="mobile-icon" aria-hidden="true" stroke-width="1.5" />
    <span>{t("Search")}</span>
  </a>
  <a class:list={["mobile-link", pathname.startsWith("/buyer/") ? "active" : ""]} href={savedHref}>
    <span class="mobile-icon-wrap">
      <Bookmark class="mobile-icon" aria-hidden="true" stroke-width="1.5" />
      {viewer && unreadCount > 0 ? <span class="mobile-dot"></span> : null}
    </span>
    <span>{t("Saved")}</span>
  </a>
  <a class:list={["mobile-link", pathname.startsWith("/owner/") || pathname.startsWith("/submit-listing") ? "active" : ""]} href={listingsHref}>
    <HousePlus class="mobile-icon" aria-hidden="true" stroke-width="1.5" />
    <span>{t("My Listings")}</span>
  </a>
  <a class:list={["mobile-link", pathname.startsWith("/account/") || pathname.startsWith("/buyer/") || pathname.startsWith("/owner/") || pathname.startsWith("/admin/") ? "active" : ""]} href={viewer ? dashboardHref : "/login"}>
    <CircleUserRound class="mobile-icon" aria-hidden="true" stroke-width="1.5" />
    <span>{t("Profile")}</span>
  </a>
</nav>
