---
interface Item {
  label: string;
  href: string;
  active?: boolean;
}

export interface Props {
  viewerLabel: string;
  viewerRoleLabel: string;
  viewerInitials: string;
  accountMenu: Item[];
}

const { viewerLabel, viewerRoleLabel, viewerInitials, accountMenu } = Astro.props;
---

<details class="account-menu">
  <summary class="account-summary">
    <span class="avatar-badge">{viewerInitials}</span>
    <span class="account-copy">
      <strong>{viewerLabel}</strong>
      <small>{viewerRoleLabel}</small>
    </span>
    <span class="chevron">▾</span>
  </summary>
  <div class="account-panel">
    <div class="account-panel-head">
      <strong>{viewerLabel}</strong>
      <small>{viewerRoleLabel}</small>
    </div>

    <div class="account-quick-grid">
      <div>
        <strong>Account</strong>
        <span>{viewerRoleLabel}</span>
      </div>
      <div>
        <strong>Navigation</strong>
        <span>Shortcuts and settings</span>
      </div>
    </div>

    {accountMenu.map((item) => (
      <a class:list={["account-item", item.active && "active"]} href={item.href}>
        <span class="account-icon" aria-hidden="true">
          {item.label === "Settings" ? (
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="3"></circle>
              <path d="M19.4 15a1.7 1.7 0 0 0 .34 1.87l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06A1.7 1.7 0 0 0 15 19.4a1.7 1.7 0 0 0-1 .6 1.7 1.7 0 0 0-.33 1V21a2 2 0 1 1-4 0v-.09a1.7 1.7 0 0 0-.33-1 1.7 1.7 0 0 0-1-.6 1.7 1.7 0 0 0-1.87.34l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06A1.7 1.7 0 0 0 4.6 15a1.7 1.7 0 0 0-.6-1 1.7 1.7 0 0 0-1-.33H3a2 2 0 1 1 0-4h.09a1.7 1.7 0 0 0 1-.33 1.7 1.7 0 0 0 .6-1 1.7 1.7 0 0 0-.34-1.87l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06A1.7 1.7 0 0 0 9 4.6a1.7 1.7 0 0 0 1-.6 1.7 1.7 0 0 0 .33-1V3a2 2 0 1 1 4 0v.09a1.7 1.7 0 0 0 .33 1 1.7 1.7 0 0 0 1 .6 1.7 1.7 0 0 0 1.87-.34l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06A1.7 1.7 0 0 0 19.4 9c.27.3.48.64.6 1 .08.32.2.66.39.94.2.29.5.5.84.58H21a2 2 0 1 1 0 4h-.09a1.7 1.7 0 0 0-.94.39c-.29.2-.5.5-.58.84-.12.36-.33.7-.6 1Z"></path>
            </svg>
          ) : item.label === "Billing" ? (
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="5" width="18" height="14" rx="2"></rect>
              <path d="M3 10h18"></path>
              <path d="M7 15h3"></path>
              <path d="M14 15h3"></path>
            </svg>
          ) : (
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
              <circle cx="12" cy="7" r="4"></circle>
            </svg>
          )}
        </span>
        <span>{item.label}</span>
      </a>
    ))}

    <form method="POST" action="/api/auth/logout">
      <button class="account-logout" type="submit">
        <span class="account-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
            <path d="M16 17l5-5-5-5"></path>
            <path d="M21 12H9"></path>
          </svg>
        </span>
        <span>Log out</span>
      </button>
    </form>
  </div>
</details>
