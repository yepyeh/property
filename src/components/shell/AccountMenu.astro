---
import {
  ChevronDown,
  LayoutDashboard,
  LogOut,
  Mail,
  MoonStar,
  Settings,
  SunMedium,
  User,
} from "lucide-react";

interface Item {
  key?: string;
  label: string;
  href: string;
  active?: boolean;
  count?: number;
}

export interface Props {
  viewerLabel: string;
  viewerRoleLabel: string;
  viewerInitials: string;
  accountMenu: Item[];
  darkModeLabel?: string;
  lightModeLabel?: string;
  logOutLabel?: string;
}

const {
  viewerLabel,
  viewerRoleLabel,
  viewerInitials,
  accountMenu,
  darkModeLabel = "Dark mode",
  lightModeLabel = "Light mode",
  logOutLabel = "Log out",
} = Astro.props;

const iconByKey = {
  dashboard: LayoutDashboard,
  inbox: Mail,
  settings: Settings,
} as const;
---

<details class="account-menu">
  <summary class="account-summary">
    <span class="avatar-badge">{viewerInitials}</span>
    <span class="chevron" aria-hidden="true">
      <ChevronDown class="h-4 w-4" strokeWidth={1.5} />
    </span>
  </summary>
  <div class="account-panel">
    <div class="account-panel-head account-item account-item-static">
      <span class="account-icon" aria-hidden="true">
        <User class="h-5 w-5" strokeWidth={1.5} />
      </span>
      <span class="account-item-copy">
        <span>Account</span>
        <small>{viewerLabel}{viewerRoleLabel ? `, ${viewerRoleLabel}` : ""}</small>
      </span>
    </div>

    {accountMenu.map((item) => (
      (() => {
        const Icon = item.key ? iconByKey[item.key as keyof typeof iconByKey] || LayoutDashboard : LayoutDashboard;
        return (
          <a class:list={["account-item", item.active && "active"]} href={item.href}>
            <span class="account-icon" aria-hidden="true">
              <Icon class="h-5 w-5" strokeWidth={1.5} />
            </span>
            <span class="account-item-copy">
              <span>{item.label}</span>
              {item.key === "inbox" && item.count && item.count > 0 ? <span class="menu-dot"></span> : null}
            </span>
          </a>
        );
      })()
    ))}

    <button
      class="account-item theme-inline"
      type="button"
      data-theme-toggle
    >
      <span class="account-icon" aria-hidden="true">
        <MoonStar class="theme-toggle-dark h-5 w-5" strokeWidth={1.5} />
        <SunMedium class="theme-toggle-light h-5 w-5" strokeWidth={1.5} />
      </span>
      <span data-theme-label data-theme-dark-label={darkModeLabel} data-theme-light-label={lightModeLabel}>{darkModeLabel}</span>
    </button>

    <form method="POST" action="/api/auth/logout">
      <button class="account-logout" type="submit">
        <span class="account-icon" aria-hidden="true">
          <LogOut class="h-5 w-5" strokeWidth={1.5} />
        </span>
        <span>{logOutLabel}</span>
      </button>
    </form>
  </div>
</details>
