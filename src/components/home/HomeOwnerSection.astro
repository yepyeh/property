---
interface OwnerStep {
  title: string;
  body: string;
}

export interface Props {
  ownerSteps: OwnerStep[];
}

const { ownerSteps } = Astro.props;
---

<section class="owners-section">
  <div class="section-heading narrow">
    <span class="section-kicker">Owner workflow</span>
    <h2>Owners need more than a form. They need a working pipeline.</h2>
    <p>
      The product edge is not just discovery. It is the handoff from listing creation to applicant tracking, billing,
      and renewal without operational chaos.
    </p>
  </div>

  <div class="owner-grid">
    {ownerSteps.map((step, index) => (
      <article class="owner-card card">
        <span class="step-index">0{index + 1}</span>
        <h3>{step.title}</h3>
        <p>{step.body}</p>
      </article>
    ))}
  </div>
</section>

<style>
  .owners-section {
    margin-top: 2.35rem;
  }

  .section-heading {
    max-width: 46rem;
    margin-bottom: 1.15rem;
  }

  .section-heading.narrow {
    max-width: 43rem;
  }

  .section-kicker,
  .step-index {
    display: inline-flex;
    align-items: center;
    min-height: 2rem;
    padding: 0.35rem 0.82rem;
    border-radius: 999px;
    border: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.72);
    color: var(--muted-strong);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .section-heading h2 {
    margin: 0.65rem 0 0;
    font-size: clamp(2.5rem, 5vw, 4.75rem);
    line-height: 0.9;
    letter-spacing: -0.1em;
  }

  .section-heading p,
  .owner-card p {
    color: var(--muted);
    line-height: 1.72;
  }

  .owner-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .owner-card {
    display: grid;
    gap: 0.85rem;
    padding: 1.3rem;
    border-radius: 1.75rem;
    background: rgba(255, 255, 255, 0.72);
  }

  .owner-card h3 {
    margin: 0;
    font-size: 1.2rem;
    line-height: 1.15;
    letter-spacing: -0.05em;
  }

  @media (max-width: 1080px) {
    .owner-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
