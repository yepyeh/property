---
interface OwnerStep {
  title: string;
  body: string;
}

export interface Props {
  ownerSteps: OwnerStep[];
}

const { ownerSteps } = Astro.props;
---

<section class="owners-section">
  <div class="section-heading narrow">
    <span class="section-kicker">Owner workflow</span>
    <h2>Owners need more than a form. They need a working pipeline.</h2>
  </div>

  <div class="owner-grid">
    {ownerSteps.map((step, index) => (
      <article class="owner-card">
        <span class="step-index">0{index + 1}</span>
        <h3>{step.title}</h3>
        <p>{step.body}</p>
      </article>
    ))}
  </div>
</section>

<style is:inline>
  .owners-section {
    padding-block: var(--space-2xl);
    border-top: 1px solid var(--border);
  }

  .section-heading {
    max-width: 48rem;
    margin-bottom: var(--space-xl);
  }

  .section-heading.narrow {
    max-width: 45rem;
  }

  .section-kicker,
  .step-index {
    display: inline-flex;
    align-items: center;
    color: var(--muted);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .section-heading h2 {
    margin: 0.7rem 0 0;
    font-size: var(--text-display);
    line-height: 0.9;
    letter-spacing: -0.1em;
  }

  .owner-card p {
    color: var(--muted);
    line-height: 1.76;
  }

  .owner-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-m);
  }

  .owner-card {
    display: grid;
    gap: 0.9rem;
    padding: var(--space-l);
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
    background: transparent;
  }

  .owner-card h3 {
    margin: 0;
    font-size: var(--text-lg);
    line-height: 1.15;
    letter-spacing: -0.05em;
  }

  @media (max-width: 1080px) {
    .owner-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
