---
interface BrowseCity {
  name: string;
  note: string;
  href: string;
}

export interface Props {
  browseCities: BrowseCity[];
}

const { browseCities } = Astro.props;
---

<section class="city-section">
  <div class="section-heading">
    <span class="section-kicker">Browse by city</span>
    <h2>Start with location. Narrow by price, type, and confidence signals after.</h2>
    <p>
      That sequencing matters in Southeast Asia. City and district familiarity usually comes before fine-grained
      filtering, especially on mobile.
    </p>
  </div>

  <div class="city-grid">
    {browseCities.map((city) => (
      <a class="city-card card" href={city.href}>
        <strong>{city.name}</strong>
        <span>{city.note}</span>
      </a>
    ))}
  </div>
</section>

<style>
  .city-section {
    margin-top: 1.15rem;
  }

  .section-heading {
    max-width: 52rem;
    margin-bottom: 1rem;
  }

  .section-kicker {
    display: inline-flex;
    align-items: center;
    min-height: 2rem;
    padding: 0.22rem 0.75rem;
    border-radius: 999px;
    background: var(--brand-soft);
    color: var(--accent-strong);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .section-heading h2 {
    margin: 0.9rem 0 0;
    font-size: clamp(2rem, 4vw, 3.2rem);
    line-height: 1;
    letter-spacing: -0.08em;
    font-family: "Plus Jakarta Sans", sans-serif;
  }

  .section-heading p,
  .city-card span {
    color: var(--muted);
    line-height: 1.7;
    margin: 0;
  }

  .city-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .city-card {
    padding: 1.25rem;
    border: 1px solid var(--line);
    text-decoration: none;
    color: inherit;
    background: rgba(255, 255, 255, 0.88);
    box-shadow: 0 1px 2px rgba(16, 24, 40, 0.04), 0 16px 36px rgba(16, 24, 40, 0.06);
    transition: transform 180ms ease, box-shadow 180ms ease;
  }

  .city-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 18px 40px rgba(15, 23, 42, 0.1);
  }

  .city-card strong {
    display: block;
    margin-bottom: 0.35rem;
  }

  @media (max-width: 1100px) {
    .city-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
