---
interface BrowseCity {
  name: string;
  note: string;
  href: string;
}

export interface Props {
  browseCities: BrowseCity[];
}

const { browseCities } = Astro.props;
---

<section class="city-section">
  <div class="section-heading">
    <span class="section-kicker">Browse by city</span>
    <h2>Start with location. Narrow by price, type, and confidence signals after.</h2>
  </div>

  <div class="city-grid">
    {browseCities.map((city, index) => (
      <a class:list={["city-card", index === 0 && "featured"]} href={city.href}>
        <span class="city-index">0{index + 1}</span>
        <strong>{city.name}</strong>
        <span>{city.note}</span>
      </a>
    ))}
  </div>
</section>

<style is:inline>
  .city-section {
    padding-block: var(--space-2xl);
    border-top: 1px solid var(--border);
  }

  .section-heading {
    max-width: 48rem;
    margin-bottom: var(--space-xl);
  }

  .section-kicker,
  .city-index {
    display: inline-flex;
    align-items: center;
    color: var(--muted);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .section-heading h2 {
    margin: 0.7rem 0 0;
    font-size: var(--text-display);
    line-height: 0.9;
    letter-spacing: -0.1em;
  }

  .city-card span:last-child {
    color: var(--muted);
    line-height: 1.76;
  }

  .city-grid {
    display: grid;
    grid-template-columns: 1.2fr repeat(3, minmax(0, 1fr));
    gap: var(--space-m);
  }

  .city-card {
    display: grid;
    align-content: start;
    gap: var(--space-s);
    min-height: 12rem;
    padding: var(--space-l);
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
    background: transparent;
    text-decoration: none;
  }

  .city-card strong {
    font-size: var(--text-lg);
    letter-spacing: -0.05em;
  }

  .city-card.featured {
    background: color-mix(in srgb, var(--card) 34%, transparent);
  }

  @media (max-width: 1080px) {
    .city-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 760px) {
    .city-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
