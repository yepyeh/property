---
interface BrowseCity {
  name: string;
  note: string;
  href: string;
}

export interface Props {
  browseCities: BrowseCity[];
}

const { browseCities } = Astro.props;
---

<section class="city-section">
  <div class="section-heading">
    <span class="section-kicker">Browse by city</span>
    <h2>Start with location. Narrow by price, type, and confidence signals after.</h2>
    <p>
      That sequencing matters in Southeast Asia. City and district familiarity usually comes before fine-grained
      filtering, especially on mobile.
    </p>
  </div>

  <div class="city-grid">
    {browseCities.map((city, index) => (
      <a class:list={["city-card", index === 0 && "featured"]} href={city.href}>
        <span class="city-index">0{index + 1}</span>
        <strong>{city.name}</strong>
        <span>{city.note}</span>
      </a>
    ))}
  </div>
</section>

<style is:inline>
  .city-section {
    margin-top: 2.75rem;
  }

  .section-heading {
    max-width: 48rem;
    margin-bottom: 1.2rem;
  }

  .section-kicker,
  .city-index {
    display: inline-flex;
    align-items: center;
    min-height: 2rem;
    padding: 0.35rem 0.82rem;
    border-radius: var(--radius-full);
    border: 1px solid var(--line);
    background: var(--surface-overlay);
    color: var(--muted-strong);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .section-heading h2 {
    margin: 0.7rem 0 0;
    font-size: var(--text-display);
    line-height: 0.9;
    letter-spacing: -0.1em;
  }

  .section-heading p,
  .city-card span:last-child {
    color: var(--muted);
    line-height: 1.76;
  }

  .city-grid {
    display: grid;
    grid-template-columns: 1.2fr repeat(3, minmax(0, 1fr));
    gap: var(--space-m);
  }

  .city-card {
    display: grid;
    align-content: start;
    gap: var(--space-s);
    min-height: 12rem;
    padding: var(--space-l);
    border-radius: calc(var(--radius-lg) * 1.8);
    border: 1px solid var(--line);
    background: var(--surface-overlay);
    text-decoration: none;
    box-shadow: var(--shadow-soft);
  }

  .city-card strong {
    font-size: var(--text-lg);
    letter-spacing: -0.05em;
  }

  .city-card.featured {
    background: linear-gradient(180deg, var(--surface-elevated-strong), var(--surface-overlay));
  }

  @media (max-width: 1080px) {
    .city-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 760px) {
    .city-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
