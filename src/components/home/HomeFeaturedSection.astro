---
import ListingCard from "../ListingCard.astro";
import type { Listing } from "../../data/listings";

export interface Props {
  featuredListings: Listing[];
}

const { featuredListings } = Astro.props;
---

<section class="feature-section">
  <div class="section-heading">
    <span class="section-kicker">Featured listings</span>
    <h2>Search results should feel curated and trustworthy, not like a noisy directory.</h2>
    <p>
      Clear pricing, compact facts, and visible trust signals matter more than decorative clutter. The public browse
      layer needs to feel efficient before it feels clever.
    </p>
  </div>

  <div class="listing-grid">
    {featuredListings.map((listing) => <ListingCard listing={listing} />)}
  </div>
</section>

<style>
  .feature-section { margin-top: 2rem; }
  .section-heading { max-width: 45rem; margin-bottom: 1rem; }
  .section-kicker {
    display: inline-flex;
    align-items: center;
    min-height: 1.8rem;
    padding: 0.18rem 0.65rem;
    border-radius: 999px;
    border: 1px solid var(--line);
    background: rgba(255,255,255,0.72);
    color: var(--muted-strong);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .section-heading h2 {
    margin: 0.45rem 0 0;
    font-size: clamp(2.4rem, 5vw, 4.5rem);
    line-height: 0.9;
    letter-spacing: -0.1em;
  }
  .section-heading p { margin: 0; color: var(--muted); line-height: 1.75; }
  .listing-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }
  @media (max-width: 1080px) { .listing-grid { grid-template-columns: 1fr; } }
</style>
