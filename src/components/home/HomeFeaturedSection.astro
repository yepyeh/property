---
import ListingCard from "../ListingCard.astro";
import type { Listing } from "../../data/listings";

export interface Props {
  featuredListings: Listing[];
}

const { featuredListings } = Astro.props;
---

<section class="feature-section section-space">
  <div class="section-heading split-heading">
    <div>
      <span class="section-kicker">Featured listings</span>
      <h2>Search results should feel curated and trustworthy, not like a noisy directory.</h2>
    </div>
  </div>

  <div class="listing-grid">
    {featuredListings.map((listing) => <ListingCard listing={listing} />)}
  </div>
</section>

<style is:inline>
  .feature-section {
    margin-top: 0;
    border-top: 1px solid var(--border);
  }

  .section-heading {
    margin-bottom: var(--space-2xl);
  }

  .split-heading {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(18rem, 0.7fr);
    gap: var(--space-m);
    align-items: end;
  }

  .section-kicker {
    display: inline-flex;
    align-items: center;
    color: var(--muted);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .section-heading h2 {
    margin: var(--space-s) 0 0;
    font-size: var(--text-display);
    line-height: 0.9;
    letter-spacing: -0.08em;
    max-width: 10.5ch;
  }

  .listing-grid {
    display: grid;
    gap: var(--space-xl);
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  @media (max-width: 1080px) {
    .split-heading,
    .listing-grid {
      grid-template-columns: 1fr;
    }

    .section-heading h2 {
      max-width: none;
    }
  }
</style>
