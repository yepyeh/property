---
import ListingCard from "../ListingCard.astro";
import type { Listing } from "../../data/listings";

export interface Props {
  featuredListings: Listing[];
}

const { featuredListings } = Astro.props;
---

<section class="feature-section">
  <div class="section-heading split-heading">
    <div>
      <span class="section-kicker">Featured listings</span>
      <h2>Search results should feel curated and trustworthy, not like a noisy directory.</h2>
    </div>
    <p>
      Clear pricing, compact facts, and visible trust signals matter more than decorative clutter. The public browse
      layer needs to feel efficient before it feels clever.
    </p>
  </div>

  <div class="listing-grid">
    {featuredListings.map((listing) => <ListingCard listing={listing} />)}
  </div>
</section>

<style is:inline>
  .feature-section {
    margin-top: 2.75rem;
  }

  .section-heading {
    margin-bottom: 1.2rem;
  }

  .split-heading {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(18rem, 0.7fr);
    gap: 1rem;
    align-items: end;
  }

  .section-kicker {
    display: inline-flex;
    align-items: center;
    min-height: 2rem;
    padding: 0.35rem 0.82rem;
    border-radius: 999px;
    border: 1px solid var(--line);
    background: rgba(255,255,255,0.76);
    color: var(--muted-strong);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .section-heading h2 {
    margin: 0.7rem 0 0;
    font-size: clamp(2.7rem, 5vw, 4.9rem);
    line-height: 0.9;
    letter-spacing: -0.1em;
    max-width: 10.5ch;
  }

  .section-heading p {
    color: var(--muted);
    line-height: 1.76;
    margin: 0;
  }

  .listing-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  @media (max-width: 1080px) {
    .split-heading,
    .listing-grid {
      grid-template-columns: 1fr;
    }

    .section-heading h2 {
      max-width: none;
    }
  }
</style>
