---
interface EntryPath {
  kicker: string;
  title: string;
  body: string;
  primaryHref: string;
  primaryLabel: string;
  secondaryHref: string;
  secondaryLabel: string;
}

export interface Props {
  entryPaths: EntryPath[];
  sectionKicker?: string;
  sectionTitle?: string;
  sectionBody?: string;
}

const {
  entryPaths,
  sectionKicker = "Choose your path",
  sectionTitle = "This homepage should route users, not make them interpret the product structure themselves.",
  sectionBody = "Most users arrive with one clear job. The public site should acknowledge that immediately instead of pushing everyone through the same generic surface.",
} = Astro.props;
---

<section class="path-section">
  <div class="section-heading narrow">
    <span class="section-kicker">{sectionKicker}</span>
    <h2>{sectionTitle}</h2>
  </div>

  <div class="path-grid">
    {entryPaths.map((path, index) => (
      <article class="path-card">
        <div class="path-head">
          <span class="mini-kicker">{path.kicker}</span>
          <span class="path-index">0{index + 1}</span>
        </div>
        <h3>{path.title}</h3>
        <p>{path.body}</p>
        <div class="path-actions">
          <a class="path-link primary" href={path.primaryHref}>{path.primaryLabel}</a>
          <a class="path-link" href={path.secondaryHref}>{path.secondaryLabel}</a>
        </div>
      </article>
    ))}
  </div>
</section>

<style is:inline>
  .path-section {
    padding-block: var(--space-2xl);
    border-top: 1px solid var(--border);
  }

  .section-heading {
    max-width: 48rem;
    margin-bottom: var(--space-xl);
  }

  .section-heading.narrow {
    max-width: 45rem;
  }

  .section-kicker,
  .mini-kicker,
  .path-index {
    display: inline-flex;
    align-items: center;
    color: var(--muted);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .section-heading h2 {
    margin: var(--space-s) 0 0;
    font-size: var(--text-display);
    line-height: 0.9;
    letter-spacing: -0.1em;
  }

  .path-card p {
    color: var(--muted);
    line-height: 1.76;
  }

  .path-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-m);
  }

  .path-card {
    display: grid;
    gap: var(--space-s);
    padding: var(--space-l);
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
    background: transparent;
  }

  .path-head {
    display: flex;
    justify-content: space-between;
    gap: var(--space-s);
    align-items: center;
    flex-wrap: wrap;
  }

  .path-card h3 {
    margin: 0;
    font-size: var(--text-lg);
    line-height: 1.12;
    letter-spacing: -0.05em;
  }

  .path-actions {
    display: flex;
    gap: var(--space-s);
    flex-wrap: wrap;
    margin-top: 0.15rem;
  }

  .path-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: calc(var(--space-xl) + var(--space-2xs));
    padding: var(--space-s) var(--space-m);
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
    background: transparent;
    color: var(--text);
    font-size: 0.88rem;
    font-weight: 700;
    text-decoration: none;
  }

  .path-link.primary {
    background: var(--brand);
    border-color: var(--brand);
    color: var(--surface-canvas);
  }

  @media (max-width: 1080px) {
    .path-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
