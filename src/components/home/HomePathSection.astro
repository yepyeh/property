---
interface EntryPath {
  kicker: string;
  title: string;
  body: string;
  primaryHref: string;
  primaryLabel: string;
  secondaryHref: string;
  secondaryLabel: string;
}

export interface Props {
  entryPaths: EntryPath[];
}

const { entryPaths } = Astro.props;
---

<section class="path-section">
  <div class="section-heading narrow">
    <span class="section-kicker">Choose your path</span>
    <h2>This homepage should route users, not make them interpret the product structure themselves.</h2>
    <p>
      Most users arrive with one clear job. The public site should acknowledge that immediately instead of pushing
      everyone through the same generic surface.
    </p>
  </div>

  <div class="path-grid">
    {entryPaths.map((path) => (
      <article class="path-card card">
        <span class="section-kicker">{path.kicker}</span>
        <h3>{path.title}</h3>
        <p>{path.body}</p>
        <div class="path-actions">
          <a class="button-primary" href={path.primaryHref}>{path.primaryLabel}</a>
          <a class="button-secondary" href={path.secondaryHref}>{path.secondaryLabel}</a>
        </div>
      </article>
    ))}
  </div>
</section>

<style>
  .path-section {
    margin-top: 1.15rem;
  }

  .section-heading {
    max-width: 52rem;
    margin-bottom: 1rem;
  }

  .section-heading.narrow {
    max-width: 46rem;
  }

  .section-kicker {
    display: inline-flex;
    align-items: center;
    min-height: 2rem;
    padding: 0.22rem 0.75rem;
    border-radius: 999px;
    background: var(--brand-soft);
    color: var(--accent-strong);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .section-heading h2 {
    margin: 0.9rem 0 0;
    font-size: clamp(2rem, 4vw, 3.2rem);
    line-height: 1;
    letter-spacing: -0.08em;
    font-family: "Plus Jakarta Sans", sans-serif;
  }

  .section-heading p,
  .path-card p {
    color: var(--muted);
    line-height: 1.7;
    margin: 0;
  }

  .path-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .path-card {
    padding: 1.25rem;
    border: 1px solid var(--line);
    color: inherit;
    background: rgba(255, 255, 255, 0.88);
    transition: transform 180ms ease, box-shadow 180ms ease;
  }

  .path-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 18px 40px rgba(15, 23, 42, 0.1);
  }

  .path-card h3 {
    margin: 0.6rem 0 0.5rem;
    font-size: 1.28rem;
    letter-spacing: -0.03em;
  }

  .path-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: 1rem;
  }

  .button-primary,
  .button-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.9rem;
    border-radius: 999px;
    padding: 0.88rem 1.1rem;
    font-weight: 700;
    text-decoration: none;
    font: inherit;
    cursor: pointer;
  }

  .button-primary {
    border: none;
    background: linear-gradient(135deg, var(--brand), #23314d);
    color: white;
  }

  .button-secondary {
    border: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.9);
    color: var(--text);
  }

  @media (max-width: 1100px) {
    .path-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 760px) {
    .path-actions {
      display: grid;
    }

    .button-primary,
    .button-secondary {
      width: 100%;
    }
  }
</style>
