---
interface EntryPath {
  kicker: string;
  title: string;
  body: string;
  primaryHref: string;
  primaryLabel: string;
  secondaryHref: string;
  secondaryLabel: string;
}

export interface Props {
  entryPaths: EntryPath[];
  sectionKicker?: string;
  sectionTitle?: string;
  sectionBody?: string;
}

const {
  entryPaths,
  sectionKicker = "Choose your path",
  sectionTitle = "This homepage should route users, not make them interpret the product structure themselves.",
  sectionBody = "Most users arrive with one clear job. The public site should acknowledge that immediately instead of pushing everyone through the same generic surface.",
} = Astro.props;
---

<section class="path-section">
  <div class="section-heading narrow">
    <span class="section-kicker">{sectionKicker}</span>
    <h2>{sectionTitle}</h2>
    <p>{sectionBody}</p>
  </div>

  <div class="path-grid">
    {entryPaths.map((path, index) => (
      <article class="path-card card">
        <div class="path-head">
          <span class="mini-kicker">{path.kicker}</span>
          <span class="path-index">0{index + 1}</span>
        </div>
        <h3>{path.title}</h3>
        <p>{path.body}</p>
        <div class="path-actions">
          <a class="path-link primary" href={path.primaryHref}>{path.primaryLabel}</a>
          <a class="path-link" href={path.secondaryHref}>{path.secondaryLabel}</a>
        </div>
      </article>
    ))}
  </div>
</section>

<style is:inline>
  .path-section {
    margin-top: 2.75rem;
  }

  .section-heading {
    max-width: 48rem;
    margin-bottom: 1.2rem;
  }

  .section-heading.narrow {
    max-width: 45rem;
  }

  .section-kicker,
  .mini-kicker,
  .path-index {
    display: inline-flex;
    align-items: center;
    min-height: 2rem;
    padding: 0.35rem 0.82rem;
    border-radius: 999px;
    border: 1px solid var(--line);
    background: var(--surface-overlay);
    color: var(--muted-strong);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .path-index {
    background: var(--bg-soft);
  }

  .section-heading h2 {
    margin: 0.7rem 0 0;
    font-size: clamp(2.7rem, 5vw, 4.9rem);
    line-height: 0.9;
    letter-spacing: -0.1em;
  }

  .section-heading p,
  .path-card p {
    color: var(--muted);
    line-height: 1.76;
  }

  .path-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .path-card {
    display: grid;
    gap: 0.95rem;
    padding: 1.35rem;
    border-radius: 1.8rem;
    background: var(--surface-overlay);
    box-shadow: var(--shadow-soft);
  }

  .path-head {
    display: flex;
    justify-content: space-between;
    gap: 0.8rem;
    align-items: center;
    flex-wrap: wrap;
  }

  .path-card h3 {
    margin: 0;
    font-size: 1.28rem;
    line-height: 1.12;
    letter-spacing: -0.05em;
  }

  .path-actions {
    display: flex;
    gap: 0.7rem;
    flex-wrap: wrap;
    margin-top: 0.15rem;
  }

  .path-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.7rem;
    padding: 0.75rem 0.98rem;
    border-radius: 999px;
    border: 1px solid var(--line);
    background: var(--surface-elevated-strong);
    color: var(--text);
    font-size: 0.88rem;
    font-weight: 700;
    text-decoration: none;
  }

  .path-link.primary {
    background: var(--brand);
    border-color: var(--brand);
    color: var(--surface-canvas);
  }

  @media (max-width: 1080px) {
    .path-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
