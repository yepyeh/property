---
interface EntryPath {
  kicker: string;
  title: string;
  body: string;
  primaryHref: string;
  primaryLabel: string;
  secondaryHref: string;
  secondaryLabel: string;
}

export interface Props {
  entryPaths: EntryPath[];
}

const { entryPaths } = Astro.props;
---

<section class="path-section">
  <div class="section-heading narrow">
    <span class="section-kicker">Choose your path</span>
    <h2>This homepage should route users, not make them interpret the product structure themselves.</h2>
    <p>
      Most users arrive with one clear job. The public site should acknowledge that immediately instead of pushing
      everyone through the same generic surface.
    </p>
  </div>

  <div class="path-grid">
    {entryPaths.map((path) => (
      <article class="path-card card">
        <span class="mini-kicker">{path.kicker}</span>
        <h3>{path.title}</h3>
        <p>{path.body}</p>
        <div class="path-actions">
          <a class="path-link primary" href={path.primaryHref}>{path.primaryLabel}</a>
          <a class="path-link" href={path.secondaryHref}>{path.secondaryLabel}</a>
        </div>
      </article>
    ))}
  </div>
</section>

<style>
  .path-section {
    margin-top: 2.35rem;
  }

  .section-heading {
    max-width: 46rem;
    margin-bottom: 1.15rem;
  }

  .section-heading.narrow {
    max-width: 44rem;
  }

  .section-kicker,
  .mini-kicker {
    display: inline-flex;
    align-items: center;
    min-height: 2rem;
    padding: 0.35rem 0.82rem;
    border-radius: 999px;
    border: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.72);
    color: var(--muted-strong);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .section-heading h2 {
    margin: 0.65rem 0 0;
    font-size: clamp(2.5rem, 5vw, 4.75rem);
    line-height: 0.9;
    letter-spacing: -0.1em;
  }

  .section-heading p,
  .path-card p {
    color: var(--muted);
    line-height: 1.72;
  }

  .path-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .path-card {
    display: grid;
    gap: 0.85rem;
    padding: 1.3rem;
    border-radius: 1.75rem;
    background: rgba(255, 255, 255, 0.72);
    box-shadow: var(--shadow-soft);
  }

  .path-card h3 {
    margin: 0;
    font-size: 1.24rem;
    line-height: 1.15;
    letter-spacing: -0.05em;
  }

  .path-actions {
    display: flex;
    gap: 0.7rem;
    flex-wrap: wrap;
    margin-top: 0.2rem;
  }

  .path-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.6rem;
    padding: 0.72rem 0.95rem;
    border-radius: 999px;
    border: 1px solid var(--line);
    background: white;
    color: var(--text);
    font-size: 0.88rem;
    font-weight: 700;
    text-decoration: none;
  }

  .path-link.primary {
    background: var(--brand);
    border-color: var(--brand);
    color: white;
  }

  @media (max-width: 1080px) {
    .path-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
