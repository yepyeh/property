---
interface QuickFilter {
  label: string;
  href: string;
}

export interface Props {
  quickFilters: QuickFilter[];
  trustSignals: string[];
}

const { quickFilters, trustSignals } = Astro.props;
---

<section class="hero-shell" id="top">
  <div class="hero-grid">
    <div class="hero-copy">
      <span class="section-label">Search-first property marketplace</span>
      <h1>Find the right place faster, then follow through with confidence.</h1>
      <p class="hero-text">
        Search, shortlist, save, and enquire from one calmer interface. Built for buyers, owners, and teams that need
        cleaner property workflows in Southeast Asia.
      </p>

      <div class="hero-signals">
        {trustSignals.map((signal) => (
          <div class="signal-row">
            <span class="signal-dot"></span>
            <span>{signal}</span>
          </div>
        ))}
      </div>

      <div class="hero-actions">
        <a class="button-dark" href="/for-buyers">Start your search</a>
        <a class="button-light" href="/for-owners">Post a property</a>
      </div>
    </div>

    <form class="search-card card" method="GET" action="/listings/">
      <div class="search-head">
        <strong>Find</strong>
        <span>Search active inventory</span>
      </div>

      <div class="toggle-row">
        <label class="toggle-pill active">
          <input type="radio" name="intent" value="buy" checked />
          <span>Buy</span>
        </label>
        <label class="toggle-pill">
          <input type="radio" name="intent" value="rent" />
          <span>Rent</span>
        </label>
      </div>

      <label class="field field-wide">
        <span>Location</span>
        <input type="text" name="city" value="Ho Chi Minh City" placeholder="City or district" />
      </label>

      <div class="field-grid">
        <label class="field">
          <span>Property type</span>
          <select name="propertyType">
            <option value="">Any property</option>
            <option value="Condo">Condo</option>
            <option value="Villa">Villa</option>
            <option value="Townhouse">Townhouse</option>
            <option value="Apartment">Apartment</option>
            <option value="House">House</option>
            <option value="Land">Land</option>
          </select>
        </label>
        <label class="field">
          <span>Budget ceiling</span>
          <select name="maxPrice">
            <option value="">Any budget</option>
            <option value="5">Up to 5B VND</option>
            <option value="10">Up to 10B VND</option>
            <option value="20">Up to 20B VND</option>
          </select>
        </label>
      </div>

      <div class="field-grid compact-grid">
        <label class="field">
          <span>Any beds</span>
          <select name="minBeds">
            <option value="">Any beds</option>
            <option value="1">1+</option>
            <option value="2">2+</option>
            <option value="3">3+</option>
            <option value="4">4+</option>
          </select>
        </label>
        <button class="submit-button" type="submit">Search inventory</button>
      </div>
    </form>
  </div>

  <div class="hero-foot">
    <div class="metric-strip">
      <span class="metric-kicker">Live search</span>
      <strong>Query-driven inventory</strong>
      <span>Buyer and rent intent</span>
    </div>
    <div class="metric-strip">
      <span class="metric-kicker">Owner workflow</span>
      <strong>Leads, billing, renewals</strong>
      <span>Supply-side operations</span>
    </div>
    <div class="metric-strip">
      <span class="metric-kicker">PWA-ready</span>
      <strong>Mobile-first shell</strong>
      <span>App-like behavior</span>
    </div>
    <div class="quick-links">
      {quickFilters.map((filter) => <a href={filter.href}>{filter.label}</a>)}
    </div>
  </div>
</section>

<style>
  .hero-shell {
    display: grid;
    gap: 1.35rem;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(20rem, 0.82fr);
    gap: 1.25rem;
    align-items: stretch;
  }

  .hero-copy {
    padding: 1.15rem 0.15rem 0.25rem;
  }

  .section-label,
  .metric-kicker {
    display: inline-flex;
    align-items: center;
    min-height: 2rem;
    padding: 0.35rem 0.82rem;
    border-radius: 999px;
    border: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.72);
    color: var(--muted-strong);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .hero-copy h1 {
    margin: 1.1rem 0 0;
    max-width: 9ch;
    font-size: clamp(4rem, 8vw, 6rem);
    line-height: 0.86;
    letter-spacing: -0.095em;
    font-weight: 800;
  }

  .hero-text {
    max-width: 54ch;
    margin-top: 1rem;
    color: var(--muted);
    font-size: 1.02rem;
    line-height: 1.72;
  }

  .hero-signals {
    display: grid;
    gap: 0.72rem;
    margin-top: 1.4rem;
    max-width: 43rem;
  }

  .signal-row {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
    color: var(--muted-strong);
    font-size: 0.95rem;
    line-height: 1.55;
  }

  .signal-dot {
    width: 0.55rem;
    height: 0.55rem;
    margin-top: 0.48rem;
    border-radius: 999px;
    background: #b8f4be;
    box-shadow: 0 0 0 0.28rem rgba(184, 244, 190, 0.22);
    flex: none;
  }

  .hero-actions {
    display: flex;
    gap: 0.8rem;
    flex-wrap: wrap;
    margin-top: 1.6rem;
  }

  .button-dark,
  .button-light,
  .submit-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3.2rem;
    padding: 0.95rem 1.2rem;
    border-radius: 999px;
    border: 1px solid transparent;
    font: inherit;
    font-weight: 700;
    text-decoration: none;
    cursor: pointer;
  }

  .button-dark,
  .submit-button {
    background: var(--brand);
    color: white;
    border-color: var(--brand);
    box-shadow: 0 14px 28px rgba(17, 17, 17, 0.12);
  }

  .button-light {
    background: rgba(255, 255, 255, 0.84);
    color: var(--text);
    border-color: var(--line);
  }

  .search-card {
    padding: 1.35rem;
    display: grid;
    gap: 0.95rem;
    background: rgba(255, 255, 255, 0.96);
    border-radius: 2rem;
  }

  .search-head {
    display: flex;
    justify-content: space-between;
    gap: 0.8rem;
    align-items: center;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid var(--line);
  }

  .search-head strong {
    font-size: 1rem;
    letter-spacing: -0.03em;
  }

  .search-head span {
    color: var(--muted);
    font-size: 0.82rem;
  }

  .toggle-row {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.65rem;
  }

  .toggle-pill {
    position: relative;
    display: block;
    cursor: pointer;
  }

  .toggle-pill input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .toggle-pill span {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 3rem;
    border-radius: 999px;
    border: 1px solid var(--line);
    background: var(--bg-soft);
    font-weight: 700;
  }

  .toggle-pill.active span {
    background: var(--brand);
    border-color: var(--brand);
    color: white;
  }

  .field-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.8rem;
  }

  .compact-grid {
    align-items: end;
  }

  .field {
    display: grid;
    gap: 0.42rem;
  }

  .field-wide {
    grid-column: 1 / -1;
  }

  .field span {
    color: var(--muted-strong);
    font-size: 0.82rem;
    font-weight: 700;
  }

  .field input,
  .field select {
    width: 100%;
    min-height: 3.2rem;
    padding: 0.92rem 1rem;
    border-radius: 1.05rem;
    border: 1px solid var(--line);
    background: var(--bg-soft);
    color: var(--text);
    font: inherit;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.8);
  }

  .hero-foot {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.9rem;
  }

  .metric-strip,
  .quick-links {
    min-height: 100%;
    padding: 1rem 1.1rem;
    border-radius: 1.6rem;
    border: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.66);
    box-shadow: var(--shadow-soft);
  }

  .metric-strip {
    display: grid;
    gap: 0.35rem;
  }

  .metric-strip strong {
    font-size: 1.05rem;
    letter-spacing: -0.04em;
  }

  .metric-strip span:last-child {
    color: var(--muted);
    line-height: 1.6;
  }

  .quick-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    align-content: flex-start;
  }

  .quick-links a {
    display: inline-flex;
    align-items: center;
    min-height: 2.5rem;
    padding: 0.7rem 0.95rem;
    border-radius: 999px;
    background: white;
    border: 1px solid var(--line);
    color: var(--text);
    font-size: 0.86rem;
    font-weight: 700;
    text-decoration: none;
  }

  @media (max-width: 1080px) {
    .hero-grid,
    .hero-foot {
      grid-template-columns: 1fr;
    }

    .hero-copy h1 {
      max-width: none;
    }
  }

  @media (max-width: 760px) {
    .hero-copy {
      padding-top: 0.3rem;
    }

    .hero-copy h1 {
      font-size: clamp(3rem, 14vw, 4.45rem);
    }

    .field-grid,
    .toggle-row {
      grid-template-columns: 1fr;
    }

    .button-dark,
    .button-light,
    .submit-button {
      width: 100%;
    }
  }
</style>
