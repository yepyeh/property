---
interface QuickFilter {
  label: string;
  href: string;
}

export interface Props {
  quickFilters: QuickFilter[];
  trustSignals: string[];
  t?: (key: string) => string;
}

const { quickFilters, trustSignals, t = (value: string) => value } = Astro.props;
---

<section class="hero-shell section-space" id="top">
  <div class="hero-grid glass-card">
    <div class="hero-copy">
      <span class="section-label">{t("Search-first property marketplace")}</span>
      <h1>{t("Find the right place faster, then follow through with confidence.")}</h1>
      <p class="hero-text secondary-text">
        {t("Search, shortlist, save, and enquire from one calmer interface. Built for buyers, owners, and teams that need cleaner property workflows in Southeast Asia.")}
      </p>

      <div class="hero-signals">
        {trustSignals.map((signal) => (
          <div class="signal-row">
            <span class="signal-dot"></span>
            <span>{signal}</span>
          </div>
        ))}
      </div>

      <div class="hero-actions">
        <a class="button-dark" href="/for-buyers">{t("Start your search")}</a>
        <a class="button-light" href="/for-owners">{t("Post a property")}</a>
      </div>
    </div>

    <div class="hero-side">
      <form class="search-card" method="GET" action="/listings/">
        <div class="search-head">
          <strong>{t("Search")}</strong>
          <span class="secondary-text">{t("Active inventory")}</span>
        </div>

        <div class="toggle-row">
          <label class="toggle-pill active">
            <input type="radio" name="intent" value="buy" checked />
            <span>{t("Buy")}</span>
          </label>
          <label class="toggle-pill">
            <input type="radio" name="intent" value="rent" />
            <span>{t("Rent")}</span>
          </label>
        </div>

        <label class="field field-wide">
          <span>{t("Location")}</span>
          <input type="text" name="city" value="Ho Chi Minh City" placeholder={t("City or district")} />
        </label>

        <div class="field-grid">
          <label class="field">
            <span>{t("Property type")}</span>
            <select name="propertyType">
              <option value="">{t("Any property")}</option>
              <option value="Condo">Condo</option>
              <option value="Villa">Villa</option>
              <option value="Townhouse">Townhouse</option>
              <option value="Apartment">Apartment</option>
              <option value="House">House</option>
              <option value="Land">Land</option>
            </select>
          </label>
          <label class="field">
            <span>{t("Budget ceiling")}</span>
            <select name="maxPrice">
              <option value="">{t("Any budget")}</option>
              <option value="5">Up to 5B VND</option>
              <option value="10">Up to 10B VND</option>
              <option value="20">Up to 20B VND</option>
            </select>
          </label>
        </div>

        <div class="field-grid compact-grid">
          <label class="field">
            <span>{t("Any beds")}</span>
            <select name="minBeds">
              <option value="">{t("Any beds")}</option>
              <option value="1">1+</option>
              <option value="2">2+</option>
              <option value="3">3+</option>
              <option value="4">4+</option>
            </select>
          </label>
          <button class="submit-button" type="submit">{t("Search inventory")}</button>
        </div>
      </form>

      <div class="side-metrics">
        <div class="metric-card">
          <span class="metric-kicker">{t("Live search")}</span>
          <strong>{t("Query-driven inventory")}</strong>
          <span class="secondary-text">{t("Buyer and rent intent")}</span>
        </div>
        <div class="metric-card">
          <span class="metric-kicker">{t("Owner workflow")}</span>
          <strong>{t("Leads, billing, renewals")}</strong>
          <span class="secondary-text">{t("Supply-side operations")}</span>
        </div>
      </div>
    </div>
  </div>

  <div class="hero-foot">
    <div class="quick-links glass-card">
      <div class="quick-head">
        <span class="metric-kicker">{t("Fast routes")}</span>
        <strong>{t("Start from the most common searches")}</strong>
      </div>
      <div class="quick-grid">
        {quickFilters.map((filter) => <a href={filter.href}>{filter.label}</a>)}
      </div>
    </div>
    <div class="metric-banner glass-card">
      <span class="metric-kicker">{t("PWA-ready")}</span>
      <strong>{t("Mobile-first shell")}</strong>
      <span class="secondary-text">{t("Installable, app-like behavior with a cleaner browsing flow on smaller screens.")}</span>
    </div>
  </div>
</section>

<style is:inline>
  .hero-shell {
    display: grid;
    gap: var(--space-l);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.22fr) minmax(20rem, 0.78fr);
    gap: var(--space-l);
    align-items: stretch;
    padding: var(--space-xl);
    background: linear-gradient(180deg, var(--surface-panel-subtle), var(--surface-panel-muted));
  }

  .hero-copy {
    padding: 0;
  }

  .section-label,
  .metric-kicker {
    display: inline-flex;
    align-items: center;
    min-height: 2rem;
    padding: 0.35rem 0.82rem;
    border-radius: 999px;
    border: 1px solid var(--line);
    background: var(--surface-overlay);
    color: var(--muted-strong);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .hero-copy h1 {
    margin: var(--space-s) 0 0;
    max-width: 8.5ch;
    font-size: var(--text-display);
    line-height: 0.84;
    letter-spacing: -0.06em;
    font-weight: 800;
  }

  .hero-text {
    max-width: 56ch;
    margin-top: var(--space-s);
    font-size: var(--text-base);
    line-height: 1.78;
  }

  .hero-signals {
    display: grid;
    gap: var(--space-s);
    margin-top: var(--space-l);
    max-width: 43rem;
  }

  .signal-row {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
    color: var(--muted-strong);
    font-size: 0.95rem;
    line-height: 1.55;
  }

  .signal-dot {
    width: 0.55rem;
    height: 0.55rem;
    margin-top: 0.48rem;
    border-radius: 999px;
    background: color-mix(in srgb, var(--accent-strong) 28%, var(--surface-elevated-strong));
    box-shadow: 0 0 0 0.28rem color-mix(in srgb, var(--accent-strong) 22%, transparent);
    flex: none;
  }

  .hero-actions {
    display: flex;
    gap: var(--space-s);
    flex-wrap: wrap;
    margin-top: var(--space-l);
  }

  .button-dark,
  .button-light,
  .submit-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3.2rem;
    padding: 0.95rem 1.2rem;
    border-radius: 999px;
    border: 1px solid transparent;
    font: inherit;
    font-weight: 700;
    text-decoration: none;
    cursor: pointer;
    transition:
      background-color var(--foundation-duration-fast) var(--foundation-ease),
      border-color var(--foundation-duration-fast) var(--foundation-ease),
      color var(--foundation-duration-fast) var(--foundation-ease),
      transform var(--foundation-duration-fast) var(--foundation-ease),
      box-shadow var(--foundation-duration-fast) var(--foundation-ease);
  }

  .button-dark,
  .submit-button {
    background: var(--brand);
    color: var(--surface-canvas);
    border-color: var(--brand);
    box-shadow: 0 14px 28px var(--shadow-color);
  }

  .button-light {
    background: var(--surface-overlay-strong);
    color: var(--text);
    border-color: var(--line);
  }
  .button-dark:hover,
  .button-light:hover,
  .submit-button:hover {
    transform: translateY(-1px);
  }

  .hero-side {
    display: grid;
    gap: var(--space-m);
  }

  .search-card {
    padding: var(--space-l);
    display: grid;
    gap: var(--space-s);
    background: var(--surface-elevated-strong);
    border-radius: var(--radius-lg);
    border: 1px solid var(--line);
    box-shadow: var(--shadow-soft);
  }

  .search-head {
    display: flex;
    justify-content: space-between;
    gap: var(--space-s);
    align-items: center;
    padding-bottom: var(--space-xs);
    border-bottom: 1px solid var(--line);
  }

  .search-head strong {
    font-size: 1rem;
    letter-spacing: -0.03em;
  }

  .search-head span {
    color: var(--muted);
    font-size: 0.82rem;
  }

  .toggle-row {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-s);
  }

  .toggle-pill {
    position: relative;
    display: block;
    cursor: pointer;
  }

  .toggle-pill input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .toggle-pill span {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 3rem;
    border-radius: 999px;
    border: 1px solid var(--line);
    background: var(--bg-soft);
    font-weight: 700;
  }

  .toggle-pill.active span {
    background: var(--brand);
    border-color: var(--brand);
    color: var(--surface-canvas);
  }

  .field-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-s);
  }

  .compact-grid {
    align-items: end;
  }

  .field {
    display: grid;
    gap: 0.42rem;
  }

  .field-wide {
    grid-column: 1 / -1;
  }

  .field span {
    color: var(--muted-strong);
    font-size: 0.82rem;
    font-weight: 700;
  }

  .field input,
  .field select {
    width: 100%;
    min-height: 3.2rem;
    padding: 0.92rem 1rem;
    border-radius: 1rem;
    border: 1px solid var(--line);
    background: var(--bg-soft);
    color: var(--text);
    font: inherit;
    box-shadow: inset 0 1px 0 var(--surface-overlay);
  }

  .side-metrics {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-s);
  }

  .metric-card,
  .metric-banner,
  .quick-links {
    border-radius: 1.6rem;
    border: 1px solid var(--line);
    background: var(--surface-panel-muted);
    box-shadow: var(--shadow-soft);
  }

  .metric-card {
    display: grid;
    gap: var(--space-xs);
    padding: var(--space-m);
  }

  .metric-card strong,
  .metric-banner strong,
  .quick-head strong {
    font-size: 1.08rem;
    letter-spacing: -0.04em;
  }

  .metric-card span:last-child,
  .metric-banner span:last-child {
    color: var(--muted);
    line-height: 1.6;
  }

  .hero-foot {
    display: grid;
    grid-template-columns: minmax(0, 1.5fr) minmax(18rem, 0.72fr);
    gap: var(--space-m);
  }

  .quick-links {
    padding: var(--space-l);
  }

  .quick-head {
    display: grid;
    gap: 0.25rem;
    margin-bottom: var(--space-s);
  }

  .quick-grid {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-s);
  }

  .quick-grid a {
    display: inline-flex;
    align-items: center;
    min-height: 2.5rem;
    padding: 0.7rem 0.95rem;
    border-radius: 999px;
    background: var(--surface-elevated-strong);
    border: 1px solid var(--line);
    color: var(--text);
    font-size: 0.86rem;
    font-weight: 700;
    text-decoration: none;
  }

  .metric-banner {
    display: grid;
    gap: 0.3rem;
    padding: var(--space-l);
    align-content: start;
  }

  @media (max-width: 1080px) {
    .hero-grid,
    .hero-foot,
    .side-metrics {
      grid-template-columns: 1fr;
    }

    .hero-copy h1 {
      max-width: none;
    }
  }

  @media (max-width: 760px) {
    .hero-grid {
      padding: var(--space-l);
    }

    .hero-copy h1 {
      font-size: clamp(2.4rem, 10vw, 4rem);
      max-width: 10ch;
    }

    .field-grid,
    .toggle-row {
      grid-template-columns: 1fr;
    }

    .button-dark,
    .button-light,
    .submit-button {
      width: 100%;
    }
  }
</style>
