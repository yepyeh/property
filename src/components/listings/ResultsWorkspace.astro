---
import ListingCard from "../ListingCard.astro";
import type { Listing } from "../../data/listings";

interface MappableListing {
  slug: string;
  title: string;
  priceLabel: string;
  ward: string;
  district: string;
  city: string;
  lat: number;
  lng: number;
}

export interface Props {
  listings: Listing[];
  mappableListings: MappableListing[];
  allDistricts: string[];
  topNeighborhoods: string[];
  showCompareLink?: boolean;
  t?: (value: string) => string;
}

const { listings, mappableListings, allDistricts, topNeighborhoods, showCompareLink = false, t = (value: string) => value } = Astro.props;
---

<div class="mobile-view-toggle" data-default-view="list">
  <button type="button" class="toggle-chip is-active" data-results-view-trigger="list">{t("List")}</button>
  <button
    type="button"
    class="toggle-chip"
    data-results-view-trigger="map"
    disabled={mappableListings.length === 0}
    aria-disabled={mappableListings.length === 0 ? "true" : "false"}
  >
    {t("Map")}
  </button>
</div>

<section class="results-layout" data-results-view="list">
  <aside class="market-panel glass-card">
    <span class="section-kicker">{t("Map view")}</span>
    <h2>{t("See the filtered listings on a live map")}</h2>
    {mappableListings.length > 0 ? (
      <div id="results-map" class="results-map" data-listings={JSON.stringify(mappableListings)}></div>
    ) : (
      <div class="map-empty">
        <strong>{t("No map coordinates for this result set yet.")}</strong>
        <span>{t("Try a broader filter set or add owner coordinates when posting listings.")}</span>
      </div>
    )}
    <div class="district-list">
      {(allDistricts.length > 0 ? allDistricts : [t("No matching districts")]).slice(0, 5).map((district) => <b>{district}</b>)}
    </div>
    {topNeighborhoods.length > 0 && (
      <div class="neighborhood-list">
        {topNeighborhoods.map((place) => <span>{place}</span>)}
      </div>
    )}
  </aside>

  <div class="results-list">
    {listings.length > 0 ? (
      listings.map((listing) => (
        <div
          class="listing-card-shell"
          data-listing-card={listing.slug}
          data-has-map={listing.location ? "true" : "false"}
          tabindex={listing.location ? 0 : -1}
        >
          <ListingCard listing={listing} showCompareLink={showCompareLink} t={t} />
        </div>
      ))
    ) : (
      <article class="empty-state glass-card">
        <span class="section-kicker">{t("No matches")}</span>
        <h2>{t("There are no listings for this filter set yet.")}</h2>
        <p>
          {t("Broaden the city or district, lower the bed count requirement, or clear the price range. If you are testing owner supply, you can also add a new listing from the dashboard.")}
        </p>
        <div class="empty-actions">
          <a class="button-dark" href="/listings/">{t("Clear filters")}</a>
          <a class="button-secondary" href="/submit-listing/">{t("Post a listing")}</a>
        </div>
      </article>
    )}
  </div>
</section>

<style is:inline>
  .mobile-view-toggle {
    display: none;
    gap: var(--space-s);
    padding: var(--space-2xs);
    margin-bottom: var(--space-m);
    border-radius: var(--radius-sm);
    background: transparent;
    border: 1px solid var(--border);
  }

  .toggle-chip,
  .button-dark,
  .button-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: calc(var(--space-xl) + var(--space-s));
    border-radius: var(--radius-full);
    padding: var(--space-s) var(--space-m);
    font-weight: 700;
    text-decoration: none;
    font: inherit;
    border: 1px solid var(--border);
  }

  .toggle-chip {
    flex: 1 1 0;
    min-height: calc(var(--space-xl) + var(--space-s));
    background: transparent;
    color: var(--text);
    cursor: pointer;
  }

  .toggle-chip.is-active {
    background: var(--brand);
    color: var(--surface-canvas);
    border-color: var(--brand);
  }

  .toggle-chip[disabled] {
    opacity: 0.45;
    cursor: not-allowed;
  }

  .results-layout {
    display: grid;
    grid-template-columns: minmax(20rem, 0.42fr) minmax(0, 1fr);
    gap: var(--space-xl);
    align-items: start;
    margin-bottom: var(--space-xl);
  }

  .market-panel,
  .empty-state {
    padding: var(--space-xl);
    background: transparent;
    border-radius: var(--radius-sm);
  }

  .market-panel {
    position: sticky;
    top: 6rem;
  }

  .section-kicker {
    display: inline-flex;
    align-items: center;
    color: var(--muted);
    font-size: var(--text-xs);
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .market-panel h2,
  .empty-state h2 {
    margin: var(--space-xs) 0 0;
    font-size: var(--text-2xl);
    letter-spacing: -0.05em;
    line-height: 1;
  }

  .empty-state p {
    color: var(--muted);
    line-height: 1.7;
    margin: var(--space-s) 0 0;
  }

  .results-map {
    min-height: 22rem;
    margin-top: var(--space-m);
    border-radius: var(--radius-sm);
    overflow: hidden;
    border: 1px solid var(--border);
    background: transparent;
  }

  .map-empty {
    display: grid;
    gap: var(--space-xs);
    margin-top: var(--space-m);
    padding: var(--space-m);
    border-radius: var(--radius-sm);
    background: transparent;
    border: 1px solid var(--border);
  }

  .map-empty strong {
    font-size: 0.98rem;
    letter-spacing: -0.02em;
  }

  .map-empty span {
    color: var(--muted);
    line-height: 1.6;
  }

  .district-list {
    display: grid;
    gap: var(--space-m);
  }

  .district-list b {
    display: block;
    padding: var(--space-s) var(--space-m);
    border-radius: var(--radius-sm);
    background: transparent;
    border: 1px solid var(--border);
    font-size: 0.95rem;
  }

  .neighborhood-list {
    display: flex;
    gap: var(--space-s);
    flex-wrap: wrap;
    margin-top: var(--space-m);
  }

  .neighborhood-list span {
    display: inline-flex;
    align-items: center;
    min-height: 2rem;
    padding: 0.22rem 0.75rem;
    border-radius: var(--radius-sm);
    border: 1px solid color-mix(in srgb, var(--accent) 36%, var(--border));
    color: var(--accent);
    font-size: 0.82rem;
    font-weight: 700;
  }

  .results-list {
    display: grid;
    gap: var(--space-m);
  }

  .results-list > :global(*) + :global(*) {
    margin-top: 0;
  }

  .listing-card-shell {
    border-radius: var(--radius-lg);
    transition: transform 180ms ease, box-shadow 180ms ease;
  }

  .district-list,
  .neighborhood-list {
    margin-top: 1rem;
  }

  .listing-card-shell.is-active {
    transform: translateY(-2px);
    box-shadow: var(--shadow-soft);
  }

  .listing-card-shell.is-active :global(.listing-card) {
    outline: 2px solid color-mix(in srgb, var(--accent) 24%, transparent);
    outline-offset: 2px;
  }

  .empty-actions {
    display: flex;
    justify-content: space-between;
    gap: var(--space-m);
    align-items: flex-start;
    flex-wrap: wrap;
    margin-top: var(--space-m);
  }

  .button-dark {
    background: var(--brand);
    color: var(--surface-canvas);
    border-color: var(--brand);
  }

  .button-secondary {
    background: var(--surface-elevated-strong);
    color: var(--text);
  }

  @media (max-width: 1100px) {
    .results-layout {
      grid-template-columns: 1fr;
    }

    .market-panel {
      position: static;
    }
  }

  @media (max-width: 760px) {
    .mobile-view-toggle {
      display: flex;
    }

    .empty-actions {
      display: grid;
    }

    .button-dark,
    .button-secondary {
      width: 100%;
    }

    .results-layout[data-results-view="list"] .market-panel {
      display: none;
    }

    .results-layout[data-results-view="map"] .results-list {
      display: none;
    }
  }
</style>
