---
export interface Props {
  t?: (value: string) => string;
}

const { t = (value: string) => value } = Astro.props;
---

<section class="results-hero card">
  <div class="hero-copy">
    <span class="section-kicker">{t("Search results")}</span>
    <h1>{t("Search property with less noise and stronger buyer signals.")}</h1>
  </div>
  <div class="hero-actions">
    <a class="button-secondary" href="/">{t("Home")}</a>
    <a class="button-dark" href="#results">{t("Jump to results")}</a>
  </div>
</section>

<style is:inline>
  .results-hero {
    display: flex;
    justify-content: space-between;
    gap: var(--space-m);
    align-items: flex-start;
    flex-wrap: wrap;
    margin-bottom: var(--space-m);
    padding: var(--space-l);
    background: var(--surface-overlay-strong);
    box-shadow: var(--shadow-soft);
  }

  .section-kicker {
    display: inline-flex;
    align-items: center;
    min-height: calc(var(--space-l) * 0.95);
    padding: calc(var(--space-2xs) * 1.1) var(--space-s);
    border-radius: var(--radius-full);
    border: 1px solid var(--line);
    background: var(--surface-overlay);
    color: var(--muted-strong);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .hero-copy {
    max-width: 44rem;
  }

  .hero-copy h1 {
    margin: var(--space-s) 0 0;
    font-size: var(--text-display);
    line-height: 0.92;
    letter-spacing: -0.09em;
  }

  .hero-actions {
    display: flex;
    gap: var(--space-s);
    align-items: flex-start;
    flex-wrap: wrap;
  }

  @media (max-width: 760px) {
    .results-hero,
    .hero-actions {
      display: grid;
    }

    .button-dark,
    .button-secondary {
      width: 100%;
    }
  }
</style>
