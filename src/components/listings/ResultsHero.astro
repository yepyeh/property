---
export interface Props {
  t?: (value: string) => string;
}

const { t = (value: string) => value } = Astro.props;
---

<section class="results-hero card">
  <div class="hero-copy">
    <span class="section-kicker">{t("Search results")}</span>
    <h1>{t("Search property with less noise and stronger buyer signals.")}</h1>
    <p>
      {t("The results surface should feel decisive: clear filters, stable URLs, visible result counts, and cleaner cards that help a buyer compare quickly.")}
    </p>
  </div>
  <div class="hero-actions">
    <a class="button-secondary" href="/">{t("Home")}</a>
    <a class="button-dark" href="#results">{t("Jump to results")}</a>
  </div>
</section>

<style is:inline>
  .results-hero {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: flex-start;
    flex-wrap: wrap;
    margin-bottom: 1rem;
    padding: 1.35rem;
    background: rgba(255,255,255,0.82);
    box-shadow: var(--shadow-soft);
  }

  .section-kicker {
    display: inline-flex;
    align-items: center;
    min-height: 2rem;
    padding: 0.35rem 0.82rem;
    border-radius: 999px;
    border: 1px solid var(--line);
    background: rgba(255,255,255,0.78);
    color: var(--muted-strong);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .hero-copy {
    max-width: 44rem;
  }

  .hero-copy h1 {
    margin: 0.75rem 0 0;
    font-size: clamp(2.8rem, 5vw, 4.9rem);
    line-height: 0.92;
    letter-spacing: -0.09em;
  }

  .hero-copy p {
    color: var(--muted);
    line-height: 1.76;
    margin-top: 0.8rem;
  }

  .hero-actions {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
    flex-wrap: wrap;
  }

  .button-dark,
  .button-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.9rem;
    border-radius: 999px;
    padding: 0.82rem 1rem;
    font-weight: 700;
    text-decoration: none;
    font: inherit;
    border: 1px solid var(--line);
  }

  .button-dark {
    background: var(--brand);
    color: white;
    border-color: var(--brand);
  }

  .button-secondary {
    background: white;
    color: var(--text);
  }

  @media (max-width: 760px) {
    .results-hero,
    .hero-actions {
      display: grid;
    }

    .button-dark,
    .button-secondary {
      width: 100%;
    }
  }
</style>
