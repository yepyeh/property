---
export interface Props {
  total: number;
  countries: number;
  cities: number;
  forRent: number;
  hasFilters: boolean;
  allCities: string[];
  selectedIntent: string;
  t?: (value: string) => string;
}

const { total, countries, cities, forRent, hasFilters, allCities, selectedIntent, t = (value: string) => value } = Astro.props;
---

<section class="results-summary card" id="results">
  <div class="summary-main">
    <strong>{total} {t("listings")}</strong>
    <p>
      {t("Across")} {countries} {t("countries")} · {cities} {t("cities")} · {forRent} {t("rentals live")}
      {hasFilters ? ` · ${t("filtered results")}` : ` · ${t("full inventory")}`}
    </p>
    <div class="summary-pills">
      <span>{selectedIntent === "rent" ? t("Rental search") : t("Purchase search")}</span>
      <span>{hasFilters ? t("Custom filter set") : t("Full live inventory")}</span>
    </div>
  </div>
  <div class="summary-links">
    <span>{t("Popular city routes")}</span>
    {allCities.slice(0, 3).map((city) => <a href={`/listings/?intent=${selectedIntent}&city=${encodeURIComponent(city)}`}>{city}</a>)}
  </div>
</section>

<style is:inline>
  .results-summary {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: flex-start;
    flex-wrap: wrap;
    margin-bottom: 1rem;
    padding: 1.35rem;
    background: var(--surface-overlay-strong);
    box-shadow: var(--shadow-soft);
  }

  .results-summary strong {
    display: block;
    font-size: 2.45rem;
    letter-spacing: -0.08em;
  }

  .results-summary p,
  .summary-links span {
    color: var(--muted);
    margin-top: 0.7rem;
    line-height: 1.72;
    font-weight: 700;
  }

  .summary-main {
    display: grid;
    gap: 0.7rem;
  }

  .summary-pills {
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
  }

  .summary-pills span {
    display: inline-flex;
    align-items: center;
    min-height: 2rem;
    padding: 0.3rem 0.78rem;
    border-radius: 999px;
    background: var(--surface-elevated);
    border: 1px solid var(--line);
    color: var(--muted-strong);
    font-size: 0.8rem;
    font-weight: 700;
  }

  .summary-links {
    display: flex;
    justify-content: space-between;
    gap: 0.8rem;
    align-items: center;
    flex-wrap: wrap;
  }

  .summary-links a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.7rem;
    border-radius: 999px;
    padding: 0.78rem 0.96rem;
    font-weight: 700;
    text-decoration: none;
    font: inherit;
    border: 1px solid var(--line);
    background: var(--surface-elevated-strong);
    color: var(--text);
  }

  @media (max-width: 760px) {
    .results-summary,
    .summary-links {
      display: grid;
    }
  }
</style>
