---
export interface Props {
  total: number;
  cities: number;
  forRent: number;
  hasFilters: boolean;
  allCities: string[];
  selectedIntent: string;
}

const { total, cities, forRent, hasFilters, allCities, selectedIntent } = Astro.props;
---

<section class="results-summary card" id="results">
  <div class="summary-main">
    <strong>{total} listings</strong>
    <p>
      across {cities} cities · {forRent} rentals live
      {hasFilters ? " · filtered results" : " · full inventory"}
    </p>
    <div class="summary-pills">
      <span>{selectedIntent === "rent" ? "Rental search" : "Purchase search"}</span>
      <span>{hasFilters ? "Custom filter set" : "Full live inventory"}</span>
    </div>
  </div>
  <div class="summary-links">
    <span>Popular city routes</span>
    {allCities.slice(0, 3).map((city) => <a href={`/listings/?intent=${selectedIntent}&city=${encodeURIComponent(city)}`}>{city}</a>)}
  </div>
</section>

<style is:inline>
  .results-summary {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: flex-start;
    flex-wrap: wrap;
    margin-bottom: 1rem;
    padding: 1.35rem;
    background: rgba(255,255,255,0.82);
    box-shadow: var(--shadow-soft);
  }

  .results-summary strong {
    display: block;
    font-size: 2.45rem;
    letter-spacing: -0.08em;
  }

  .results-summary p,
  .summary-links span {
    color: var(--muted);
    margin-top: 0.7rem;
    line-height: 1.72;
    font-weight: 700;
  }

  .summary-main {
    display: grid;
    gap: 0.7rem;
  }

  .summary-pills {
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
  }

  .summary-pills span {
    display: inline-flex;
    align-items: center;
    min-height: 2rem;
    padding: 0.3rem 0.78rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.92);
    border: 1px solid var(--line);
    color: var(--muted-strong);
    font-size: 0.8rem;
    font-weight: 700;
  }

  .summary-links {
    display: flex;
    justify-content: space-between;
    gap: 0.8rem;
    align-items: center;
    flex-wrap: wrap;
  }

  .summary-links a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.7rem;
    border-radius: 999px;
    padding: 0.78rem 0.96rem;
    font-weight: 700;
    text-decoration: none;
    font: inherit;
    border: 1px solid var(--line);
    background: white;
    color: var(--text);
  }

  @media (max-width: 760px) {
    .results-summary,
    .summary-links {
      display: grid;
    }
  }
</style>
