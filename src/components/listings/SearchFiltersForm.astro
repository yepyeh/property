---
import type { ListingFilters } from "../../lib/marketplace-types";

export interface Props {
  filters: ListingFilters;
  owner: { role: string } | null;
  dashboardHref: string;
  activeFilters: string[];
  allCountries?: string[];
  t?: (value: string) => string;
}

const { filters, owner, dashboardHref, activeFilters, allCountries = [], t = (value: string) => value } = Astro.props;
const selectedIntent = filters.intent === "rent" ? "rent" : "buy";
const selectedSort = filters.sort || "newest";
---

<form class="search-frame card" method="GET" action="/listings/">
  <div class="search-head">
    <div>
      <p class="search-kicker">{t("Refine the shortlist")}</p>
      <h2>{t("Search by location, price band, and home type.")}</h2>
    </div>
  </div>

  <div class="intent-tabs">
    <label class:list-active={selectedIntent === "buy"}>
      <input type="radio" name="intent" value="buy" checked={selectedIntent === "buy"} />
      <span>{t("Buy")}</span>
    </label>
    <label class:list-active={selectedIntent === "rent"}>
      <input type="radio" name="intent" value="rent" checked={selectedIntent === "rent"} />
      <span>{t("Rent")}</span>
    </label>
  </div>

  <div class="filter-grid">
    <label class="field">
      <span>{t("Country")}</span>
      <select name="country">
        <option value="">{t("All countries")}</option>
        {allCountries.map((country) => <option value={country} selected={filters.country === country}>{country}</option>)}
      </select>
    </label>
    <label class="field">
      <span>{t("City")}</span>
      <input type="text" name="city" value={filters.city} placeholder={t("Ho Chi Minh City")} />
    </label>
    <label class="field">
      <span>{t("District")}</span>
      <input type="text" name="district" value={filters.district} placeholder={t("Thu Duc City")} />
    </label>
    <label class="field">
      <span>{t("Property type")}</span>
      <select name="propertyType">
        <option value="">{t("Any property")}</option>
        <option value="Condo" selected={filters.propertyType === "Condo"}>{t("Condo")}</option>
        <option value="Villa" selected={filters.propertyType === "Villa"}>{t("Villa")}</option>
        <option value="Townhouse" selected={filters.propertyType === "Townhouse"}>{t("Townhouse")}</option>
        <option value="Apartment" selected={filters.propertyType === "Apartment"}>{t("Apartment")}</option>
        <option value="House" selected={filters.propertyType === "House"}>{t("House")}</option>
        <option value="Land" selected={filters.propertyType === "Land"}>{t("Land")}</option>
      </select>
    </label>
    <label class="field">
      <span>{t("Sale mode")}</span>
      <select name="saleMode">
        <option value="">{t("Any mode")}</option>
        <option value="private-sale" selected={filters.saleMode === "private-sale"}>{t("Private sale")}</option>
        <option value="auction" selected={filters.saleMode === "auction"}>{t("Auction")}</option>
      </select>
    </label>
    <label class="field">
      <span>{t("Minimum beds")}</span>
      <select name="minBeds">
        <option value="">{t("Any beds")}</option>
        <option value="1" selected={filters.minBeds === 1}>1+</option>
        <option value="2" selected={filters.minBeds === 2}>2+</option>
        <option value="3" selected={filters.minBeds === 3}>3+</option>
        <option value="4" selected={filters.minBeds === 4}>4+</option>
      </select>
    </label>
    <label class="field">
      <span>{t("Minimum price")}</span>
      <input type="number" min="0" step="0.01" name="minPrice" value={filters.minPrice ?? ""} placeholder="0" />
    </label>
    <label class="field">
      <span>{t("Maximum price")}</span>
      <input type="number" min="0" step="0.01" name="maxPrice" value={filters.maxPrice ?? ""} placeholder="10" />
    </label>
    <label class="field">
      <span>{t("Sort")}</span>
      <select name="sort">
        <option value="newest" selected={selectedSort === "newest"}>{t("Newest")}</option>
        <option value="price-asc" selected={selectedSort === "price-asc"}>{t("Price: low to high")}</option>
        <option value="price-desc" selected={selectedSort === "price-desc"}>{t("Price: high to low")}</option>
        <option value="beds-desc" selected={selectedSort === "beds-desc"}>{t("Beds")}</option>
      </select>
    </label>
    <div class="filter-actions">
      <button class="button-dark" type="submit">{t("Search")}</button>
      <a class="button-secondary" href="/listings/">{t("Clear")}</a>
    </div>
  </div>

  <div class="utility-row">
    <div class="filter-chips">
      {activeFilters.length > 0 ? activeFilters.map((filter) => <span>{filter}</span>) : <span>{t("All live inventory")}</span>}
    </div>
    <div class="utility-links">
      <a href={dashboardHref}>{owner?.role === "buyer" ? t("Saved searches") : t("Track enquiries")}</a>
      <a href={owner?.role === "buyer" ? "/signup?role=owner" : "/submit-listing/"}>{owner?.role === "buyer" ? t("Create owner account") : t("Post listing")}</a>
    </div>
  </div>
</form>

<style is:inline>
  .search-frame {
    margin-bottom: var(--space-m);
    padding: var(--space-l);
    background: var(--surface-overlay);
    box-shadow: var(--shadow-soft);
  }

  .intent-tabs,
  .filter-grid {
    display: grid;
    gap: var(--space-m);
  }

  .search-head {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(18rem, 0.75fr);
    gap: var(--space-m);
    align-items: end;
    margin-bottom: var(--space-m);
  }

  .search-kicker {
    margin: 0;
    font-size: var(--text-xs);
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent-strong);
  }

  .search-head h2 {
    margin: var(--space-2xs) 0 0;
    font-size: var(--text-2xl);
    line-height: 0.98;
    letter-spacing: -0.07em;
  }

  .intent-tabs {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    margin-bottom: var(--space-m);
  }

  .intent-tabs label {
    position: relative;
    cursor: pointer;
  }

  .intent-tabs input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .intent-tabs label span,
  .utility-links a,
  .filter-chips span {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: calc(var(--space-xl) + var(--space-s));
    border-radius: var(--radius-full);
    padding: var(--space-s) var(--space-m);
    font-weight: 700;
    text-decoration: none;
    font: inherit;
    border: 1px solid var(--line);
  }

  .intent-tabs label span,
  .button-secondary,
  .utility-links a,
  .filter-chips span {
    background: var(--surface-elevated-strong);
    color: var(--text);
  }

  .intent-tabs label.list-active span {
    background: var(--brand);
    color: var(--surface-canvas);
    border-color: var(--brand);
  }

  .filter-grid {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .field {
    display: grid;
    gap: var(--space-2xs);
  }

  .field span {
    font-size: var(--text-xs);
    font-weight: 700;
    color: var(--muted-strong);
  }

  .field input,
  .field select {
    width: 100%;
    min-height: calc(var(--space-xl) + var(--space-m));
    border-radius: var(--radius-lg);
    border: 1px solid var(--line);
    background: var(--bg-soft);
    padding: var(--space-s) var(--space-m);
    color: var(--text);
    font: inherit;
  }

  .filter-actions,
  .utility-links,
  .filter-chips {
    display: flex;
    gap: var(--space-s);
    flex-wrap: wrap;
  }

  .filter-actions {
    align-items: end;
  }

  .utility-row {
    display: flex;
    justify-content: space-between;
    gap: var(--space-m);
    align-items: flex-start;
    flex-wrap: wrap;
    margin-top: var(--space-m);
    padding-top: var(--space-m);
    border-top: 1px solid var(--line);
  }

  .filter-chips span {
    min-height: calc(var(--space-l) * 1.05);
    padding: var(--space-xs) var(--space-s);
    font-size: var(--text-xs);
    background: var(--surface-overlay-strong);
  }

  @media (max-width: 1100px) {
    .search-head,
    .filter-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 760px) {
    .intent-tabs,
    .utility-row {
      grid-template-columns: 1fr;
      display: grid;
    }

    .button-dark,
    .button-secondary {
      width: 100%;
    }
  }
</style>
