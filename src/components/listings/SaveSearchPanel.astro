---
export interface Props {
  owner: { role: string } | null;
  filters: {
    intent?: string;
    city?: string;
    district?: string;
    propertyType?: string;
    saleMode?: string;
    minPrice?: number;
    maxPrice?: number;
    minBeds?: number;
    sort?: string;
  };
  dashboardHref: string;
  currentSearchQuery: string;
}

const { owner, filters, dashboardHref, currentSearchQuery } = Astro.props;
---

<section class="save-search card">
  <div class="save-copy">
    <span class="section-kicker">Buyer alerts</span>
    <h2>Save this search</h2>
    <p>Keep the current filter set as a reusable shortlist and turn it into an alert workflow later.</p>
    <div class="save-points">
      <span>Reusable search presets</span>
      <span>Buyer follow-up later</span>
      <span>Alert-ready structure</span>
    </div>
    <div class="save-meter">
      <strong>Best used for:</strong>
      <span>buyers watching one district, one budget band, or one property type over time.</span>
    </div>
  </div>
  {owner ? (
    <form method="POST" action="/api/saved-searches" class="save-form">
      <input type="hidden" name="intent" value={filters.intent} />
      <input type="hidden" name="city" value={filters.city} />
      <input type="hidden" name="district" value={filters.district} />
      <input type="hidden" name="propertyType" value={filters.propertyType} />
      <input type="hidden" name="saleMode" value={filters.saleMode} />
      <input type="hidden" name="minPrice" value={filters.minPrice ?? ""} />
      <input type="hidden" name="maxPrice" value={filters.maxPrice ?? ""} />
      <input type="hidden" name="minBeds" value={filters.minBeds ?? ""} />
      <input type="hidden" name="sort" value={filters.sort} />
      <label class="field">
        <span>Search name</span>
        <input type="text" name="name" value={`Saved search · ${filters.intent === "rent" ? "Rent" : "Buy"} · ${filters.city || "All cities"}`} />
      </label>
      <div class="save-actions">
        <button type="submit" class="button-dark">Save search</button>
        <a class="button-secondary" href={dashboardHref}>Manage saved searches</a>
      </div>
    </form>
  ) : (
    <div class="save-auth">
      <p>Sign in to save this filter set and turn it into a reusable buyer alert.</p>
      <a class="button-dark" href={`/login?redirect=${encodeURIComponent(`/listings/?${currentSearchQuery}`)}`}>Sign in to save</a>
    </div>
  )}
</section>

<style is:inline>
  .save-search {
    display: grid;
    grid-template-columns: minmax(0, 0.92fr) minmax(0, 1.08fr);
    gap: 1rem;
    align-items: stretch;
    margin-bottom: 1rem;
    padding: 1.35rem;
    background: rgba(255,255,255,0.82);
    box-shadow: var(--shadow-soft);
  }

  .save-copy {
    display: grid;
    gap: 0.7rem;
    align-content: start;
  }

  .section-kicker {
    display: inline-flex;
    align-items: center;
    min-height: 2rem;
    padding: 0.35rem 0.82rem;
    border-radius: 999px;
    border: 1px solid var(--line);
    background: rgba(255,255,255,0.76);
    color: var(--muted-strong);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .save-search h2 {
    margin: 0;
    font-size: clamp(1.9rem, 3vw, 2.8rem);
    letter-spacing: -0.08em;
    line-height: 0.96;
  }

  .save-search p {
    color: var(--muted);
    line-height: 1.72;
  }

  .save-points {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
  }

  .save-points span {
    display: inline-flex;
    align-items: center;
    min-height: 2.2rem;
    padding: 0.55rem 0.8rem;
    border-radius: 999px;
    background: var(--bg-soft);
    border: 1px solid var(--line);
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--muted-strong);
  }

  .save-meter {
    display: grid;
    gap: 0.25rem;
    padding: 0.95rem 1rem;
    border-radius: 20px;
    background: linear-gradient(180deg, rgba(255,255,255,0.96), rgba(243,239,231,0.9));
    border: 1px solid var(--line);
  }

  .save-meter strong {
    font-size: 0.95rem;
  }

  .save-meter span {
    color: var(--muted);
    line-height: 1.65;
  }

  .save-form,
  .field {
    display: grid;
    gap: 0.45rem;
  }

  .field span {
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--muted-strong);
  }

  .field input {
    width: 100%;
    min-height: 3.1rem;
    border-radius: 1rem;
    border: 1px solid var(--line);
    background: var(--bg-soft);
    padding: 0.92rem 1rem;
    color: var(--text);
    font: inherit;
  }

  .save-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: 0.8rem;
  }

  .button-dark,
  .button-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.85rem;
    border-radius: 999px;
    padding: 0.84rem 1rem;
    font-weight: 700;
    text-decoration: none;
    font: inherit;
    border: 1px solid var(--line);
  }

  .button-dark {
    background: var(--brand);
    color: white;
    border-color: var(--brand);
    cursor: pointer;
  }

  .button-secondary {
    background: white;
    color: var(--text);
  }

  .save-auth {
    display: grid;
    gap: 1rem;
    align-content: center;
  }

  @media (max-width: 1100px) {
    .save-search {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 760px) {
    .save-actions {
      display: grid;
    }

    .button-dark,
    .button-secondary {
      width: 100%;
    }
  }
</style>
