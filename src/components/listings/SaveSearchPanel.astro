---
export interface Props {
  owner: { role: string } | null;
  filters: {
    intent?: string;
    city?: string;
    district?: string;
    propertyType?: string;
    saleMode?: string;
    minPrice?: number;
    maxPrice?: number;
    minBeds?: number;
    sort?: string;
  };
  dashboardHref: string;
  currentSearchQuery: string;
}

const { owner, filters, dashboardHref, currentSearchQuery } = Astro.props;
---

<section class="save-search glass-card">
  <div class="save-copy">
    <span class="section-kicker">Buyer alerts</span>
    <h2>Save this search</h2>
    <p>Keep the current filter set as a reusable shortlist and turn it into an alert workflow later.</p>
    <div class="save-points">
      <span>Reusable search presets</span>
      <span>Buyer follow-up later</span>
      <span>Alert-ready structure</span>
    </div>
    <div class="save-meter">
      <strong>Best used for:</strong>
      <span>buyers watching one district, one budget band, or one property type over time.</span>
    </div>
  </div>
  {owner ? (
    <form method="POST" action="/api/saved-searches" class="save-form">
      <input type="hidden" name="intent" value={filters.intent} />
      <input type="hidden" name="city" value={filters.city} />
      <input type="hidden" name="district" value={filters.district} />
      <input type="hidden" name="propertyType" value={filters.propertyType} />
      <input type="hidden" name="saleMode" value={filters.saleMode} />
      <input type="hidden" name="minPrice" value={filters.minPrice ?? ""} />
      <input type="hidden" name="maxPrice" value={filters.maxPrice ?? ""} />
      <input type="hidden" name="minBeds" value={filters.minBeds ?? ""} />
      <input type="hidden" name="sort" value={filters.sort} />
      <label class="field">
        <span>Search name</span>
        <input class="input-luxury" type="text" name="name" value={`Saved search · ${filters.intent === "rent" ? "Rent" : "Buy"} · ${filters.city || "All cities"}`} />
      </label>
      <div class="save-actions">
        <button type="submit" class="btn-primary">Save search</button>
        <a class="button-shell" href={dashboardHref}>Manage saved searches</a>
      </div>
    </form>
  ) : (
    <div class="save-auth">
      <p>Sign in to save this filter set and turn it into a reusable buyer alert.</p>
      <a class="btn-primary" href={`/login?redirect=${encodeURIComponent(`/listings/?${currentSearchQuery}`)}`}>Sign in to save</a>
    </div>
  )}
</section>

<style is:inline>
  .save-search {
    display: grid;
    grid-template-columns: minmax(0, 0.92fr) minmax(0, 1.08fr);
    gap: var(--space-m);
    align-items: stretch;
    margin-bottom: var(--space-m);
    padding: var(--space-xl);
    background: color-mix(in srgb, var(--card) 94%, transparent);
  }

  .save-copy,
  .save-form,
  .field,
  .save-auth,
  .save-meter {
    display: grid;
    gap: var(--space-m);
  }

  .section-kicker,
  .save-points span {
    display: inline-flex;
    align-items: center;
    min-height: calc(var(--space-l) + var(--space-xs));
    padding: var(--space-xs) var(--space-s);
    border-radius: var(--radius-full);
    border: 1px solid var(--border);
    background: color-mix(in srgb, var(--card) 78%, transparent);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.08em;
  }

  .section-kicker {
    color: var(--accent);
    text-transform: uppercase;
  }

  .save-search h2,
  .save-search p,
  .save-meter span,
  .field span,
  .button-shell {
    margin: 0;
  }

  .save-search h2 {
    font-size: var(--text-4xl);
    letter-spacing: -0.06em;
    line-height: 0.94;
  }

  .save-search p,
  .save-meter span {
    color: var(--muted);
    line-height: 1.72;
  }

  .save-points,
  .save-actions {
    display: flex;
    gap: var(--space-s);
    flex-wrap: wrap;
  }

  .save-points span {
    color: var(--foundation-text);
  }

  .save-meter {
    padding: var(--space-m);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
    background: color-mix(in srgb, var(--card) 78%, transparent);
  }

  .field span {
    color: var(--foundation-text);
    font-size: var(--text-sm);
    font-weight: 700;
  }

  .button-shell {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: calc(var(--space-xl) + var(--space-s));
    border-radius: var(--radius-full);
    padding: var(--space-s) var(--space-m);
    font-weight: 700;
    text-decoration: none;
    border: 1px solid var(--border);
    background: color-mix(in srgb, var(--card) 78%, transparent);
    color: inherit;
    transition: all var(--duration-fast) var(--transition-luxury);
  }

  .button-shell:hover {
    color: var(--accent);
    border-color: color-mix(in srgb, var(--accent) 22%, var(--border));
  }

  @media (max-width: 1100px) {
    .save-search {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 760px) {
    .save-actions {
      display: grid;
    }

    .btn-primary,
    .button-shell {
      width: 100%;
    }
  }
</style>
