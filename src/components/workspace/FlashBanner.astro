---
export interface Props {
  message: string;
  tone?: "success" | "info";
}
const { message, tone = "success" } = Astro.props;
---
<div class:list={["card", "flash-banner", `flash-${tone}`]}>{message}</div>
<style is:inline>
  .flash-banner {
    margin-top: 1rem;
    padding: 1.5rem;
    font-weight: 700;
    background: linear-gradient(180deg, var(--surface-overlay-strong), var(--surface-panel-muted));
    box-shadow: var(--shadow-panel);
  }
  .flash-success {
    border-left: 4px solid var(--success-border);
    color: var(--success-text);
  }
  .flash-info {
    border-left: 4px solid var(--info-border);
    color: var(--info-text);
  }
</style>
