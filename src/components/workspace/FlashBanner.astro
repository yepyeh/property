---
export interface Props {
  message: string;
  tone?: "success" | "info";
}
const { message, tone = "success" } = Astro.props;
---
<div class:list={["card", "flash-banner", `flash-${tone}`]}>{message}</div>
<style is:inline>
  .flash-banner {
    margin-top: 1rem;
    padding: 1.5rem;
    font-weight: 700;
    background: rgba(255, 255, 255, 0.88);
    box-shadow: 0 1px 2px rgba(16, 24, 40, 0.04), 0 16px 40px rgba(16, 24, 40, 0.06);
  }
  .flash-success {
    border-left: 4px solid rgba(18, 183, 106, 0.35);
    color: #067647;
  }
  .flash-info {
    border-left: 4px solid rgba(37, 99, 235, 0.35);
    color: #1d4ed8;
  }
</style>
