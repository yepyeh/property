---
export interface Props {
  message: string;
}
const { message } = Astro.props;
---
<div class="card flash-banner">{message}</div>
<style is:inline>
  .flash-banner {
    margin-top: 1rem;
    padding: 1.5rem;
    border-left: 4px solid rgba(18, 183, 106, 0.35);
    color: #067647;
    font-weight: 700;
    background: rgba(255, 255, 255, 0.88);
    box-shadow: 0 1px 2px rgba(16, 24, 40, 0.04), 0 16px 40px rgba(16, 24, 40, 0.06);
  }
</style>
