---
export interface Props {
  message: string;
  tone?: "success" | "info";
}
const { message, tone = "success" } = Astro.props;
---
<div class:list={["card", "flash-banner", `flash-${tone}`]}>{message}</div>
<style is:inline>
  .flash-banner {
    margin-top: 1rem;
    padding: 1.5rem;
    font-weight: 700;
    background: var(--surface-overlay-strong);
    box-shadow: 0 1px 2px rgba(16, 24, 40, 0.04), 0 16px 40px rgba(16, 24, 40, 0.06);
  }
  .flash-success {
    border-left: 4px solid var(--success-border);
    color: var(--success-text);
  }
  .flash-info {
    border-left: 4px solid var(--info-border);
    color: var(--info-text);
  }
</style>
