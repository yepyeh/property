---
export interface Action {
  href?: string;
  label: string;
  kind?: "primary" | "secondary";
  formAction?: string;
}

export interface Props {
  eyebrow: string;
  title: string;
  text: string;
  actions?: Action[];
}

const { eyebrow, title, text, actions = [] } = Astro.props;
---

<section class="page-hero card">
  <div class="hero-copy">
    <p class="eyebrow">{eyebrow}</p>
    <h1 class="hero-title">{title}</h1>
    <p class="hero-text">{text}</p>
  </div>
  {actions.length > 0 && (
    <div class="hero-actions">
      {actions.map((action) =>
        action.formAction ? (
          <form method="POST" action={action.formAction}>
            <button class={action.kind === "secondary" ? "button-secondary" : "button-primary"} type="submit">{action.label}</button>
          </form>
        ) : (
          <a class={action.kind === "secondary" ? "button-secondary" : "button-primary"} href={action.href}>{action.label}</a>
        )
      )}
    </div>
  )}
</section>

<style is:inline>
  .page-hero {
    padding: var(--space-l);
    background:
      radial-gradient(circle at top left, color-mix(in srgb, var(--hero-glow) 46%, transparent), transparent 32rem),
      linear-gradient(180deg, var(--surface-overlay-strong), var(--surface-panel-muted));
    box-shadow: var(--shadow-panel);
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-m);
    flex-wrap: wrap;
  }
  .hero-copy { max-width: 46rem; }
  .eyebrow {
    margin: 0 0 var(--space-2xs);
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
  }
  .hero-title {
    margin: 0;
    font-size: var(--text-5xl);
    letter-spacing: -0.06em;
    line-height: 1;
  }
  .hero-text {
    margin: 0;
    line-height: 1.65;
    color: var(--muted);
  }
  .hero-actions {
    display: flex;
    align-items: center;
    gap: var(--space-m);
    flex-wrap: wrap;
  }
  .button-primary,
  .button-secondary {
    text-decoration: none;
  }
  @media (max-width: 760px) {
    .page-hero,
    .hero-actions { display: grid; }
    .button-primary,
    .button-secondary { width: 100%; }
  }
</style>
