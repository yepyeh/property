---
export interface Block {
  eyebrow: string;
  title: string;
  copy: string;
}

export interface Props {
  blocks: Block[];
}

const { blocks } = Astro.props;
---

<section class="card profile-panel">
  {blocks.map((block) => (
    <div class="profile-block">
      <p class="eyebrow">{block.eyebrow}</p>
      <strong>{block.title}</strong>
      <span>{block.copy}</span>
    </div>
  ))}
  <form method="POST" action="/api/auth/logout" class="profile-actions">
    <button class="button-secondary" type="submit">Log out</button>
  </form>
</section>

<style is:inline>
  .profile-panel {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-m);
    align-items: end;
    margin-top: var(--space-m);
    padding: var(--space-l);
    background: linear-gradient(180deg, var(--surface-overlay-strong), var(--surface-panel-muted));
    box-shadow: var(--shadow-panel);
  }
  .eyebrow {
    margin: 0 0 0.45rem;
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
  }
  .profile-block span { color: var(--muted); }
  .profile-block strong { display: block; margin-bottom: 0.2rem; }
  .button-secondary {
    text-decoration: none;
  }
  @media (max-width: 820px) {
    .profile-panel { grid-template-columns: 1fr; }
  }
</style>
