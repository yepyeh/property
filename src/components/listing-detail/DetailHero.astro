---
import { getAuctionTimingLabel, type Listing } from "../../data/listings";

export interface Props {
  listing: Listing;
  intentLabel: string;
  ownerTrustLabel: string;
  isBuyer: boolean;
  isSaved: boolean;
  savedListing: boolean;
  t?: (value: string) => string;
}

const { listing, intentLabel, ownerTrustLabel, isBuyer, isSaved, savedListing, t = (value: string) => value } = Astro.props;
const heroImage = listing.imageUrls?.[0];
const coverPosition = listing.coverFocus ? `${listing.coverFocus.x}% ${listing.coverFocus.y}%` : "center";
const galleryImages = listing.imageUrls || [];
const isAuction = listing.saleMode === "auction";
const auctionTimingLabel = isAuction ? getAuctionTimingLabel(listing.auction) : null;
const heroImageStyle = heroImage ? `--hero-image:url(${heroImage});--hero-position:${coverPosition}` : undefined;
---

<section class="detail-hero glass-card">
  <div class="hero-media">
    <div class={`hero-image ${listing.tone}`} style={heroImageStyle}>
      <div class="hero-badges">
        <span class="hero-pill">{intentLabel}</span>
        <span class="hero-pill hero-pill-soft">{listing.status}</span>
      </div>
      <div class="gallery-count">{galleryImages.length} {t("photos")}</div>
      <div class="hero-image-note">
        <strong>{listing.ward}, {listing.district}</strong>
        <span>{listing.city}, {listing.country}</span>
      </div>
    </div>
    {galleryImages.length > 1 && (
      <div class="gallery-strip">
        {galleryImages.slice(0, 4).map((imageUrl, index) => (
          <div class="gallery-card">
            <img src={imageUrl} alt={`${listing.title} photo ${index + 1}`} loading="lazy" />
            <span>{index === 0 ? t("Primary view") : `${t("Gallery")} ${index + 1}`}</span>
          </div>
        ))}
      </div>
    )}
  </div>

  <div class="hero-panel">
    <a class="back-link" href="/listings/">{t("All listings")}</a>
    <p class="eyebrow">{listing.type} · {listing.district}, {listing.city}, {listing.country}</p>
    <h1>{listing.title}</h1>
    <p class="price">{listing.priceLabel}</p>
    {isAuction && listing.auction && (
      <div class="auction-summary">
        <span>{listing.auction.phase === "live" ? t("Bidding is live") : listing.auction.phase === "ended" ? t("Auction closed") : t("Auction scheduled")}</span>
        {listing.auction.startingPriceLabel && <span>{t("Opening bid")} {listing.auction.startingPriceLabel}</span>}
        {auctionTimingLabel && <span>{t(auctionTimingLabel)}</span>}
      </div>
    )}
    <p class="summary">{listing.summary}</p>

    <div class="fact-grid">
      <article class="surface-card">
        <strong>{listing.beds}</strong>
        <span>{t("Bedrooms")}</span>
      </article>
      <article class="surface-card">
        <strong>{listing.baths}</strong>
        <span>{t("Bathrooms")}</span>
      </article>
      <article class="surface-card">
        <strong>{listing.area}</strong>
        <span>{t("Square meters")}</span>
      </article>
    </div>

    <div class="trust-bar">
      <span class="hero-pill hero-pill-soft">{ownerTrustLabel}</span>
      <span class="hero-pill hero-pill-soft">{listing.owner.role}</span>
      <span class="hero-pill hero-pill-soft">{t("Replies in")} {listing.owner.responseTime}</span>
    </div>

    <div class="hero-signal-grid">
      <article class="surface-card">
        <strong>{listing.stats.views24h}</strong>
        <span>{t("Views in the last 24 hours")}</span>
      </article>
      <article class="surface-card">
        <strong>{listing.stats.saves}</strong>
        <span>{t("Saves from active buyers")}</span>
      </article>
      <article class="surface-card">
        <strong>{listing.stats.enquiries}</strong>
        <span>{t("Recent enquiry conversations")}</span>
      </article>
    </div>

    <div class="hero-actions">
      {isBuyer ? (
        <form method="POST" action={isSaved ? "/api/saved-listings/delete" : "/api/saved-listings"}>
          <input type="hidden" name="listingSlug" value={listing.slug} />
          <input type="hidden" name="redirectTo" value={`/listings/${listing.slug}/`} />
          <button type="submit" class="button-shell">{isSaved ? t("Saved to shortlist") : t("Save to shortlist")}</button>
        </form>
      ) : (
        <a class="button-shell" href={`/login?redirect=${encodeURIComponent(`/listings/${listing.slug}/`)}`}>{t("Sign in to save")}</a>
      )}
      <a class="btn-primary" href="#enquiry-panel">{t("Enquire now")}</a>
    </div>
    {savedListing && <p class="flash-inline">{t("Listing saved to your shortlist. Compare it before you decide whether to contact.")}</p>}
  </div>
</section>

<style is:inline>
  .detail-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(20rem, 0.95fr);
    gap: var(--space-m);
    overflow: hidden;
    padding: var(--space-m);
    background:
      radial-gradient(circle at 14% 14%, color-mix(in srgb, var(--accent) 8%, transparent), transparent 22%),
      linear-gradient(180deg, color-mix(in srgb, var(--card) 94%, transparent), color-mix(in srgb, var(--card) 82%, transparent));
  }

  .hero-media,
  .gallery-strip,
  .fact-grid,
  .hero-panel,
  .hero-signal-grid,
  .gallery-card {
    display: grid;
    gap: var(--space-m);
  }

  .hero-image {
    min-height: calc(var(--space-xl) * 6);
    padding: var(--space-m);
    border-radius: var(--radius-lg);
    background-image:
      linear-gradient(180deg, color-mix(in srgb, var(--background) 10%, transparent), color-mix(in srgb, var(--background) 42%, transparent)),
      var(--hero-image, linear-gradient(135deg, color-mix(in srgb, var(--accent) 30%, white), color-mix(in srgb, var(--accent) 24%, black)));
    background-size: cover;
    background-position: var(--hero-position, center);
    display: flex;
    flex-direction: column;
    gap: var(--space-s);
  }

  .sea:not([style]) { --hero-image: linear-gradient(135deg, color-mix(in srgb, var(--accent) 30%, white), color-mix(in srgb, var(--accent) 24%, black)); }
  .sun:not([style]) { --hero-image: linear-gradient(135deg, color-mix(in srgb, var(--accent) 24%, white), color-mix(in srgb, var(--accent) 18%, black)); }
  .forest:not([style]) { --hero-image: linear-gradient(135deg, color-mix(in srgb, var(--accent) 20%, white), color-mix(in srgb, var(--accent) 34%, black)); }
  .night:not([style]) { --hero-image: linear-gradient(135deg, color-mix(in srgb, var(--background) 18%, white), color-mix(in srgb, var(--background) 70%, black)); }
  .clay:not([style]) { --hero-image: linear-gradient(135deg, color-mix(in srgb, var(--accent) 16%, white), color-mix(in srgb, var(--background) 26%, white)); }
  .sky:not([style]) { --hero-image: linear-gradient(135deg, color-mix(in srgb, var(--accent) 22%, white), color-mix(in srgb, var(--background) 18%, white)); }

  .hero-badges,
  .hero-actions,
  .trust-bar,
  .auction-summary {
    display: flex;
    gap: var(--space-s);
    flex-wrap: wrap;
    align-items: center;
  }

  .hero-pill,
  .gallery-count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: calc(var(--space-l) + var(--space-xs));
    padding: var(--space-xs) var(--space-s);
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border: 1px solid var(--border);
    backdrop-filter: blur(var(--glass-blur));
  }

  .hero-pill {
    background: color-mix(in srgb, var(--card) 72%, transparent);
    color: var(--foundation-text);
  }

  .hero-pill-soft,
  .gallery-count,
  .auction-summary span {
    background: color-mix(in srgb, var(--card) 78%, transparent);
    color: var(--foundation-text);
  }

  .gallery-count {
    margin-top: auto;
    margin-left: auto;
  }

  .hero-image-note {
    margin-top: auto;
    padding: var(--space-s) var(--space-m);
    border-radius: var(--radius-lg);
    background: color-mix(in srgb, var(--card) 74%, transparent);
    border: 1px solid var(--border);
    backdrop-filter: blur(var(--glass-blur));
  }

  .hero-image-note strong,
  .hero-image-note span {
    display: block;
  }

  .hero-image-note span,
  .summary,
  .flash-inline,
  .gallery-card span,
  .surface-card span {
    color: var(--muted);
    line-height: 1.7;
  }

  .hero-panel {
    align-content: start;
    padding: var(--space-s);
  }

  .back-link,
  .eyebrow,
  h1,
  .price,
  .summary,
  .flash-inline {
    margin: 0;
  }

  .back-link {
    color: var(--muted);
    text-decoration: none;
    font-weight: 700;
  }

  .eyebrow {
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.08em;
    color: var(--accent);
    text-transform: uppercase;
  }

  h1 {
    font-size: var(--text-5xl);
    letter-spacing: -0.06em;
    line-height: 0.94;
  }

  .price {
    font-size: var(--text-2xl);
    font-weight: 800;
    letter-spacing: -0.05em;
  }

  .fact-grid,
  .hero-signal-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .surface-card {
    padding: var(--space-m);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
    background: color-mix(in srgb, var(--card) 78%, transparent);
  }

  .surface-card strong {
    display: block;
    margin-bottom: var(--space-xs);
    font-size: var(--text-lg);
    letter-spacing: -0.03em;
  }

  .button-shell {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: calc(var(--space-xl) + var(--space-s));
    padding: var(--space-s) var(--space-m);
    border-radius: var(--radius-full);
    border: 1px solid var(--border);
    background: color-mix(in srgb, var(--card) 78%, transparent);
    color: inherit;
    text-decoration: none;
    font: inherit;
    font-weight: 700;
    cursor: pointer;
    transition: all var(--duration-fast) var(--transition-luxury);
  }

  .button-shell:hover {
    color: var(--accent);
    border-color: color-mix(in srgb, var(--accent) 22%, var(--border));
  }

  .flash-inline {
    color: color-mix(in srgb, var(--accent) 72%, white);
    font-weight: 700;
  }

  .gallery-strip {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .gallery-strip img {
    width: 100%;
    height: calc(var(--space-xl) * 2.2);
    border-radius: var(--radius-lg);
    object-fit: cover;
    background: color-mix(in srgb, var(--card) 80%, transparent);
  }

  @media (max-width: 1100px) {
    .detail-hero,
    .hero-signal-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 760px) {
    .fact-grid,
    .gallery-strip {
      grid-template-columns: 1fr;
    }

    .hero-actions,
    .trust-bar {
      display: grid;
    }

    .btn-primary,
    .button-shell {
      width: 100%;
    }
  }
</style>
