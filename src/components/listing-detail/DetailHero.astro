---
import type { Listing } from "../../data/listings";

export interface Props {
  listing: Listing;
  intentLabel: string;
  ownerTrustLabel: string;
  isBuyer: boolean;
  isSaved: boolean;
  savedListing: boolean;
  t?: (value: string) => string;
}

const { listing, intentLabel, ownerTrustLabel, isBuyer, isSaved, savedListing, t = (value: string) => value } = Astro.props;
const heroImage = listing.imageUrls?.[0];
const galleryImages = listing.imageUrls || [];
const isAuction = listing.saleMode === "auction";
---

<section class="detail-hero card">
  <div class="hero-media">
    <div class={`hero-image ${listing.tone}`} style={heroImage ? `background-image: linear-gradient(180deg, rgba(15, 23, 42, 0.08), rgba(15, 23, 42, 0.42)), url(${heroImage})` : undefined}>
      <div class="hero-badges">
        <span class="badge-primary">{intentLabel}</span>
        <span class="badge-secondary">{listing.status}</span>
      </div>
      <div class="gallery-count">{galleryImages.length} {t("photos")}</div>
      <div class="hero-image-note">
        <strong>{listing.ward}, {listing.district}</strong>
        <span>{listing.city}, {listing.country}</span>
      </div>
    </div>
    {galleryImages.length > 1 && (
      <div class="gallery-strip">
        {galleryImages.slice(0, 4).map((imageUrl, index) => (
          <div class="gallery-card">
            <img src={imageUrl} alt={`${listing.title} photo ${index + 1}`} loading="lazy" />
            <span>{index === 0 ? t("Primary view") : `${t("Gallery")} ${index + 1}`}</span>
          </div>
        ))}
      </div>
    )}
  </div>

  <div class="hero-panel">
    <a class="back-link" href="/listings/">{t("All listings")}</a>
    <p class="eyebrow">{listing.type} · {listing.district}, {listing.city}, {listing.country}</p>
    <h1>{listing.title}</h1>
    <p class="price">{listing.priceLabel}</p>
    {isAuction && listing.auction && (
      <div class="auction-summary">
        <span>{listing.auction.phase === "live" ? t("Bidding is live") : listing.auction.phase === "ended" ? t("Auction closed") : t("Auction scheduled")}</span>
        {listing.auction.startingPriceLabel && <span>{t("Opening bid")} {listing.auction.startingPriceLabel}</span>}
        {listing.auction.endsAt && <span>{t("Ends")} {listing.auction.endsAt}</span>}
      </div>
    )}
    <p class="summary">{listing.summary}</p>

    <div class="fact-grid">
      <article>
        <strong>{listing.beds}</strong>
        <span>{t("Bedrooms")}</span>
      </article>
      <article>
        <strong>{listing.baths}</strong>
        <span>{t("Bathrooms")}</span>
      </article>
      <article>
        <strong>{listing.area}</strong>
        <span>{t("Square meters")}</span>
      </article>
    </div>

    <div class="trust-bar">
      <span>{ownerTrustLabel}</span>
      <span>{listing.owner.role}</span>
      <span>{t("Replies in")} {listing.owner.responseTime}</span>
    </div>

    <div class="hero-signal-grid">
      <article>
        <strong>{listing.stats.views24h}</strong>
        <span>{t("Views in the last 24 hours")}</span>
      </article>
      <article>
        <strong>{listing.stats.saves}</strong>
        <span>{t("Saves from active buyers")}</span>
      </article>
      <article>
        <strong>{listing.stats.enquiries}</strong>
        <span>{t("Recent enquiry conversations")}</span>
      </article>
    </div>

    <div class="hero-actions">
      {isBuyer ? (
        <form method="POST" action={isSaved ? "/api/saved-listings/delete" : "/api/saved-listings"}>
          <input type="hidden" name="listingSlug" value={listing.slug} />
          <input type="hidden" name="redirectTo" value={`/listings/${listing.slug}/`} />
          <button type="submit" class="button-secondary">{isSaved ? t("Saved to shortlist") : t("Save to shortlist")}</button>
        </form>
      ) : (
        <a class="button-secondary" href={`/login?redirect=${encodeURIComponent(`/listings/${listing.slug}/`)}`}>{t("Sign in to save")}</a>
      )}
      <a class="button-dark" href="#enquiry-panel">{t("Enquire now")}</a>
    </div>
    {savedListing && <p class="flash-inline">{t("Listing saved to your shortlist. Compare it before you decide whether to contact.")}</p>}
  </div>
</section>

<style is:inline>
  .detail-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(20rem, 0.95fr);
    gap: 1rem;
    overflow: hidden;
    padding: 1.1rem;
    background:
      radial-gradient(circle at 14% 14%, rgba(15, 118, 110, 0.08), transparent 22%),
      linear-gradient(180deg, rgba(255,255,255,0.96), rgba(255,255,255,0.9));
    box-shadow: 0 1px 2px rgba(16, 24, 40, 0.04), 0 18px 40px rgba(16, 24, 40, 0.06);
  }

  .hero-media,
  .gallery-strip,
  .fact-grid {
    display: grid;
    gap: 1rem;
  }

  .hero-image {
    min-height: 25rem;
    padding: 1rem;
    border-radius: 22px;
    background-size: cover;
    background-position: center;
    display: flex;
    align-items: flex-start;
    justify-content: flex-start;
    flex-direction: column;
  }

  .hero-image-note {
    margin-top: auto;
    padding: 0.95rem 1rem;
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.9);
    color: var(--brand);
    backdrop-filter: blur(10px);
  }

  .hero-image-note strong,
  .hero-image-note span {
    display: block;
  }

  .hero-image-note span {
    margin-top: 0.2rem;
    color: var(--muted-strong);
  }

  .sea:not([style]) { background-image: linear-gradient(180deg, rgba(15,23,42,0.08), rgba(15,23,42,0.42)), linear-gradient(135deg, #98d4d5, #2f6f89); }
  .sun:not([style]) { background-image: linear-gradient(180deg, rgba(15,23,42,0.08), rgba(15,23,42,0.42)), linear-gradient(135deg, #f4c78d, #cf6f46); }
  .forest:not([style]) { background-image: linear-gradient(180deg, rgba(15,23,42,0.08), rgba(15,23,42,0.42)), linear-gradient(135deg, #a7d4b0, #255a4a); }
  .night:not([style]) { background-image: linear-gradient(180deg, rgba(15,23,42,0.08), rgba(15,23,42,0.45)), linear-gradient(135deg, #9ca8e6, #212c58); }
  .clay:not([style]) { background-image: linear-gradient(180deg, rgba(15,23,42,0.08), rgba(15,23,42,0.45)), linear-gradient(135deg, #deb28d, #996347); }
  .sky:not([style]) { background-image: linear-gradient(180deg, rgba(15,23,42,0.08), rgba(15,23,42,0.45)), linear-gradient(135deg, #c2dff6, #4f7cab); }

  .hero-badges,
  .hero-actions,
  .trust-bar {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    align-items: center;
  }

  .gallery-count {
    margin-top: auto;
    margin-left: auto;
    display: inline-flex;
    align-items: center;
    min-height: 2rem;
    padding: 0.2rem 0.75rem;
    border-radius: 999px;
    background: rgba(15, 23, 42, 0.76);
    color: white;
    font-size: 0.78rem;
    font-weight: 800;
  }

  .hero-signal-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.85rem;
  }

  .auction-summary {
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
    align-items: center;
  }

  .auction-summary span {
    display: inline-flex;
    align-items: center;
    min-height: 2rem;
    padding: 0.22rem 0.75rem;
    border-radius: 999px;
    background: rgba(15, 23, 42, 0.06);
    color: var(--muted-strong);
    font-size: 0.8rem;
    font-weight: 700;
  }

  .hero-signal-grid article {
    padding: 1rem;
    border-radius: 20px;
    background: linear-gradient(180deg, #ffffff, #f8fafc);
    border: 1px solid rgba(208, 213, 221, 0.74);
  }

  .hero-signal-grid strong {
    display: block;
    font-size: 1.2rem;
    letter-spacing: -0.04em;
  }

  .hero-signal-grid span {
    display: block;
    margin-top: 0.3rem;
    color: var(--muted);
    line-height: 1.5;
  }

  .badge-primary,
  .badge-secondary,
  .trust-bar span {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2rem;
    padding: 0.22rem 0.75rem;
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.04em;
  }

  .badge-primary,
  .badge-secondary {
    background: rgba(255,255,255,0.92);
    color: var(--brand);
  }

  .hero-panel {
    display: grid;
    gap: 1rem;
    padding: 0.35rem 0.3rem 0.3rem;
    align-content: start;
  }

  .back-link {
    color: var(--muted);
    text-decoration: none;
    font-weight: 700;
  }

  .eyebrow {
    margin: 0;
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    color: var(--accent-strong);
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    font-size: clamp(2.4rem, 4.8vw, 4.35rem);
    letter-spacing: -0.08em;
    line-height: 0.96;
  }

  .price {
    margin: 0;
    font-size: 1.75rem;
    font-weight: 800;
    letter-spacing: -0.05em;
  }

  .summary,
  .flash-inline {
    color: var(--muted);
    line-height: 1.7;
    margin: 0;
  }

  .fact-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .fact-grid article {
    padding: 1rem;
    border-radius: 22px;
    background: linear-gradient(180deg, #ffffff, #f8fafc);
    border: 1px solid rgba(208, 213, 221, 0.74);
  }

  .fact-grid strong {
    display: block;
    margin-bottom: 0.35rem;
    font-size: 1.4rem;
    letter-spacing: -0.04em;
  }

  .trust-bar span {
    background: rgba(248,250,252,0.96);
    border: 1px solid rgba(208, 213, 221, 0.74);
    color: var(--text);
    font-weight: 700;
  }

  .button-dark,
  .button-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.8rem;
    padding: 0.85rem 1rem;
    border-radius: 999px;
    font: inherit;
    font-weight: 700;
    text-decoration: none;
    cursor: pointer;
  }

  .button-dark {
    border: none;
    background: var(--brand);
    color: white;
    box-shadow: 0 14px 28px rgba(16, 24, 40, 0.16);
  }

  .button-secondary {
    border: 1px solid var(--line-strong);
    background: white;
    color: var(--text);
  }

  .flash-inline {
    color: #067647;
    font-weight: 700;
  }

  .gallery-strip {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .gallery-card {
    display: grid;
    gap: 0.4rem;
  }

  .gallery-strip img {
    width: 100%;
    height: 7.5rem;
    border-radius: 18px;
    object-fit: cover;
    background: rgba(14, 22, 40, 0.08);
  }

  .gallery-card span {
    color: var(--muted);
    font-size: 0.82rem;
    font-weight: 600;
  }

  @media (max-width: 1100px) {
    .detail-hero {
      grid-template-columns: 1fr;
    }

    .hero-signal-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 760px) {
    .fact-grid,
    .gallery-strip {
      grid-template-columns: 1fr;
    }

    .button-dark,
    .button-secondary {
      width: 100%;
    }

    .hero-actions,
    .trust-bar {
      display: grid;
    }
  }
</style>
