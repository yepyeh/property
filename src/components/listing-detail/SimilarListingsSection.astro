---
import ListingCard from "../ListingCard.astro";
import type { Listing } from "../../data/listings";

export interface Props {
  similarListings: Listing[];
}

const { similarListings } = Astro.props;
---

{similarListings.length > 0 && (
  <section class="similar-section">
    <div class="section-head">
      <span class="section-kicker">Similar listings</span>
      <h2>Nearby alternatives worth comparing</h2>
      <p>Good detail pages should recover the browse journey instead of trapping the user on one listing.</p>
    </div>
    <div class="similar-grid">
      {similarListings.map((similarListing) => <ListingCard listing={similarListing} />)}
    </div>
  </section>
)}

<style>
  .similar-section {
    margin-top: 1.15rem;
  }

  .section-head {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    align-items: center;
    margin-bottom: 1rem;
  }

  .section-kicker {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2rem;
    padding: 0.22rem 0.75rem;
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    background: var(--brand-soft);
    color: var(--accent-strong);
    text-transform: uppercase;
  }

  .section-head h2 {
    margin: 0.75rem 0 0;
    font-size: clamp(1.8rem, 3vw, 2.4rem);
    letter-spacing: -0.08em;
    line-height: 1;
  }

  .section-head p {
    color: var(--muted);
    line-height: 1.7;
    margin: 0;
  }

  .similar-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  @media (max-width: 1100px) {
    .similar-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 760px) {
    .section-head {
      display: grid;
    }
  }
</style>
