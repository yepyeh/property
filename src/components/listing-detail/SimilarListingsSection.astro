---
import ListingCard from "../ListingCard.astro";
import type { Listing } from "../../data/listings";

export interface Props {
  similarListings: Listing[];
  t?: (value: string) => string;
}

const { similarListings, t = (value: string) => value } = Astro.props;
---

{similarListings.length > 0 && (
  <section class="similar-section">
    <div class="section-head">
      <span class="section-kicker">{t("Similar listings")}</span>
      <h2>{t("Nearby alternatives worth comparing")}</h2>
    </div>
    <div class="similar-grid">
      {similarListings.map((similarListing) => <ListingCard listing={similarListing} t={t} />)}
    </div>
  </section>
)}

<style is:inline>
  .similar-section {
    margin-top: var(--space-l);
  }

  .section-head {
    display: flex;
    gap: var(--space-s);
    flex-wrap: wrap;
    align-items: center;
    margin-bottom: var(--space-m);
  }

  .section-kicker {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: calc(var(--space-l) * 0.95);
    padding: calc(var(--space-2xs) * 0.8) var(--space-s);
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    font-weight: 800;
    letter-spacing: 0.04em;
    background: var(--brand-soft);
    color: var(--accent-strong);
    text-transform: uppercase;
  }

  .section-head h2 {
    margin: var(--space-s) 0 0;
    font-size: var(--text-3xl);
    letter-spacing: -0.08em;
    line-height: 1;
  }

  .similar-grid {
    display: grid;
    gap: var(--space-m);
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  @media (max-width: 1100px) {
    .similar-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 760px) {
    .section-head {
      display: grid;
    }
  }
</style>
