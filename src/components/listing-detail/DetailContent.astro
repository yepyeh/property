---
import type { AuctionTimelineStep, Listing } from "../../data/listings";
import type { ListingInsights } from "../../lib/insights";
import type { AuctionEventRecord } from "../../lib/marketplace-types";

export interface Props {
  listing: Listing;
  mapHref: string;
  mapEmbedHref?: string;
  insights?: ListingInsights;
  hasPremiumInsights?: boolean;
  auctionTimeline?: AuctionTimelineStep[];
  auctionEvents?: AuctionEventRecord[];
  t?: (value: string) => string;
}

const { listing, mapHref, mapEmbedHref, insights, hasPremiumInsights = false, auctionTimeline = [], auctionEvents = [], t = (value: string) => value } = Astro.props;
const neighborhood = listing.neighborhood;
const location = listing.location;
const isAuction = listing.saleMode === "auction";
---

<article class="content-panel card">
  {isAuction && listing.auction && (
    <div class="panel-section">
      <span class="section-kicker">Auction structure</span>
      <h2>{t("How this auction works")}</h2>
      <div class="auction-grid">
        <article>
          <strong>{t("Status")}</strong>
          <p>{listing.auction.phase === "live" ? t("Bidding is live now.") : listing.auction.phase === "ended" ? t("This auction has ended.") : t("Auction is scheduled.")}</p>
        </article>
        <article>
          <strong>{t("Opening bid")}</strong>
          <p>{listing.auction.startingPriceLabel || listing.priceLabel}</p>
        </article>
        <article>
          <strong>{t("Reserve")}</strong>
          <p>{listing.auction.reservePriceLabel || t("Reserve not published")}</p>
        </article>
        <article>
          <strong>{t("Window")}</strong>
          <p>{listing.auction.startsAt || t("Start to be announced")} {t("to")} {listing.auction.endsAt || t("end to be announced")}</p>
        </article>
      </div>
      {listing.auction.terms && <p class="auction-terms">{listing.auction.terms}</p>}
      {auctionTimeline.length > 0 && (
        <div class="auction-timeline">
          {auctionTimeline.map((step) => (
            <article class={`timeline-step timeline-${step.state}`}>
              <strong>{t(step.title)}</strong>
              <p>{t(step.body)}</p>
            </article>
          ))}
        </div>
      )}
      {auctionEvents.length > 0 && (
        <div class="auction-events">
          <div class="events-head">
            <strong>{t("Live auction signals")}</strong>
            <span>{t("Recent updates for watchers and registered bidders")}</span>
          </div>
          {auctionEvents.map((event) => (
            <article class="event-row">
              <div class="event-copy">
                <strong>{event.title}</strong>
                <p>{event.message}</p>
              </div>
              <div class="event-meta">
                {event.value_label && <span>{event.value_label}</span>}
                <small>{event.created_at}</small>
              </div>
            </article>
          ))}
        </div>
      )}
    </div>
  )}

  <div class="panel-section">
    <span class="section-kicker">{t("Overview")}</span>
    <h2>{t("Property overview")}</h2>
    <p>{listing.description}</p>
    <div class="overview-grid">
      <article>
        <strong>{t("Best suited for")}</strong>
        <p>{listing.intent === "rent" ? t("Renters who want a settled move-in experience, not another generic short-stay unit.") : t("Buyers who want location confidence and a layout that can hold long-term value.")}</p>
      </article>
      <article>
        <strong>{t("Why this listing stands out")}</strong>
        <p>{listing.summary}</p>
      </article>
    </div>
  </div>

  <div class="panel-section">
    <span class="section-kicker">{t("Highlights")}</span>
    <div class="tag-row">
      {listing.tags.map((tag) => <span>{tag}</span>)}
    </div>
  </div>

  <div class="panel-section">
    <span class="section-kicker">{t("Included features")}</span>
    <div class="feature-grid">
      {listing.features.map((feature) => (
        <div class="feature-item">
          <span class="feature-dot"></span>
          <span>{feature}</span>
        </div>
      ))}
    </div>
  </div>

  {insights && (
    <div class="panel-section">
      <span class="section-kicker">{t("Market insights")}</span>
      <h2>{t("How this listing sits against nearby alternatives")}</h2>
      <p>{t("These signals come from comparable live listings in the same market. They help users understand asking-price context and demand, but they are not completed sale records.")}</p>
      <div class="insights-grid">
        <article class="insight-card">
          <strong>{t("Free insight")}</strong>
          <ul>
            <li>{t("Comparable listings")}: {insights.free.comparableCount}</li>
            <li>{t("District median ask")}: {insights.free.districtMedianLabel}</li>
            <li>{t("Average price per m2")}: {insights.free.averagePricePerSqmLabel}</li>
            <li>{t("Comparable range")}: {insights.free.rangeLabel}</li>
          </ul>
          <p>{insights.free.pricingPositionLabel}</p>
          <p>{insights.free.demandLabel}</p>
        </article>

        <article class={`insight-card premium-card ${hasPremiumInsights ? "is-open" : "is-locked"}`}>
          <strong>{t("Premium insight")}</strong>
          {hasPremiumInsights ? (
            <>
              <ul>
                <li>{t("Pricing band")}: {insights.premium.pricingBandLabel}</li>
                <li>{t("Value position")}: {insights.premium.percentileLabel}</li>
              </ul>
              <p>{insights.premium.narrative}</p>
              <div class="premium-comps">
                {insights.premium.comparableListings.map((entry) => (
                  <a class="premium-comp" href={`/listings/${entry.slug}/`}>
                    <strong>{entry.title}</strong>
                    <span>{entry.priceLabel}</span>
                    <span>{entry.locationLabel}</span>
                    <small>{entry.reasons.join(" · ")}</small>
                  </a>
                ))}
              </div>
            </>
          ) : (
            <>
              <p>{t("Advanced users can unlock deeper pricing context, ranked comparables, and stronger negotiation cues.")}</p>
              <ul>
                <li>{t("Comparable pricing band")}</li>
                <li>{t("Local percentile positioning")}</li>
                <li>{t("Top matched alternatives")}</li>
              </ul>
            </>
          )}
        </article>
      </div>
    </div>
  )}

  {neighborhood && (
    <div class="panel-section">
      <span class="section-kicker">Neighborhood context</span>
      <h2>{t("What this location adds beyond the unit itself")}</h2>
      <p>{neighborhood.headline}</p>
      <div class="context-grid">
        <article>
          <strong>{t("Commute and access")}</strong>
          <p>{neighborhood.commute}</p>
        </article>
        <article>
          <strong>{t("Nearby anchors")}</strong>
          <ul>
            {neighborhood.nearby.map((item) => <li>{item}</li>)}
          </ul>
        </article>
        <article>
          <strong>{t("Trust signals")}</strong>
          <ul>
            {neighborhood.trustSignals.map((item) => <li>{item}</li>)}
          </ul>
        </article>
      </div>
    </div>
  )}

  <div class="panel-section">
    <span class="section-kicker">{t("Map and access")}</span>
    <h2>{t("Location view")}</h2>
    <p>
      {t("Use the map as orientation, not as a promise of exact door-level precision. For marketplace trust, approximate neighborhood placement is usually the right balance until the owner chooses to reveal more.")}
    </p>
    <div class="map-panel">
      {mapEmbedHref ? (
        <iframe
          title={`Map for ${listing.title}`}
          src={mapEmbedHref}
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      ) : (
        <div class="map-fallback">
          <strong>{listing.ward}, {listing.district}</strong>
          <span>{listing.city}, {listing.country}</span>
        </div>
      )}
      <div class="map-meta">
        <strong>{location?.precisionLabel || t("Approximate neighborhood view")}</strong>
        <span>{listing.ward}, {listing.district}, {listing.city}, {listing.country}</span>
        <div class="map-actions">
          <a class="button-dark" href={mapHref} target="_blank" rel="noreferrer">{t("Open map")}</a>
        </div>
      </div>
    </div>
  </div>

  {listing.imageUrls && listing.imageUrls.length > 0 && (
    <div class="panel-section">
      <span class="section-kicker">{t("Photo gallery")}</span>
      <div class="gallery-editorial">
        <div class="gallery-primary" style={`background-image:url(${listing.imageUrls[0]})`}></div>
        <div class="gallery-rail">
          {listing.imageUrls.slice(1).map((imageUrl) => (
            <img src={imageUrl} alt={listing.title} loading="lazy" />
          ))}
        </div>
      </div>
    </div>
  )}
</article>

<style is:inline>
  .content-panel {
    padding: 1.1rem;
    background: var(--surface-elevated);
    box-shadow: 0 1px 2px rgba(16, 24, 40, 0.04), 0 18px 40px rgba(16, 24, 40, 0.06);
  }

  .panel-section + .panel-section {
    margin-top: 1.25rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--line);
  }

  .section-kicker,
  .tag-row span {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2rem;
    padding: 0.22rem 0.75rem;
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.04em;
  }

  .section-kicker {
    background: var(--brand-soft);
    color: var(--accent-strong);
    text-transform: uppercase;
  }

  .tag-row,
  .map-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    align-items: center;
  }

  .panel-section h2 {
    margin: 0.7rem 0 0;
    font-size: 1.55rem;
    letter-spacing: -0.03em;
  }

  .panel-section p,
  .feature-item {
    color: var(--muted);
    line-height: 1.7;
    margin: 0;
  }

  .auction-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 1rem;
  }

  .auction-grid article {
    padding: 1rem;
    border-radius: 22px;
    background: linear-gradient(180deg, var(--surface-elevated-strong), var(--surface-panel-muted));
    border: 1px solid var(--line);
  }

  .auction-grid strong {
    display: block;
    margin-bottom: 0.55rem;
    font-size: 1rem;
    letter-spacing: -0.02em;
  }

  .auction-terms {
    margin-top: 1rem !important;
  }

  .auction-timeline {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.85rem;
    margin-top: 1rem;
  }

  .timeline-step {
    padding: 1rem;
    border-radius: 18px;
    background: linear-gradient(180deg, color-mix(in srgb, var(--surface-input-strong) 94%, transparent), color-mix(in srgb, var(--surface-panel-muted) 90%, transparent));
    border: 1px solid var(--line);
  }

  .timeline-step strong {
    display: block;
    margin-bottom: 0.4rem;
    font-size: 0.96rem;
    letter-spacing: -0.02em;
  }

  .timeline-step p {
    margin: 0;
    color: var(--muted);
    line-height: 1.65;
  }

  .timeline-active {
    border-color: color-mix(in srgb, var(--accent-9) 18%, var(--line));
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--accent-9) 12%, transparent);
  }

  .timeline-complete {
    background: color-mix(in srgb, var(--accent-1) 58%, var(--surface-elevated-strong));
  }
  .auction-events {
    display: grid;
    gap: 0.75rem;
    margin-top: 1rem;
  }
  .events-head {
    display: flex;
    justify-content: space-between;
    gap: 0.75rem;
    flex-wrap: wrap;
    color: var(--muted);
    font-size: 0.95rem;
  }
  .event-row {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: start;
    padding: 0.95rem 1rem;
    border-radius: 18px;
    background: linear-gradient(180deg, var(--surface-elevated-strong), var(--surface-panel-muted));
    border: 1px solid var(--line);
  }
  .event-copy p {
    margin: 0.2rem 0 0;
    color: var(--muted);
    line-height: 1.6;
  }
  .event-meta {
    display: grid;
    justify-items: end;
    gap: 0.3rem;
    text-align: right;
    color: var(--muted);
    font-size: 0.88rem;
  }

  .tag-row span {
    background: rgba(248,250,252,0.96);
    border: 1px solid var(--line);
    color: var(--text);
    font-weight: 700;
  }

  .feature-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 1rem;
  }

  .insights-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 1rem;
  }

  .insight-card {
    padding: 1rem;
    border-radius: 22px;
    background: linear-gradient(180deg, var(--surface-elevated-strong), var(--surface-panel-muted));
    border: 1px solid var(--line);
    display: grid;
    gap: 0.7rem;
  }

  .insight-card strong {
    font-size: 1rem;
    letter-spacing: -0.02em;
  }

  .insight-card ul,
  .context-grid ul {
    margin: 0;
    padding-left: 1.1rem;
    display: grid;
    gap: 0.35rem;
    color: var(--muted);
  }

  .premium-card.is-locked {
    background: linear-gradient(180deg, color-mix(in srgb, var(--accent-strong) 10%, transparent), var(--surface-elevated-strong));
  }

  .premium-comps {
    display: grid;
    gap: 0.7rem;
  }

  .premium-comp {
    display: grid;
    gap: 0.2rem;
    padding: 0.9rem;
    border-radius: 18px;
    background: var(--surface-overlay);
    border: 1px solid var(--line);
    text-decoration: none;
  }

  .premium-comp span,
  .premium-comp small {
    color: var(--muted);
  }

  .overview-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 1rem;
  }

  .overview-grid article {
    padding: 1rem;
    border-radius: 22px;
    background: linear-gradient(180deg, var(--surface-elevated-strong), var(--surface-panel-muted));
    border: 1px solid var(--line);
  }

  .overview-grid strong {
    display: block;
    margin-bottom: 0.55rem;
    font-size: 1rem;
    letter-spacing: -0.02em;
  }

  .feature-item {
    display: flex;
    gap: 0.7rem;
    align-items: center;
    padding: 0.9rem 1rem;
    border-radius: 20px;
    background: linear-gradient(180deg, var(--surface-elevated-strong), var(--surface-panel-muted));
    border: 1px solid var(--line);
  }

  .feature-dot {
    width: 0.65rem;
    height: 0.65rem;
    border-radius: 999px;
    background: linear-gradient(135deg, var(--brand), #23314d);
    flex: none;
  }

  .context-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 1rem;
  }

  .context-grid article {
    padding: 1rem;
    border-radius: 22px;
    background: linear-gradient(180deg, var(--surface-elevated-strong), var(--surface-panel-muted));
    border: 1px solid var(--line);
  }

  .context-grid strong {
    display: block;
    margin-bottom: 0.55rem;
    font-size: 1rem;
    letter-spacing: -0.02em;
  }

  .context-grid p,
  .context-grid ul {
    margin: 0;
    color: var(--muted);
    line-height: 1.65;
  }

  .map-panel {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(16rem, 0.8fr);
    gap: 1rem;
    margin-top: 1rem;
  }

  .map-panel iframe,
  .map-fallback {
    width: 100%;
    min-height: 20rem;
    border: 0;
    border-radius: 22px;
    background:
      linear-gradient(180deg, var(--accent-1), rgba(15, 23, 42, 0.12)),
      radial-gradient(circle at 22% 20%, rgba(15, 118, 110, 0.16), transparent 18%),
      linear-gradient(135deg, #f8fafc, #e5edf6);
  }

  .map-fallback {
    display: grid;
    place-content: center;
    gap: 0.35rem;
    padding: 1.2rem;
    text-align: center;
  }

  .map-fallback strong {
    font-size: 1.1rem;
    letter-spacing: -0.03em;
  }

  .map-fallback span,
  .map-meta span {
    color: var(--muted);
  }

  .map-meta {
    display: grid;
    gap: 0.9rem;
    align-content: start;
    padding: 1rem;
    border-radius: 24px;
    background: linear-gradient(180deg, var(--surface-elevated-strong), var(--surface-panel-muted));
    border: 1px solid var(--line);
  }

  .map-meta strong {
    font-size: 1rem;
    letter-spacing: -0.02em;
  }

  .button-dark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.8rem;
    padding: 0.85rem 1rem;
    border-radius: 999px;
    font: inherit;
    font-weight: 700;
    text-decoration: none;
    cursor: pointer;
    border: none;
    background: var(--brand);
    color: var(--surface-canvas);
    box-shadow: 0 14px 28px rgba(16, 24, 40, 0.16);
  }

  .gallery-editorial {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(16rem, 0.85fr);
    gap: 1rem;
    margin-top: 1rem;
  }

  .gallery-primary {
    min-height: 31rem;
    border-radius: 22px;
    background-size: cover;
    background-position: center;
    background-color: rgba(14, 22, 40, 0.08);
  }

  .gallery-rail {
    display: grid;
    gap: 1rem;
  }

  .gallery-rail img {
    width: 100%;
    height: 9.6rem;
    border-radius: 18px;
    object-fit: cover;
    background: rgba(14, 22, 40, 0.08);
  }

  @media (max-width: 1100px) {
    .insights-grid,
    .overview-grid,
    .auction-grid,
    .auction-timeline,
    .auction-events,
    .context-grid,
    .map-panel,
    .gallery-editorial {
      grid-template-columns: 1fr;
    }
    .event-row {
      flex-direction: column;
    }
    .event-meta {
      justify-items: start;
      text-align: left;
    }
  }

  @media (max-width: 760px) {
    .feature-grid {
      grid-template-columns: 1fr;
    }

    .gallery-primary {
      min-height: 18rem;
    }
  }
</style>
