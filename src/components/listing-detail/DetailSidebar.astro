---
import { estimateMonthlyPayment, formatVndAmount } from "../../lib/affordability";
import type { Listing } from "../../data/listings";
import type { AuctionWatchRecord } from "../../lib/marketplace-types";

export interface Props {
  listing: Listing;
  ownerTrustLabel: string;
  enquirySent: boolean;
  isBuyer?: boolean;
  reportSent?: boolean;
  protectedFlow?: boolean;
  auctionWatch?: AuctionWatchRecord | null;
  auctionWatchUpdated?: boolean;
  auctionWatchRemoved?: boolean;
  t?: (value: string) => string;
}

const {
  listing,
  ownerTrustLabel,
  enquirySent,
  isBuyer = false,
  reportSent = false,
  protectedFlow = false,
  auctionWatch = null,
  auctionWatchUpdated = false,
  auctionWatchRemoved = false,
  t = (value: string) => value,
} = Astro.props;
const defaultDownPayment = 20;
const defaultRate = 7.5;
const defaultYears = 20;
const defaultMonthlyEstimate = formatVndAmount(
  estimateMonthlyPayment(listing.numericPrice, defaultDownPayment, defaultRate, defaultYears)
);
---

<aside class="sidebar-stack">
  <section class="enquiry-panel card" id="enquiry-panel">
    <span class="section-kicker">{t("Enquiry panel")}</span>
    <h2>{t("Contact the owner")}</h2>
    <p class="enquiry-copy">
      {t("Structured enquiries are the conversion layer. Buyers should know who they are contacting and owners should receive clean intent data, not vague messages.")}
    </p>
    {enquirySent && <p class="success-banner">{t("Enquiry sent successfully. The owner can now see it in the dashboard.")}</p>}
    {protectedFlow && <p class="info-banner">{t("Your enquiry stays inside the platform flow first. That gives both sides a cleaner history and a safer follow-up path.")}</p>}
    {auctionWatchUpdated && <p class="success-banner">{t("Auction watch updated. You will now get the alerts you asked for on this listing.")}</p>}
    {auctionWatchRemoved && <p class="info-banner">{t("Auction watch removed. This listing is no longer being tracked for your auction alerts.")}</p>}

    <div class="owner-card">
      <strong>{listing.owner.name}</strong>
      <span>{listing.owner.role}</span>
      <span>{ownerTrustLabel} · {t("Replies in")} {listing.owner.responseTime}</span>
    </div>

    <div class="expectation-row">
      <article>
        <strong>{t("Best first message")}</strong>
        <span>{t("Ask about availability, viewings, and any building or ownership conditions.")}</span>
      </article>
      <article>
        <strong>{t("Typical response")}</strong>
        <span>{listing.owner.responseTime} {t("when the listing is actively managed.")}</span>
      </article>
    </div>

    {isBuyer && (
      <div class="buyer-guide">
        <strong>{t("Not sure yet?")}</strong>
        <p>{t("Save this to your shortlist first. Add it to a collection if you are planning by area or trip. Then compare it against two or three other places. If it still looks strongest, mark it as a finalist and come back here to enquire.")}</p>
        <a class="guide-link" href="/help/buyer-shortlist-and-compare/">{t("Open buyer guide")}</a>
      </div>
    )}

    {isBuyer && <a class="button-secondary full-width" href="/buyer/compare/">{t("Compare against saved homes")}</a>}

    {listing.saleMode === "auction" && (
      <section class="auction-watch-panel">
        <div class="watch-head">
          <strong>{t("Watch auction")}</strong>
          <span>{auctionWatch ? t("Watching with refined alerts") : t("Save alert rules before bidding starts")}</span>
        </div>
        {isBuyer ? (
          <>
            <form class="auction-watch-form" method="POST" action="/api/account/auction-watch">
              <input type="hidden" name="listingSlug" value={listing.slug} />
              <input type="hidden" name="redirectTo" value={`/listings/${listing.slug}/`} />
              <label>
                <span>{t("My maximum bid")}</span>
                <input type="number" min="0" step="0.01" name="maxBidAmount" value={auctionWatch?.max_bid_amount ?? ""} placeholder={t("Optional bidding ceiling")} />
              </label>
              <label>
                <span>{t("Notify me if this does not sell below")}</span>
                <input type="number" min="0" step="0.01" name="notifyUnsoldUnder" value={auctionWatch?.notify_unsold_under ?? ""} placeholder={t("Optional fallback price")} />
              </label>
              <label class="check-row">
                <input type="checkbox" name="notifyOutbid" checked={auctionWatch ? Boolean(auctionWatch.notify_outbid) : true} />
                <span>{t("Notify me if someone beats my bid")}</span>
              </label>
              <label class="check-row">
                <input type="checkbox" name="notifyOverMaxBid" checked={auctionWatch ? Boolean(auctionWatch.notify_over_max_bid) : true} />
                <span>{t("Notify me if the auction goes over my maximum bid")}</span>
              </label>
              <label class="check-row">
                <input type="checkbox" name="notifyStartingSoon" checked={auctionWatch ? Boolean(auctionWatch.notify_starting_soon) : true} />
                <span>{t("Notify me before bidding starts")}</span>
              </label>
              <label class="check-row">
                <input type="checkbox" name="notifyEndingSoon" checked={auctionWatch ? Boolean(auctionWatch.notify_ending_soon) : true} />
                <span>{t("Notify me when the auction is ending soon")}</span>
              </label>
              <button type="submit" class="button-secondary full-width">{auctionWatch ? t("Update auction alerts") : t("Watch this auction")}</button>
            </form>
            {auctionWatch && (
              <form method="POST" action="/api/account/auction-watch/delete">
                <input type="hidden" name="listingSlug" value={listing.slug} />
                <input type="hidden" name="redirectTo" value={`/listings/${listing.slug}/`} />
                <button type="submit" class="button-tertiary full-width">{t("Stop watching this auction")}</button>
              </form>
            )}
          </>
        ) : (
          <a class="button-secondary full-width" href={`/login?redirect=${encodeURIComponent(`/listings/${listing.slug}/`)}`}>{t("Sign in to watch this auction")}</a>
        )}
      </section>
    )}

    <form class="enquiry-form" method="POST" action="/api/enquiries">
      <input type="hidden" name="listingSlug" value={listing.slug} />
      <input type="hidden" name="listingTitle" value={listing.title} />
      <label>
        <span>{t("Your name")}</span>
        <input type="text" name="applicantName" required placeholder={t("Enter your name")} />
      </label>
      <label>
        <span>{t("Contact")}</span>
        <input type="text" name="contact" required placeholder={t("Email, WhatsApp, or phone number")} />
      </label>
      <label>
        <span>{t("Preferred viewing time")}</span>
        <input type="text" name="preferredTime" placeholder={t("Saturday morning")} />
      </label>
      <label>
        <span>{t("Message")}</span>
        <textarea name="message" rows="5" required placeholder={`${t("Hi, I'm interested in")} ${listing.title}. ${t("Is it still available?")}`}></textarea>
      </label>
      <button type="submit" class="button-dark full-width">{t("Send enquiry")}</button>
    </form>
  </section>

  <section class="stats-panel card">
    <span class="section-kicker">{t("Demand signals")}</span>
    <div class="stats-grid">
      <article>
        <strong>{listing.stats.views24h}</strong>
        <span>{t("Views in the last 24 hours")}</span>
      </article>
      <article>
        <strong>{listing.stats.saves}</strong>
        <span>{t("Buyers saved this listing")}</span>
      </article>
      <article>
        <strong>{listing.stats.enquiries}</strong>
        <span>{t("Open conversations")}</span>
      </article>
    </div>
  </section>

  <section class="report-panel card">
    <span class="section-kicker">{t("Protection")}</span>
    <h2>{t("Need to flag this listing?")}</h2>
    <p class="enquiry-copy">{t("Report listings that look misleading, duplicated, suspicious, or unsafe. This creates a moderation record for admin review.")}</p>
    {reportSent && <p class="success-banner">{t("Report submitted. The moderation queue now includes this listing.")}</p>}
    <form class="report-form" method="POST" action="/api/listings/report">
      <input type="hidden" name="listingSlug" value={listing.slug} />
      <input type="hidden" name="redirectTo" value={`/listings/${listing.slug}/`} />
      <label>
        <span>{t("Reason")}</span>
        <select name="reason">
          <option value="misleading information">{t("Misleading information")}</option>
          <option value="duplicate listing">{t("Duplicate listing")}</option>
          <option value="suspicious contact">{t("Suspicious contact")}</option>
          <option value="pricing issue">{t("Pricing issue")}</option>
          <option value="other safety concern">{t("Other safety concern")}</option>
        </select>
      </label>
      <label>
        <span>{t("Your name")}</span>
        <input type="text" name="reporterName" placeholder={t("Optional")} />
      </label>
      <label>
        <span>{t("Contact")}</span>
        <input type="text" name="reporterContact" placeholder={t("Optional email or phone")} />
      </label>
      <label>
        <span>{t("Details")}</span>
        <textarea name="details" rows="4" placeholder={t("What looks wrong or unsafe?")}></textarea>
      </label>
      <button type="submit" class="button-secondary full-width">{t("Report listing")}</button>
    </form>
  </section>

  {listing.intent === "buy" && (
    <section
      class="budget-panel card"
      data-affordability-card
      data-price={listing.numericPrice}
    >
      <span class="section-kicker">{t("Budget guide")}</span>
      <h2>{t("Estimate the monthly cost")}</h2>
      <p class="enquiry-copy">{t("A quick financing check before you contact. Major portals push this because buyers use it constantly during shortlisting.")}</p>
      <div class="budget-output">
        <strong data-monthly-output>{defaultMonthlyEstimate} VND / month</strong>
        <span data-financed-output>Loan amount: {formatVndAmount(listing.numericPrice * 0.8)} VND</span>
      </div>
      <div class="budget-grid">
        <label>
          <span>{t("Down payment %")}</span>
          <input data-down-input type="number" min="0" max="90" step="1" value={defaultDownPayment} />
        </label>
        <label>
          <span>{t("Interest %")}</span>
          <input data-rate-input type="number" min="0" max="25" step="0.1" value={defaultRate} />
        </label>
        <label>
          <span>{t("Years")}</span>
          <input data-years-input type="number" min="1" max="35" step="1" value={defaultYears} />
        </label>
      </div>
    </section>
  )}
</aside>

{listing.intent === "buy" && (
  <script is:inline>
    document.querySelectorAll("[data-affordability-card]").forEach((card) => {
      const price = Number(card.getAttribute("data-price") || "0");
      const downInput = card.querySelector("[data-down-input]");
      const rateInput = card.querySelector("[data-rate-input]");
      const yearsInput = card.querySelector("[data-years-input]");
      const monthlyOutput = card.querySelector("[data-monthly-output]");
      const financedOutput = card.querySelector("[data-financed-output]");

      const format = (value) =>
        new Intl.NumberFormat("en-US", { maximumFractionDigits: 0 }).format(Math.round(value));

      const compute = () => {
        const down = Math.max(0, Math.min(90, Number(downInput?.value || 20)));
        const rate = Math.max(0, Number(rateInput?.value || 7.5));
        const years = Math.max(1, Number(yearsInput?.value || 20));
        const principal = price * Math.max(0, 1 - down / 100);
        const monthlyRate = rate / 100 / 12;
        const months = years * 12;
        const monthly = monthlyRate <= 0
          ? principal / months
          : (principal * monthlyRate * Math.pow(1 + monthlyRate, months)) / (Math.pow(1 + monthlyRate, months) - 1);

        if (monthlyOutput) monthlyOutput.textContent = `${format(monthly)} VND / month`;
        if (financedOutput) financedOutput.textContent = `Loan amount: ${format(principal)} VND`;
      };

      [downInput, rateInput, yearsInput].forEach((input) => input?.addEventListener("input", compute));
      compute();
    });
  </script>
)}

<style is:inline>
  .sidebar-stack {
    display: grid;
    gap: 1rem;
    position: sticky;
    top: 6rem;
  }

  .enquiry-panel,
  .stats-panel,
  .budget-panel {
    padding: 1.1rem;
    background: rgba(255, 255, 255, 0.92);
    box-shadow: 0 1px 2px rgba(16, 24, 40, 0.04), 0 18px 40px rgba(16, 24, 40, 0.06);
  }

  .section-kicker {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2rem;
    padding: 0.22rem 0.75rem;
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    background: var(--brand-soft);
    color: var(--accent-strong);
    text-transform: uppercase;
  }

  .enquiry-panel h2 {
    margin: 0.7rem 0 0;
    font-size: 1.55rem;
    letter-spacing: -0.03em;
  }

  .enquiry-copy,
  .owner-card span,
  .stats-grid span {
    color: var(--muted);
    line-height: 1.7;
    margin: 0;
  }

  .success-banner {
    padding: 0.9rem 1rem;
    border-radius: 18px;
    background: rgba(18, 183, 106, 0.08);
    color: #067647;
    font-weight: 700;
  }

  .info-banner {
    padding: 0.9rem 1rem;
    border-radius: 18px;
    background: rgba(30, 64, 175, 0.08);
    color: #1e40af;
    font-weight: 700;
  }

  .budget-output {
    display: grid;
    gap: 0.18rem;
    margin-top: 0.9rem;
    padding: 1rem;
    border-radius: 20px;
    background: linear-gradient(180deg, #ffffff, #f8fafc);
    border: 1px solid rgba(208, 213, 221, 0.74);
  }

  .budget-output strong {
    font-size: 1.25rem;
    letter-spacing: -0.04em;
  }

  .budget-output span {
    color: var(--muted);
  }

  .budget-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.75rem;
    margin-top: 0.9rem;
  }

  .owner-card {
    display: grid;
    gap: 0.2rem;
    padding: 1rem;
    border-radius: 22px;
    background: linear-gradient(180deg, #ffffff, #f8fafc);
    border: 1px solid rgba(208, 213, 221, 0.74);
  }

  .owner-card strong {
    display: block;
    font-size: 1.05rem;
    margin-bottom: 0.15rem;
  }

  .buyer-guide {
    margin-top: 1rem;
    padding: 0.95rem 1rem;
    border-radius: 18px;
    background: rgba(15, 23, 42, 0.05);
    border: 1px solid var(--line);
  }

  .auction-watch-panel {
    margin-top: 1rem;
    padding: 1rem;
    border-radius: 20px;
    background: rgba(15, 23, 42, 0.05);
    border: 1px solid var(--line);
  }

  .watch-head {
    display: grid;
    gap: 0.2rem;
    margin-bottom: 0.85rem;
  }

  .watch-head strong {
    font-size: 1rem;
    letter-spacing: -0.02em;
  }

  .watch-head span {
    color: var(--muted);
    line-height: 1.55;
  }

  .auction-watch-form {
    display: grid;
    gap: 0.75rem;
  }

  .check-row {
    display: flex;
    gap: 0.7rem;
    align-items: flex-start;
    padding: 0.8rem 0.9rem;
    border-radius: 16px;
    background: rgba(255,255,255,0.72);
    border: 1px solid var(--line);
  }

  .check-row input {
    margin-top: 0.15rem;
  }

  .buyer-guide p {
    margin: 0.35rem 0 0;
    color: var(--muted);
    line-height: 1.65;
  }

  .guide-link {
    width: fit-content;
    margin-top: 0.6rem;
    color: var(--accent-strong);
    font-weight: 700;
    text-decoration: none;
  }

  .enquiry-form {
    display: grid;
    gap: 0.85rem;
    margin-top: 1rem;
  }

  .report-form {
    display: grid;
    gap: 0.85rem;
    margin-top: 1rem;
  }

  .expectation-row {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.8rem;
    margin-top: 1rem;
  }

  .expectation-row article {
    padding: 0.95rem 1rem;
    border-radius: 18px;
    background: rgba(243, 239, 231, 0.72);
    border: 1px solid var(--line);
  }

  .expectation-row strong,
  .expectation-row span {
    display: block;
  }

  .expectation-row strong {
    margin-bottom: 0.35rem;
    font-size: 0.95rem;
  }

  .expectation-row span {
    color: var(--muted);
    line-height: 1.6;
  }

  .enquiry-form label {
    display: grid;
    gap: 0.4rem;
  }

  .report-form label {
    display: grid;
    gap: 0.4rem;
  }

  .budget-grid label {
    display: grid;
    gap: 0.4rem;
  }

  .enquiry-form label span,
  .budget-grid label span {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--text);
  }

  .enquiry-form input,
  .enquiry-form textarea,
  .report-form input,
  .report-form textarea,
  .report-form select,
  .budget-grid input {
    width: 100%;
    border: 1px solid var(--line);
    border-radius: 16px;
    background: white;
    padding: 0.95rem 1rem;
    color: var(--text);
    font: inherit;
  }

  .button-dark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.8rem;
    padding: 0.85rem 1rem;
    border-radius: 999px;
    font: inherit;
    font-weight: 700;
    cursor: pointer;
    border: none;
    background: var(--brand);
    color: white;
    box-shadow: 0 14px 28px rgba(16, 24, 40, 0.16);
  }

  .button-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.8rem;
    padding: 0.85rem 1rem;
    border-radius: 999px;
    font: inherit;
    font-weight: 700;
    cursor: pointer;
    border: 1px solid var(--line-strong);
    background: white;
    color: var(--text);
    text-decoration: none;
  }

  .full-width {
    width: 100%;
  }

  .stats-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: 1fr;
  }

  .stats-grid article {
    padding: 1rem;
    border-radius: 22px;
    background: linear-gradient(180deg, #ffffff, #f8fafc);
    border: 1px solid rgba(208, 213, 221, 0.74);
  }

  .stats-grid strong {
    display: block;
    margin-bottom: 0.35rem;
    font-size: 1.4rem;
    letter-spacing: -0.04em;
  }

  @media (max-width: 1100px) {
    .sidebar-stack {
      position: static;
    }
  }

  @media (max-width: 760px) {
    .expectation-row {
      grid-template-columns: 1fr;
    }

    .budget-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
