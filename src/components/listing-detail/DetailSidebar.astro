---
import type { Listing } from "../../data/listings";

export interface Props {
  listing: Listing;
  ownerTrustLabel: string;
  enquirySent: boolean;
  isBuyer?: boolean;
}

const { listing, ownerTrustLabel, enquirySent, isBuyer = false } = Astro.props;
---

<aside class="sidebar-stack">
  <section class="enquiry-panel card" id="enquiry-panel">
    <span class="section-kicker">Enquiry panel</span>
    <h2>Contact the owner</h2>
    <p class="enquiry-copy">
      Structured enquiries are the conversion layer. Buyers should know who they are contacting and owners should
      receive clean intent data, not vague messages.
    </p>
    {enquirySent && <p class="success-banner">Enquiry sent successfully. The owner can now see it in the dashboard.</p>}

    <div class="owner-card">
      <strong>{listing.owner.name}</strong>
      <span>{listing.owner.role}</span>
      <span>{ownerTrustLabel} · Replies in {listing.owner.responseTime}</span>
    </div>

    <div class="expectation-row">
      <article>
        <strong>Best first message</strong>
        <span>Ask about availability, viewings, and any building or ownership conditions.</span>
      </article>
      <article>
        <strong>Typical response</strong>
        <span>{listing.owner.responseTime} when the listing is actively managed.</span>
      </article>
    </div>

    {isBuyer && (
      <div class="buyer-guide">
        <strong>Not sure yet?</strong>
        <p>Save this to your shortlist first. Then compare it against two or three other places. If it still looks strongest, mark it as a finalist and come back here to enquire.</p>
        <a class="guide-link" href="/help/buyer-shortlist-and-compare/">Open buyer guide</a>
      </div>
    )}

    {isBuyer && <a class="button-secondary full-width" href="/buyer/compare/">Compare against saved homes</a>}

    <form class="enquiry-form" method="POST" action="/api/enquiries">
      <input type="hidden" name="listingSlug" value={listing.slug} />
      <input type="hidden" name="listingTitle" value={listing.title} />
      <label>
        <span>Your name</span>
        <input type="text" name="applicantName" required placeholder="Enter your name" />
      </label>
      <label>
        <span>Contact</span>
        <input type="text" name="contact" required placeholder="Email, WhatsApp, or phone number" />
      </label>
      <label>
        <span>Preferred viewing time</span>
        <input type="text" name="preferredTime" placeholder="Saturday morning" />
      </label>
      <label>
        <span>Message</span>
        <textarea name="message" rows="5" required placeholder={`Hi, I'm interested in ${listing.title}. Is it still available?`}></textarea>
      </label>
      <button type="submit" class="button-dark full-width">Send enquiry</button>
    </form>
  </section>

  <section class="stats-panel card">
    <span class="section-kicker">Demand signals</span>
    <div class="stats-grid">
      <article>
        <strong>{listing.stats.views24h}</strong>
        <span>Views in the last 24 hours</span>
      </article>
      <article>
        <strong>{listing.stats.saves}</strong>
        <span>Buyers saved this listing</span>
      </article>
      <article>
        <strong>{listing.stats.enquiries}</strong>
        <span>Open conversations</span>
      </article>
    </div>
  </section>
</aside>

<style is:inline>
  .sidebar-stack {
    display: grid;
    gap: 1rem;
    position: sticky;
    top: 6rem;
  }

  .enquiry-panel,
  .stats-panel {
    padding: 1.1rem;
    background: rgba(255, 255, 255, 0.92);
    box-shadow: 0 1px 2px rgba(16, 24, 40, 0.04), 0 18px 40px rgba(16, 24, 40, 0.06);
  }

  .section-kicker {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2rem;
    padding: 0.22rem 0.75rem;
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    background: var(--brand-soft);
    color: var(--accent-strong);
    text-transform: uppercase;
  }

  .enquiry-panel h2 {
    margin: 0.7rem 0 0;
    font-size: 1.55rem;
    letter-spacing: -0.03em;
  }

  .enquiry-copy,
  .owner-card span,
  .stats-grid span {
    color: var(--muted);
    line-height: 1.7;
    margin: 0;
  }

  .success-banner {
    padding: 0.9rem 1rem;
    border-radius: 18px;
    background: rgba(18, 183, 106, 0.08);
    color: #067647;
    font-weight: 700;
  }

  .owner-card {
    display: grid;
    gap: 0.2rem;
    padding: 1rem;
    border-radius: 22px;
    background: linear-gradient(180deg, #ffffff, #f8fafc);
    border: 1px solid rgba(208, 213, 221, 0.74);
  }

  .owner-card strong {
    display: block;
    font-size: 1.05rem;
    margin-bottom: 0.15rem;
  }

  .buyer-guide {
    margin-top: 1rem;
    padding: 0.95rem 1rem;
    border-radius: 18px;
    background: rgba(15, 23, 42, 0.05);
    border: 1px solid var(--line);
  }

  .buyer-guide p {
    margin: 0.35rem 0 0;
    color: var(--muted);
    line-height: 1.65;
  }

  .guide-link {
    width: fit-content;
    margin-top: 0.6rem;
    color: var(--accent-strong);
    font-weight: 700;
    text-decoration: none;
  }

  .enquiry-form {
    display: grid;
    gap: 0.85rem;
    margin-top: 1rem;
  }

  .expectation-row {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.8rem;
    margin-top: 1rem;
  }

  .expectation-row article {
    padding: 0.95rem 1rem;
    border-radius: 18px;
    background: rgba(243, 239, 231, 0.72);
    border: 1px solid var(--line);
  }

  .expectation-row strong,
  .expectation-row span {
    display: block;
  }

  .expectation-row strong {
    margin-bottom: 0.35rem;
    font-size: 0.95rem;
  }

  .expectation-row span {
    color: var(--muted);
    line-height: 1.6;
  }

  .enquiry-form label {
    display: grid;
    gap: 0.4rem;
  }

  .enquiry-form label span {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--text);
  }

  .enquiry-form input,
  .enquiry-form textarea {
    width: 100%;
    border: 1px solid var(--line);
    border-radius: 16px;
    background: white;
    padding: 0.95rem 1rem;
    color: var(--text);
    font: inherit;
  }

  .button-dark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.8rem;
    padding: 0.85rem 1rem;
    border-radius: 999px;
    font: inherit;
    font-weight: 700;
    cursor: pointer;
    border: none;
    background: var(--brand);
    color: white;
    box-shadow: 0 14px 28px rgba(16, 24, 40, 0.16);
  }

  .button-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.8rem;
    padding: 0.85rem 1rem;
    border-radius: 999px;
    font: inherit;
    font-weight: 700;
    cursor: pointer;
    border: 1px solid var(--line-strong);
    background: white;
    color: var(--text);
    text-decoration: none;
  }

  .full-width {
    width: 100%;
  }

  .stats-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: 1fr;
  }

  .stats-grid article {
    padding: 1rem;
    border-radius: 22px;
    background: linear-gradient(180deg, #ffffff, #f8fafc);
    border: 1px solid rgba(208, 213, 221, 0.74);
  }

  .stats-grid strong {
    display: block;
    margin-bottom: 0.35rem;
    font-size: 1.4rem;
    letter-spacing: -0.04em;
  }

  @media (max-width: 1100px) {
    .sidebar-stack {
      position: static;
    }
  }

  @media (max-width: 760px) {
    .expectation-row {
      grid-template-columns: 1fr;
    }
  }
</style>
