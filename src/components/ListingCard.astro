---
import type { Listing } from "../data/listings";

export interface Props {
  listing: Listing;
}

const { listing } = Astro.props;
const heroImage = listing.imageUrls?.[0];
const intentLabel = listing.intent === "rent" ? "To rent" : "For sale";
const neighborhood = listing.neighborhood;
---

<article class={`listing-card card ${listing.tone}`}>
  <a class="photo-wrap" href={`/listings/${listing.slug}/`}>
    <div class="photo" style={heroImage ? `background-image: linear-gradient(180deg, rgba(17, 17, 17, 0.08), rgba(17, 17, 17, 0.34)), url(${heroImage})` : undefined}>
      <div class="photo-top">
        <div class="chip-row">
          <span class="intent-chip">{intentLabel}</span>
          <span class="status-chip">{listing.status}</span>
        </div>
        <span class="save-count">{listing.stats.saves} saves</span>
      </div>
    </div>
  </a>

  <div class="listing-body">
    <div class="listing-top">
      <div>
        <p class="price">{listing.priceLabel}</p>
        <h3><a href={`/listings/${listing.slug}/`}>{listing.title}</a></h3>
      </div>
      <span class="meta-label">{listing.intent === "rent" ? "Rental" : "Sale"}</span>
    </div>

    <p class="meta">{listing.ward}, {listing.district}, {listing.city}</p>
    <div class="fact-row">
      <span>{listing.type}</span>
      <span>{listing.beds} beds</span>
      <span>{listing.baths} baths</span>
      <span>{listing.area} m2</span>
    </div>
    <p class="summary">{listing.summary}</p>
    {neighborhood && (
      <div class="context-panel">
        <p class="context-headline">{neighborhood.headline}</p>
        <div class="context-row">
          <span>{neighborhood.commute}</span>
          <span>{neighborhood.nearby[0]}</span>
        </div>
      </div>
    )}

    <div class="listing-footer">
      <div class="signal-row">
        <span>{listing.stats.enquiries} enquiries</span>
        <span>{listing.owner.verified ? "Verified owner" : "Owner listed"}</span>
      </div>
      <a class="details-link" href={`/listings/${listing.slug}/`}>View details</a>
    </div>
  </div>
</article>

<style>
  .listing-card {
    overflow: hidden;
    background: rgba(255, 255, 255, 0.95);
    border-radius: 1.95rem;
    box-shadow: 0 24px 54px rgba(17, 17, 17, 0.08);
    transition: transform 180ms ease, box-shadow 180ms ease;
  }

  .listing-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 32px 68px rgba(17, 17, 17, 0.11);
  }

  .photo-wrap {
    display: block;
    text-decoration: none;
  }

  .photo {
    min-height: 15rem;
    padding: 1rem;
    display: flex;
    align-items: flex-start;
    background-size: cover;
    background-position: center;
  }

  .photo-top {
    width: 100%;
    display: flex;
    justify-content: space-between;
    gap: 0.8rem;
    align-items: flex-start;
    flex-wrap: wrap;
  }

  .sea .photo:not([style]) { background-image: linear-gradient(180deg, rgba(17,17,17,0.06), rgba(17,17,17,0.26)), linear-gradient(135deg, #c7ddd7, #95bcb4); }
  .sun .photo:not([style]) { background-image: linear-gradient(180deg, rgba(17,17,17,0.06), rgba(17,17,17,0.3)), linear-gradient(135deg, #edd1ab, #d29b67); }
  .forest .photo:not([style]) { background-image: linear-gradient(180deg, rgba(17,17,17,0.06), rgba(17,17,17,0.3)), linear-gradient(135deg, #c9d9c7, #92ac96); }
  .night .photo:not([style]) { background-image: linear-gradient(180deg, rgba(17,17,17,0.06), rgba(17,17,17,0.34)), linear-gradient(135deg, #d2d7e1, #8890a6); }
  .clay .photo:not([style]) { background-image: linear-gradient(180deg, rgba(17,17,17,0.06), rgba(17,17,17,0.3)), linear-gradient(135deg, #e8d0bf, #ba917c); }
  .sky .photo:not([style]) { background-image: linear-gradient(180deg, rgba(17,17,17,0.06), rgba(17,17,17,0.3)), linear-gradient(135deg, #d9e6ee, #9db2be); }

  .chip-row {
    display: flex;
    gap: 0.45rem;
    flex-wrap: wrap;
  }

  .intent-chip,
  .status-chip,
  .save-count,
  .meta-label {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 1.95rem;
    padding: 0.22rem 0.72rem;
    border-radius: 999px;
    font-size: 0.72rem;
    font-weight: 800;
  }

  .intent-chip,
  .status-chip,
  .save-count {
    background: rgba(255, 255, 255, 0.9);
    color: #111;
    border: 1px solid rgba(17, 17, 17, 0.06);
    backdrop-filter: blur(10px);
  }

  .listing-body {
    display: grid;
    gap: 0.9rem;
    padding: 1.15rem;
  }

  .listing-top,
  .listing-footer,
  .fact-row,
  .signal-row,
  .context-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.7rem;
    flex-wrap: wrap;
  }

  .price {
    margin: 0;
    font-size: 1.5rem;
    font-weight: 800;
    letter-spacing: -0.06em;
  }

  h3 {
    margin: 0.25rem 0 0;
    font-size: 1.16rem;
    line-height: 1.18;
    letter-spacing: -0.05em;
  }

  h3 a {
    text-decoration: none;
  }

  .meta-label {
    border: 1px solid var(--line);
    background: var(--bg-soft);
    color: var(--muted-strong);
  }

  .meta,
  .summary,
  .fact-row,
  .signal-row,
  .context-row,
  .context-headline {
    color: var(--muted);
  }

  .meta,
  .summary,
  .context-headline {
    margin: 0;
    line-height: 1.68;
  }

  .fact-row,
  .signal-row,
  .context-row {
    font-size: 0.88rem;
  }

  .fact-row {
    padding: 0.75rem 0;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }

  .context-panel {
    display: grid;
    gap: 0.58rem;
    padding: 0.92rem;
    border-radius: 1.25rem;
    background: rgba(243, 239, 231, 0.78);
    border: 1px solid var(--line);
  }

  .details-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.7rem;
    padding: 0.78rem 1rem;
    border-radius: 999px;
    background: var(--brand);
    color: white;
    font-weight: 700;
    text-decoration: none;
  }

  @media (max-width: 760px) {
    .listing-top,
    .listing-footer,
    .fact-row,
    .signal-row,
    .context-row {
      display: grid;
    }

    .details-link {
      width: 100%;
    }
  }
</style>
