---
import { getAuctionTimingLabel, type Listing } from "../data/listings";

export interface Props {
  listing: Listing;
  showCompareLink?: boolean;
  t?: (value: string) => string;
}

const { listing, showCompareLink = false, t = (value: string) => value } = Astro.props;
const heroImage = listing.imageUrls?.[0];
const coverPosition = listing.coverFocus ? `${listing.coverFocus.x}% ${listing.coverFocus.y}%` : "center";
const intentLabel = listing.intent === "rent" ? t("To rent") : t("For sale");
const neighborhood = listing.neighborhood;
const imageCount = listing.imageUrls?.length || 0;
const isAuction = listing.saleMode === "auction";
const auctionLabel = listing.auction?.phase === "live" ? t("Live auction") : listing.auction?.phase === "ended" ? t("Auction ended") : t("Auction");
const auctionTimingLabel = isAuction ? getAuctionTimingLabel(listing.auction) : null;
---

<article class="glass-card luxury-transition group overflow-hidden hover:-translate-y-1 hover:border-accent">
  <a class="block no-underline" href={`/listings/${listing.slug}/`}>
    <div class="relative aspect-[4/3] overflow-hidden border-b border-border">
      {heroImage ? (
        <img
          src={heroImage}
          alt={listing.title}
          class="h-full w-full object-cover transition-transform duration-[400ms] ease-luxury group-hover:scale-[1.03]"
          style={`object-position:${coverPosition}`}
        />
      ) : (
        <div class="bg-card-surface h-full w-full" />
      )}

      <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(10,10,10,0.08),rgba(10,10,10,0.4))]" />

      <div class="absolute inset-x-0 top-0 flex items-start justify-between gap-s p-m">
        <div class="flex flex-wrap gap-xs">
          <span class="glass-effect rounded-full px-s py-xs text-xs font-semibold uppercase tracking-[0.12em] text-white">
            {intentLabel}
          </span>
          {isAuction && (
            <span class="glass-effect rounded-full px-s py-xs text-xs font-semibold uppercase tracking-[0.12em] text-white">
              {auctionLabel}
            </span>
          )}
          <span class="glass-effect rounded-full px-s py-xs text-xs font-semibold uppercase tracking-[0.12em] text-white">
            {listing.status}
          </span>
        </div>

        <div class="flex flex-wrap justify-end gap-xs">
          <span class="glass-effect rounded-full px-s py-xs text-xs font-medium text-white">
            {listing.stats.saves} {t("saves")}
          </span>
          <span class="glass-effect rounded-full px-s py-xs text-xs font-medium text-white">
            {imageCount} {t("photos")}
          </span>
        </div>
      </div>
    </div>
  </a>

  <div class="grid gap-s p-m">
    <div class="flex flex-wrap gap-xs">
      <span class="rounded-full bg-accent px-s py-xs text-xs font-semibold uppercase tracking-[0.12em] text-accent-foreground">
        {listing.type}
      </span>
      <span class="rounded-full border border-border px-s py-xs text-xs font-medium uppercase tracking-[0.12em] text-muted">
        {listing.intent === "rent" ? t("Monthly rental") : isAuction ? t("Auction") : t("Private sale")}
      </span>
    </div>

    <div class="flex flex-wrap items-start justify-between gap-s">
      <div class="min-w-0 flex-1">
        <p class="text-lg font-semibold tracking-[-0.05em] text-white">{listing.priceLabel}</p>
        <h3 class="mt-xs text-lg font-semibold tracking-[-0.04em] text-white">
          <a href={`/listings/${listing.slug}/`} class="luxury-transition no-underline hover:text-accent">
            {listing.title}
          </a>
        </h3>
      </div>
      <span class="rounded-full border border-border px-s py-xs text-xs font-medium uppercase tracking-[0.12em] text-muted">
        {listing.intent === "rent" ? t("Rental") : t("Sale")}
      </span>
    </div>

    <p class="secondary-text text-sm leading-7">{listing.ward}, {listing.district}, {listing.city}, {listing.country}</p>

    <div class="flex flex-wrap items-center justify-between gap-s border-y border-border py-s text-sm text-muted">
      <span>{listing.type}</span>
      <span>{listing.beds} {t("beds")}</span>
      <span>{listing.baths} {t("baths")}</span>
      <span>{listing.area} m2</span>
    </div>

    <p class="secondary-text min-h-[4.5rem] text-sm leading-7">{listing.summary}</p>

    {isAuction && listing.auction && (
      <div class="flex flex-wrap items-center justify-between gap-s rounded-lg border border-border bg-card p-s">
        <strong class="text-sm font-semibold tracking-[-0.03em] text-white">
          {listing.auction.startingPriceLabel || listing.priceLabel}
        </strong>
        {auctionTimingLabel && <span class="secondary-text text-sm">{t(auctionTimingLabel)}</span>}
      </div>
    )}

    {neighborhood && (
      <div class="grid gap-xs rounded-lg border border-border bg-card p-s">
        <p class="text-sm font-medium text-white">{neighborhood.headline}</p>
        <div class="flex flex-wrap items-center justify-between gap-s text-sm text-muted">
          <span>{neighborhood.commute}</span>
          <span>{neighborhood.nearby[0]}</span>
        </div>
      </div>
    )}

    <div class="flex flex-wrap items-center justify-between gap-s">
      <div class="flex flex-wrap items-center gap-s text-sm text-muted">
        <span>{listing.stats.enquiries} {t("enquiries")}</span>
        <span>{listing.owner.verified ? t("Verified owner") : t("Owner listed")}</span>
      </div>

      <div class="flex flex-wrap items-center gap-s">
        {showCompareLink && (
          <a class="luxury-transition rounded-full border border-border px-s py-xs text-sm font-medium no-underline text-muted hover:text-white" href="/buyer/compare/">
            {t("Compare")}
          </a>
        )}
        <a class="btn-primary" href={`/listings/${listing.slug}/`}>{t("View details")}</a>
      </div>
    </div>
  </div>
</article>
