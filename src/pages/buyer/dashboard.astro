---
import Layout from "../../layouts/Layout.astro";
import WorkspaceHero from "../../components/workspace/WorkspaceHero.astro";
import WorkspaceStats from "../../components/workspace/WorkspaceStats.astro";
import AccountSummaryCard from "../../components/workspace/AccountSummaryCard.astro";
import FlashBanner from "../../components/workspace/FlashBanner.astro";
import { getBuyerDashboardData } from "../../lib/dashboard";
import { getDB } from "../../lib/runtime";

const owner = Astro.locals.owner;

if (!owner || (owner.role !== "buyer" && owner.role !== "admin")) {
  return Astro.redirect("/login");
}

const { savedSearches, savedListings, enquiries, recentlyViewed, inboxNotifications, unreadNotificationCount } = await getBuyerDashboardData(owner.id, getDB(Astro.locals.runtime));
const savedSearchDeleted = Astro.url.searchParams.get("savedSearchDeleted");
const savedListingDeleted = Astro.url.searchParams.get("savedListingDeleted");
const savedListingUpdated = Astro.url.searchParams.get("savedListingUpdated");
const finalistCount = savedListings.filter((listing) => listing.buyer_state === "finalist").length;
const enquiryStatusCounts = {
  new: enquiries.filter((enquiry) => enquiry.response_status === "new").length,
  responded: enquiries.filter((enquiry) => enquiry.response_status === "responded").length,
  archived: enquiries.filter((enquiry) => enquiry.response_status === "archived").length,
};
---

<Layout title="Buyer Dashboard | Property App 2026" description="Manage saved searches and buyer-side activity in the marketplace.">
  <WorkspaceHero
    eyebrow="Buyer workspace"
    title="Track homes, return to strong areas, and keep your shortlist moving."
    text="This should feel like a clean buyer workspace, not a storage page. Saved searches, favorite listings, and new activity stay in one place so revisits feel deliberate."
    actions={[
      { href: "/listings/", label: "Browse listings" },
      ...(savedListings.length > 1 ? [{ href: "/buyer/compare/", label: "Compare saved homes", kind: "secondary" as const }] : []),
      { href: "/account/inbox", label: "Open inbox", kind: "secondary" },
      { href: "/account/notifications", label: "Notification settings", kind: "secondary" },
    ]}
  />

  {savedSearchDeleted && <FlashBanner message="Saved search deleted." />}
  {savedListingDeleted && <FlashBanner message="Saved listing removed." />}
  {savedListingUpdated && <FlashBanner message="Shortlist state updated." />}

  <WorkspaceStats
    items={[
      { label: "Searches", value: savedSearches.length, copy: "Saved searches" },
      { label: "Favorites", value: savedListings.length, copy: "Saved listings" },
      { label: "Finalists", value: finalistCount, copy: "Decision-ready homes" },
      { label: "Enquiries", value: enquiries.length, copy: "Sent enquiries" },
      { label: "Recent", value: recentlyViewed.length, copy: "Recently viewed" },
      { label: "Inbox", value: unreadNotificationCount, copy: "Unread notifications" },
    ]}
  />

  <AccountSummaryCard
    blocks={[
      { eyebrow: "Signed in as", title: owner.full_name, copy: owner.email },
      { eyebrow: "Account role", title: owner.role, copy: "Browse, save, compare, and return to high-intent searches" },
    ]}
  />

  <section class="split-grid section-gap">
    <article class="card panel">
      <div class="panel-head">
        <div>
          <p class="eyebrow">Recent activity</p>
          <h2>Recent inbox activity</h2>
          <p class="panel-copy">Saved-search updates, listing changes, and account activity stay visible here first.</p>
        </div>
        <a class="panel-link" href="/account/inbox">View all</a>
      </div>
      {inboxNotifications.length === 0 ? <p class="empty-copy">No inbox notifications yet.</p> : (
        <ul class="stack-list compact-list">
          {inboxNotifications.map((notification) => (
            <li class="list-item">
              <strong>{notification.title}</strong>
              <p>{notification.message}</p>
              <div class="meta-row">
                <span>{notification.category}</span>
                <span>{notification.created_at}</span>
              </div>
            </li>
          ))}
        </ul>
      )}
      <div class="action-row">
        <a class="button-secondary" href="/account/inbox">Open inbox</a>
        <a class="button-tertiary" href="/account/notifications">Manage settings</a>
      </div>
    </article>

    <article class="card panel">
      <div class="panel-head">
        <div>
          <p class="eyebrow">Favorites</p>
          <h2>Saved listings</h2>
          <p class="panel-copy">Your shortlist of specific homes worth comparing, revisiting, or enquiring on. The strongest listings should surface key facts and one good image immediately.</p>
        </div>
      </div>
      {savedListings.length === 0 ? <p class="empty-copy">No saved listings yet. Save individual properties from the listing detail page.</p> : (
        <ul class="stack-list saved-list-grid">
          {savedListings.map((savedListing) => (
            <li class="list-item saved-property-card">
              {savedListing.listing?.imageUrls?.[0] ? (
                <a class="saved-media" href={`/listings/${savedListing.listing_slug}/`} style={`background-image:url(${savedListing.listing.imageUrls[0]})`}></a>
              ) : (
                <a class="saved-media saved-media-fallback" href={`/listings/${savedListing.listing_slug}/`}>No photo yet</a>
              )}
              <div class="saved-content">
              <strong>{savedListing.listing?.title ?? savedListing.listing_slug}</strong>
              <p>{savedListing.listing?.ward ?? "Unknown ward"} · {savedListing.listing?.district ?? "Unknown district"} · {savedListing.listing?.city ?? "Unknown city"}</p>
              <div class="meta-row">
                <span>{savedListing.listing?.priceLabel ?? "Listing unavailable"}</span>
                {savedListing.listing && <span>{savedListing.listing.beds} beds · {savedListing.listing.area} m2</span>}
              </div>
              <div class="meta-row">
                <span class={`shortlist-chip state-${savedListing.buyer_state ?? "saved"}`}>{savedListing.buyer_state ?? "saved"}</span>
                {savedListing.follow_up_on && <span>Follow up {savedListing.follow_up_on}</span>}
              </div>
              {savedListing.buyer_note && <p class="enquiry-snippet"><strong>Buyer note:</strong> {savedListing.buyer_note}</p>}
              <form class="saved-state-form" method="POST" action="/api/saved-listings/update">
                <input type="hidden" name="listingSlug" value={savedListing.listing_slug} />
                <input type="hidden" name="redirectTo" value="/buyer/dashboard/" />
                <select name="buyerState">
                  <option value="saved" selected={(savedListing.buyer_state ?? "saved") === "saved"}>Saved</option>
                  <option value="finalist" selected={savedListing.buyer_state === "finalist"}>Finalist</option>
                  <option value="contacted" selected={savedListing.buyer_state === "contacted"}>Contacted</option>
                  <option value="follow_up" selected={savedListing.buyer_state === "follow_up"}>Follow up</option>
                </select>
                <input type="date" name="followUpOn" value={savedListing.follow_up_on ?? ""} />
                <input type="text" name="buyerNote" value={savedListing.buyer_note ?? ""} placeholder="Short note" />
                <button type="submit" class="button-tertiary">Update</button>
              </form>
              <div class="action-row">
                <a class="button-secondary" href={`/listings/${savedListing.listing_slug}/`}>View listing</a>
                <form method="POST" action="/api/saved-listings/delete">
                  <input type="hidden" name="listingSlug" value={savedListing.listing_slug} />
                  <input type="hidden" name="redirectTo" value="/buyer/dashboard/" />
                  <button type="submit" class="button-tertiary">Remove</button>
                </form>
              </div>
              </div>
            </li>
          ))}
        </ul>
      )}
    </article>
  </section>

  <section class="card panel section-gap">
    <div class="panel-head">
      <div>
        <p class="eyebrow">Decision</p>
        <h2>Shortlist comparison</h2>
        <p class="panel-copy">Use your saved listings as a working shortlist. Comparison is where price, trust, and location start competing directly.</p>
      </div>
      {savedListings.length > 1 && <a class="panel-link" href="/buyer/compare/">Open compare view</a>}
    </div>
    {savedListings.length > 1 ? (
      <div class="compare-preview">
        {savedListings.slice(0, 3).map((savedListing) => (
          <div class="compare-chip">
            <strong>{savedListing.listing?.title ?? savedListing.listing_slug}</strong>
            <span>{savedListing.listing?.priceLabel ?? "No price"}</span>
          </div>
        ))}
      </div>
    ) : (
      <p class="empty-copy">Save at least two listings to use the compare view.</p>
    )}
  </section>

  <section class="card panel section-gap">
    <div class="panel-head">
      <div>
        <p class="eyebrow">Contact history</p>
        <h2>Sent enquiries</h2>
        <p class="panel-copy">Track which homes you already contacted so the shortlist, compare flow, and owner responses stay connected.</p>
      </div>
    </div>
    <div class="compare-preview status-preview">
      <div class="compare-chip">
        <strong>{enquiryStatusCounts.new}</strong>
        <span>Awaiting owner reply</span>
      </div>
      <div class="compare-chip">
        <strong>{enquiryStatusCounts.responded}</strong>
        <span>Owner responded</span>
      </div>
      <div class="compare-chip">
        <strong>{enquiryStatusCounts.archived}</strong>
        <span>Archived</span>
      </div>
    </div>
    {enquiries.length === 0 ? <p class="empty-copy">No enquiries sent yet. Use listing detail pages to contact owners.</p> : (
      <ul class="stack-list compact-list">
        {enquiries.map((enquiry) => (
          <li class="list-item">
            <strong>{enquiry.listing_title}</strong>
            <p>{enquiry.ward ?? "Unknown ward"} · {enquiry.district ?? "Unknown district"} · {enquiry.city ?? "Unknown city"}</p>
            <div class="meta-row">
              <span>{enquiry.price_label ?? "Price unavailable"}</span>
              <span>{enquiry.created_at}</span>
            </div>
            <div class="meta-row">
              <span>Status: {enquiry.response_status ?? "new"}</span>
              {enquiry.responded_at && <span>Updated {enquiry.responded_at}</span>}
            </div>
            {enquiry.owner_note && <p class="enquiry-snippet"><strong>Owner note:</strong> {enquiry.owner_note}</p>}
            <p class="enquiry-snippet">{enquiry.message}</p>
            <div class="action-row">
              <a class="button-secondary" href={`/listings/${enquiry.listing_slug}/`}>Open listing</a>
            </div>
          </li>
        ))}
      </ul>
    )}
  </section>

  <section class="card panel section-gap">
    <div class="panel-head">
      <div>
        <p class="eyebrow">Return path</p>
        <h2>Recently viewed</h2>
        <p class="panel-copy">This keeps your browse trail intact before a listing is important enough to save or compare.</p>
      </div>
    </div>
    {recentlyViewed.length === 0 ? <p class="empty-copy">No recent listing views yet.</p> : (
      <ul class="stack-list compact-list">
        {recentlyViewed.map((view) => (
          <li class="list-item">
            <strong>{view.listing?.title ?? view.listing_slug}</strong>
            <p>{view.listing?.ward ?? "Unknown ward"} · {view.listing?.district ?? "Unknown district"} · {view.listing?.city ?? "Unknown city"}</p>
            <div class="meta-row">
              <span>{view.listing?.priceLabel ?? "Price unavailable"}</span>
              <span>Viewed {view.updated_at}</span>
            </div>
            <div class="action-row">
              <a class="button-secondary" href={`/listings/${view.listing_slug}/`}>Open listing</a>
            </div>
          </li>
        ))}
      </ul>
    )}
  </section>

  <section class="card panel section-gap">
    <div class="panel-head">
      <div>
        <p class="eyebrow">Search intent</p>
        <h2>Saved searches</h2>
        <p class="panel-copy">Reusable routes back into the market when you are tracking one area, budget, or housing type over time.</p>
      </div>
    </div>
    {savedSearches.length === 0 ? <p class="empty-copy">No saved searches yet. Save a filter from the listings page to build your shortlist.</p> : (
      <ul class="stack-list compact-list search-list">
        {savedSearches.map((search) => (
          <li class="list-item">
            <strong>{search.name}</strong>
            <p>{search.last_result_count} matching listings at last save</p>
            <div class={`freshness-row ${search.new_result_count ? "freshness-hot" : ""}`}>
              <span>{search.freshness_label}</span>
            </div>
            <div class="meta-row">
              <span>{search.route_query ? `/listings/?${search.route_query}` : "/listings/"}</span>
            </div>
            <div class="action-row">
              <a class="button-secondary" href={`/api/saved-searches/visit?id=${search.id}&redirectTo=${encodeURIComponent(search.route_query ? `/listings/?${search.route_query}` : "/listings/")}`}>Open search</a>
              <form method="POST" action="/api/saved-searches/delete">
                <input type="hidden" name="id" value={search.id} />
                <input type="hidden" name="redirectTo" value="/buyer/dashboard/" />
                <button type="submit" class="button-tertiary">Delete</button>
              </form>
            </div>
          </li>
        ))}
      </ul>
    )}
  </section>

  <style is:inline>
    .split-grid {
      display: grid;
      gap: 1rem;
      margin-top: 1rem;
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .list-item {
      padding: 1rem;
      border-radius: 22px;
      background: linear-gradient(180deg, rgba(255,255,255,0.98), rgba(248,250,252,0.92));
      border: 1px solid var(--line);
    }

    .saved-list-grid {
      display: grid;
      gap: 1rem;
    }

    .saved-property-card {
      display: grid;
      grid-template-columns: minmax(11rem, 13rem) minmax(0, 1fr);
      gap: 1rem;
      align-items: stretch;
    }

    .saved-media {
      display: block;
      min-height: 11.5rem;
      border-radius: 20px;
      background-size: cover;
      background-position: center;
      background-color: rgba(15, 23, 42, 0.06);
      text-decoration: none;
    }

    .saved-media-fallback {
      display: grid;
      place-items: center;
      color: var(--muted-strong);
      font-weight: 700;
      background-image: linear-gradient(135deg, rgba(205, 215, 228, 0.8), rgba(239, 244, 249, 0.98));
    }

    .saved-content {
      display: grid;
      gap: 0.8rem;
      align-content: start;
    }

    .search-list .list-item p,
    .saved-content p,
    .enquiry-snippet {
      margin: 0;
      color: var(--muted);
      line-height: 1.65;
    }

    .compare-preview {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 0.8rem;
    }

    .saved-state-form {
      display: grid;
      grid-template-columns: 0.9fr 0.9fr 1.3fr auto;
      gap: 0.55rem;
      align-items: center;
    }

    .shortlist-chip {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: fit-content;
      min-height: 1.8rem;
      padding: 0.2rem 0.65rem;
      border-radius: 999px;
      font-size: 0.78rem;
      font-weight: 700;
      text-transform: capitalize;
      background: rgba(15, 23, 42, 0.06);
      color: var(--muted-strong);
    }

    .state-contacted {
      background: rgba(30, 64, 175, 0.12);
      color: #1e40af;
    }

    .state-finalist {
      background: rgba(6, 95, 70, 0.12);
      color: #065f46;
    }

    .state-follow_up {
      background: rgba(146, 64, 14, 0.12);
      color: #92400e;
    }

    .compare-chip {
      display: grid;
      gap: 0.35rem;
      padding: 1rem;
      border-radius: 20px;
      background: linear-gradient(180deg, rgba(255,255,255,0.98), rgba(248,250,252,0.92));
      border: 1px solid var(--line);
    }

    .compare-chip span {
      color: var(--muted);
    }

    .status-preview {
      margin-bottom: 1rem;
    }

    .freshness-row {
      display: inline-flex;
      align-items: center;
      width: fit-content;
      padding: 0.45rem 0.7rem;
      border-radius: 999px;
      background: rgba(15, 23, 42, 0.06);
      color: var(--muted-strong);
      font-size: 0.82rem;
      font-weight: 700;
    }

    .freshness-hot {
      background: rgba(6, 95, 70, 0.12);
      color: #065f46;
    }

    @media (max-width: 960px) {
      .split-grid {
        grid-template-columns: 1fr;
      }

      .compare-preview,
      .saved-property-card,
      .saved-state-form {
        grid-template-columns: 1fr;
      }
    }
  </style>
</Layout>
