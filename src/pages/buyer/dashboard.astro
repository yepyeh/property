---
import Layout from "../../layouts/Layout.astro";
import WorkspaceHero from "../../components/workspace/WorkspaceHero.astro";
import WorkspaceStats from "../../components/workspace/WorkspaceStats.astro";
import AccountSummaryCard from "../../components/workspace/AccountSummaryCard.astro";
import FlashBanner from "../../components/workspace/FlashBanner.astro";
import { getBuyerDashboardData } from "../../lib/dashboard";
import { getDB } from "../../lib/runtime";

const owner = Astro.locals.owner;

if (!owner || (owner.role !== "buyer" && owner.role !== "admin")) {
  return Astro.redirect("/login");
}

const { savedSearches, savedListings, inboxNotifications, unreadNotificationCount } = await getBuyerDashboardData(owner.id, getDB(Astro.locals.runtime));
const savedSearchDeleted = Astro.url.searchParams.get("savedSearchDeleted");
const savedListingDeleted = Astro.url.searchParams.get("savedListingDeleted");
---

<Layout title="Buyer Dashboard | Property App 2026" description="Manage saved searches and buyer-side activity in the marketplace.">
  <WorkspaceHero
    eyebrow="Buyer workspace"
    title="Track homes, return to strong areas, and keep your shortlist moving."
    text="This should feel like a clean buyer workspace, not a storage page. Saved searches, favorite listings, and new activity stay in one place so revisits feel deliberate."
    actions={[
      { href: "/listings/", label: "Browse listings" },
      ...(savedListings.length > 1 ? [{ href: "/buyer/compare/", label: "Compare saved homes", kind: "secondary" as const }] : []),
      { href: "/account/inbox", label: "Open inbox", kind: "secondary" },
      { href: "/account/notifications", label: "Notification settings", kind: "secondary" },
    ]}
  />

  {savedSearchDeleted && <FlashBanner message="Saved search deleted." />}
  {savedListingDeleted && <FlashBanner message="Saved listing removed." />}

  <WorkspaceStats
    items={[
      { label: "Searches", value: savedSearches.length, copy: "Saved searches" },
      { label: "Favorites", value: savedListings.length, copy: "Saved listings" },
      { label: "Inbox", value: unreadNotificationCount, copy: "Unread notifications" },
    ]}
  />

  <AccountSummaryCard
    blocks={[
      { eyebrow: "Signed in as", title: owner.full_name, copy: owner.email },
      { eyebrow: "Account role", title: owner.role, copy: "Browse, save, compare, and return to high-intent searches" },
    ]}
  />

  <section class="split-grid section-gap">
    <article class="card panel">
      <div class="panel-head">
        <div>
          <p class="eyebrow">Recent activity</p>
          <h2>Recent inbox activity</h2>
          <p class="panel-copy">Saved-search updates, listing changes, and account activity stay visible here first.</p>
        </div>
        <a class="panel-link" href="/account/inbox">View all</a>
      </div>
      {inboxNotifications.length === 0 ? <p class="empty-copy">No inbox notifications yet.</p> : (
        <ul class="stack-list compact-list">
          {inboxNotifications.map((notification) => (
            <li class="list-item">
              <strong>{notification.title}</strong>
              <p>{notification.message}</p>
              <div class="meta-row">
                <span>{notification.category}</span>
                <span>{notification.created_at}</span>
              </div>
            </li>
          ))}
        </ul>
      )}
      <div class="action-row">
        <a class="button-secondary" href="/account/inbox">Open inbox</a>
        <a class="button-tertiary" href="/account/notifications">Manage settings</a>
      </div>
    </article>

    <article class="card panel">
      <div class="panel-head">
        <div>
          <p class="eyebrow">Favorites</p>
          <h2>Saved listings</h2>
          <p class="panel-copy">Your shortlist of specific homes worth comparing, revisiting, or enquiring on. The strongest listings should surface key facts and one good image immediately.</p>
        </div>
      </div>
      {savedListings.length === 0 ? <p class="empty-copy">No saved listings yet. Save individual properties from the listing detail page.</p> : (
        <ul class="stack-list saved-list-grid">
          {savedListings.map((savedListing) => (
            <li class="list-item saved-property-card">
              {savedListing.listing?.imageUrls?.[0] ? (
                <a class="saved-media" href={`/listings/${savedListing.listing_slug}/`} style={`background-image:url(${savedListing.listing.imageUrls[0]})`}></a>
              ) : (
                <a class="saved-media saved-media-fallback" href={`/listings/${savedListing.listing_slug}/`}>No photo yet</a>
              )}
              <div class="saved-content">
              <strong>{savedListing.listing?.title ?? savedListing.listing_slug}</strong>
              <p>{savedListing.listing?.ward ?? "Unknown ward"} · {savedListing.listing?.district ?? "Unknown district"} · {savedListing.listing?.city ?? "Unknown city"}</p>
              <div class="meta-row">
                <span>{savedListing.listing?.priceLabel ?? "Listing unavailable"}</span>
                {savedListing.listing && <span>{savedListing.listing.beds} beds · {savedListing.listing.area} m2</span>}
              </div>
              <div class="action-row">
                <a class="button-secondary" href={`/listings/${savedListing.listing_slug}/`}>View listing</a>
                <form method="POST" action="/api/saved-listings/delete">
                  <input type="hidden" name="listingSlug" value={savedListing.listing_slug} />
                  <input type="hidden" name="redirectTo" value="/buyer/dashboard/" />
                  <button type="submit" class="button-tertiary">Remove</button>
                </form>
              </div>
              </div>
            </li>
          ))}
        </ul>
      )}
    </article>
  </section>

  <section class="card panel section-gap">
    <div class="panel-head">
      <div>
        <p class="eyebrow">Decision</p>
        <h2>Shortlist comparison</h2>
        <p class="panel-copy">Use your saved listings as a working shortlist. Comparison is where price, trust, and location start competing directly.</p>
      </div>
      {savedListings.length > 1 && <a class="panel-link" href="/buyer/compare/">Open compare view</a>}
    </div>
    {savedListings.length > 1 ? (
      <div class="compare-preview">
        {savedListings.slice(0, 3).map((savedListing) => (
          <div class="compare-chip">
            <strong>{savedListing.listing?.title ?? savedListing.listing_slug}</strong>
            <span>{savedListing.listing?.priceLabel ?? "No price"}</span>
          </div>
        ))}
      </div>
    ) : (
      <p class="empty-copy">Save at least two listings to use the compare view.</p>
    )}
  </section>

  <section class="card panel section-gap">
    <div class="panel-head">
      <div>
        <p class="eyebrow">Search intent</p>
        <h2>Saved searches</h2>
        <p class="panel-copy">Reusable routes back into the market when you are tracking one area, budget, or housing type over time.</p>
      </div>
    </div>
    {savedSearches.length === 0 ? <p class="empty-copy">No saved searches yet. Save a filter from the listings page to build your shortlist.</p> : (
      <ul class="stack-list compact-list search-list">
        {savedSearches.map((search) => (
          <li class="list-item">
            <strong>{search.name}</strong>
            <p>{search.last_result_count} matching listings at last save</p>
            <div class="meta-row">
              <span>{search.route_query ? `/listings/?${search.route_query}` : "/listings/"}</span>
            </div>
            <div class="action-row">
              <a class="button-secondary" href={search.route_query ? `/listings/?${search.route_query}` : "/listings/"}>Open search</a>
              <form method="POST" action="/api/saved-searches/delete">
                <input type="hidden" name="id" value={search.id} />
                <button type="submit" class="button-tertiary">Delete</button>
              </form>
            </div>
          </li>
        ))}
      </ul>
    )}
  </section>

  <style is:inline>
    .split-grid {
      display: grid;
      gap: 1rem;
      margin-top: 1rem;
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .list-item {
      padding: 1rem;
      border-radius: 22px;
      background: linear-gradient(180deg, rgba(255,255,255,0.98), rgba(248,250,252,0.92));
      border: 1px solid var(--line);
    }

    .saved-list-grid {
      display: grid;
      gap: 1rem;
    }

    .saved-property-card {
      display: grid;
      grid-template-columns: minmax(11rem, 13rem) minmax(0, 1fr);
      gap: 1rem;
      align-items: stretch;
    }

    .saved-media {
      display: block;
      min-height: 11.5rem;
      border-radius: 20px;
      background-size: cover;
      background-position: center;
      background-color: rgba(15, 23, 42, 0.06);
      text-decoration: none;
    }

    .saved-media-fallback {
      display: grid;
      place-items: center;
      color: var(--muted-strong);
      font-weight: 700;
      background-image: linear-gradient(135deg, rgba(205, 215, 228, 0.8), rgba(239, 244, 249, 0.98));
    }

    .saved-content {
      display: grid;
      gap: 0.8rem;
      align-content: start;
    }

    .search-list .list-item p,
    .saved-content p {
      margin: 0;
      color: var(--muted);
      line-height: 1.65;
    }

    .compare-preview {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 0.8rem;
    }

    .compare-chip {
      display: grid;
      gap: 0.35rem;
      padding: 1rem;
      border-radius: 20px;
      background: linear-gradient(180deg, rgba(255,255,255,0.98), rgba(248,250,252,0.92));
      border: 1px solid var(--line);
    }

    .compare-chip span {
      color: var(--muted);
    }

    @media (max-width: 960px) {
      .split-grid {
        grid-template-columns: 1fr;
      }

      .compare-preview,
      .saved-property-card {
        grid-template-columns: 1fr;
      }
    }
  </style>
</Layout>
