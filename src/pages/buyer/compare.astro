---
import Layout from "../../layouts/Layout.astro";
import WorkspaceHero from "../../components/workspace/WorkspaceHero.astro";
import FlashBanner from "../../components/workspace/FlashBanner.astro";
import { estimateMonthlyPayment, formatVndAmount } from "../../lib/affordability";
import { getBuyerDashboardData } from "../../lib/dashboard";
import { getDB } from "../../lib/runtime";

const viewer = Astro.locals.owner;

if (!viewer || (viewer.role !== "buyer" && viewer.role !== "admin")) {
  return Astro.redirect("/login");
}

const { savedListings } = await getBuyerDashboardData(viewer.id, getDB(Astro.locals.runtime));
const savedListingUpdated = Astro.url.searchParams.get("savedListingUpdated");
const compareEntries = savedListings
  .filter((entry) => entry.listing)
  .slice(0, 3);
const compareCollections = Array.from(new Set(compareEntries.map((entry) => entry.collection_name?.trim()).filter(Boolean)));

function getPros(listing: NonNullable<(typeof compareEntries)[number]["listing"]>) {
  return [
    `${listing.beds} bed / ${listing.baths} bath layout`,
    listing.owner.verified ? "Verified contact" : "Direct owner flow",
    listing.neighborhood?.headline || `${listing.ward}, ${listing.district}`,
  ];
}

function getCons(listing: NonNullable<(typeof compareEntries)[number]["listing"]>) {
  return [
    listing.imageUrls?.length ? `${listing.imageUrls.length} gallery image${listing.imageUrls.length === 1 ? "" : "s"}` : "No gallery yet",
    listing.owner.responseTime || "Response time unknown",
    listing.status,
  ];
}
---

<Layout title="Compare Saved Listings | Property App 2026" description="Compare shortlisted homes side by side across price, location, trust signals, and key facts.">
  <WorkspaceHero
    eyebrow="Buyer comparison"
    title="Compare shortlisted homes side by side."
    text="This is where a shortlist turns into a decision. Compare price, area, trust, and location first. If one listing clearly pulls ahead, mark it as a finalist. If you are ready, move it to contacted and continue from the listing page."
    actions={[
      { href: "/buyer/dashboard/", label: "Back to dashboard", kind: "secondary" },
      { href: "/listings/", label: "Browse listings", kind: "secondary" },
    ]}
  />

  {savedListingUpdated && <FlashBanner message="Shortlist decision updated from compare view." />}

  <section class="card compare-help section-gap">
    <strong>Need help using compare?</strong>
    <p>Compare is best for two or three listings you already care about. If you want the full buyer workflow spelled out, use the help centre article below.</p>
    {compareCollections.length > 0 && (
      <div class="collection-summary">
        {compareCollections.map((collection) => <span>{collection}</span>)}
      </div>
    )}
    <div class="action-row">
      <a class="button-secondary small" href="/help/buyer-shortlist-and-compare/">Open buyer compare guide</a>
      <a class="button-tertiary small" href="/help/what-changed-march-2026/">What changed</a>
    </div>
  </section>

  {compareEntries.length < 2 ? (
    <section class="card compare-empty section-gap">
      <strong>Save at least two listings to compare them.</strong>
      <p>Use the buyer dashboard or any listing detail page to build a shortlist first.</p>
      <a class="button-secondary" href="/listings/">Browse listings</a>
    </section>
  ) : (
    <section class="card compare-table section-gap">
      <div class="compare-guide">
        <strong>Decision rule</strong>
        <p>Use compare for two or three listings only. When one option still looks strongest after price, location context, trust, and watchouts, mark it as a finalist. Contact only after that.</p>
      </div>
      <div class="compare-grid compare-head">
        <div class="compare-label">Compare</div>
        {compareEntries.map((entry) => {
          const listing = entry.listing!;
          return (
          <article class="compare-property">
            {listing.imageUrls?.[0] ? (
              <div class="compare-media" style={`background-image:url(${listing.imageUrls[0]})`}></div>
            ) : (
              <div class="compare-media compare-fallback">No gallery</div>
            )}
            <strong>{listing.title}</strong>
            <p>{listing.ward}, {listing.district}</p>
            <span class={`state-chip state-${entry.buyer_state ?? "saved"}`}>{entry.buyer_state ?? "saved"}</span>
            <span class="state-chip collection-pill">{entry.collection_name?.trim() || "General shortlist"}</span>
            <div class="decision-actions">
              <form method="POST" action="/api/saved-listings/update">
                <input type="hidden" name="listingSlug" value={entry.listing_slug} />
                <input type="hidden" name="buyerState" value="finalist" />
                <input type="hidden" name="redirectTo" value="/buyer/compare/" />
                <button type="submit" class="button-primary small">Mark finalist</button>
              </form>
              <form method="POST" action="/api/saved-listings/update">
                <input type="hidden" name="listingSlug" value={entry.listing_slug} />
                <input type="hidden" name="buyerState" value="contacted" />
                <input type="hidden" name="redirectTo" value="/buyer/compare/" />
                <button type="submit" class="button-tertiary small">Ready to contact</button>
              </form>
            </div>
            <a class="button-secondary small" href={`/listings/${listing.slug}/`}>Open listing</a>
          </article>
        )})}
      </div>

      {[
        { label: "Price", values: compareEntries.map((entry) => entry.listing!.priceLabel) },
        { label: "Estimated monthly", values: compareEntries.map((entry) => `${formatVndAmount(estimateMonthlyPayment(entry.listing!.numericPrice))} VND / month`) },
        { label: "Property type", values: compareEntries.map((entry) => entry.listing!.type) },
        { label: "Bedrooms", values: compareEntries.map((entry) => `${entry.listing!.beds}`) },
        { label: "Bathrooms", values: compareEntries.map((entry) => `${entry.listing!.baths}`) },
        { label: "Area", values: compareEntries.map((entry) => `${entry.listing!.area} m2`) },
        { label: "Status", values: compareEntries.map((entry) => entry.listing!.status) },
        { label: "Trust", values: compareEntries.map((entry) => entry.listing!.owner.verified ? "Verified contact" : "Owner listed") },
        { label: "Response time", values: compareEntries.map((entry) => entry.listing!.owner.responseTime) },
        { label: "Location context", values: compareEntries.map((entry) => entry.listing!.neighborhood?.headline || `${entry.listing!.ward}, ${entry.listing!.district}`) },
        { label: "Pluses", values: compareEntries.map((entry) => getPros(entry.listing!).join(" · ")) },
        { label: "Watchouts", values: compareEntries.map((entry) => getCons(entry.listing!).join(" · ")) },
      ].map((row) => (
        <div class="compare-grid compare-row">
          <div class="compare-label">{row.label}</div>
          {row.values.map((value) => (
            <div class="compare-cell">{value}</div>
          ))}
        </div>
      ))}
    </section>
  )}

  <style is:inline>
    .compare-empty {
      padding: 1.4rem;
      display: grid;
      gap: 0.75rem;
      justify-items: start;
    }

    .compare-empty p {
      margin: 0;
      color: var(--muted);
      line-height: 1.65;
    }

    .compare-table {
      padding: 1rem;
      overflow-x: auto;
    }

    .compare-help {
      padding: 1.1rem;
      display: grid;
      gap: 0.65rem;
    }

    .compare-help p {
      margin: 0;
      color: var(--muted);
      line-height: 1.65;
    }

    .collection-summary {
      display: flex;
      flex-wrap: wrap;
      gap: 0.55rem;
    }

    .collection-summary span,
    .collection-pill {
      display: inline-flex;
      align-items: center;
      min-height: 1.8rem;
      padding: 0.2rem 0.7rem;
      border-radius: 999px;
      background: rgba(15, 23, 42, 0.06);
      color: var(--muted-strong);
      font-size: 0.78rem;
      font-weight: 700;
    }

    .compare-guide {
      padding: 1rem 1.05rem;
      margin-bottom: 0.9rem;
      border-radius: 20px;
      background: rgba(15, 23, 42, 0.05);
      border: 1px solid var(--line);
    }

    .compare-guide p {
      margin: 0.35rem 0 0;
      color: var(--muted);
      line-height: 1.65;
    }

    .compare-grid {
      display: grid;
      grid-template-columns: minmax(10rem, 13rem) repeat(3, minmax(15rem, 1fr));
      gap: 0.8rem;
      align-items: stretch;
    }

    .compare-head {
      margin-bottom: 0.8rem;
    }

    .compare-row {
      padding-top: 0.8rem;
      border-top: 1px solid var(--line);
    }

    .compare-label,
    .compare-cell,
    .compare-property {
      padding: 0.95rem 1rem;
      border-radius: 20px;
      background: linear-gradient(180deg, rgba(255,255,255,0.98), rgba(248,250,252,0.92));
      border: 1px solid var(--line);
    }

    .compare-label {
      font-weight: 800;
      color: var(--muted-strong);
    }

    .compare-property {
      display: grid;
      gap: 0.6rem;
      align-content: start;
    }

    .decision-actions {
      display: grid;
      gap: 0.45rem;
    }

    .state-chip {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: fit-content;
      min-height: 1.8rem;
      padding: 0.2rem 0.65rem;
      border-radius: 999px;
      font-size: 0.78rem;
      font-weight: 700;
      text-transform: capitalize;
      background: rgba(15, 23, 42, 0.06);
      color: var(--muted-strong);
    }

    .state-finalist {
      background: rgba(6, 95, 70, 0.12);
      color: #065f46;
    }

    .state-contacted {
      background: rgba(30, 64, 175, 0.12);
      color: #1e40af;
    }

    .button-primary {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 2.45rem;
      padding: 0.7rem 1rem;
      border-radius: 999px;
      border: none;
      background: linear-gradient(135deg, var(--accent), var(--accent-strong));
      color: white;
      font-weight: 700;
      cursor: pointer;
      text-decoration: none;
    }

    .compare-property p,
    .compare-cell {
      margin: 0;
      color: var(--muted);
      line-height: 1.6;
    }

    .compare-property strong {
      font-size: 1rem;
      letter-spacing: -0.02em;
    }

    .compare-media {
      min-height: 9rem;
      border-radius: 16px;
      background-size: cover;
      background-position: center;
      background-color: rgba(15, 23, 42, 0.06);
    }

    .compare-fallback {
      display: grid;
      place-items: center;
      color: var(--muted-strong);
      font-weight: 700;
      background-image: linear-gradient(135deg, rgba(205, 215, 228, 0.8), rgba(239, 244, 249, 0.98));
    }

    @media (max-width: 960px) {
      .compare-grid {
        grid-template-columns: minmax(8rem, 10rem) repeat(3, minmax(13rem, 1fr));
      }
    }
  </style>
</Layout>
