---
import Layout from "../layouts/Layout.astro";
import ListingFlow from "../components/flows/ListingFlow";

const created = Astro.url.searchParams.get("created");
const owner = Astro.locals.owner;
const t = Astro.locals.t || ((value: string) => value);
---

<Layout
  title={`${t("Post a listing")} | Property App 2026`}
  description={t("Owners can publish listings through a concierge-style multi-step flow with autosave and live preview.")}
  inlineShellCss={true}
>
  <ListingFlow
    client:load
    createdSlug={created || ""}
    ownerName={owner?.full_name ?? ""}
    ownerEmail={owner?.email ?? ""}
    ownerPhone={owner?.phone ?? ""}
  />
</Layout>
