---
import Layout from "../layouts/Layout.astro";

const created = Astro.url.searchParams.get("created");
const owner = Astro.locals.owner;
const t = Astro.locals.t || ((value: string) => value);
---

<Layout title={`${t("Post a listing")} | Property App 2026`} description={t("Owners can submit property listings directly into the marketplace.")}>
  <section class="page-head card">
    <div class="head-copy">
      <span class="pill">{t("Owner flow")}</span>
      <h1 class="section-title">{t("Post a listing")}</h1>
      <p class="section-copy">
        {t("Build the listing with enough trust, location context, and media intent that a buyer can decide whether it is worth enquiring. Every new listing starts on a 7-day free trial, then can be upgraded into paid or promoted visibility.")}
      </p>
      <div class="head-signals">
        <span>{t("Searchable facts first")}</span>
        <span>{t("Trust and location context next")}</span>
        <span>{t("Gallery and contact layer after publish")}</span>
      </div>
    </div>
    <div class="actions">
      <a class="ghost" href="/owner/dashboard/">{t("Owner dashboard")}</a>
      <a class="ghost" href="/help/posting-and-managing-listings/">{t("Owner help")}</a>
      <form method="POST" action="/api/auth/logout">
        <button class="ghost" type="submit">{t("Log out")}</button>
      </form>
    </div>
  </section>

  {created && (
    <div class="notice card">
      {t("Listing created successfully. New slug:")} <code>{created}</code>. {t("Add photos from the")} <a href="/owner/dashboard/">{t("owner dashboard")}</a>.
    </div>
  )}

  <section class="prep-grid">
    <div class="pricing card">
      <strong>{t("Monetization path")}</strong>
      <ul>
        <li>{t("Free: every listing is visible for 7 days.")}</li>
        <li>{t("Paid: keep a listing live after the free-trial window.")}</li>
        <li>{t("Promoted: push the listing above standard inventory.")}</li>
      </ul>
    </div>

    <div class="pricing card">
      <strong>{t("What makes a listing perform")}</strong>
      <ul>
        <li>{t("Specific headline and summary, not generic sales language.")}</li>
        <li>{t("Real neighborhood context: commute, landmarks, buyer trust signals.")}</li>
        <li>{t("Clear ownership identity and realistic response expectations.")}</li>
      </ul>
    </div>

    <div class="pricing card">
      <strong>{t("Photo checklist")}</strong>
      <ul>
        <li>{t("One strong exterior or tower/context image.")}</li>
        <li>{t("Main living area in natural light.")}</li>
        <li>{t("Kitchen, primary bedroom, and bathroom.")}</li>
        <li>{t("One neighborhood or amenities image if available.")}</li>
      </ul>
    </div>

    <div class="pricing card">
      <strong>{t("Before you publish")}</strong>
      <ul>
        <li>{t("Lead with the specific buyer fit, not vague “luxury” claims.")}</li>
        <li>{t("Use the location section to explain why the area works.")}</li>
        <li>{t("Upload a gallery immediately after publishing from the owner workspace.")}</li>
      </ul>
    </div>
  </section>

  <section class="onboarding-strip card">
    <div class="strip-copy">
      <span class="pill">Publishing rhythm</span>
      <h2>{t("Good onboarding keeps owners moving with confidence.")}</h2>
      <p>{t("Use this page to build the decision layer first. After publish, go straight to the owner dashboard to upload media, monitor performance, and respond to enquiries.")}</p>
    </div>
    <div class="strip-grid">
      <article>
        <strong>{t("Stage 1")}</strong>
        <span>{t("Set the facts buyers filter on: city, type, price, beds, and sale mode.")}</span>
      </article>
      <article>
        <strong>{t("Stage 2")}</strong>
        <span>{t("Write the positioning and location context so the listing feels credible.")}</span>
      </article>
      <article>
        <strong>{t("Stage 3")}</strong>
        <span>{t("Publish, upload a gallery, and tighten the listing from live buyer signals.")}</span>
      </article>
    </div>
  </section>

  <section class="section-map card">
    <div class="section-map-copy">
      <span class="pill">Build in order</span>
      <h2 class="section-title">Treat this like a publish flow, not a raw database form.</h2>
      <p class="section-copy">Start with the searchable facts, then write the buyer-facing positioning, then finish the trust and contact layer. The better the first version is, the less paid promotion has to compensate for weak content.</p>
      <div class="action-row">
        <a class="ghost small-ghost" href="/help/posting-and-managing-listings/">Open owner guide</a>
        <a class="ghost small-ghost" href="/help/what-changed-march-2026/">What changed</a>
      </div>
    </div>
    <ol class="section-steps">
      <li><strong>Core facts</strong><span>Searchable details and price.</span></li>
      <li><strong>Positioning</strong><span>Headline, summary, and standout features.</span></li>
      <li><strong>Location context</strong><span>Commute, nearby anchors, and trust signals.</span></li>
      <li><strong>Contact identity</strong><span>Who replies and how quickly.</span></li>
    </ol>
  </section>

  <form class="form-shell card" method="POST" action="/api/listings">
    <div class="section-block">
      <div class="section-intro">
        <strong>1. Core listing details</strong>
        <p>These fields define the searchable market route, price, and main housing facts.</p>
      </div>

      <div class="grid two">
        <label>Listing title<input name="title" required placeholder="Modern 3BR condo in Thu Duc" /></label>
        <label>Intent<select name="intent"><option value="buy">Buy</option><option value="rent">Rent</option></select></label>
      </div>

      <div class="grid two">
        <label>Sale mode<select name="saleMode"><option value="private-sale">Private sale / standard listing</option><option value="auction">Auction</option></select></label>
        <label>Property type<select name="propertyType"><option>Condo</option><option>Villa</option><option>Townhouse</option><option>Apartment</option><option>House</option><option>Land</option></select></label>
      </div>

      <div class="grid three">
        <label>Country<select name="country" required><option value="Vietnam">Vietnam</option><option value="Singapore">Singapore</option><option value="Indonesia">Indonesia</option><option value="Thailand">Thailand</option><option value="Philippines">Philippines</option><option value="Malaysia">Malaysia</option><option value="Brunei">Brunei</option><option value="Myanmar">Myanmar</option><option value="Cambodia">Cambodia</option><option value="Laos">Laos</option></select></label>
        <label>City<input name="city" required placeholder="Ho Chi Minh City" /></label>
        <label>District<input name="district" required placeholder="Thu Duc City" /></label>
      </div>
      <div class="grid two">
        <label>Ward<input name="ward" required placeholder="An Khanh" /></label>
      </div>

      <div class="grid four">
        <label>Price label<input name="priceLabel" required placeholder="9.5B VND" /></label>
        <label>Numeric price<input name="numericPrice" type="number" min="0" step="0.01" required placeholder="9.5" /></label>
        <label>Price unit<select name="priceUnit"><option value="VND">VND</option><option value="VND / month">VND / month</option></select></label>
        <label>Status label<input name="statusLabel" placeholder="Signature listing, New release, Move-in ready" /></label>
      </div>

      <div class="grid three">
        <label>Beds<input name="beds" type="number" min="0" required value="2" /></label>
        <label>Baths<input name="baths" type="number" min="0" required value="2" /></label>
        <label>Area (m2)<input name="area" type="number" min="1" required value="90" /></label>
      </div>
    </div>

    <div class="outcome-preview card-inset" data-outcome-preview>
      <div class="section-intro">
        <strong>What you unlock after step one</strong>
        <p>Once the core facts are in place, the system can route the listing correctly, open the 7-day free visibility window, and give you a usable live listing instead of a draft buried in a back office.</p>
      </div>
      <div class="preview-grid">
        <article class="preview-card live-preview">
          <span class="preview-kicker">Your live route</span>
          <strong data-preview-title>Add the core facts above</strong>
          <p data-preview-route>The system will turn this into a searchable listing route with the right buy/rent, location, and property filters.</p>
          <div class="preview-metadata">
            <span data-preview-intent>Intent pending</span>
            <span data-preview-location>Location pending</span>
            <span data-preview-facts>Facts pending</span>
          </div>
        </article>

        <article class="preview-card">
          <span class="preview-kicker">Included immediately</span>
          <ul class="preview-list">
            <li>Search placement in the right market lane</li>
            <li>7-day free visibility to test real demand</li>
            <li>Owner dashboard tracking for views, saves, and enquiries</li>
            <li>Upgrade path into paid, promoted, or auction mode later</li>
          </ul>
        </article>

        <article class="preview-card">
          <span class="preview-kicker">Why use this service</span>
          <ul class="preview-list">
            <li>Cleaner buyer intent than old directory-style portals</li>
            <li>Structured enquiry history instead of scattered messages</li>
            <li>Trust, verification, and safety tools inside the workflow</li>
            <li>Self-serve first, with concierge support when needed</li>
          </ul>
        </article>
      </div>
    </div>

    <div class="section-block">
      <div class="section-intro">
        <strong>2. Position the listing</strong>
        <p>Write this as if a buyer is deciding whether to open the detail page, save it, or enquire.</p>
      </div>
      <div class="grid three">
        <label>Visual tone<select name="tone"><option value="sea">Sea</option><option value="sun">Sun</option><option value="forest">Forest</option><option value="night">Night</option><option value="clay">Clay</option><option value="sky">Sky</option></select></label>
        <label>Tags<input name="tags" placeholder="River-facing, School-run ready, Investor-safe" /></label>
        <label>Auction starting price<input name="auctionStartingPriceLabel" placeholder="Opening bid 11.2B VND" /></label>
      </div>
      <label>Short summary<textarea name="summary" rows="3" required placeholder="High-floor condo with clean finish quality, direct bridge access into the core, and a layout that feels stronger than typical investor stock."></textarea><span class="field-tip">Three lines. Think listing card, not brochure. Lead with the buyer fit and the strongest differentiator.</span></label>
      <label>Full description<textarea name="description" rows="6" required placeholder="Describe the home, location, condition, buyer fit, and why it stands out against nearby alternatives."></textarea><span class="field-tip">Write for a buyer deciding whether to enquire today, not for an internal property record.</span></label>
      <label>Included features<input name="features" placeholder="Private garden, Home office, Pool deck, Covered parking" /></label>
      <div class="grid three">
        <label>Auction starts<input name="auctionStartsAt" type="datetime-local" /></label>
        <label>Auction ends<input name="auctionEndsAt" type="datetime-local" /></label>
        <label>Reserve price label<input name="auctionReservePriceLabel" placeholder="Reserve on request" /></label>
      </div>
      <label>Auction terms<textarea name="auctionTerms" rows="3" placeholder="Explain inspections, registration, reserve conditions, and when bids close."></textarea><span class="field-tip">Only use these fields when the listing is actually running as an auction.</span></label>
    </div>

    <div class="section-block card-inset">
      <div class="section-intro">
        <strong>3. Location and trust context</strong>
        <p>This matters more than generic marketing copy. Add the commute, landmarks, and buyer signals people actually use to decide whether to enquire.</p>
      </div>
      <label>Neighborhood headline<textarea name="neighborhoodHeadline" rows="3" placeholder="A calmer family pocket in Thu Duc with strong access to international schools and riverfront services."></textarea></label>
      <label>Commute and access<textarea name="commuteNotes" rows="3" placeholder="About 15 to 20 minutes to Thu Thiem, 25 minutes to District 1 outside peak traffic."></textarea></label>
      <div class="grid two">
        <label>Nearby landmarks or amenities<input name="nearbyPlaces" placeholder="International school, Metro stop, Retail podium" /><span class="field-tip">Comma-separated is fine.</span></label>
        <label>Trust signals<input name="trustSignals" placeholder="Low-rise pocket, Verified owner, Strong rental fallback" /><span class="field-tip">Use the things a cautious buyer would actually ask.</span></label>
      </div>
      <div class="grid three">
        <label>Latitude<input name="lat" type="number" step="0.000001" placeholder="10.7826" /></label>
        <label>Longitude<input name="lng" type="number" step="0.000001" placeholder="106.7297" /></label>
        <label>Map precision label<input name="locationPrecisionLabel" placeholder="Approximate area in Thu Thiem" /></label>
      </div>
    </div>

    <div class="section-block">
      <div class="section-intro">
        <strong>4. Contact identity</strong>
        <p>Buyers need to know who they are contacting and how quickly they should expect a reply.</p>
      </div>
      <div class="grid four">
        <label>Owner name<input name="ownerName" required placeholder="Nguyen Anh" value={owner?.full_name ?? ""} /></label>
        <label>Owner email<input name="ownerEmail" type="email" required placeholder="owner@example.com" value={owner?.email ?? ""} /></label>
        <label>Owner phone<input name="ownerPhone" required placeholder="+84 ..." value={owner?.phone ?? ""} /></label>
        <label>Contact role<input name="ownerRole" placeholder="Owner, Developer team, Exclusive seller" /></label>
      </div>
      <div class="grid two">
        <label>Expected response time<input name="ownerResponseTime" placeholder="~15 minutes" /></label>
        <label class="check-field"><input type="checkbox" name="ownerVerified" /> <span>Show as verified contact</span></label>
      </div>
    </div>

    <div class="submit-row">
      <p class="submit-copy">After publishing, add photos from the owner dashboard to complete the card and detail page presentation. Strong media is the fastest improvement you can make after the first live version.</p>
      <button type="submit">Publish listing</button>
    </div>
  </form>

  <script is:inline>
    const submitForm = document.querySelector(".form-shell");
    if (submitForm) {
      const titleInput = submitForm.querySelector('input[name="title"]');
      const intentInput = submitForm.querySelector('select[name="intent"]');
      const propertyTypeInput = submitForm.querySelector('select[name="propertyType"]');
      const cityInput = submitForm.querySelector('input[name="city"]');
      const districtInput = submitForm.querySelector('input[name="district"]');
      const priceLabelInput = submitForm.querySelector('input[name="priceLabel"]');
      const bedsInput = submitForm.querySelector('input[name="beds"]');
      const bathsInput = submitForm.querySelector('input[name="baths"]');
      const areaInput = submitForm.querySelector('input[name="area"]');

      const titleNode = submitForm.querySelector("[data-preview-title]");
      const routeNode = submitForm.querySelector("[data-preview-route]");
      const intentNode = submitForm.querySelector("[data-preview-intent]");
      const locationNode = submitForm.querySelector("[data-preview-location]");
      const factsNode = submitForm.querySelector("[data-preview-facts]");

      const updatePreview = () => {
        const title = titleInput?.value.trim();
        const intent = intentInput?.value === "rent" ? "Rental route" : "Sale route";
        const propertyType = propertyTypeInput?.value || "Property";
        const city = cityInput?.value.trim();
        const district = districtInput?.value.trim();
        const priceLabel = priceLabelInput?.value.trim();
        const beds = bedsInput?.value || "?";
        const baths = bathsInput?.value || "?";
        const area = areaInput?.value || "?";

        if (titleNode) {
          titleNode.textContent = title || "Add the core facts above";
        }

        if (routeNode) {
          routeNode.textContent = title && city
            ? `${title} will go live in the ${intent.toLowerCase()} for ${city}${district ? `, ${district}` : ""}, with the right searchable route from the first publish.`
            : "The system will turn this into a searchable listing route with the right buy/rent, location, and property filters.";
        }

        if (intentNode) intentNode.textContent = `${intent} · ${propertyType}`;
        if (locationNode) locationNode.textContent = city ? `${city}${district ? ` · ${district}` : ""}` : "Location pending";
        if (factsNode) factsNode.textContent = priceLabel ? `${priceLabel} · ${beds}bd / ${baths}ba · ${area} m2` : "Facts pending";
      };

      [titleInput, intentInput, propertyTypeInput, cityInput, districtInput, priceLabelInput, bedsInput, bathsInput, areaInput]
        .forEach((field) => {
          field?.addEventListener("input", updatePreview);
          field?.addEventListener("change", updatePreview);
        });

      updatePreview();
    }
  </script>

  <style is:inline>
    .page-head,
    .form-shell,
    .notice,
    .pricing {
      padding: 1.5rem;
      margin-bottom: 1rem;
    }
    .prep-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
      margin-bottom: 1rem;
    }
    .pricing ul {
      margin: 0.6rem 0 0;
      padding-left: 1.1rem;
      color: var(--muted);
      line-height: 1.7;
    }
    .page-head {
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      align-items: flex-start;
      background:
        radial-gradient(circle at top left, color-mix(in srgb, var(--hero-glow) 42%, transparent), transparent 32rem),
        linear-gradient(180deg, var(--surface-overlay-strong), var(--surface-panel-muted));
    }
    .head-copy {
      display: grid;
      gap: 0.8rem;
    }
    .head-signals {
      display: flex;
      flex-wrap: wrap;
      gap: 0.65rem;
    }
    .head-signals span {
      padding: 0.65rem 0.9rem;
      border-radius: 999px;
      background: color-mix(in srgb, var(--surface-input) 82%, transparent);
      border: 1px solid var(--line);
      color: var(--muted);
      font-size: 0.88rem;
      font-weight: 600;
    }
    .actions {
      display: flex;
      gap: 0.75rem;
      flex-wrap: wrap;
    }
    .ghost,
    button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0.95rem 1.2rem;
      border-radius: 999px;
      text-decoration: none;
      font-weight: 700;
    }
    .ghost {
      border: 1px solid var(--line);
      background: color-mix(in srgb, var(--surface-input) 86%, transparent);
      box-shadow: inset 0 1px 0 color-mix(in srgb, var(--surface-overlay-strong) 88%, transparent);
    }
    .small-ghost {
      padding: 0.8rem 1rem;
    }
    .form-shell {
      display: grid;
      gap: 1rem;
      background: linear-gradient(180deg, var(--surface-elevated-strong), var(--surface-panel-muted));
    }
    .onboarding-strip {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(24rem, 1fr);
      gap: 1rem;
      padding: 1.35rem;
      margin-bottom: 1rem;
      background:
        linear-gradient(180deg, var(--surface-overlay-strong), var(--surface-panel-muted));
    }
    .strip-copy,
    .strip-grid,
    .action-row {
      display: grid;
      gap: 0.75rem;
    }
    .strip-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
    .strip-grid article {
      padding: 1rem;
      border-radius: var(--radius-panel);
      background: color-mix(in srgb, var(--surface-input) 84%, transparent);
      border: 1px solid var(--line);
      display: grid;
      gap: 0.35rem;
      box-shadow: inset 0 1px 0 color-mix(in srgb, var(--surface-overlay-strong) 88%, transparent);
    }
    .strip-grid strong {
      font-size: 0.92rem;
      letter-spacing: -0.02em;
    }
    .strip-grid span {
      color: var(--muted);
      line-height: 1.6;
      font-size: 0.9rem;
    }
    .section-map {
      display: grid;
      grid-template-columns: minmax(0, 1.3fr) minmax(18rem, 0.7fr);
      gap: 1rem;
      padding: 1.35rem;
      margin-bottom: 1rem;
      align-items: start;
    }
    .section-map-copy {
      display: grid;
      gap: 0.75rem;
    }
    .section-steps {
      display: grid;
      gap: 0.8rem;
      margin: 0;
      padding: 0;
      list-style: none;
    }
    .section-steps li {
      display: grid;
      gap: 0.2rem;
      padding: 0.95rem 1rem;
      border-radius: var(--radius-panel);
      background: color-mix(in srgb, var(--surface-input) 84%, transparent);
      border: 1px solid var(--line);
      box-shadow: inset 0 1px 0 color-mix(in srgb, var(--surface-overlay-strong) 88%, transparent);
    }
    .section-steps span {
      color: var(--muted);
      line-height: 1.55;
    }
    .section-block {
      display: grid;
      gap: 1rem;
      padding: 1.2rem;
      border-radius: calc(var(--radius-panel) + 0.15rem);
      background: linear-gradient(180deg, color-mix(in srgb, var(--surface-overlay-strong) 92%, transparent), color-mix(in srgb, var(--surface-rail) 92%, transparent));
      border: 1px solid var(--line);
      box-shadow: inset 0 1px 0 color-mix(in srgb, var(--surface-overlay-strong) 90%, transparent);
    }
    .section-intro {
      display: grid;
      gap: 0.3rem;
    }
    .section-intro strong {
      font-size: 1.05rem;
      letter-spacing: -0.02em;
    }
    .section-intro p,
    .submit-copy {
      color: var(--muted);
      line-height: 1.7;
      margin: 0;
    }
    .grid {
      display: grid;
      gap: 0.9rem;
    }
    .card-inset {
      display: grid;
      gap: 0.9rem;
      padding: 1.1rem;
      border-radius: calc(var(--radius-panel) + 0.15rem);
      background: linear-gradient(180deg, color-mix(in srgb, var(--surface-input-strong) 94%, transparent), color-mix(in srgb, var(--surface-panel-muted) 90%, transparent));
      border: 1px solid var(--line);
    }
    .outcome-preview {
      gap: 1rem;
    }
    .preview-grid {
      display: grid;
      grid-template-columns: 1.15fr 1fr 1fr;
      gap: 1rem;
    }
    .preview-card {
      display: grid;
      gap: 0.7rem;
      padding: 1rem;
      border-radius: var(--radius-panel);
      background: linear-gradient(180deg, color-mix(in srgb, var(--surface-input-strong) 94%, transparent), color-mix(in srgb, var(--surface-panel-muted) 90%, transparent));
      border: 1px solid var(--line);
      align-content: start;
    }
    .live-preview {
      background:
        radial-gradient(circle at top left, color-mix(in srgb, var(--accent-strong) 14%, transparent), transparent 22rem),
        linear-gradient(180deg, var(--surface-elevated-strong), var(--surface-panel-muted));
    }
    .preview-kicker {
      display: inline-flex;
      align-items: center;
      min-height: 1.9rem;
      width: fit-content;
      padding: 0.22rem 0.7rem;
      border-radius: 999px;
      background: color-mix(in srgb, var(--surface-input) 84%, transparent);
      border: 1px solid var(--line);
      color: var(--muted-strong);
      font-size: 0.76rem;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }
    .preview-card strong {
      font-size: 1.05rem;
      letter-spacing: -0.02em;
    }
    .preview-card p {
      margin: 0;
      color: var(--muted);
      line-height: 1.65;
    }
    .preview-metadata {
      display: flex;
      flex-wrap: wrap;
      gap: 0.55rem;
    }
    .preview-metadata span {
      display: inline-flex;
      align-items: center;
      min-height: 1.9rem;
      padding: 0.2rem 0.7rem;
      border-radius: 999px;
      background: color-mix(in srgb, var(--brand-soft) 84%, var(--surface-elevated-strong));
      color: var(--muted-strong);
      font-size: 0.78rem;
      font-weight: 700;
    }
    .preview-list {
      margin: 0;
      padding-left: 1rem;
      color: var(--muted);
      line-height: 1.65;
      display: grid;
      gap: 0.35rem;
    }
    .card-inset strong {
      font-size: 1.05rem;
      letter-spacing: -0.02em;
    }
    .card-inset p {
      margin: 0;
      color: var(--muted);
      line-height: 1.7;
    }
    .grid.two { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .grid.three { grid-template-columns: repeat(3, minmax(0, 1fr)); }
    .grid.four { grid-template-columns: repeat(4, minmax(0, 1fr)); }
    label {
      display: block;
      color: var(--muted);
      font-size: 0.92rem;
      font-weight: 600;
    }
    input, select, textarea {
      width: 100%;
      margin-top: 0.4rem;
      padding: 0.95rem 1rem;
      border-radius: var(--radius-input);
      border: 1px solid var(--line);
