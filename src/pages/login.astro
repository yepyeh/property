---
import Layout from "../layouts/Layout.astro";
import { sanitizeInternalRedirect } from "../lib/http";

const error = Astro.url.searchParams.get("error");
const redirectTo = sanitizeInternalRedirect(Astro.url.searchParams.get("redirect"), "");
---

<Layout title="Account Login | Property App 2026" description="Secure login for buyer, owner, and administrator accounts.">
  <section class="auth-shell">
    <div class="auth-story card">
      <span class="pill">Protected access</span>
      <h1>Sign back in without losing your place.</h1>
      <p>
        Buyers return to shortlist, compare, and enquiry history. Owners return to listing performance, billing, and response workflows.
      </p>

      <div class="story-grid">
        <article>
          <strong>For buyers</strong>
          <span>Continue from saved listings, finalists, and follow-up plans.</span>
        </article>
        <article>
          <strong>For owners</strong>
          <span>Manage live inventory, enquiries, promotion, and auction-ready listings.</span>
        </article>
      </div>

      <div class="story-band">
        <strong>Why accounts matter</strong>
        <ul>
          <li>Saved searches, shortlist state, and compare stay attached to one account.</li>
          <li>Owner workflows keep payments, media, and enquiries in one place.</li>
          <li>Trust and verification signals stay tied to the account using the platform.</li>
        </ul>
      </div>
    </div>

    <section class="auth-panel card">
      <div class="panel-head">
        <div>
          <span class="eyebrow">Welcome back</span>
          <h2>Account login</h2>
        </div>
        <p>Use the account you created. The system routes you into the correct workflow automatically.</p>
      </div>

      {error && <p class="error">Login failed. Check the email and password and try again.</p>}

      <form class="login-form" method="POST" action="/api/auth/login">
        <input type="hidden" name="redirect" value={redirectTo} />

        <label class="field">
          <span>Email</span>
          <input type="email" name="email" required placeholder="name@example.com" />
        </label>

        <label class="field">
          <span>Password</span>
          <input type="password" name="password" required placeholder="Enter password" />
        </label>

        <button type="submit">Sign in</button>
      </form>

      <div class="panel-footer">
        <div class="footer-card">
          <strong>New here?</strong>
          <span>Create the account type that matches the job you need to do.</span>
        </div>
        <p class="switch-link">
          <a href="/signup?role=owner">Create an owner account</a>
          <a href="/signup?role=buyer">Create a buyer account</a>
        </p>
      </div>
    </section>
  </section>

  <style is:inline>
    .auth-shell {
      display: grid;
      grid-template-columns: minmax(0, 1.08fr) minmax(22rem, 0.92fr);
      gap: 1.15rem;
      align-items: stretch;
    }
    .auth-story,
    .auth-panel {
      padding: 1.6rem;
    }
    .auth-story {
      background:
        radial-gradient(circle at top left, color-mix(in srgb, var(--hero-glow) 48%, transparent), transparent 30rem),
        linear-gradient(180deg, var(--surface-overlay-strong), var(--surface-panel-muted));
      display: grid;
      gap: 1.15rem;
      min-height: 100%;
    }
    .auth-story h1,
    .panel-head h2 {
      margin: 0;
      font-size: clamp(2rem, 4vw, 3.5rem);
      line-height: 0.95;
      letter-spacing: -0.06em;
    }
    .auth-story p,
    .panel-head p,
    .story-band li,
    .footer-card span {
      margin: 0;
      color: var(--muted);
      line-height: 1.7;
    }
    .story-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.85rem;
    }
    .story-grid article,
    .story-band,
    .footer-card {
      padding: 1rem 1.05rem;
      border-radius: var(--radius-panel);
      background: color-mix(in srgb, var(--surface-input) 84%, transparent);
      border: 1px solid var(--line);
      display: grid;
      gap: 0.35rem;
      box-shadow: inset 0 1px 0 color-mix(in srgb, var(--surface-overlay-strong) 88%, transparent);
    }
    .story-grid strong,
    .story-band strong,
    .footer-card strong {
      font-size: 0.95rem;
      letter-spacing: -0.02em;
    }
    .story-grid span {
      color: var(--muted);
      line-height: 1.6;
      font-size: 0.92rem;
    }
    .story-band ul {
      margin: 0;
      padding-left: 1rem;
      display: grid;
      gap: 0.35rem;
    }
    .auth-panel {
      display: grid;
      gap: 1rem;
      align-content: start;
      background: linear-gradient(180deg, var(--surface-elevated-strong), var(--surface-panel-muted));
    }
    .panel-head {
      display: grid;
      gap: 0.65rem;
    }
    .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--muted);
    }
    .error {
      margin: 0;
      padding: 0.95rem 1rem;
      border-radius: 1.1rem;
      background: var(--danger-bg);
      color: var(--danger-text);
      font-weight: 600;
      border: 1px solid var(--danger-border);
    }
    .login-form {
      display: grid;
      gap: 0.95rem;
    }
    .field {
      display: grid;
      gap: 0.45rem;
      color: var(--muted);
      font-size: 0.9rem;
      font-weight: 600;
    }
    input {
      width: 100%;
      padding: 1rem 1rem;
      border-radius: var(--radius-input);
      border: 1px solid var(--line);
      background: color-mix(in srgb, var(--surface-input-strong) 92%, transparent);
      font: inherit;
      color: var(--text);
      box-shadow: inset 0 1px 0 color-mix(in srgb, var(--surface-overlay-strong) 84%, transparent);
    }
    input:focus {
      outline: none;
      border-color: var(--line-strong);
      box-shadow: 0 0 0 4px var(--accent-1);
    }
    button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 1rem 1.2rem;
      border: none;
      border-radius: 999px;
      background: linear-gradient(180deg, color-mix(in srgb, var(--brand) 94%, white), var(--brand));
      color: var(--surface-canvas);
      font-weight: 700;
      cursor: pointer;
      box-shadow: 0 16px 32px -20px var(--shadow-deep-color);
    }
    .panel-footer {
      display: grid;
      gap: 0.85rem;
    }
    .switch-link {
      display: flex;
      flex-wrap: wrap;
      gap: 0.8rem 1rem;
      margin: 0;
    }
    .switch-link a {
      color: var(--accent-strong);
      font-weight: 700;
      text-decoration: none;
    }
    @media (max-width: 960px) {
      .auth-shell,
      .story-grid {
        grid-template-columns: 1fr;
      }
      .auth-story h1,
      .panel-head h2 {
        font-size: clamp(2rem, 10vw, 2.9rem);
      }
    }
  </style>
</Layout>
