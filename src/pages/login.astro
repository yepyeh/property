---
import Layout from "../layouts/Layout.astro";
import { sanitizeInternalRedirect } from "../lib/http";

const error = Astro.url.searchParams.get("error");
const redirectTo = sanitizeInternalRedirect(Astro.url.searchParams.get("redirect"), "");
const t = Astro.locals.t || ((value: string) => value);
---

<Layout title={`${t("Account login")} | Property App 2026`} description={t("Secure login for buyer, owner, and administrator accounts.")}>
  <section class="auth-shell">
    <div class="auth-story card">
      <span class="pill">{t("Protected access")}</span>
      <h1>{t("Sign back in without losing your place.")}</h1>
      <p>
        Buyers return to shortlist, compare, and enquiry history. Owners return to listing performance, billing, and response workflows.
      </p>

      <div class="story-grid">
        <article>
          <strong>For buyers</strong>
          <span>Continue from saved listings, finalists, and follow-up plans.</span>
        </article>
        <article>
          <strong>For owners</strong>
          <span>Manage live inventory, enquiries, promotion, and auction-ready listings.</span>
        </article>
      </div>

      <div class="story-band">
        <strong>Why accounts matter</strong>
        <ul>
          <li>Saved searches, shortlist state, and compare stay attached to one account.</li>
          <li>Owner workflows keep payments, media, and enquiries in one place.</li>
          <li>Trust and verification signals stay tied to the account using the platform.</li>
        </ul>
      </div>
    </div>

    <section class="auth-panel card">
      <div class="panel-head">
        <div>
          <span class="eyebrow">Welcome back</span>
          <h2>Account login</h2>
        </div>
        <p>Use the account you created. The system routes you into the correct workflow automatically.</p>
      </div>

      {error && <p class="error">{t("Login failed. Check the email and password and try again.")}</p>}

      <form class="login-form" method="POST" action="/api/auth/login">
        <input type="hidden" name="redirect" value={redirectTo} />

        <label class="field">
          <span>{t("Email")}</span>
          <input class="input-luxury" type="email" name="email" required placeholder="name@example.com" />
        </label>

        <label class="field">
          <span>{t("Password")}</span>
          <input class="input-luxury" type="password" name="password" required placeholder="Enter password" />
        </label>

        <button class="btn-primary" type="submit">{t("Sign in")}</button>
      </form>

      <div class="panel-footer">
        <div class="footer-card">
          <strong>New here?</strong>
          <span>Create the account type that matches the job you need to do.</span>
        </div>
        <p class="switch-link">
          <a href="/signup?role=owner">Create an owner account</a>
          <a href="/signup?role=buyer">Create a buyer account</a>
        </p>
      </div>
    </section>
  </section>

  <style is:inline>
    .auth-shell {
      display: grid;
      grid-template-columns: minmax(0, 1.08fr) minmax(22rem, 0.92fr);
      gap: var(--space-m);
      align-items: stretch;
    }
    .auth-story,
    .auth-panel {
      padding: var(--space-l);
    }
    .auth-story {
      background:
        radial-gradient(circle at top left, color-mix(in srgb, var(--hero-glow) 48%, transparent), transparent 30rem),
        linear-gradient(180deg, var(--surface-overlay-strong), var(--surface-panel-muted));
      display: grid;
      gap: var(--space-m);
      min-height: 100%;
    }
    .auth-story h1,
    .panel-head h2 {
      margin: 0;
      font-size: var(--text-5xl);
      line-height: 0.95;
      letter-spacing: -0.06em;
    }
    .auth-story p,
    .panel-head p,
    .story-band li,
    .footer-card span {
      margin: 0;
      color: var(--muted);
      line-height: 1.7;
    }
    .story-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: var(--space-s);
    }
    .story-grid article,
    .story-band,
    .footer-card {
      padding: var(--space-m);
      border-radius: var(--radius-panel);
      background: color-mix(in srgb, var(--surface-input) 84%, transparent);
      border: 1px solid var(--line);
      display: grid;
      gap: var(--space-2xs);
      box-shadow: inset 0 1px 0 color-mix(in srgb, var(--surface-overlay-strong) 88%, transparent);
    }
    .story-grid strong,
    .story-band strong,
    .footer-card strong {
      font-size: var(--text-base);
      letter-spacing: -0.02em;
    }
    .story-grid span {
      color: var(--muted);
      line-height: 1.6;
      font-size: var(--text-sm);
    }
    .story-band ul {
      margin: 0;
      padding-left: var(--space-m);
      display: grid;
      gap: var(--space-2xs);
    }
    .auth-panel {
      display: grid;
      gap: var(--space-m);
      align-content: start;
      background: linear-gradient(180deg, var(--surface-elevated-strong), var(--surface-panel-muted));
    }
    .panel-head {
      display: grid;
      gap: var(--space-xs);
    }
    .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: var(--space-2xs);
      font-size: var(--text-xs);
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--muted);
    }
    .error {
      margin: 0;
      padding: var(--space-s) var(--space-m);
      border-radius: var(--radius-lg);
      background: var(--danger-bg);
      color: var(--danger-text);
      font-weight: 600;
      border: 1px solid var(--danger-border);
    }
    .login-form {
      display: grid;
      gap: var(--space-s);
    }
    .field {
      display: grid;
      gap: var(--space-2xs);
      color: var(--muted);
      font-size: var(--text-sm);
      font-weight: 600;
    }
    input {
      width: 100%;
    }
    .login-form input {
      width: 100%;
    }
    .login-form input { }
    .panel-footer {
      display: grid;
      gap: var(--space-s);
    }
    .switch-link {
      display: flex;
      flex-wrap: wrap;
      gap: var(--space-s) var(--space-m);
      margin: 0;
    }
    .switch-link a {
      color: var(--accent-strong);
      font-weight: 700;
      text-decoration: none;
    }
    @media (max-width: 960px) {
      .auth-shell,
      .story-grid {
        grid-template-columns: 1fr;
      }
      .auth-story h1,
      .panel-head h2 {
        font-size: var(--text-4xl);
      }
    }
  </style>
</Layout>
