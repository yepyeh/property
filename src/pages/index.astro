---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Astro on Cloudflare">
  <section class="hero card">
    <p class="eyebrow">Astro + Cloudflare Workers</p>
    <h1>Ship the project from this repo to your Cloudflare account.</h1>
    <p class="lede">
      The app is configured for Astro server output, Wrangler deployment, and Cloudflare's Workers runtime.
      Log in with Wrangler, then deploy from this workspace.
    </p>

    <div class="actions">
      <a href="https://developers.cloudflare.com/workers/frameworks/framework-guides/astro/">Cloudflare guide</a>
      <a href="https://docs.astro.build/en/guides/deploy/cloudflare/">Astro guide</a>
    </div>
  </section>

  <section class="grid">
    <article class="card panel">
      <h2>Local development</h2>
      <p>Run <code>npm run dev</code> to iterate locally.</p>
    </article>
    <article class="card panel">
      <h2>Preview Worker build</h2>
      <p>Run <code>npm run preview</code> to build and serve via Wrangler.</p>
    </article>
    <article class="card panel">
      <h2>Deploy to Cloudflare</h2>
      <p>Run <code>npm run deploy</code> after <code>wrangler login</code>.</p>
    </article>
  </section>

  <style>
    .hero {
      padding: 2.5rem;
    }

    .eyebrow {
      margin: 0 0 0.75rem;
      color: var(--accent-2);
      font-size: 0.9rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
    }

    h1 {
      margin: 0;
      max-width: 12ch;
      font-size: clamp(2.8rem, 7vw, 5.8rem);
      line-height: 0.96;
    }

    .lede {
      max-width: 56rem;
      margin: 1.25rem 0 0;
      color: var(--muted);
      font-size: 1.15rem;
      line-height: 1.65;
    }

    .actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.9rem;
      margin-top: 1.75rem;
    }

    .actions a {
      padding: 0.9rem 1.2rem;
      border: 1px solid var(--border);
      border-radius: 999px;
      text-decoration: none;
      transition: transform 180ms ease, border-color 180ms ease;
    }

    .actions a:hover {
      transform: translateY(-1px);
      border-color: rgba(31, 36, 48, 0.3);
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1rem;
      margin-top: 1rem;
    }

    .panel {
      padding: 1.4rem;
    }

    .panel h2 {
      margin-top: 0;
      margin-bottom: 0.5rem;
      font-size: 1.1rem;
    }

    .panel p {
      margin: 0;
      color: var(--muted);
      line-height: 1.6;
    }

    code {
      font-family: "SF Mono", "Monaco", "Cascadia Code", Consolas, monospace;
      font-size: 0.95em;
    }

    @media (max-width: 760px) {
      .hero {
        padding: 1.5rem;
      }

      .grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</Layout>
