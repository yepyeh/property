---
import Layout from "../layouts/Layout.astro";
import HomeHero from "../components/home/HomeHero.astro";
import HomePathSection from "../components/home/HomePathSection.astro";
import HomeCitySection from "../components/home/HomeCitySection.astro";
import HomeFeaturedSection from "../components/home/HomeFeaturedSection.astro";
import HomeOwnerSection from "../components/home/HomeOwnerSection.astro";
import HomeProductBand from "../components/home/HomeProductBand.astro";
import { getAllListings } from "../lib/listings";
import { getDB } from "../lib/runtime";

const t = Astro.locals.t || ((value: string) => value);

const quickFilters = [
  { label: t("Buy in HCMC"), href: "/listings/?intent=buy&city=Ho%20Chi%20Minh%20City" },
  { label: t("Rent in Hanoi"), href: "/listings/?intent=rent&city=Hanoi" },
  { label: t("Under 5B VND"), href: "/listings/?intent=buy&maxPrice=5" },
  { label: t("Family homes"), href: "/listings/?intent=buy&minBeds=3" },
  { label: t("Live auctions"), href: "/listings/?intent=buy&saleMode=auction" },
  { label: t("Newest listings"), href: "/listings/?sort=newest" },
];
const featuredListings = (await getAllListings(getDB(Astro.locals.runtime))).slice(0, 6);
const browseCities = [
  { name: "Ho Chi Minh City", note: "Condos, villas, and launch inventory", href: "/guides/vietnam/ho-chi-minh-city/" },
  { name: "Hanoi", note: "Family homes, urban rentals, and district-led search", href: "/guides/vietnam/hanoi/" },
  { name: "Da Nang", note: "Coastal relocation demand and second-home supply", href: "/guides/vietnam/da-nang/" },
  { name: "Thu Duc City", note: "Growth corridor, education hubs, and condo supply", href: "/guides/vietnam/ho-chi-minh-city/thu-duc-city/" },
];
const trustSignals = [
  t("Verified owners and agent-facing listing controls"),
  t("Saved searches, favorites, and inquiry tracking in one account system"),
  t("Auction-ready property flow for houses, land, and high-attention inventory"),
  t("Search-first mobile experience designed to behave like a lightweight property app"),
];
const ownerSteps = [
  {
    title: "Post and publish quickly",
    body: "Owners can publish on mobile or desktop, upload photos, and keep availability accurate without waiting for an agency handoff.",
  },
  {
    title: "Capture enquiries cleanly",
    body: "Every applicant lands in a structured workflow so follow-up does not vanish into email threads or phone notes.",
  },
  {
    title: "Monetize with simple upgrades",
    body: "Free trials, paid extensions, and promoted placement already exist in the product and can scale with demand.",
  },
];
const entryPaths = [
  {
    kicker: "For buyers",
    title: "Search, save, and enquire without noise",
    body: "Start with listings, filters, map context, and saved searches if you are here to find a place.",
    primaryHref: "/for-buyers",
    primaryLabel: "Explore buyer flow",
    secondaryHref: "/listings/?intent=buy",
    secondaryLabel: "Browse listings",
  },
  {
    kicker: "For owners",
    title: "Post, manage leads, and renew visibility",
    body: "Use the owner flow if you want to create listings, manage enquiries, upload images, and control promotion.",
    primaryHref: "/for-owners",
    primaryLabel: "Explore owner flow",
    secondaryHref: "/submit-listing/",
    secondaryLabel: "Post a listing",
  },
  {
    kicker: "Pricing",
    title: "Understand how the monetization model works",
    body: "See the 7-day free listing, paid visibility, and promoted placement without digging through the app.",
    primaryHref: "/pricing",
    primaryLabel: "View pricing",
    secondaryHref: "/for-owners",
    secondaryLabel: "Owner plans",
  },
  {
    kicker: "Personal help",
    title: "Need something beyond what is already advertised?",
    body: "Use concierge support when you want human help sourcing, narrowing, positioning, or preparing inventory that the standard workflow does not fully cover.",
    primaryHref: "/concierge",
    primaryLabel: "Request concierge help",
    secondaryHref: "/trust",
    secondaryLabel: "See trust approach",
  },
];
const comparePoints = [
  {
    kicker: "Typical portal model",
    title: "Good at directory depth",
    body: "Large operators often do breadth and categories well, but users still have to manage most of the decision flow themselves.",
  },
  {
    kicker: "Property App model",
    title: "Better at guided decisions",
    body: "We combine cleaner search, market guides, shortlist and compare, owner operations, trust systems, concierge help, and auctions in one connected product.",
  },
];
---

<Layout
  title="Property App 2026"
  description="A modern property marketplace for browsing listings, posting homes, and managing enquiries on mobile and desktop."
  inlineShellCss={true}
>
    <HomeHero quickFilters={quickFilters} trustSignals={trustSignals} t={t} />

  <HomePathSection
    entryPaths={entryPaths}
    sectionKicker={t("Choose your path")}
    sectionTitle={t("This homepage should route users, not make them interpret the product structure themselves.")}
    sectionBody={t("Most users arrive with one clear job. The public site should acknowledge that immediately instead of pushing everyone through the same generic surface.")}
  />

  <HomeCitySection browseCities={browseCities} />

  <HomeFeaturedSection featuredListings={featuredListings} />

  <section class="compare-band card">
    <div class="compare-head">
      <span class="pill">{t("How we compare")}</span>
      <h2>{t("We are not trying to be louder than the old portal model. We are trying to be more useful.")}</h2>
      <p>{t("The strongest competitors already prove the market exists. The product opportunity is to reduce clutter, improve trust, and help buyers and owners move through real workflows instead of directory pages.")}</p>
    </div>
    <div class="compare-grid">
      {comparePoints.map((point) => (
        <article>
          <span class="pill subtle">{point.kicker}</span>
          <strong>{point.title}</strong>
          <p>{point.body}</p>
        </article>
      ))}
    </div>
  </section>

  <HomeOwnerSection ownerSteps={ownerSteps} />

  <HomeProductBand />
</Layout>

<style is:inline>
  .compare-band {
    padding: 1.4rem;
    margin-top: 1rem;
    display: grid;
    gap: 1rem;
  }

  .compare-head {
    display: grid;
    gap: 0.7rem;
  }

  .compare-head h2 {
    margin: 0;
    font-size: clamp(2rem, 4vw, 3.2rem);
    line-height: 0.96;
    letter-spacing: -0.08em;
    max-width: 14ch;
  }

  .compare-head p,
  .compare-grid p {
    margin: 0;
    color: var(--muted);
    line-height: 1.7;
  }

  .compare-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .compare-grid article {
    display: grid;
    gap: 0.55rem;
    padding: 1rem;
    border-radius: 20px;
    background: linear-gradient(180deg, var(--surface-elevated-strong), var(--surface-panel-muted));
    border: 1px solid var(--line);
  }

  .compare-grid strong {
    font-size: 1rem;
    letter-spacing: -0.03em;
  }

  .pill.subtle {
    background: var(--surface-overlay);
  }

  @media (max-width: 860px) {
    .compare-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
