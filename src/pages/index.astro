---
import Layout from "../layouts/Layout.astro";
import HomeHero from "../components/home/HomeHero.astro";
import HomePathSection from "../components/home/HomePathSection.astro";
import HomeCitySection from "../components/home/HomeCitySection.astro";
import HomeFeaturedSection from "../components/home/HomeFeaturedSection.astro";
import HomeOwnerSection from "../components/home/HomeOwnerSection.astro";
import HomeProductBand from "../components/home/HomeProductBand.astro";
import { getAllListings } from "../lib/listings";
import { getDB } from "../lib/runtime";

const quickFilters = [
  { label: "Buy in HCMC", href: "/listings/?intent=buy&city=Ho%20Chi%20Minh%20City" },
  { label: "Rent in Hanoi", href: "/listings/?intent=rent&city=Hanoi" },
  { label: "Under 5B VND", href: "/listings/?intent=buy&maxPrice=5" },
  { label: "Family homes", href: "/listings/?intent=buy&minBeds=3" },
  { label: "Newest listings", href: "/listings/?sort=newest" },
];
const featuredListings = (await getAllListings(getDB(Astro.locals.runtime))).slice(0, 6);
const browseCities = [
  { name: "Ho Chi Minh City", note: "Condos, villas, and launch inventory", href: "/listings/?intent=buy&city=Ho%20Chi%20Minh%20City" },
  { name: "Hanoi", note: "Family homes, urban rentals, and district-led search", href: "/listings/?intent=buy&city=Hanoi" },
  { name: "Da Nang", note: "Coastal relocation demand and second-home supply", href: "/listings/?intent=buy&city=Da%20Nang" },
  { name: "Thu Duc City", note: "Growth corridor, education hubs, and condo supply", href: "/listings/?intent=buy&district=Thu%20Duc%20City" },
];
const trustSignals = [
  "Verified owners and agent-facing listing controls",
  "Saved searches, favorites, and inquiry tracking in one account system",
  "Search-first mobile experience designed to behave like a lightweight property app",
];
const ownerSteps = [
  {
    title: "Post and publish quickly",
    body: "Owners can publish on mobile or desktop, upload photos, and keep availability accurate without waiting for an agency handoff.",
  },
  {
    title: "Capture enquiries cleanly",
    body: "Every applicant lands in a structured workflow so follow-up does not vanish into email threads or phone notes.",
  },
  {
    title: "Monetize with simple upgrades",
    body: "Free trials, paid extensions, and promoted placement already exist in the product and can scale with demand.",
  },
];
const entryPaths = [
  {
    kicker: "For buyers",
    title: "Search, save, and enquire without noise",
    body: "Start with listings, filters, map context, and saved searches if you are here to find a place.",
    primaryHref: "/for-buyers",
    primaryLabel: "Explore buyer flow",
    secondaryHref: "/listings/?intent=buy",
    secondaryLabel: "Browse listings",
  },
  {
    kicker: "For owners",
    title: "Post, manage leads, and renew visibility",
    body: "Use the owner flow if you want to create listings, manage enquiries, upload images, and control promotion.",
    primaryHref: "/for-owners",
    primaryLabel: "Explore owner flow",
    secondaryHref: "/submit-listing/",
    secondaryLabel: "Post a listing",
  },
  {
    kicker: "Pricing",
    title: "Understand how the monetization model works",
    body: "See the 7-day free listing, paid visibility, and promoted placement without digging through the app.",
    primaryHref: "/pricing",
    primaryLabel: "View pricing",
    secondaryHref: "/for-owners",
    secondaryLabel: "Owner plans",
  },
];
---

<Layout
  title="Property App 2026"
  description="A modern property marketplace for browsing listings, posting homes, and managing enquiries on mobile and desktop."
>
    <HomeHero quickFilters={quickFilters} trustSignals={trustSignals} />

  <HomePathSection entryPaths={entryPaths} />

  <HomeCitySection browseCities={browseCities} />

  <HomeFeaturedSection featuredListings={featuredListings} />

  <HomeOwnerSection ownerSteps={ownerSteps} />

  <HomeProductBand />
</Layout>
