---
import Layout from "../layouts/Layout.astro";
import ListingCard from "../components/ListingCard.astro";
import { getAllListings, getDB } from "../lib/marketplace";

const quickFilters = [
  { label: "Buy in HCMC", href: "/listings/?intent=buy&city=Ho%20Chi%20Minh%20City" },
  { label: "Rent in Hanoi", href: "/listings/?intent=rent&city=Hanoi" },
  { label: "Under 5B VND", href: "/listings/?intent=buy&maxPrice=5" },
  { label: "Family homes", href: "/listings/?intent=buy&minBeds=3" },
  { label: "Newest listings", href: "/listings/?sort=newest" },
];
const featuredListings = (await getAllListings(getDB(Astro.locals.runtime))).slice(0, 6);
const browseCities = [
  { name: "Ho Chi Minh City", note: "Condos, villas, and launch inventory", href: "/listings/?intent=buy&city=Ho%20Chi%20Minh%20City" },
  { name: "Hanoi", note: "Family homes, urban rentals, and district-led search", href: "/listings/?intent=buy&city=Hanoi" },
  { name: "Da Nang", note: "Coastal relocation demand and second-home supply", href: "/listings/?intent=buy&city=Da%20Nang" },
  { name: "Thu Duc City", note: "Growth corridor, education hubs, and condo supply", href: "/listings/?intent=buy&district=Thu%20Duc%20City" },
];
const trustSignals = [
  "Verified owners and agent-facing listing controls",
  "Saved searches, favorites, and inquiry tracking in one account system",
  "Search-first mobile experience designed to behave like a lightweight property app",
];
const ownerSteps = [
  {
    title: "Post and publish quickly",
    body: "Owners can publish on mobile or desktop, upload photos, and keep availability accurate without waiting for an agency handoff.",
  },
  {
    title: "Capture enquiries cleanly",
    body: "Every applicant lands in a structured workflow so follow-up does not vanish into email threads or phone notes.",
  },
  {
    title: "Monetize with simple upgrades",
    body: "Free trials, paid extensions, and promoted placement already exist in the product and can scale with demand.",
  },
];
---

<Layout
  title="Property App 2026"
  description="A modern property marketplace for browsing listings, posting homes, and managing enquiries on mobile and desktop."
>
  <section class="hero-shell card" id="top">
    <div class="hero-main">
      <div class="hero-copy">
        <span class="eyebrow-badge">Search-first property marketplace</span>
        <h1>Find the right place faster, then follow through with confidence.</h1>
        <p class="hero-text">
          The product should feel closer to Rightmove in structure: one dominant search action, clear buy-versus-rent
          intent, and stronger account workflows once a user decides to save, enquire, or post.
        </p>

        <div class="hero-points">
          {trustSignals.map((signal) => (
            <div class="point-row">
              <span class="point-mark"></span>
              <span>{signal}</span>
            </div>
          ))}
        </div>

        <div class="hero-actions">
          <a class="button-primary" href="/listings/?intent=buy">Search homes</a>
          <a class="button-secondary" href="/signup?role=owner">Post your listing</a>
        </div>
      </div>

      <form class="search-card" method="GET" action="/listings/">
        <div class="search-top">
          <label class="intent-chip active">
            <input type="radio" name="intent" value="buy" checked />
            <span>Buy</span>
          </label>
          <label class="intent-chip">
            <input type="radio" name="intent" value="rent" />
            <span>Rent</span>
          </label>
        </div>

        <div class="search-card-body">
          <label class="field field-wide">
            <span>Location</span>
            <input type="text" name="city" value="Ho Chi Minh City" placeholder="City or district" />
          </label>
          <div class="field-grid">
            <label class="field">
              <span>Property type</span>
              <select name="propertyType">
                <option value="">Any property</option>
                <option value="Condo">Condo</option>
                <option value="Villa">Villa</option>
                <option value="Townhouse">Townhouse</option>
                <option value="Apartment">Apartment</option>
                <option value="House">House</option>
                <option value="Land">Land</option>
              </select>
            </label>
            <label class="field">
              <span>Budget ceiling</span>
              <select name="maxPrice">
                <option value="">Any budget</option>
                <option value="5">Up to 5B VND</option>
                <option value="10">Up to 10B VND</option>
                <option value="20">Up to 20B VND</option>
              </select>
            </label>
          </div>
          <div class="field-grid field-grid-tight">
            <label class="field">
              <span>Beds</span>
              <select name="minBeds">
                <option value="">Any beds</option>
                <option value="1">1+</option>
                <option value="2">2+</option>
                <option value="3">3+</option>
                <option value="4">4+</option>
              </select>
            </label>
            <button class="button-dark" type="submit">Search live inventory</button>
          </div>
        </div>

        <div class="quick-filter-row">
          {quickFilters.map((filter) => <a href={filter.href}>{filter.label}</a>)}
        </div>
      </form>
    </div>

    <div class="hero-metrics">
      <article>
        <strong>Live search</strong>
        <span>Query-driven inventory across buy and rent intent</span>
      </article>
      <article>
        <strong>Owner workflow</strong>
        <span>Listings, photos, enquiries, billing, and renewals in one system</span>
      </article>
      <article>
        <strong>PWA-ready</strong>
        <span>Mobile-first shell that can install and behave like a lightweight app</span>
      </article>
    </div>
  </section>

  <section class="city-section">
    <div class="section-heading">
      <span class="section-kicker">Browse by city</span>
      <h2>Start with location. Narrow by price, type, and confidence signals after.</h2>
      <p>
        That sequencing matters in Southeast Asia. City and district familiarity usually comes before fine-grained
        filtering, especially on mobile.
      </p>
    </div>

    <div class="city-grid">
      {browseCities.map((city) => (
        <a class="city-card card" href={city.href}>
          <strong>{city.name}</strong>
          <span>{city.note}</span>
        </a>
      ))}
    </div>
  </section>

  <section class="feature-section">
    <div class="section-heading">
      <span class="section-kicker">Featured listings</span>
      <h2>Search results should feel curated and trustworthy, not like a noisy directory.</h2>
      <p>
        Clear pricing, compact facts, and visible trust signals matter more than decorative clutter. The public browse
        layer needs to feel efficient before it feels clever.
      </p>
    </div>

    <div class="listing-grid">
      {featuredListings.map((listing) => <ListingCard listing={listing} />)}
    </div>

    <div class="section-actions">
      <a class="button-secondary" href="/listings/?intent=buy">Browse all listings</a>
    </div>
  </section>

  <section class="owners-section">
    <div class="section-heading narrow">
      <span class="section-kicker">Owner workflow</span>
      <h2>Owners need more than a form. They need a working pipeline.</h2>
      <p>
        The product edge is not just discovery. It is the handoff from listing creation to applicant tracking, billing,
        and renewal without operational chaos.
      </p>
    </div>

    <div class="owner-grid">
      {ownerSteps.map((step, index) => (
        <article class="owner-card card">
          <span class="step-index">0{index + 1}</span>
          <h3>{step.title}</h3>
          <p>{step.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="product-band card">
    <div class="band-copy">
      <span class="section-kicker">Mobile app path</span>
      <h2>Start as a serious web marketplace. Let native come later.</h2>
      <p>
        PWA support is already the right base. It gives you installability and repeat-use behavior now, while the core
        marketplace mechanics get proven first.
      </p>
    </div>
    <div class="band-panel">
      <div class="panel-window">
        <p class="panel-label">Saved search</p>
        <strong>2-bed condo under 9B VND</strong>
        <span>Thu Duc · District 7 · Binh Thanh</span>
      </div>
      <div class="panel-window muted">
        <p class="panel-label">Owner inbox</p>
        <strong>3 new enquiries</strong>
        <span>2 require follow-up today</span>
      </div>
    </div>
  </section>

  <style>
    .hero-shell {
      padding: 1.1rem;
      display: grid;
      gap: 1rem;
      background: linear-gradient(180deg, rgba(255,255,255,0.94), rgba(255,255,255,0.82));
    }

    .hero-main {
      display: grid;
      grid-template-columns: minmax(0, 1.1fr) minmax(22rem, 0.9fr);
      gap: 1rem;
      align-items: stretch;
    }

    .hero-copy,
    .search-card,
    .product-band,
    .city-card,
    .owner-card {
      box-shadow: 0 1px 2px rgba(16, 24, 40, 0.04), 0 16px 36px rgba(16, 24, 40, 0.06);
    }

    .hero-copy {
      padding: 2rem;
      border-radius: 24px;
      background: linear-gradient(180deg, rgba(255,255,255,0.74), rgba(255,255,255,0.56));
    }

    .eyebrow-badge,
    .section-kicker {
      display: inline-flex;
      align-items: center;
      min-height: 2rem;
      padding: 0.22rem 0.75rem;
      border-radius: 999px;
      background: var(--brand-soft);
      color: var(--accent-strong);
      font-size: 0.78rem;
      font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .hero-copy h1,
    .section-heading h2,
    .band-copy h2 {
      margin: 0.9rem 0 0;
      font-size: clamp(2.5rem, 5vw, 4.9rem);
      line-height: 0.94;
      letter-spacing: -0.06em;
      font-family: "Plus Jakarta Sans", sans-serif;
    }

    .section-heading h2,
    .band-copy h2 {
      font-size: clamp(2rem, 4vw, 3.2rem);
      line-height: 1;
    }

    .hero-text,
    .section-heading p,
    .owner-card p,
    .band-copy p,
    .city-card span,
    .hero-metrics span,
    .panel-window span {
      color: var(--muted);
      line-height: 1.7;
      margin: 0;
    }

    .hero-points {
      display: grid;
      gap: 0.75rem;
      margin-top: 1.4rem;
    }

    .point-row {
      display: flex;
      gap: 0.75rem;
      align-items: flex-start;
    }

    .point-mark {
      width: 0.7rem;
      height: 0.7rem;
      margin-top: 0.45rem;
      border-radius: 999px;
      background: linear-gradient(135deg, var(--brand), #23314d);
      flex: none;
    }

    .hero-actions,
    .quick-filter-row,
    .section-actions {
      display: flex;
      gap: 0.75rem;
      flex-wrap: wrap;
    }

    .hero-actions {
      margin-top: 1.5rem;
    }

    .button-primary,
    .button-secondary,
    .button-dark,
    .quick-filter-row a {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 2.9rem;
      border-radius: 999px;
      padding: 0.88rem 1.1rem;
      font-weight: 700;
      text-decoration: none;
      font: inherit;
      cursor: pointer;
    }

    .button-primary {
      border: none;
      background: linear-gradient(135deg, var(--brand), #23314d);
      color: white;
      box-shadow: 0 14px 30px rgba(18, 183, 106, 0.2);
    }

    .button-secondary,
    .quick-filter-row a {
      border: 1px solid var(--line);
      background: rgba(255, 255, 255, 0.9);
      color: var(--text);
    }

    .button-dark {
      width: 100%;
      border: none;
      background: var(--brand);
      color: white;
      box-shadow: 0 12px 24px rgba(16, 24, 40, 0.16);
    }

    .search-card {
      padding: 1.1rem;
      border-radius: 24px;
      background: linear-gradient(180deg, #ffffff, #f8fafc);
      border: 1px solid var(--line);
    }

    .search-top,
    .field-grid,
    .hero-metrics,
    .city-grid,
    .listing-grid,
    .owner-grid,
    .band-panel {
      display: grid;
      gap: 1rem;
    }

    .search-top {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      margin-bottom: 1rem;
    }

    .intent-chip {
      position: relative;
      cursor: pointer;
    }

    .intent-chip input {
      position: absolute;
      opacity: 0;
      pointer-events: none;
    }

    .intent-chip span {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 2.8rem;
      border-radius: 999px;
      border: 1px solid var(--line);
      background: #f8fafc;
      font-weight: 700;
    }

    .intent-chip.active span,
    .intent-chip:has(input:checked) span {
      background: var(--brand);
      border-color: var(--brand);
      color: white;
    }

    .search-card-body {
      display: grid;
      gap: 0.9rem;
    }

    .field {
      display: grid;
      gap: 0.45rem;
      color: var(--text);
      font-size: 0.9rem;
      font-weight: 700;
    }

    .field-wide {
      grid-column: 1 / -1;
    }

    .field input,
    .field select {
      width: 100%;
      min-height: 3.2rem;
      border-radius: 16px;
      border: 1px solid var(--line);
      background: white;
      padding: 0.95rem 1rem;
      color: var(--text);
      font: inherit;
    }

    .field-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .field-grid-tight {
      align-items: end;
    }

    .quick-filter-row {
      margin-top: 1rem;
    }

    .quick-filter-row a {
      min-height: 2.4rem;
      padding: 0.62rem 0.9rem;
      font-size: 0.84rem;
    }

    .hero-metrics {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .hero-metrics article,
    .product-band {
      padding: 1.15rem;
      border-radius: 22px;
      border: 1px solid var(--line);
      background: rgba(255, 255, 255, 0.78);
    }

    .hero-metrics strong,
    .city-card strong,
    .owner-card h3,
    .panel-window strong {
      display: block;
      margin-bottom: 0.35rem;
    }

    .city-section,
    .feature-section,
    .owners-section,
    .product-band {
      margin-top: 1.15rem;
    }

    .section-heading {
      max-width: 52rem;
      margin-bottom: 1rem;
    }

    .section-heading.narrow {
      max-width: 46rem;
    }

    .city-grid,
    .listing-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .owner-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .city-card,
    .owner-card {
      padding: 1.25rem;
      border: 1px solid var(--line);
      text-decoration: none;
      color: inherit;
      background: rgba(255, 255, 255, 0.88);
    }

    .step-index,
    .panel-label {
      display: inline-flex;
      color: var(--accent-strong);
      font-size: 0.78rem;
      font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .owner-card h3 {
      margin: 0.6rem 0 0.5rem;
      font-size: 1.22rem;
      letter-spacing: -0.02em;
    }

    .product-band {
      display: grid;
      grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
      gap: 1rem;
      background: linear-gradient(180deg, rgba(16, 24, 40, 0.96), rgba(30, 41, 59, 0.94));
      color: white;
    }

    .band-copy h2,
    .band-copy p,
    .band-copy .section-kicker,
    .panel-window,
    .panel-window span {
      color: rgba(248, 250, 252, 0.92);
    }

    .band-panel {
      grid-template-columns: 1fr;
      align-content: center;
    }

    .panel-window {
      padding: 1rem;
      border-radius: 20px;
      background: rgba(255, 255, 255, 0.08);
      border: 1px solid rgba(255, 255, 255, 0.08);
    }

    .panel-window.muted {
      background: rgba(255, 255, 255, 0.04);
    }

    @media (max-width: 1100px) {
      .hero-main,
      .product-band,
      .city-grid,
      .listing-grid,
      .owner-grid,
      .hero-metrics {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 760px) {
      .hero-shell {
        padding: 0.8rem;
      }

      .hero-copy,
      .search-card,
      .city-card,
      .owner-card,
      .product-band {
        padding: 1rem;
      }

      .field-grid,
      .search-top {
        grid-template-columns: 1fr;
      }

      .button-primary,
      .button-secondary,
      .button-dark {
        width: 100%;
      }

      .hero-actions,
      .quick-filter-row,
      .section-actions {
        display: grid;
      }
    }
  </style>
</Layout>
