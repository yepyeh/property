---
import Layout from "../layouts/Layout.astro";
import ListingCard from "../components/ListingCard.astro";
import { getAllListings, getDB } from "../lib/marketplace";

const quickFilters = [
  { label: "Buy", href: "/listings/?intent=buy" },
  { label: "Rent", href: "/listings/?intent=rent" },
  { label: "Ho Chi Minh City", href: "/listings/?intent=buy&city=Ho%20Chi%20Minh%20City" },
  { label: "Under 5B VND", href: "/listings/?intent=buy&maxPrice=5" },
  { label: "3+ bedrooms", href: "/listings/?intent=buy&minBeds=3" },
  { label: "New listings", href: "/listings/?sort=newest" },
];
const featuredListings = (await getAllListings(getDB(Astro.locals.runtime))).slice(0, 3);
const topNav = ["Buy", "Rent", "New Projects", "Find Agent", "Guides"];
const utilityLinks = ["Saved searches", "Saved homes", "Enquiry tracking", "Owner dashboard"];
const browseCities = [
  { name: "Ho Chi Minh City", note: "Apartments, villas, and launch inventory", href: "/listings/?intent=buy&city=Ho%20Chi%20Minh%20City" },
  { name: "Hanoi", note: "Family homes, West Lake, and long-term rentals", href: "/listings/?intent=buy&city=Hanoi" },
  { name: "Da Nang", note: "Coastal living, townhouses, and relocation demand", href: "/listings/?intent=buy&city=Da%20Nang" },
];

const workflows = [
  {
    title: "Post your own listing",
    body: "Owners publish from mobile or desktop, add photos, set pricing, and mark availability without waiting for an agency handoff.",
  },
  {
    title: "Track enquiries",
    body: "Applicants flow into one inbox with contact details, intent, and status so owners can reply fast and avoid losing deals.",
  },
  {
    title: "Install like an app",
    body: "The product is designed as a PWA, so visitors can save it to their home screen and return to a fast app-style experience.",
  },
];

const platformFeatures = [
  "Smart search by location, budget, property type, and move-in intent",
  "Seller dashboard for drafts, live listings, messages, and applicant status",
  "Trust signals such as verified owners, lead response times, and saved searches",
  "Responsive experience tuned for mobile-first browsing and PWA installation",
];
---

<Layout
  title="Property App 2026"
  description="A modern property marketplace for browsing listings, posting homes, and managing enquiries on mobile and desktop."
>
  <header class="topbar">
    <a class="brand" href="#top">
      <span class="brand-mark">P</span>
      <span>
        <strong>Property App</strong>
        <small>Vietnam property marketplace</small>
      </span>
    </a>
    <nav class="nav">
      {topNav.map((item) => (
        <a href={item === "Buy" ? "/listings/?intent=buy" : item === "Rent" ? "/listings/?intent=rent" : "#owners"}>{item}</a>
      ))}
    </nav>
    <div class="header-actions">
      <a class="account-link" href="/owner/dashboard/">My Property App</a>
      <a class="cta" href="/listings/?intent=buy">Browse listings</a>
    </div>
  </header>

  <section class="hero card" id="top">
    <div class="hero-copy">
      <span class="pill">Search first, then organise</span>
      <h1>Find the right home fast. Save, compare, and enquire without chaos.</h1>
      <p class="intro">
        The product direction now follows the Rightmove pattern more closely: clear user intent, dominant search,
        and account-level organisation. For Southeast Asia, that structure is paired with mobile-first enquiry flow
        and stronger owner response signals.
      </p>

      <div class="hero-actions">
        <a class="primary" href="/listings/?intent=buy">Search properties</a>
        <a class="secondary" href="/submit-listing/">Post your listing</a>
      </div>

      <div class="utility-strip">
        {utilityLinks.map((item) => <span>{item}</span>)}
      </div>

      <div class="stats">
        <div>
          <strong>2 min</strong>
          <span>target owner response window</span>
        </div>
        <div>
          <strong>1 tap</strong>
          <span>PWA install from mobile</span>
        </div>
        <div>
          <strong>3 loops</strong>
          <span>search, save, and send enquiries</span>
        </div>
      </div>
    </div>

    <form class="search-panel" method="GET" action="/listings/">
      <div class="search-top">
        <label class="mode active">
          <input type="radio" name="intent" value="buy" checked />
          <span>Buy</span>
        </label>
        <label class="mode">
          <input type="radio" name="intent" value="rent" />
          <span>Rent</span>
        </label>
      </div>

      <div class="search-box">
        <label>
          Search city
          <input type="text" name="city" value="Ho Chi Minh City" />
        </label>
        <div class="search-grid">
          <label>
            Property type
            <select name="propertyType">
              <option value="">Any property</option>
              <option value="Condo">Condo</option>
              <option value="Villa">Villa</option>
              <option value="Townhouse">Townhouse</option>
              <option value="Apartment">Apartment</option>
              <option value="House">House</option>
              <option value="Land">Land</option>
            </select>
          </label>
          <label>
            Maximum price
            <select name="maxPrice">
              <option value="">Any budget</option>
              <option value="5">Up to 5B VND</option>
              <option value="10">Up to 10B VND</option>
              <option value="20">Up to 20B VND</option>
            </select>
          </label>
        </div>
        <div class="search-grid compact">
          <label>
            Beds
            <select name="minBeds">
              <option value="">Any beds</option>
              <option value="1">1+</option>
              <option value="2">2+</option>
              <option value="3">3+</option>
              <option value="4">4+</option>
            </select>
          </label>
          <div class="search-actions">
            <button class="search-button" type="submit">Search live inventory</button>
            <a class="secondary clear-link" href="/listings/">Clear</a>
          </div>
        </div>
      </div>

      <div class="chip-row">
        {quickFilters.map((filter) => <a href={filter.href}>{filter.label}</a>)}
      </div>
    </form>
  </section>

  <section class="city-browser card">
    <div class="section-head compact">
      <span class="pill">Browse by city</span>
      <h2 class="section-title">Start with place. Then narrow by property, budget, and trust.</h2>
      <p class="section-copy">
        That is the Rightmove lesson worth keeping. In this market, city and district familiarity matter before
        deep filtering, especially on mobile.
      </p>
    </div>
    <div class="city-grid">
      {browseCities.map((city) => (
        <a class="city-card" href={city.href}>
          <strong>{city.name}</strong>
          <span>{city.note}</span>
        </a>
      ))}
    </div>
  </section>

  <section class="overview" id="listings">
    <div class="section-head">
      <span class="pill">Featured listings</span>
      <h2 class="section-title">A cleaner result set than directory-style property portals.</h2>
      <p class="section-copy">
        Search results should feel trustworthy and scannable. Better cards, clearer status, and stronger enquiry
        intent matter more than piling every possible link onto the first screen.
      </p>
    </div>

    <div class="listing-grid">
      {featuredListings.map((listing) => <ListingCard listing={listing} />)}
    </div>
    <div class="browse-row">
      <a class="secondary" href="/listings/?intent=buy">Browse all listings</a>
    </div>
  </section>

  <section class="owners" id="owners">
    <div class="section-head narrow">
      <span class="pill">Seller experience</span>
      <h2 class="section-title">Owners need more than a form. They need a workflow.</h2>
      <p class="section-copy">
        Listing creation, applicant intake, and follow-up should live in one system. That is the core product
        advantage over directory-style portals.
      </p>
    </div>

    <div class="workflow-grid">
      {workflows.map((item, index) => (
        <article class="workflow card">
          <span class="step">0{index + 1}</span>
          <h3>{item.title}</h3>
          <p>{item.body}</p>
        </article>
      ))}
    </div>

    <div class="split-grid">
      <article class="dashboard card">
        <div class="window-bar">
          <span></span><span></span><span></span>
        </div>
        <div class="dashboard-body">
          <div class="dashboard-column">
            <p class="label">Owner dashboard</p>
            <h3>One view for active listings and open enquiries.</h3>
            <ul>
              <li>Draft and publish listings</li>
              <li>View applicant messages and status</li>
              <li>Pause, renew, or promote listings</li>
            </ul>
          </div>
          <div class="pipeline">
            <div class="pipeline-card">
              <strong>New enquiry</strong>
              <span>Pham Linh · Wants a Saturday viewing</span>
            </div>
            <div class="pipeline-card">
              <strong>Qualified lead</strong>
              <span>Nguyen An · Budget approved</span>
            </div>
            <div class="pipeline-card">
              <strong>Follow-up due</strong>
              <span>Tran Minh · Awaiting floor plan</span>
            </div>
          </div>
        </div>
      </article>

      <article class="notes card">
        <span class="pill">Product direction</span>
        <ul>
          {platformFeatures.map((feature) => <li>{feature}</li>)}
        </ul>
      </article>
    </div>
  </section>

  <section class="app" id="app">
    <article class="app-shell card">
      <div class="section-head compact">
        <span class="pill">Mobile app path</span>
        <h2 class="section-title">Start as a PWA. Earn the right to become a native app later.</h2>
        <p class="section-copy">
          That is the pragmatic route. You get installability, offline shell caching, and home-screen presence
          now, without splitting effort across iOS, Android, and web before the marketplace mechanics are proven.
        </p>
      </div>

      <div class="phone-grid">
        <div class="phone-frame">
          <div class="phone-screen">
            <p class="mini-label">Saved search</p>
            <strong>Modern 2BR under 9B VND</strong>
            <span>Thu Duc · District 2 · District 7</span>
            <div class="mini-feed">
              <div>
                <b>12</b>
                <span>new matches</span>
              </div>
              <div>
                <b>4</b>
                <span>owner replies</span>
              </div>
            </div>
          </div>
        </div>

        <div class="install-card">
          <h3>PWA checklist now in place</h3>
          <ul>
            <li>Install prompt metadata and manifest</li>
            <li>Service worker registration for offline shell caching</li>
            <li>Mobile-first layout and touch-friendly controls</li>
          </ul>
          <p>
            Next product step is not app-store packaging. It is saved searches, enquiry persistence, and owner inbox quality.
          </p>
        </div>
      </div>
    </article>
  </section>

  <section class="footer-bar">
    <div>
      <p class="footer-title">What this version proves</p>
      <p>Search-first information architecture with a stronger marketplace shape for Southeast Asia.</p>
    </div>
    <a href="https://www.rightmove.co.uk/" target="_blank" rel="noreferrer">Rightmove reference</a>
  </section>

  <style>
    .topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      margin-bottom: 1rem;
      padding: 0.7rem 0.4rem;
    }

    .brand {
      display: inline-flex;
      align-items: center;
      gap: 0.85rem;
      text-decoration: none;
    }

    .brand-mark {
      display: grid;
      place-items: center;
      width: 2.75rem;
      height: 2.75rem;
      border-radius: 18px;
      background: linear-gradient(135deg, var(--accent), var(--bg-deep));
      color: white;
      font-family: "Fraunces", serif;
      font-size: 1.25rem;
    }

    .brand strong,
    .brand small {
      display: block;
    }

    .brand small {
      color: var(--muted);
      font-size: 0.78rem;
    }

    .nav {
      display: flex;
      gap: 1.2rem;
      color: var(--muted);
    }

    .nav a,
    .account-link,
    .cta,
    .primary,
    .secondary,
    .footer-bar a,
    .city-card {
      text-decoration: none;
      transition: transform 160ms ease, opacity 160ms ease, background 160ms ease;
    }

    .header-actions {
      display: flex;
      align-items: center;
      gap: 0.8rem;
    }

    .account-link {
      color: var(--muted);
      font-weight: 600;
    }

    .cta,
    .primary,
    .search-button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0.95rem 1.2rem;
      border-radius: 999px;
      border: none;
      background: linear-gradient(135deg, var(--accent), var(--accent-strong));
      color: white;
      font-weight: 700;
      cursor: pointer;
      box-shadow: 0 14px 30px rgba(15, 118, 110, 0.2);
      text-decoration: none;
    }

    .hero {
      display: grid;
      grid-template-columns: 1.1fr 0.9fr;
      gap: 1.2rem;
      padding: 1.1rem;
      overflow: hidden;
      position: relative;
    }

    .hero::after {
      content: "";
      position: absolute;
      inset: auto -6rem -8rem auto;
      width: 18rem;
      height: 18rem;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(232, 157, 91, 0.32), transparent 70%);
      pointer-events: none;
    }

    .hero-copy,
    .search-panel {
      position: relative;
      z-index: 1;
      border-radius: 24px;
    }

    .hero-copy {
      padding: 2.4rem;
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.72), rgba(255, 255, 255, 0.52));
    }

    .hero-copy h1 {
      margin: 1rem 0 0;
      max-width: 11ch;
      font-family: "Fraunces", serif;
      font-size: clamp(3.1rem, 7vw, 6.2rem);
      line-height: 0.9;
      letter-spacing: -0.04em;
    }

    .intro {
      max-width: 48rem;
      margin: 1.25rem 0 0;
      color: var(--muted);
      font-size: 1.08rem;
      line-height: 1.75;
    }

    .hero-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.9rem;
      margin-top: 1.8rem;
    }

    .utility-strip {
      display: flex;
      flex-wrap: wrap;
      gap: 0.6rem;
      margin-top: 1rem;
    }

    .utility-strip span {
      padding: 0.65rem 0.85rem;
      border-radius: 999px;
      background: rgba(14, 22, 40, 0.05);
      color: var(--muted);
      font-size: 0.9rem;
      font-weight: 600;
    }

    .secondary {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0.95rem 1.2rem;
      border-radius: 999px;
      border: 1px solid var(--line);
      background: rgba(255, 255, 255, 0.72);
      color: var(--text);
      font-weight: 700;
    }

    .stats {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 0.9rem;
      margin-top: 2rem;
    }

    .stats div {
      padding: 1rem;
      border-radius: 22px;
      background: rgba(14, 22, 40, 0.06);
      border: 1px solid rgba(14, 22, 40, 0.06);
    }

    .stats strong {
      display: block;
      font-size: 1.3rem;
      font-weight: 800;
    }

    .stats span {
      display: block;
      margin-top: 0.35rem;
      color: var(--muted);
      font-size: 0.92rem;
      line-height: 1.5;
    }

    .search-panel {
      align-self: end;
      padding: 1.4rem;
      background: linear-gradient(180deg, rgba(14, 22, 40, 0.96), rgba(14, 22, 40, 0.88));
      color: #f8fafc;
    }

    .search-top {
      display: flex;
      gap: 0.55rem;
      flex-wrap: wrap;
      margin-bottom: 1rem;
    }

    .mode {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 999px;
      cursor: pointer;
    }

    .mode input {
      position: absolute;
      opacity: 0;
      pointer-events: none;
    }

    .mode span {
      padding: 0.65rem 0.95rem;
      border-radius: 999px;
      border: 1px solid rgba(255, 255, 255, 0.1);
      background: rgba(255, 255, 255, 0.04);
      color: inherit;
    }

    .mode.active span,
    .mode:has(input:checked) span {
      background: white;
      color: var(--bg-deep);
      border-color: white;
    }

    .search-box {
      padding: 1rem;
      border-radius: 24px;
      background: rgba(255, 255, 255, 0.06);
      border: 1px solid rgba(255, 255, 255, 0.08);
    }

    .search-box label {
      display: block;
      margin-bottom: 0.9rem;
      color: rgba(248, 250, 252, 0.72);
      font-size: 0.88rem;
      font-weight: 600;
    }

    .search-box input,
    .search-box select {
      width: 100%;
      margin-top: 0.45rem;
      padding: 0.9rem 1rem;
      border-radius: 16px;
      border: 1px solid rgba(255, 255, 255, 0.1);
      background: rgba(255, 255, 255, 0.1);
      color: white;
      font: inherit;
    }

    .search-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.8rem;
    }

    .search-grid.compact {
      margin-top: 0.8rem;
      align-items: end;
    }

    .search-actions {
      display: grid;
      gap: 0.7rem;
    }

    .search-button {
      width: 100%;
      margin-top: 0.3rem;
    }

    .clear-link {
      width: 100%;
      background: rgba(255, 255, 255, 0.08);
      border-color: rgba(255, 255, 255, 0.14);
      color: white;
      text-align: center;
    }

    .chip-row {
      display: flex;
      flex-wrap: wrap;
      gap: 0.55rem;
      margin-top: 0.95rem;
    }

    .chip-row a {
      text-decoration: none;
      padding: 0.55rem 0.8rem;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.08);
      color: rgba(248, 250, 252, 0.82);
      font-size: 0.84rem;
    }

    .city-browser,
    .overview,
    .owners,
    .app {
      margin-top: 1.1rem;
    }

    .section-head {
      padding: 1.2rem 0.4rem 1rem;
      max-width: 48rem;
    }

    .section-head.narrow,
    .section-head.compact {
      max-width: 42rem;
    }

    .city-browser {
      padding: 1.2rem;
    }

    .city-grid,
    .listing-grid,
    .workflow-grid,
    .split-grid,
    .phone-grid {
      display: grid;
      gap: 1rem;
    }

    .city-grid,
    .listing-grid,
    .workflow-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .city-card {
      display: grid;
      gap: 0.5rem;
      padding: 1.2rem;
      border-radius: 24px;
      background: rgba(255, 255, 255, 0.75);
      border: 1px solid var(--line);
    }

    .city-card strong {
      font-size: 1.1rem;
    }

    .city-card span {
      color: var(--muted);
      line-height: 1.6;
    }

    .workflow,
    .notes,
    .dashboard,
    .app-shell {
      padding: 1.4rem;
    }

    .workflow h3,
    .dashboard h3,
    .install-card h3 {
      margin: 0.3rem 0 0.55rem;
      font-size: 1.25rem;
      line-height: 1.2;
    }

    .workflow p,
    .notes li,
    .install-card p,
    .install-card li,
    .dashboard li {
      color: var(--muted);
      line-height: 1.65;
    }

    .step,
    .label,
    .mini-label,
    .footer-title {
      display: inline-block;
      color: var(--accent-strong);
      font-size: 0.82rem;
      font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .split-grid {
      grid-template-columns: 1.3fr 0.7fr;
      margin-top: 1rem;
    }

    .window-bar {
      display: flex;
      gap: 0.4rem;
    }

    .window-bar span {
      width: 0.75rem;
      height: 0.75rem;
      border-radius: 50%;
      background: rgba(17, 24, 39, 0.16);
    }

    .dashboard-body {
      display: grid;
      grid-template-columns: 1fr 0.78fr;
      gap: 1rem;
      margin-top: 1.1rem;
    }

    .dashboard ul,
    .notes ul,
    .install-card ul {
      margin: 0.8rem 0 0;
      padding-left: 1.1rem;
    }

    .pipeline {
      display: grid;
      gap: 0.8rem;
    }

    .pipeline-card {
      padding: 1rem;
      border-radius: 18px;
      background: linear-gradient(180deg, rgba(15, 118, 110, 0.08), rgba(15, 22, 40, 0.03));
      border: 1px solid rgba(15, 118, 110, 0.1);
    }

    .pipeline-card strong,
    .pipeline-card span,
    .phone-screen strong,
    .phone-screen span {
      display: block;
    }

    .pipeline-card span,
    .phone-screen span {
      margin-top: 0.35rem;
      color: var(--muted);
    }

    .notes {
      background: linear-gradient(180deg, rgba(232, 157, 91, 0.2), rgba(255, 255, 255, 0.8));
    }

    .app-shell {
      background: linear-gradient(180deg, rgba(14, 22, 40, 0.96), rgba(18, 34, 61, 0.9));
      color: #f8fafc;
    }

    .app-shell .section-copy,
    .app-shell .pill,
    .app-shell li,
    .app-shell p {
      color: rgba(248, 250, 252, 0.84);
    }

    .phone-grid {
      grid-template-columns: 0.6fr 1fr;
      align-items: center;
      margin-top: 1rem;
    }

    .phone-frame {
      width: min(18rem, 100%);
      padding: 0.75rem;
      border-radius: 36px;
      background: linear-gradient(180deg, #0b1220, #243349);
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.24);
    }

    .phone-screen {
      padding: 1rem;
      min-height: 20rem;
      border-radius: 28px;
      background:
        radial-gradient(circle at top, rgba(255, 255, 255, 0.16), transparent 25%),
        linear-gradient(180deg, #17434a 0%, #0d1627 100%);
    }

    .mini-feed {
      display: grid;
      gap: 0.8rem;
      margin-top: 1.2rem;
    }

    .mini-feed div {
      padding: 0.9rem;
      border-radius: 20px;
      background: rgba(255, 255, 255, 0.08);
    }

    .mini-feed b {
      display: block;
      font-size: 1.4rem;
    }

    .install-card {
      padding: 1rem 0;
    }

    .browse-row {
      margin-top: 1rem;
    }

    .footer-bar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      margin-top: 1.2rem;
      padding: 1.2rem 0.5rem 0;
      color: var(--muted);
    }

    .footer-bar a {
      padding: 0.9rem 1rem;
      border-radius: 999px;
      border: 1px solid var(--line);
    }

    @media (max-width: 960px) {
      .hero,
      .split-grid,
      .phone-grid,
      .city-grid,
      .listing-grid,
      .workflow-grid,
      .dashboard-body {
        grid-template-columns: 1fr;
      }

      .hero-copy h1 {
        max-width: 100%;
      }
