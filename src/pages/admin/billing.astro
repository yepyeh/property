---
import Layout from "../../layouts/Layout.astro";
import { getAdminBillingData } from "../../lib/dashboard";
import { isExpiryEmailEnabled } from "../../lib/notifications";
import { getDB } from "../../lib/runtime";

const owner = Astro.locals.owner;

if (!owner || owner.role !== "admin") {
  return Astro.redirect("/owner/dashboard/");
}

const { listings, payments, emailDeliveries } = await getAdminBillingData(getDB(Astro.locals.runtime));
const updated = Astro.url.searchParams.get("updated");
const emailed = Number(Astro.url.searchParams.get("emailed") || 0);
const skipped = Number(Astro.url.searchParams.get("skipped") || 0);
const failed = Number(Astro.url.searchParams.get("failed") || 0);
const emailError = Astro.url.searchParams.get("emailError");
const expiryEmailEnabled = isExpiryEmailEnabled(Astro.locals.runtime);

const analytics = {
  totalListings: listings.length,
  activePromoted: listings.filter((listing) => listing.plan_type === "promoted" && listing.promoted_until).length,
  activePaid: listings.filter((listing) => listing.plan_type === "paid" || listing.paid_until).length,
  activeFreeTrial: listings.filter((listing) => listing.plan_type === "free_trial" && listing.status !== "Expired listing").length,
  expiredListings: listings.filter((listing) => listing.status === "Expired listing").length,
  expiringSoon: listings.filter((listing) => {
    const paid = listing.paid_until ? new Date(listing.paid_until).getTime() - Date.now() : Number.POSITIVE_INFINITY;
    const promoted = listing.promoted_until ? new Date(listing.promoted_until).getTime() - Date.now() : Number.POSITIVE_INFINITY;
    const trial = listing.trial_ends_at ? new Date(listing.trial_ends_at).getTime() - Date.now() : Number.POSITIVE_INFINITY;
    const threshold = 3 * 24 * 60 * 60 * 1000;
    return paid <= threshold || promoted <= threshold || trial <= threshold;
  }).length,
  paymentCount: payments.length,
  emailSentCount: emailDeliveries.filter((delivery) => delivery.status === "sent").length,
  emailFailedCount: emailDeliveries.filter((delivery) => delivery.status === "failed").length,
  revenueVnd: payments.reduce((sum, payment) => sum + Number(payment.amount || 0), 0),
  promotedSales: payments.filter((payment) => payment.plan_type === "promoted").length,
  paidSales: payments.filter((payment) => payment.plan_type === "paid").length,
};

const conversionRate = analytics.totalListings > 0
  ? Math.round(((analytics.paidSales + analytics.promotedSales) / analytics.totalListings) * 100)
  : 0;
---

<Layout title="Admin Billing | Property App 2026" description="Review listing plans and manually manage billing states before payment automation is added.">
  <section class="page-head card">
    <div>
      <span class="pill">Admin billing</span>
      <h1 class="section-title">Listing plans and upgrades</h1>
      <p class="section-copy">
        This is the operational billing console before Stripe. It lets you move listings between free-trial, paid,
        and promoted states and control the duration windows manually.
      </p>
    </div>
    <div class="actions">
      <a class="ghost" href="/owner/dashboard/">Owner dashboard</a>
      <form method="POST" action="/api/auth/logout">
        <button class="ghost" type="submit">Log out</button>
      </form>
    </div>
  </section>

  {updated && (
    <div class="card flash">
      Updated billing state for <code>{updated}</code>.
    </div>
  )}

  {(emailed || skipped || failed) ? (
    <div class="card flash">
      Expiry email dispatch finished. Sent <strong>{emailed}</strong>, skipped <strong>{skipped}</strong>, failed <strong>{failed}</strong>.
    </div>
  ) : null}

  {emailError && (
    <div class="card flash error-flash">
      Expiry emails were not sent: <code>{emailError}</code>. Set <code>RESEND_API_KEY</code> and <code>NOTIFICATION_FROM_EMAIL</code>.
    </div>
  )}

  <section class="analytics-grid">
    <article class="card stat"><strong>{analytics.totalListings}</strong><span>tracked listings</span></article>
    <article class="card stat"><strong>{analytics.activePaid}</strong><span>paid listings</span></article>
    <article class="card stat"><strong>{analytics.activePromoted}</strong><span>promoted listings</span></article>
    <article class="card stat"><strong>{analytics.activeFreeTrial}</strong><span>free-trial listings</span></article>
    <article class="card stat"><strong>{analytics.expiredListings}</strong><span>expired listings</span></article>
    <article class="card stat"><strong>{analytics.expiringSoon}</strong><span>expiring within 3 days</span></article>
    <article class="card stat"><strong>{analytics.paymentCount}</strong><span>recorded payments</span></article>
    <article class="card stat"><strong>{analytics.emailSentCount}</strong><span>expiry emails sent</span></article>
    <article class="card stat"><strong>{analytics.emailFailedCount}</strong><span>expiry email failures</span></article>
  </section>

  <section class="card panel summary-panel">
    <h2>Revenue summary</h2>
    <div class="summary-grid">
      <div>
        <strong>{analytics.revenueVnd.toLocaleString("en-US")} VND</strong>
        <span>recorded Stripe revenue</span>
      </div>
      <div>
        <strong>{conversionRate}%</strong>
        <span>listing-to-payment conversion</span>
      </div>
      <div>
        <strong>{analytics.paidSales}</strong>
        <span>standard listing sales</span>
      </div>
      <div>
        <strong>{analytics.promotedSales}</strong>
        <span>promotion sales</span>
      </div>
    </div>
  </section>

  <section class="card panel summary-panel">
    <h2>Expiry email delivery</h2>
    <p>
      Send renewal and expiry emails for listings that are already inside the warning window or have already expired.
      Delivery is deduped per listing event so repeated sends do not spam the same reminder.
    </p>
    <div class="actions">
      <form method="POST" action="/api/admin/notifications/send-expiry">
        <button type="submit" class="primary" disabled={!expiryEmailEnabled}>Send pending expiry emails</button>
      </form>
      <span>{expiryEmailEnabled ? "Resend delivery is configured." : "Email delivery is not configured yet."}</span>
    </div>
  </section>

  <section class="card panel">
    <h2>All listing plans</h2>
    {listings.length === 0 ? <p>No listings available.</p> : (
      <ul class="listing-grid">
        {listings.map((listing) => (
          <li>
            <strong>{listing.title}</strong>
            <span>{listing.owner_name} · {listing.owner_email}</span>
            <span>{listing.city} · {listing.district} · {listing.intent}</span>
            <span>Plan: {listing.plan_type}</span>
            {listing.trial_ends_at && <span>Trial ends: {listing.trial_ends_at}</span>}
            {listing.paid_until && <span>Paid until: {listing.paid_until}</span>}
            {listing.promoted_until && <span>Promoted until: {listing.promoted_until}</span>}

            <div class="billing-controls">
              <form method="POST" action="/api/listings/plan">
                <input type="hidden" name="listingSlug" value={listing.slug} />
                <input type="hidden" name="planType" value="free_trial" />
                <button type="submit" class="ghost small">Reset to 7-day free trial</button>
              </form>

              <form method="POST" action="/api/listings/plan" class="inline-form">
                <input type="hidden" name="listingSlug" value={listing.slug} />
                <input type="hidden" name="planType" value="paid" />
                <label>
                  Paid days
                  <input type="number" name="paidDays" min="1" value="30" />
                </label>
                <button type="submit" class="small primary">Apply paid</button>
              </form>

              <form method="POST" action="/api/listings/plan" class="inline-form">
                <input type="hidden" name="listingSlug" value={listing.slug} />
                <input type="hidden" name="planType" value="promoted" />
                <label>
                  Promote days
                  <input type="number" name="promotedDays" min="1" value="7" />
                </label>
                <button type="submit" class="small dark">Apply promoted</button>
              </form>
            </div>
          </li>
        ))}
      </ul>
    )}
  </section>

  <section class="card panel payment-panel">
    <h2>Payment ledger</h2>
    {payments.length === 0 ? <p>No payments recorded yet.</p> : (
      <ul class="listing-grid">
        {payments.map((payment) => (
          <li>
            <strong>{payment.plan_type} · {payment.amount} {String(payment.currency).toUpperCase()}</strong>
            <span>{payment.owner_email ?? "Unknown owner"}</span>
            <span>{payment.listing_slug}</span>
            <span>Status: {payment.status}</span>
            <span>{payment.paid_at ? `Paid at: ${payment.paid_at}` : `Created: ${payment.created_at}`}</span>
            <span>Stripe session: {payment.stripe_session_id}</span>
          </li>
        ))}
      </ul>
    )}
  </section>

  <section class="card panel payment-panel">
    <h2>Expiry email ledger</h2>
    {emailDeliveries.length === 0 ? <p>No expiry emails recorded yet.</p> : (
      <ul class="listing-grid">
        {emailDeliveries.map((delivery) => (
          <li>
            <strong>{delivery.status} · {delivery.category} · {delivery.level}</strong>
            <span>{delivery.owner_email}</span>
            <span>{delivery.listing_title}</span>
            <span>Due at: {delivery.due_at}</span>
            <span>{delivery.sent_at ? `Sent at: ${delivery.sent_at}` : `Created: ${delivery.created_at}`}</span>
            {delivery.error_message && <span>Error: {delivery.error_message}</span>}
            {delivery.provider_message_id && <span>Provider message: {delivery.provider_message_id}</span>}
          </li>
        ))}
      </ul>
    )}
  </section>

  <style is:inline>
    .page-head, .panel, .stat { padding: 1.4rem; }
    .payment-panel { margin-top: 1rem; }
    .summary-panel { margin-top: 1rem; }
    .page-head {
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      align-items: flex-start;
      margin-bottom: 1rem;
    }
    .actions,
    .billing-controls {
      display: flex;
      gap: 0.75rem;
      flex-wrap: wrap;
      align-items: center;
    }
    .analytics-grid,
    .summary-grid {
      display: grid;
      gap: 1rem;
    }
    .analytics-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      margin-bottom: 1rem;
    }
    .summary-grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
      margin-top: 1rem;
    }
    .stat strong,
    .summary-grid strong {
      display: block;
      font-size: 1.7rem;
    }
    .stat span,
    .summary-grid span {
      color: var(--muted);
    }
    .flash {
      padding: 1rem 1.2rem;
      margin-bottom: 1rem;
      color: var(--accent-strong);
      font-weight: 700;
    }
    .error-flash {
      color: #991b1b;
    }
    .ghost,
    .primary,
    .dark {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      text-decoration: none;
      font-weight: 700;
      border-radius: 999px;
      cursor: pointer;
    }
    .ghost {
      padding: 0.95rem 1.2rem;
      border: 1px solid var(--line);
      background: rgba(255,255,255,0.72);
      color: var(--text);
    }
    .primary, .dark {
      padding: 0.85rem 1rem;
      border: none;
      color: white;
    }
    .primary {
      background: linear-gradient(135deg, var(--accent), var(--accent-strong));
    }
    .dark {
      background: var(--bg-deep);
    }
    .small {
      padding: 0.75rem 0.95rem;
      font-size: 0.92rem;
    }
    .listing-grid {
      list-style: none;
      padding: 0;
      margin: 1rem 0 0;
      display: grid;
      gap: 1rem;
    }
    .listing-grid li {
      display: grid;
      gap: 0.35rem;
      padding: 1rem;
      border-radius: 18px;
      background: rgba(255,255,255,0.55);
    }
    .listing-grid span,
    .panel p,
    label {
      color: var(--muted);
    }
    .inline-form {
      display: flex;
      align-items: end;
      gap: 0.6rem;
      flex-wrap: wrap;
    }
    label {
      display: grid;
      gap: 0.3rem;
      font-size: 0.9rem;
      font-weight: 600;
    }
    input {
      padding: 0.75rem 0.85rem;
      border-radius: 14px;
      border: 1px solid var(--line);
      background: rgba(255,255,255,0.8);
      font: inherit;
      min-width: 6rem;
    }
    @media (max-width: 960px) {
      .page-head {
        display: grid;
      }
      .analytics-grid,
      .summary-grid {
        grid-template-columns: 1fr;
      }
      .inline-form {
        align-items: stretch;
      }
    }
  </style>
</Layout>
