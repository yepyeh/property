---
import Layout from "../layouts/Layout.astro";

const plans = [
  {
    name: "Free Trial",
    price: "7 days free",
    body: "Good for first-time owners who want to test buyer response before paying for longer visibility.",
    bullets: ["Listing goes live immediately", "Structured enquiries", "Upgrade later if demand is real"],
  },
  {
    name: "Standard Paid",
    price: "499,000 VND",
    body: "Keep the listing live beyond the trial window and avoid disappearing as soon as the free period ends.",
    bullets: ["30-day visibility", "Works for serious inventory", "Best default paid option"],
  },
  {
    name: "Promoted Add-on",
    price: "199,000 VND",
    body: "Push a listing above normal inventory for a shorter burst when the listing quality justifies more exposure.",
    bullets: ["7-day boost", "Prioritized placement", "Best used on stronger listings"],
  },
];
---

<Layout
  title="Pricing | Property App 2026"
  description="Simple listing pricing for owners: free trial, standard paid visibility, and promoted placement."
>
  <section class="hero-shell glass-card">
    <span class="pill">Pricing</span>
    <h1>Keep pricing simple enough that owners understand it in one pass.</h1>
    <p>
      The model is intentionally straightforward: free to test demand, paid to stay live, promoted to rank higher. That is enough to monetize without bloating the product.
    </p>
  </section>

  <section class="pricing-grid section-space">
    {plans.map((plan) => (
      <article class="glass-card pricing-card">
        <span class="pill">Plan</span>
        <h2>{plan.name}</h2>
        <strong>{plan.price}</strong>
        <p>{plan.body}</p>
        <ul>
          {plan.bullets.map((bullet) => <li>{bullet}</li>)}
        </ul>
      </article>
    ))}
  </section>

  <section class="glass-card note-shell section-space">
    <div class="note-copy">
      <span class="pill">Why this model</span>
      <h2>Permanent listings are usually the wrong idea.</h2>
      <p>
        Time-bounded visibility keeps the marketplace fresher, protects trust, and gives owners a cleaner renewal decision.
      </p>
    </div>
    <a class="btn-primary" href="/for-owners">See owner workflow</a>
  </section>

  <style is:inline>
    .hero-shell,
    .pricing-card,
    .note-shell {
      display: grid;
      gap: var(--space-m);
      padding: var(--space-xl);
    }

    .hero-shell h1,
    .pricing-card h2,
    .note-copy h2 {
      margin: 0;
      font-size: var(--text-5xl);
      line-height: 0.94;
      letter-spacing: -0.06em;
    }

    .pricing-card h2,
    .note-copy h2 {
      font-size: var(--text-2xl);
    }

    .hero-shell p,
    .pricing-card p,
    .note-copy p,
    .pricing-card li {
      margin: 0;
      color: var(--muted);
      line-height: 1.72;
    }

    .hero-shell {
      background:
        radial-gradient(circle at top left, color-mix(in srgb, var(--accent) 10%, transparent), transparent 28rem),
        linear-gradient(180deg, color-mix(in srgb, var(--card) 94%, transparent), color-mix(in srgb, var(--card) 82%, transparent));
    }

    .pricing-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: var(--space-m);
    }

    .pricing-card strong {
      display: block;
      font-size: var(--text-3xl);
      letter-spacing: -0.05em;
    }

    .pricing-card ul {
      margin: 0;
      padding-left: var(--space-m);
      display: grid;
      gap: var(--space-xs);
    }

    .note-shell {
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: center;
    }

    @media (max-width: 980px) {
      .pricing-grid,
      .note-shell {
        grid-template-columns: 1fr;
      }
    }
  </style>
</Layout>
