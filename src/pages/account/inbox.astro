---
import Layout from "../../layouts/Layout.astro";
import WorkspaceHero from "../../components/workspace/WorkspaceHero.astro";
import FlashBanner from "../../components/workspace/FlashBanner.astro";
import { getInboxNotifications } from "../../lib/notifications";
import { getDB } from "../../lib/runtime";

const viewer = Astro.locals.owner;

if (!viewer) {
  return Astro.redirect("/login");
}

const notifications = await getInboxNotifications(getDB(Astro.locals.runtime), viewer.id, 100);
const read = Astro.url.searchParams.get("read");
const allRead = Astro.url.searchParams.get("allRead");
const returnHref = viewer.role === "buyer" ? "/buyer/dashboard/" : "/owner/dashboard/";
---

<Layout title="Notification Inbox | Property App 2026" description="Review and manage in-app notifications across buyer and owner workflows.">
  <WorkspaceHero
    eyebrow="Notification inbox"
    title="One feed for account activity."
    text="Expiry reminders, enquiries, billing events, and buyer-side activity land in one timeline so important state changes stay easy to scan and easy to clear."
    actions={[
      { href: returnHref, label: "Back to dashboard", kind: "secondary" },
      { href: "/account/notifications", label: "Settings", kind: "secondary" },
      { formAction: "/api/account/inbox/read-all", label: "Mark all read" },
    ]}
  />

  {(read || allRead) && (
    <FlashBanner message={allRead ? "All notifications marked as read." : "Notification marked as read."} />
  )}

  <section class="inbox-metrics section-gap">
    <article class="card metric-card">
      <span class="metric-label">Unread now</span>
      <strong>{notifications.filter((notification) => !notification.read_at).length}</strong>
      <p>Items that still need a look.</p>
    </article>
    <article class="card metric-card">
      <span class="metric-label">Feed size</span>
      <strong>{notifications.length}</strong>
      <p>Recent account events kept in one place.</p>
    </article>
    <article class="card metric-card">
      <span class="metric-label">Role</span>
      <strong>{viewer.role}</strong>
      <p>{viewer.role === "buyer" ? "Buyer-side alerts and saved-search changes." : "Owner-side listings, billing, and enquiry events."}</p>
    </article>
  </section>

  <section class="card panel">
    <div class="panel-head">
      <div>
        <p class="eyebrow">Feed</p>
        <h2>Recent notifications</h2>
        <p class="panel-copy">Unread items stay elevated until you clear them, so the feed works more like a task list than a passive log.</p>
      </div>
    </div>

    {notifications.length === 0 ? <p class="empty-copy">No in-app notifications yet.</p> : (
      <ul class="inbox-list">
        {notifications.map((notification) => (
          <li class:list-unread={!notification.read_at} class="inbox-item">
            <div class="item-head">
              <div>
                <strong>{notification.title}</strong>
                <span class="category-chip">{notification.category}</span>
              </div>
              <span class="timestamp">{notification.created_at}</span>
            </div>
            <p>{notification.message}</p>
            <div class="item-actions">
              <div class="action-row">
                {notification.href && <a class="button-secondary small" href={notification.href}>Open</a>}
                {!notification.read_at && (
                  <form method="POST" action="/api/account/inbox/read">
                    <input type="hidden" name="id" value={notification.id} />
                    <button class="button-tertiary small" type="submit">Mark read</button>
                  </form>
                )}
              </div>
            </div>
          </li>
        ))}
      </ul>
    )}
  </section>

  <style is:inline>
    .inbox-metrics {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1rem;
    }

    .metric-card {
      padding: 1.1rem;
      display: grid;
      gap: 0.4rem;
    }

    .metric-card strong {
      font-size: 1.8rem;
      letter-spacing: -0.05em;
      text-transform: capitalize;
    }

    .metric-card p,
    .metric-label {
      margin: 0;
      color: var(--muted);
    }

    .metric-label {
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      font-weight: 800;
    }

    .inbox-list {
      display: grid;
      gap: 1rem;
      margin: 0;
      padding: 0;
      list-style: none;
    }

    .inbox-item {
      padding: 1.1rem;
      border-radius: 22px;
      background: linear-gradient(180deg, var(--surface-elevated-strong), var(--surface-panel-muted));
      border: 1px solid var(--line);
    }

    .item-head {
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      align-items: flex-start;
      flex-wrap: wrap;
    }

    .item-head strong {
      display: block;
      font-size: 1rem;
      letter-spacing: -0.02em;
    }

    .timestamp,
    .inbox-item p {
      color: var(--muted);
      line-height: 1.7;
    }

    .inbox-item p {
      margin: 0.75rem 0 0;
    }

    .category-chip {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 1.8rem;
      margin-top: 0.45rem;
      padding: 0.2rem 0.65rem;
      border-radius: 999px;
      background: var(--surface-soft);
      color: var(--accent-strong);
      font-size: 0.78rem;
      font-weight: 700;
      text-transform: capitalize;
    }

    .list-unread {
      border-color: var(--line-strong);
      background: linear-gradient(180deg, color-mix(in srgb, var(--accent-strong) 10%, transparent), var(--surface-elevated-strong));
    }

    .item-actions {
      margin-top: 1rem;
    }

    @media (max-width: 760px) {
      .inbox-metrics,
      .item-head {
        display: grid;
      }
    }
  </style>
</Layout>
