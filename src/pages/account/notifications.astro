---
import Layout from "../../layouts/Layout.astro";
import { getDB, getNotificationPreferences } from "../../lib/marketplace";

const viewer = Astro.locals.owner;

if (!viewer) {
  return Astro.redirect("/login");
}

const preferences = await getNotificationPreferences(getDB(Astro.locals.runtime), viewer.id);
const updated = Astro.url.searchParams.get("updated");
const returnHref = viewer.role === "buyer" ? "/buyer/dashboard/" : "/owner/dashboard/";
---

<Layout title="Notification Settings | Property App 2026" description="Manage email and in-app notification preferences for your marketplace account.">
  <section class="page-head card">
    <div>
      <span class="pill">Notification settings</span>
      <h1 class="section-title">Manage notification delivery</h1>
      <p class="section-copy">
        Choose which notification types you want, how often you want digests, and whether they should arrive by email
        or in-app only.
      </p>
    </div>
    <div class="actions">
      <a class="ghost" href={returnHref}>Back to dashboard</a>
      <form method="POST" action="/api/auth/logout">
        <button class="ghost" type="submit">Log out</button>
      </form>
    </div>
  </section>

  {updated && (
    <div class="card flash">
      Notification preferences updated.
    </div>
  )}

  <form class="settings-grid" method="POST" action="/api/account/notifications">
    <section class="card panel">
      <h2>Channels</h2>
      <label class="toggle"><input type="checkbox" name="emailEnabled" checked={Boolean(preferences?.email_enabled)} /><span>Email notifications</span></label>
      <label class="toggle"><input type="checkbox" name="inAppEnabled" checked={Boolean(preferences?.in_app_enabled)} /><span>In-app notifications</span></label>

      <h2>Digest cadence</h2>
      <div class="radio-row">
        <label><input type="radio" name="cadence" value="daily" checked={(preferences?.cadence ?? "daily") === "daily"} /> Daily</label>
        <label><input type="radio" name="cadence" value="weekly" checked={(preferences?.cadence ?? "daily") === "weekly"} /> Weekly</label>
      </div>
      <p class="helper">Cadence is stored now and used for digest-style notification workflows as they are added.</p>
    </section>

    <section class="card panel">
      <h2>Notification types</h2>
      <label class="toggle"><input type="checkbox" name="listingExpiry" checked={Boolean(preferences?.listing_expiry)} /><span>Listing expiry and renewal reminders</span></label>
      <label class="toggle"><input type="checkbox" name="enquiryActivity" checked={Boolean(preferences?.enquiry_activity)} /><span>New enquiry activity</span></label>
      <label class="toggle"><input type="checkbox" name="billingEvents" checked={Boolean(preferences?.billing_events)} /><span>Billing and upgrade events</span></label>
      <label class="toggle"><input type="checkbox" name="savedSearchMatches" checked={Boolean(preferences?.saved_search_matches)} /><span>Saved search matches</span></label>
      <label class="toggle"><input type="checkbox" name="savedListingUpdates" checked={Boolean(preferences?.saved_listing_updates)} /><span>Saved listing updates</span></label>

      <button type="submit" class="primary">Save preferences</button>
    </section>
  </form>

  <style>
    .page-head, .panel { padding: 1.4rem; }
    .page-head {
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      align-items: flex-start;
      margin-bottom: 1rem;
    }
    .actions,
    .radio-row {
      display: flex;
      gap: 0.75rem;
      flex-wrap: wrap;
      align-items: center;
    }
    .settings-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
    }
    .panel {
      display: grid;
      gap: 1rem;
    }
    .toggle {
      display: flex;
      gap: 0.75rem;
      align-items: center;
      color: var(--text);
      font-weight: 600;
    }
    .toggle input,
    .radio-row input {
      width: auto;
      margin: 0;
    }
    .helper {
      color: var(--muted);
      line-height: 1.6;
    }
    .ghost,
    .primary {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0.95rem 1.2rem;
      border-radius: 999px;
      text-decoration: none;
      font-weight: 700;
    }
    .ghost {
      border: 1px solid var(--line);
      background: rgba(255,255,255,0.72);
      color: var(--text);
      cursor: pointer;
    }
    .primary {
      border: none;
      background: linear-gradient(135deg, var(--accent), var(--accent-strong));
      color: white;
      cursor: pointer;
    }
    .flash {
      padding: 1rem 1.2rem;
      margin-bottom: 1rem;
      color: var(--accent-strong);
      font-weight: 700;
    }
    @media (max-width: 960px) {
      .settings-grid {
        grid-template-columns: 1fr;
      }
    }
    @media (max-width: 760px) {
      .page-head {
        display: grid;
      }
    }
  </style>
</Layout>
