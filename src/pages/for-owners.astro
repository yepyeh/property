---
import Layout from "../layouts/Layout.astro";

const ownerBenefits = [
  {
    title: "Publish and update directly",
    body: "Owners can post listings themselves, upload photos, and keep availability current without waiting on an agency workflow.",
  },
  {
    title: "Manage enquiries in one place",
    body: "Every lead lands in a cleaner owner workflow instead of disappearing across calls, inboxes, and spreadsheet notes.",
  },
  {
    title: "Monetize visibility intentionally",
    body: "Start with a 7-day free listing, then extend or promote only when the inventory deserves more visibility.",
  },
  {
    title: "Get hands-on support when needed",
    body: "If a listing needs more than standard self-serve tools, concierge support can help with launch quality, positioning, and auction preparation.",
  },
];

const workflowSteps = [
  "Create an owner account",
  "Post a listing with location context and images",
  "Receive structured enquiries",
  "Upgrade to paid or promoted placement when needed",
];

const ownerComparison = [
  {
    title: "What typical operators do",
    body: "Many large property operators are still optimized around publishing volume first: post the listing, hope for leads, then manage the rest across different tools.",
  },
  {
    title: "Where that breaks down",
    body: "Owners lose continuity between listing quality, lead quality, follow-up, billing, and renewal. The portal is live, but the workflow around it is weak.",
  },
  {
    title: "What we do better",
    body: "Publishing, gallery management, listing insights, enquiry response state, trust tools, billing, concierge support, and auctions live inside one operating flow.",
  },
];
---

<Layout
  title="For Owners | Property App 2026"
  description="Post homes, manage enquiries, and control listing visibility with a cleaner owner workflow."
>
  <section class="hero-shell glass-card">
    <div class="hero-copy">
      <span class="pill">For owners</span>
      <h1>List faster, manage leads cleanly, and pay for visibility only when it matters.</h1>
      <p>
        This is the supply-side landing page the product needed. It explains the actual owner workflow instead of expecting people to infer it from the app.
      </p>
      <div class="hero-actions">
        <a class="btn-primary" href="/signup?role=owner">Create owner account</a>
        <a class="button-shell" href="/submit-listing/">Post a listing</a>
        <a class="button-shell" href="/concierge">Talk to the team</a>
      </div>
    </div>
    <div class="surface-card hero-panel">
      <strong>Owner workflow</strong>
      <ol>
        {workflowSteps.map((step) => <li>{step}</li>)}
      </ol>
      <div class="hero-links">
        <a href="/pricing">See pricing</a>
        <a href="/concierge">Concierge support</a>
      </div>
    </div>
  </section>

  <section class="card-grid section-space">
    {ownerBenefits.map((benefit) => (
      <article class="glass-card benefit-card">
        <span class="pill">Owner benefit</span>
        <h2>{benefit.title}</h2>
        <p>{benefit.body}</p>
      </article>
    ))}
  </section>

  <section class="card-grid section-space">
    {ownerComparison.map((item) => (
      <article class="glass-card benefit-card">
        <span class="pill">Owner comparison</span>
        <h2>{item.title}</h2>
        <p>{item.body}</p>
      </article>
    ))}
  </section>

  <section class="glass-card note-shell section-space">
    <div class="note-copy">
      <span class="pill">Why this matters</span>
      <h2>Most owner tools fail in the handoff between posting and follow-up.</h2>
      <p>
        This product is aimed at that operational gap: supply creation, lead capture, billing, and renewal in one place.
      </p>
    </div>
    <a class="btn-primary" href="/owner/dashboard/">Go to owner dashboard</a>
  </section>

  <style is:inline>
    .hero-shell,
    .benefit-card,
    .note-shell {
      padding: var(--space-xl);
    }

    .hero-shell,
    .note-shell {
      display: grid;
      grid-template-columns: minmax(0, 1.15fr) minmax(0, 0.85fr);
      gap: var(--space-m);
      align-items: start;
    }

    .hero-copy,
    .benefit-card,
    .note-copy,
    .hero-panel {
      display: grid;
      gap: var(--space-m);
    }

    .hero-copy h1,
    .benefit-card h2,
    .note-copy h2 {
      margin: 0;
      font-size: var(--text-5xl);
      line-height: 0.94;
      letter-spacing: -0.06em;
    }

    .benefit-card h2,
    .note-copy h2 {
      font-size: var(--text-2xl);
    }

    .hero-copy p,
    .benefit-card p,
    .note-copy p,
    .hero-panel,
    .hero-panel li {
      margin: 0;
      color: var(--muted);
      line-height: 1.72;
    }

    .hero-shell {
      background:
        radial-gradient(circle at top left, color-mix(in srgb, var(--accent) 10%, transparent), transparent 26rem),
        linear-gradient(180deg, color-mix(in srgb, var(--card) 94%, transparent), color-mix(in srgb, var(--card) 82%, transparent));
    }

    .hero-actions,
    .hero-links {
      display: flex;
      gap: var(--space-s);
      flex-wrap: wrap;
    }

    .button-shell {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: calc(var(--space-xl) + var(--space-s));
      padding: var(--space-s) var(--space-m);
      border-radius: var(--radius-full);
      border: 1px solid var(--border);
      background: color-mix(in srgb, var(--card) 78%, transparent);
      color: inherit;
      text-decoration: none;
      font-weight: 700;
      transition: all var(--duration-fast) var(--transition-luxury);
    }

    .button-shell:hover,
    .hero-links a:hover {
      border-color: color-mix(in srgb, var(--accent) 22%, var(--border));
      color: var(--accent);
    }

    .hero-panel ol {
      margin: 0;
      padding-left: var(--space-m);
      display: grid;
      gap: var(--space-xs);
    }

    .hero-links a {
      color: inherit;
      text-decoration: none;
      font-weight: 700;
      transition: color var(--duration-fast) var(--transition-luxury);
    }

    .card-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: var(--space-m);
    }

    @media (max-width: 980px) {
      .hero-shell,
      .note-shell,
      .card-grid {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 760px) {
      .hero-actions {
        display: grid;
      }

      .btn-primary,
      .button-shell {
        width: 100%;
      }
    }
  </style>
</Layout>
