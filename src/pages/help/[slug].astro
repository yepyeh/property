---
import Layout from "../../layouts/Layout.astro";
import { getCollection, getEntry, render } from "astro:content";

const t = Astro.locals.t || ((value: string) => value);
const slug = Astro.params.slug || "";
const article = await getEntry("help", slug);

if (!article) {
  return Astro.redirect("/help/");
}

const { Content } = await render(article);
const allArticles = (await getCollection("help")).sort((a, b) => a.data.order - b.data.order);
const related = allArticles.filter((entry) => entry.id !== article.id && entry.data.category === article.data.category).slice(0, 3);
---

<Layout title={`${article.data.title} | ${t("Help Centre")}`} description={article.data.description}>
  <section class="help-article-hero card">
    <div>
      <a class="back-link" href="/help/">{t("Back to help centre")}</a>
      <span class="pill">{article.data.category}</span>
      <h1>{article.data.title}</h1>
      <p>{article.data.description}</p>
    </div>
    <div class="article-meta">
      <span>{t("Updated")}</span>
      <strong>{article.data.updatedAt}</strong>
    </div>
  </section>

  <section class="help-layout section-gap">
    <article class="card help-body">
      <Content />
    </article>

    <aside class="card help-aside">
      <strong>{t("Related guides")}</strong>
      {related.length === 0 ? <p>{t("No related guides yet.")}</p> : (
        <ul>
          {related.map((entry) => (
            <li><a href={`/help/${entry.id}/`}>{entry.data.title}</a></li>
          ))}
        </ul>
      )}
      <a class="helper-link" href="/search-helper/">{t("Open site helper")}</a>
    </aside>
  </section>

  <style is:inline>
    .help-article-hero {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: var(--space-m);
      align-items: start;
      padding: var(--space-l);
    }
    .back-link {
      display: inline-flex;
      margin-bottom: var(--space-s);
      color: var(--muted-strong);
      text-decoration: none;
      font-weight: 700;
    }
    .help-article-hero h1 {
      margin: var(--space-s) 0 0;
      font-size: var(--text-5xl);
      line-height: 0.96;
      letter-spacing: -0.08em;
      max-width: 12ch;
    }
    .help-article-hero p,
    .help-aside p,
    .help-body :global(p),
    .help-body :global(li) {
      color: var(--muted);
      line-height: 1.72;
    }
    .article-meta {
      min-width: 10rem;
      padding: var(--space-m);
      border-radius: var(--radius-lg);
      background: var(--accent-1);
      display: grid;
      gap: var(--space-2xs);
    }
    .article-meta span {
      color: var(--muted);
      font-size: var(--text-xs);
      text-transform: uppercase;
      letter-spacing: 0.08em;
      font-weight: 800;
    }
    .help-layout {
      display: grid;
      grid-template-columns: minmax(0, 1.45fr) minmax(18rem, 0.75fr);
      gap: var(--space-m);
    }
    .help-body,
    .help-aside {
      padding: var(--space-l);
    }
    .help-aside ul {
      list-style: none;
      padding: 0;
      margin: var(--space-m) 0 0;
      display: grid;
      gap: var(--space-s);
    }
    .help-aside a {
      display: block;
      padding: var(--space-s) var(--space-m);
      border-radius: var(--radius-lg);
      background: var(--surface-panel-muted);
      border: 1px solid var(--line);
      color: inherit;
      text-decoration: none;
      font-weight: 700;
    }
    .help-aside .helper-link {
      margin-top: var(--space-m);
      color: var(--accent-strong);
    }
    .help-body :global(h2) {
      margin-top: var(--space-l);
      font-size: var(--text-xl);
      letter-spacing: -0.04em;
    }
    .help-body :global(ul),
    .help-body :global(ol) {
      padding-left: var(--space-l);
    }
    @media (max-width: 960px) {
      .help-article-hero,
      .help-layout {
        grid-template-columns: 1fr;
      }
    }
  </style>
</Layout>
