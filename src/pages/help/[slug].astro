---
import Layout from "../../layouts/Layout.astro";
import { getCollection, getEntry, render } from "astro:content";

const slug = Astro.params.slug || "";
const article = await getEntry("help", slug);

if (!article) {
  return Astro.redirect("/help/");
}

const { Content } = await render(article);
const allArticles = (await getCollection("help")).sort((a, b) => a.data.order - b.data.order);
const related = allArticles.filter((entry) => entry.id !== article.id && entry.data.category === article.data.category).slice(0, 3);
---

<Layout title={`${article.data.title} | Help Centre`} description={article.data.description}>
  <section class="help-article-hero card">
    <div>
      <a class="back-link" href="/help/">Back to help centre</a>
      <span class="pill">{article.data.category}</span>
      <h1>{article.data.title}</h1>
      <p>{article.data.description}</p>
    </div>
    <div class="article-meta">
      <span>Updated</span>
      <strong>{article.data.updatedAt}</strong>
    </div>
  </section>

  <section class="help-layout section-gap">
    <article class="card help-body">
      <Content />
    </article>

    <aside class="card help-aside">
      <strong>Related guides</strong>
      {related.length === 0 ? <p>No related guides yet.</p> : (
        <ul>
          {related.map((entry) => (
            <li><a href={`/help/${entry.id}/`}>{entry.data.title}</a></li>
          ))}
        </ul>
      )}
    </aside>
  </section>

  <style is:inline>
    .help-article-hero,
    .help-body,
    .help-aside {
      padding: 1.4rem;
    }
    .help-article-hero {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 1rem;
      align-items: start;
    }
    .back-link {
      display: inline-flex;
      margin-bottom: 0.75rem;
      color: var(--muted-strong);
      text-decoration: none;
      font-weight: 700;
    }
    .help-article-hero h1 {
      margin: 0.75rem 0 0;
      font-size: clamp(2rem, 5vw, 3.2rem);
      line-height: 0.96;
      letter-spacing: -0.08em;
      max-width: 12ch;
    }
    .help-article-hero p,
    .help-aside p,
    .help-body :global(p),
    .help-body :global(li) {
      color: var(--muted);
      line-height: 1.72;
    }
    .article-meta {
      min-width: 10rem;
      padding: 1rem;
      border-radius: 20px;
      background: var(--accent-1);
      display: grid;
      gap: 0.25rem;
    }
    .article-meta span {
      color: var(--muted);
      font-size: 0.82rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      font-weight: 800;
    }
    .help-layout {
      display: grid;
      grid-template-columns: minmax(0, 1.45fr) minmax(18rem, 0.75fr);
      gap: 1rem;
    }
    .help-aside ul {
      list-style: none;
      padding: 0;
      margin: 1rem 0 0;
      display: grid;
      gap: 0.75rem;
    }
    .help-aside a {
      display: block;
      padding: 0.9rem 1rem;
      border-radius: 16px;
      background: var(--surface-panel-muted);
      border: 1px solid var(--line);
      color: inherit;
      text-decoration: none;
      font-weight: 700;
    }
    .help-body :global(h2) {
      margin-top: 1.6rem;
      font-size: 1.35rem;
      letter-spacing: -0.04em;
    }
    .help-body :global(ul),
    .help-body :global(ol) {
      padding-left: 1.2rem;
    }
    @media (max-width: 960px) {
      .help-article-hero,
      .help-layout {
        grid-template-columns: 1fr;
      }
    }
  </style>
</Layout>
