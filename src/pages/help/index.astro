---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const t = Astro.locals.t || ((value: string) => value);
const articles = (await getCollection("help")).sort((a, b) => a.data.order - b.data.order);
const categories = [
  { key: "getting-started", label: t("Getting started") },
  { key: "buyers", label: t("Buyers") },
  { key: "owners", label: t("Owners") },
  { key: "billing", label: t("Billing") },
  { key: "account", label: t("Account") },
  { key: "updates", label: t("Updates") },
];

const faqs = [
  {
    question: t("I like a listing, but I am not ready to contact yet. What should I do?"),
    answer: t("Save it to your shortlist first. Then save two or three comparable places, open compare, mark a finalist, and only then contact the strongest option."),
    href: "/help/buyer-shortlist-and-compare/",
  },
  {
    question: t("What does finalist mean?"),
    answer: t("Finalist means the listing is currently leading your shortlist after you compared it on price, location, trust, and fit."),
    href: "/help/buyer-shortlist-and-compare/",
  },
  {
    question: t("How should owners know whether to upgrade a listing?"),
    answer: t("Use upgrades after the listing is already credible. If photos, trust signals, and location context are weak, promotion will not fix the underlying problem."),
    href: "/help/posting-and-managing-listings/",
  },
  {
    question: t("Where do I manage notifications and account alerts?"),
    answer: t("Use the inbox for current activity and notification settings to control category, channel, and cadence preferences."),
    href: "/help/notifications-and-inbox/",
  },
  {
    question: t("How do I report a listing or understand trust protections?"),
    answer: t("Use the report form on a listing detail page and review the trust and safety guide for how verification and moderation work."),
    href: "/help/trust-and-safety/",
  },
];
---

<Layout title={`${t("Help Centre")} | Property App 2026`} description={t("Guides for buyers, owners, billing, notifications, and core platform workflows.")}>
  <section class="help-hero card">
    <div>
      <span class="pill">{t("Help centre")}</span>
      <h1>{t("Help users understand the product as it changes.")}</h1>
      <p>
        {t("This help centre is content-driven, so product changes can be reflected by updating articles instead of rebuilding page structure. Buyers, owners, and admins should all be able to find the right workflow quickly.")}
      </p>
    </div>
    <div class="hero-meta">
      <strong>{articles.length}</strong>
      <span>{t("Guides live now")}</span>
    </div>
  </section>

  <section class="category-grid section-gap">
    {categories.map((category) => {
      const categoryArticles = articles.filter((article) => article.data.category === category.key);
      return (
        <article class="card category-card">
          <div class="category-head">
            <strong>{category.label}</strong>
            <span>{categoryArticles.length} {t(categoryArticles.length === 1 ? "article" : "articles")}</span>
          </div>
          <ul class="article-list">
            {categoryArticles.map((article) => (
              <li>
                <a href={`/help/${article.id}/`}>
                  <strong>{article.data.title}</strong>
                  <span>{article.data.description}</span>
                </a>
              </li>
            ))}
          </ul>
        </article>
      );
    })}
  </section>

  <section class="card maintenance-note section-gap">
    <strong>{t("Recent updates")}</strong>
    <ul class="update-list">
      {articles
        .filter((article) => article.data.category === "updates")
        .slice(0, 3)
        .map((article) => (
          <li>
            <a href={`/help/${article.id}/`}>
              <strong>{article.data.title}</strong>
              <span>{article.data.updatedAt}</span>
            </a>
          </li>
        ))}
    </ul>
  </section>

  <section class="card maintenance-note section-gap">
    <div class="quick-answer-head">
      <div>
        <strong>{t("Quick answers")}</strong>
        <p>{t("Use this like a lightweight FAQ until the help centre grows into a larger knowledge base.")}</p>
      </div>
      <a class="helper-link" href="/search-helper/">{t("Open site helper")}</a>
    </div>
    <div class="faq-search">
      <input id="help-search" type="search" placeholder={t("Search guides and quick answers")} />
    </div>
    <ul class="faq-list" id="faq-list">
      {faqs.map((faq) => (
        <li data-help-search={`${faq.question} ${faq.answer}`.toLowerCase()}>
          <strong>{faq.question}</strong>
          <p>{faq.answer}</p>
          <a href={faq.href}>{t("Open related guide")}</a>
        </li>
      ))}
    </ul>
  </section>

  <section class="card maintenance-note section-gap">
    <strong>{t("How to keep this updated")}</strong>
    <p>
      {t("Each guide lives in `src/content/help/`. When a buyer flow, owner workflow, billing rule, or inbox behavior changes, the right maintenance step is to update the relevant article in that collection as part of the same code change.")}
    </p>
  </section>

  <script is:inline>
    const searchInput = document.getElementById('help-search');
    const faqItems = Array.from(document.querySelectorAll('#faq-list li'));
    if (searchInput) {
      searchInput.addEventListener('input', () => {
        const query = searchInput.value.trim().toLowerCase();
        for (const item of faqItems) {
          const haystack = item.getAttribute('data-help-search') || '';
          item.style.display = !query || haystack.includes(query) ? '' : 'none';
        }
      });
    }
  </script>

  <style is:inline>
    .help-hero {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: var(--space-m);
      align-items: start;
      padding: var(--space-l);
    }
    .help-hero h1 {
      margin: var(--space-s) 0 0;
      font-size: var(--text-5xl);
      line-height: 0.94;
      letter-spacing: -0.08em;
      max-width: 11ch;
    }
    .help-hero p,
    .maintenance-note p {
      max-width: 48rem;
      line-height: 1.7;
      color: var(--muted);
    }
    .hero-meta {
      min-width: 10rem;
      padding: var(--space-m);
      border-radius: var(--radius-lg);
      background: var(--accent-1);
      display: grid;
      gap: var(--space-2xs);
    }
    .hero-meta strong {
      font-size: var(--text-3xl);
      letter-spacing: -0.06em;
    }
    .hero-meta span,
    .category-head span,
    .article-list a span {
      color: var(--muted);
    }
    .category-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: var(--space-m);
    }
    .category-head {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: var(--space-m);
      margin-bottom: var(--space-m);
    }
    .article-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      gap: var(--space-s);
    }
    .article-list li a {
      display: grid;
      gap: var(--space-2xs);
      padding: var(--space-m);
      border-radius: var(--radius-lg);
      background: var(--surface-panel-muted);
      border: 1px solid var(--line);
      text-decoration: none;
      color: inherit;
    }
    .update-list {
      list-style: none;
      padding: 0;
      margin: var(--space-m) 0 0;
      display: grid;
      gap: var(--space-s);
    }
    .update-list li a {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: var(--space-m);
      padding: var(--space-m);
      border-radius: var(--radius-lg);
      background: var(--surface-panel-muted);
      border: 1px solid var(--line);
      text-decoration: none;
      color: inherit;
    }
    .update-list span {
      color: var(--muted);
      white-space: nowrap;
    }
    .quick-answer-head {
      display: flex;
      justify-content: space-between;
      gap: var(--space-m);
      align-items: end;
    }
    .helper-link {
      color: var(--accent-strong);
      font-weight: 700;
      text-decoration: none;
      white-space: nowrap;
    }
    .faq-search {
      margin-top: var(--space-m);
    }
    .faq-search input {
      width: 100%;
      border: 1px solid var(--line);
      border-radius: var(--radius-lg);
      background: var(--surface-elevated-strong);
      padding: var(--space-s) var(--space-m);
      color: var(--text);
      font: inherit;
    }
    .faq-list {
      list-style: none;
      padding: 0;
      margin: var(--space-m) 0 0;
      display: grid;
      gap: var(--space-s);
    }
    .faq-list li {
      display: grid;
      gap: var(--space-2xs);
      padding: var(--space-m);
      border-radius: var(--radius-lg);
      background: var(--surface-panel-muted);
      border: 1px solid var(--line);
    }
    .faq-list p {
      margin: 0;
      color: var(--muted);
    }
    .faq-list a {
      width: fit-content;
      color: var(--accent-strong);
      font-weight: 700;
      text-decoration: none;
    }
    @media (max-width: 900px) {
      .help-hero,
      .category-grid {
        grid-template-columns: 1fr;
      }
      .quick-answer-head {
        flex-direction: column;
        align-items: start;
      }
    }
  </style>
</Layout>
