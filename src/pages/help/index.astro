---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const articles = (await getCollection("help")).sort((a, b) => a.data.order - b.data.order);
const categories = [
  { key: "getting-started", label: "Getting started" },
  { key: "buyers", label: "Buyers" },
  { key: "owners", label: "Owners" },
  { key: "billing", label: "Billing" },
  { key: "account", label: "Account" },
  { key: "updates", label: "Updates" },
];

const faqs = [
  {
    question: "I like a listing, but I am not ready to contact yet. What should I do?",
    answer: "Save it to your shortlist first. Then save two or three comparable places, open compare, mark a finalist, and only then contact the strongest option.",
    href: "/help/buyer-shortlist-and-compare/",
  },
  {
    question: "What does finalist mean?",
    answer: "Finalist means the listing is currently leading your shortlist after you compared it on price, location, trust, and fit.",
    href: "/help/buyer-shortlist-and-compare/",
  },
  {
    question: "How should owners know whether to upgrade a listing?",
    answer: "Use upgrades after the listing is already credible. If photos, trust signals, and location context are weak, promotion will not fix the underlying problem.",
    href: "/help/posting-and-managing-listings/",
  },
  {
    question: "Where do I manage notifications and account alerts?",
    answer: "Use the inbox for current activity and notification settings to control category, channel, and cadence preferences.",
    href: "/help/notifications-and-inbox/",
  },
  {
    question: "How do I report a listing or understand trust protections?",
    answer: "Use the report form on a listing detail page and review the trust and safety guide for how verification and moderation work.",
    href: "/help/trust-and-safety/",
  },
];
---

<Layout title="Help Centre | Property App 2026" description="Guides for buyers, owners, billing, notifications, and core platform workflows.">
  <section class="help-hero card">
    <div>
      <span class="pill">Help centre</span>
      <h1>Help users understand the product as it changes.</h1>
      <p>
        This help centre is content-driven, so product changes can be reflected by updating articles instead of rebuilding
        page structure. Buyers, owners, and admins should all be able to find the right workflow quickly.
      </p>
    </div>
    <div class="hero-meta">
      <strong>{articles.length}</strong>
      <span>Guides live now</span>
    </div>
  </section>

  <section class="category-grid section-gap">
    {categories.map((category) => {
      const categoryArticles = articles.filter((article) => article.data.category === category.key);
      return (
        <article class="card category-card">
          <div class="category-head">
            <strong>{category.label}</strong>
            <span>{categoryArticles.length} article{categoryArticles.length === 1 ? "" : "s"}</span>
          </div>
          <ul class="article-list">
            {categoryArticles.map((article) => (
              <li>
                <a href={`/help/${article.id}/`}>
                  <strong>{article.data.title}</strong>
                  <span>{article.data.description}</span>
                </a>
              </li>
            ))}
          </ul>
        </article>
      );
    })}
  </section>

  <section class="card maintenance-note section-gap">
    <strong>Recent updates</strong>
    <ul class="update-list">
      {articles
        .filter((article) => article.data.category === "updates")
        .slice(0, 3)
        .map((article) => (
          <li>
            <a href={`/help/${article.id}/`}>
              <strong>{article.data.title}</strong>
              <span>{article.data.updatedAt}</span>
            </a>
          </li>
        ))}
    </ul>
  </section>

  <section class="card maintenance-note section-gap">
    <strong>Quick answers</strong>
    <p>Use this like a lightweight FAQ until the help centre grows into a larger knowledge base.</p>
    <div class="faq-search">
      <input id="help-search" type="search" placeholder="Search guides and quick answers" />
    </div>
    <ul class="faq-list" id="faq-list">
      {faqs.map((faq) => (
        <li data-help-search={`${faq.question} ${faq.answer}`.toLowerCase()}>
          <strong>{faq.question}</strong>
          <p>{faq.answer}</p>
          <a href={faq.href}>Open related guide</a>
        </li>
      ))}
    </ul>
  </section>

  <section class="card maintenance-note section-gap">
    <strong>How to keep this updated</strong>
    <p>
      Each guide lives in `src/content/help/`. When a buyer flow, owner workflow, billing rule, or inbox behavior changes,
      the right maintenance step is to update the relevant article in that collection as part of the same code change.
    </p>
  </section>

  <style is:inline>
    .help-hero,
    .category-card,
    .maintenance-note {
      padding: 1.4rem;
    }
    .help-hero {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 1rem;
      align-items: start;
    }
    .help-hero h1 {
      margin: 0.75rem 0 0;
      font-size: clamp(2rem, 5vw, 3.35rem);
      line-height: 0.94;
      letter-spacing: -0.08em;
      max-width: 11ch;
    }
    .help-hero p,
    .maintenance-note p {
      max-width: 48rem;
      line-height: 1.7;
      color: var(--muted);
    }
    .hero-meta {
      min-width: 10rem;
      padding: 1rem;
      border-radius: 22px;
      background: rgba(15, 23, 42, 0.05);
      display: grid;
      gap: 0.25rem;
    }
    .hero-meta strong {
      font-size: 2rem;
      letter-spacing: -0.06em;
    }
    .hero-meta span,
    .category-head span,
    .article-list a span {
      color: var(--muted);
    }
    .category-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
    }
    .category-head {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 1rem;
      margin-bottom: 1rem;
    }
    .article-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      gap: 0.8rem;
    }
    .article-list li a {
      display: grid;
      gap: 0.25rem;
      padding: 1rem;
      border-radius: 18px;
      background: rgba(255,255,255,0.72);
      border: 1px solid var(--line);
      text-decoration: none;
      color: inherit;
    }
    .update-list {
      list-style: none;
      padding: 0;
      margin: 1rem 0 0;
      display: grid;
      gap: 0.8rem;
    }
    .update-list li a {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 1rem;
      padding: 1rem;
      border-radius: 18px;
      background: rgba(255,255,255,0.72);
      border: 1px solid var(--line);
      text-decoration: none;
      color: inherit;
    }
    .update-list span {
      color: var(--muted);
      white-space: nowrap;
    }
    .faq-search {
      margin-top: 1rem;
    }
    .faq-search input {
      width: 100%;
      border: 1px solid var(--line);
      border-radius: 16px;
      background: white;
      padding: 0.95rem 1rem;
      color: var(--text);
      font: inherit;
    }
    .faq-list {
      list-style: none;
      padding: 0;
      margin: 1rem 0 0;
      display: grid;
      gap: 0.8rem;
    }
    .faq-list li {
      display: grid;
      gap: 0.35rem;
      padding: 1rem;
      border-radius: 18px;
      background: rgba(255,255,255,0.72);
      border: 1px solid var(--line);
    }
    .faq-list p {
      margin: 0;
      color: var(--muted);
    }
    .faq-list a {
      width: fit-content;
      color: var(--accent-strong);
      font-weight: 700;
      text-decoration: none;
    }
    @media (max-width: 900px) {
      .help-hero,
      .category-grid {
        grid-template-columns: 1fr;
      }
      .update-list li a {
        display: grid;
      }
    }
  </style>
  <script is:inline>
    const searchInput = document.getElementById("help-search");
    const faqItems = Array.from(document.querySelectorAll("#faq-list li"));

    if (searchInput) {
      searchInput.addEventListener("input", (event) => {
        const value = String(event.currentTarget.value || "").trim().toLowerCase();
        faqItems.forEach((item) => {
          const haystack = item.getAttribute("data-help-search") || "";
          item.style.display = !value || haystack.includes(value) ? "" : "none";
        });
      });
    }
  </script>
</Layout>
