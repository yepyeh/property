---
import Layout from "../../layouts/Layout.astro";
import WorkspaceHero from "../../components/workspace/WorkspaceHero.astro";
import WorkspaceStats from "../../components/workspace/WorkspaceStats.astro";
import AccountSummaryCard from "../../components/workspace/AccountSummaryCard.astro";
import FlashBanner from "../../components/workspace/FlashBanner.astro";
import { isBillingEnabled } from "../../lib/billing";
import { getOwnerDashboardData } from "../../lib/dashboard";
import { getDB } from "../../lib/runtime";

const owner = Astro.locals.owner;
const { listings, enquiries, payments, notifications, savedSearches, inboxNotifications, unreadNotificationCount, verificationStatus } = owner
  ? await getOwnerDashboardData(owner.id, getDB(Astro.locals.runtime))
  : { listings: [], enquiries: [], payments: [], notifications: [], savedSearches: [], inboxNotifications: [], unreadNotificationCount: 0, verificationStatus: null };
const uploaded = Astro.url.searchParams.get("uploaded");
const uploadCount = Astro.url.searchParams.get("uploadCount");
const updated = Astro.url.searchParams.get("updated");
const mediaAction = Astro.url.searchParams.get("mediaAction");
const action = Astro.url.searchParams.get("action");
const status = Astro.url.searchParams.get("status");
const planType = Astro.url.searchParams.get("planType");
const savedSearchDeleted = Astro.url.searchParams.get("savedSearchDeleted");
const billingEnabled = isBillingEnabled(Astro.locals.runtime);
const enquiryStatusCounts = {
  new: enquiries.filter((enquiry) => enquiry.response_status === "new").length,
  responded: enquiries.filter((enquiry) => enquiry.response_status === "responded").length,
  archived: enquiries.filter((enquiry) => enquiry.response_status === "archived").length,
};

function isFutureDate(value?: string | null) {
  return Boolean(value) && new Date(value as string).getTime() > Date.now();
}

function getStandardActionLabel(listing: {
  status?: string;
  paid_until?: string | null;
  promoted_until?: string | null;
}) {
  if (listing.status === "Expired listing") return "Republish for 30 days";
  if (isFutureDate(listing.promoted_until)) return "Extend paid period";
  if (isFutureDate(listing.paid_until)) return "Extend paid period";
  return "Activate 30-day standard";
}

function getPromotionActionLabel(listing: {
  status?: string;
  promoted_until?: string | null;
}) {
  if (listing.status === "Expired listing") return "Republish with promotion";
  if (isFutureDate(listing.promoted_until)) return "Extend promotion";
  return "Promote for 7 days";
}

function getImageCount(value: unknown) {
  if (typeof value !== "string" || !value) return 0;

  try {
    const parsed = JSON.parse(value);
    return Array.isArray(parsed) ? parsed.length : 0;
  } catch {
    return 0;
  }
}

function getImageUrls(value: unknown) {
  if (typeof value !== "string" || !value) return [] as string[];

  try {
    const parsed = JSON.parse(value);
    return Array.isArray(parsed) ? parsed.map((key) => `/media/${key}`) : [];
  } catch {
    return [] as string[];
  }
}
---

<Layout title="Owner Dashboard | Property App 2026" description="Review submitted listings and enquiries from the marketplace backend.">
  <WorkspaceHero
    eyebrow="Owner workspace"
    title="Run listings, enquiries, and renewals without losing the thread."
    text="This should feel closer to an operator workspace than an admin panel. Inventory health, buyer follow-up, and paid visibility all stay readable in one place."
    actions={[
      { href: "/submit-listing/", label: "Post a listing" },
      { href: "/account/inbox", label: "Open inbox", kind: "secondary" },
      { href: "/account/notifications", label: "Notification settings", kind: "secondary" },
    ]}
  />

  <WorkspaceStats
    items={[
      { label: "Inventory", value: listings.length, copy: "Database listings" },
      { label: "Pipeline", value: enquiries.length, copy: "Enquiries received" },
      { label: "Inbox", value: unreadNotificationCount, copy: "Unread notifications" },
    ]}
  />

  <AccountSummaryCard
    blocks={[
      { eyebrow: "Signed in as", title: owner?.full_name ?? "Owner account", copy: owner?.email ?? "" },
      { eyebrow: "Plan tier", title: owner?.plan_tier ?? "starter", copy: "7-day free trial, paid listing upgrades, promoted placement" },
    ]}
  />

  {uploaded && <FlashBanner message={`${uploadCount || "1"} image${uploadCount === "1" ? "" : "s"} uploaded for ${uploaded}. Gallery coverage updated immediately.`} />}
  {updated && action === "gallery-updated" && (
    <FlashBanner message={`${mediaAction === "deleted" ? "Removed one image from" : "Updated gallery order for"} ${updated}. Listing media state is live now.`} />
  )}
  {updated && action === "enquiry-responded" && (
    <FlashBanner
      tone="info"
      message={`Enquiry status for ${updated} moved to ${status || "updated"}. The buyer-facing history will reflect this on their next view.`}
    />
  )}
  {updated && action === "plan-updated" && (
    <FlashBanner
      tone="info"
      message={`Billing state for ${updated} moved to ${planType || "updated"}. Visibility rules are already recalculated.`}
    />
  )}
  {updated && !action && <FlashBanner message={`Listing state updated for ${updated}.`} />}
  {savedSearchDeleted && <FlashBanner message="Saved search deleted." />}
  {action === "verification-requested" && <FlashBanner tone="info" message="Verification request submitted. Admin review is now required before trust status changes." />}
  {action === "verification-pending" && <FlashBanner tone="info" message="A verification request is already pending review." />}

  <section class="card panel section-gap">
    <div class="panel-head">
      <div>
        <p class="eyebrow">Operator guide</p>
        <h2>Keep owner workflow predictable</h2>
        <p class="panel-copy">Owners should always know what to do next: tighten listing quality, watch demand signals, respond to enquiries, then use visibility upgrades when the listing is strong enough to justify them.</p>
      </div>
    </div>
    <div class="compare-preview">
      <article class="compare-chip">
        <strong>1. Fix presentation first</strong>
        <span>Better photos and clearer location context before paid promotion.</span>
      </article>
      <article class="compare-chip">
        <strong>2. Watch demand signals</strong>
        <span>Views, saves, and enquiries tell you whether the listing is working.</span>
      </article>
      <article class="compare-chip">
        <strong>3. React quickly</strong>
        <span>Respond to inbound enquiries and keep listing state current.</span>
      </article>
    </div>
    <div class="action-row">
      <a class="button-secondary" href="/help/posting-and-managing-listings/">Open owner guide</a>
      <a class="button-tertiary" href="/help/what-changed-march-2026/">What changed</a>
    </div>
  </section>

  <section class="split-grid split-grid-top">
    <article class="card panel">
      <div class="panel-head">
        <div>
          <p class="eyebrow">Trust status</p>
          <h2>Owner verification</h2>
          <p class="panel-copy">Verification is the platform-level signal that contact identity has been submitted for review, not just self-declared in a listing form.</p>
        </div>
      </div>
      <div class="compare-preview">
        <article class="compare-chip">
          <strong>{verificationStatus?.status ?? "not requested"}</strong>
          <span>{verificationStatus?.submitted_at ? `Submitted ${verificationStatus.submitted_at}` : "No verification request yet"}</span>
        </article>
      </div>
      <form class="verification-form" method="POST" action="/api/owner/verification/request">
        <input type="text" name="ownerNote" placeholder="Optional note for admin review" />
        <button type="submit" class="button-secondary" disabled={verificationStatus?.status === "pending"}>{verificationStatus?.status === "pending" ? "Verification pending" : "Request verification"}</button>
      </form>
    </article>

    <article class="card panel">
      <div class="panel-head">
        <div>
          <p class="eyebrow">Renewal</p>
          <h2>Renewal watchlist</h2>
          <p class="panel-copy">Listings at risk of dropping out of visibility show up here before they become a revenue leak.</p>
        </div>
        <a class="panel-link" href="/account/notifications">Preferences</a>
      </div>
      {notifications.length === 0 ? <p class="empty-copy">No renewal alerts right now.</p> : (
        <ul class="stack-list alert-list">
          {notifications.map((notification) => (
            <li class={`alert-item alert-${notification.level}`}>
              <div class="alert-head">
                <strong>{notification.listingTitle}</strong>
                <span class="badge-text">{notification.category}</span>
              </div>
              <p>{notification.message}</p>
              <div class="meta-row">
                <span>Due {notification.dueAt}</span>
                <span>{notification.ctaLabel}</span>
              </div>
            </li>
          ))}
        </ul>
      )}
    </article>

    <article class="card panel">
      <div class="panel-head">
        <div>
          <p class="eyebrow">Recent activity</p>
          <h2>Recent inbox activity</h2>
          <p class="panel-copy">Unread owner events stay visible here so you do not need to bounce into a separate notifications screen first.</p>
        </div>
        <a class="panel-link" href="/account/inbox">View all</a>
      </div>
      {inboxNotifications.length === 0 ? <p class="empty-copy">No inbox notifications yet.</p> : (
        <ul class="stack-list compact-list">
          {inboxNotifications.map((notification) => (
            <li class="list-item">
              <strong>{notification.title}</strong>
              <p>{notification.message}</p>
              <div class="meta-row">
                <span>{notification.category}</span>
                <span>{notification.created_at}</span>
              </div>
            </li>
          ))}
        </ul>
      )}
      <div class="action-row">
        <a class="button-secondary" href="/account/inbox">Open inbox</a>
        <a class="button-tertiary" href="/account/notifications">Manage settings</a>
      </div>
    </article>
  </section>

  <section class="card panel section-gap">
    <div class="panel-head">
      <div>
        <p class="eyebrow">Demand signals</p>
          <h2>Buyer demand signals</h2>
          <p class="panel-copy">Saved searches are a lightweight demand layer. Use them to understand what buyers keep coming back to.</p>
      </div>
    </div>
    {savedSearches.length === 0 ? <p class="empty-copy">No saved searches yet. Save a filter from the listings page to build buyer alerts.</p> : (
      <ul class="stack-list compact-list">
        {savedSearches.map((search) => (
          <li class="list-item">
            <strong>{search.name}</strong>
            <p>{search.last_result_count} matching listings at last save</p>
            <div class={`freshness-row ${search.new_result_count ? "freshness-hot" : ""}`}>
              <span>{search.freshness_label}</span>
            </div>
            <div class="meta-row">
              <span>{search.route_query ? `/listings/?${search.route_query}` : "/listings/"}</span>
            </div>
            <div class="action-row">
              <a class="button-secondary" href={`/api/saved-searches/visit?id=${search.id}&redirectTo=${encodeURIComponent(search.route_query ? `/listings/?${search.route_query}` : "/listings/")}`}>Open search</a>
              <form method="POST" action="/api/saved-searches/delete">
                <input type="hidden" name="id" value={search.id} />
                <input type="hidden" name="redirectTo" value="/owner/dashboard/" />
                <button type="submit" class="button-tertiary">Delete</button>
              </form>
            </div>
          </li>
        ))}
      </ul>
    )}
  </section>

  <section class="split-grid section-gap">
    <article class="card panel">
      <div class="panel-head">
        <div>
          <p class="eyebrow">Supply</p>
          <h2>Live inventory</h2>
          <p class="panel-copy">Each card shows visibility state, media coverage, and the next commercial action that actually matters. Add a stronger photo set here before you worry about promotion.</p>
        </div>
      </div>
      {listings.length === 0 ? <p class="empty-copy">No database listings yet.</p> : (
        <ul class="stack-list listing-list">
          {listings.map((listing) => {
            const imageUrls = getImageUrls(listing.image_keys);
            return (
            <li class="listing-item">
              <div class="listing-head">
                <div>
                  <strong>{listing.title}</strong>
                  <p>{listing.city} · {listing.district} · {listing.intent}</p>
                </div>
                <span class="status-chip">{listing.plan_type}</span>
              </div>
              <div class="listing-layout">
                <div class="listing-media">
                  {imageUrls.length > 0 ? (
                    <>
                      <div class="primary-media" style={`background-image:url(${imageUrls[0]})`}></div>
                      <div class="media-rail">
                        {imageUrls.slice(1, 4).map((imageUrl, railIndex) => (
                          <div class="thumb-stack">
                            <div class="thumb-media" style={`background-image:url(${imageUrl})`}></div>
                            <div class="thumb-tools">
                              <form method="POST" action="/api/upload-image/reorder">
                                <input type="hidden" name="listingSlug" value={listing.slug} />
                                <input type="hidden" name="imageIndex" value={railIndex + 1} />
                                <input type="hidden" name="direction" value="left" />
                                <button type="submit" class="thumb-action" aria-label="Move image left">←</button>
                              </form>
                              <form method="POST" action="/api/upload-image/reorder">
                                <input type="hidden" name="listingSlug" value={listing.slug} />
                                <input type="hidden" name="imageIndex" value={railIndex + 1} />
                                <input type="hidden" name="direction" value="right" />
                                <button type="submit" class="thumb-action" aria-label="Move image right">→</button>
                              </form>
                              <form method="POST" action="/api/upload-image/delete">
                                <input type="hidden" name="listingSlug" value={listing.slug} />
                                <input type="hidden" name="imageIndex" value={railIndex + 1} />
                                <button type="submit" class="thumb-action thumb-danger" aria-label="Delete image">×</button>
                              </form>
                            </div>
                          </div>
                        ))}
                        {imageUrls.length === 1 && <div class="thumb-placeholder">Add more angles</div>}
                      </div>
                      <div class="primary-tools">
                        <form method="POST" action="/api/upload-image/delete">
                          <input type="hidden" name="listingSlug" value={listing.slug} />
                          <input type="hidden" name="imageIndex" value="0" />
                          <button type="submit" class="thumb-action thumb-danger">Delete cover</button>
                        </form>
                      </div>
                    </>
                  ) : (
                    <div class="media-empty">
                      <strong>No gallery yet</strong>
                      <p>Upload 4 to 8 photos so the card and detail page stop looking provisional.</p>
                    </div>
                  )}
                </div>
                <div class="listing-main">
              <div class="meta-grid">
                <span>{listing.views_24h ?? 0} views / 24h</span>
                <span>{listing.saves ?? 0} saves</span>
                <span>{listing.enquiries} enquiries</span>
                <span>{getImageCount(listing.image_keys)} images</span>
                <span>Status: {listing.status}</span>
                {listing.trial_ends_at && <span>Trial ends: {listing.trial_ends_at}</span>}
                {listing.paid_until && <span>Paid until: {listing.paid_until}</span>}
                {listing.promoted_until && <span>Promoted until: {listing.promoted_until}</span>}
              </div>
              <div class="quality-strip">
                <span>{getImageCount(listing.image_keys) >= 4 ? "Gallery ready" : "Needs more photos"}</span>
                <span>{listing.enquiries > 0 ? "Buyer demand active" : "Awaiting enquiries"}</span>
                <a href={`/listings/${listing.slug}/`} class="quality-link">Preview public page</a>
              </div>
              <div class="performance-strip">
                <div class="performance-chip">
                  <strong>{listing.views_24h ?? 0}</strong>
                  <span>24h views</span>
                </div>
                <div class="performance-chip">
                  <strong>{listing.saves ?? 0}</strong>
                  <span>Saves</span>
                </div>
                <div class="performance-chip">
                  <strong>{listing.enquiries ?? 0}</strong>
                  <span>Enquiries</span>
                </div>
              </div>
              <div class="action-row action-row-wrap">
                <a class="button-secondary" href={`/owner/listings/${listing.slug}/`}>Open drilldown</a>
                {billingEnabled ? (
                  <>
                    <form method="POST" action="/api/billing/checkout">
                      <input type="hidden" name="listingSlug" value={listing.slug} />
                      <input type="hidden" name="planType" value="paid" />
                      <button type="submit" class="button-tertiary">{getStandardActionLabel(listing)}</button>
                    </form>
                    <form method="POST" action="/api/billing/checkout">
                      <input type="hidden" name="listingSlug" value={listing.slug} />
                      <input type="hidden" name="planType" value="promoted" />
                      <button type="submit" class="button-tertiary">{getPromotionActionLabel(listing)}</button>
                    </form>
                  </>
                ) : (
                  <span class="helper-copy">Stripe is not configured yet. Admin can still change billing state manually.</span>
                )}
              </div>
              <form class="upload-form" method="POST" action="/api/upload-image" enctype="multipart/form-data">
                <input type="hidden" name="listingSlug" value={listing.slug} />
                <label>
                  <span class="upload-label">Add photos</span>
                  <span class="upload-copy">Upload up to 8 images at once. Use one exterior, one living space, one kitchen, one bedroom, and one location/context shot.</span>
                  <input type="file" name="image" accept="image/png,image/jpeg,image/webp,image/avif" multiple required />
                </label>
                <button type="submit" class="button-secondary">Upload gallery</button>
              </form>
                </div>
              </div>
            </li>
          )})}
        </ul>
      )}
    </article>

    <div class="right-stack">
      <article class="card panel">
        <div class="panel-head">
          <div>
            <p class="eyebrow">Pipeline</p>
            <h2>Recent enquiries</h2>
            <p class="panel-copy">Most recent inbound demand on your listings.</p>
          </div>
        </div>
        <div class="compare-preview status-preview">
          <div class="compare-chip">
            <strong>{enquiryStatusCounts.new}</strong>
            <span>New enquiries</span>
          </div>
          <div class="compare-chip">
            <strong>{enquiryStatusCounts.responded}</strong>
            <span>Responded</span>
          </div>
          <div class="compare-chip">
            <strong>{enquiryStatusCounts.archived}</strong>
            <span>Archived</span>
          </div>
        </div>
        {enquiries.length === 0 ? <p class="empty-copy">No enquiries yet.</p> : (
          <ul class="stack-list compact-list">
            {enquiries.map((enquiry) => (
              <li class="list-item">
                <strong>{enquiry.applicant_name}</strong>
                <p>{enquiry.listing_title}</p>
                <div class="meta-row">
                  <span>{enquiry.contact}</span>
                  <span>Status: {enquiry.response_status ?? "new"}</span>
                </div>
                {enquiry.owner_note && <p class="inline-note">Owner note: {enquiry.owner_note}</p>}
                <form class="enquiry-status-form" method="POST" action="/api/owner/enquiries/respond">
                  <input type="hidden" name="listingSlug" value={enquiry.listing_slug} />
                  <input type="hidden" name="contact" value={enquiry.contact} />
                  <select name="responseStatus">
                    <option value="new" selected={(enquiry.response_status ?? "new") === "new"}>New</option>
                    <option value="responded" selected={enquiry.response_status === "responded"}>Responded</option>
                    <option value="archived" selected={enquiry.response_status === "archived"}>Archived</option>
                  </select>
                  <input type="text" name="ownerNote" value={enquiry.owner_note ?? ""} placeholder="Add owner note" />
                  <button type="submit" class="button-tertiary">Update</button>
                </form>
              </li>
            ))}
          </ul>
        )}
      </article>

      <article class="card panel">
        <div class="panel-head">
          <div>
            <p class="eyebrow">Revenue</p>
          <h2>Revenue log</h2>
          <p class="panel-copy">Completed upgrades and recorded billing events for this account.</p>
          </div>
        </div>
        {payments.length === 0 ? <p class="empty-copy">No payments recorded yet. New completed Stripe checkouts will appear here.</p> : (
          <ul class="stack-list compact-list">
            {payments.map((payment) => (
              <li class="list-item">
                <strong>{payment.plan_type} · {payment.amount} {String(payment.currency).toUpperCase()}</strong>
                <p>{payment.listing_slug}</p>
                <div class="meta-row">
                  <span>Status: {payment.status}</span>
                  <span>{payment.paid_at ? `Paid at: ${payment.paid_at}` : `Created: ${payment.created_at}`}</span>
                </div>
              </li>
            ))}
          </ul>
        )}
      </article>
    </div>
  </section>

  <style is:inline>
    .split-grid {
      display: grid;
      gap: 1rem;
      margin-top: 1rem;
      grid-template-columns: minmax(0, 1.45fr) minmax(0, 1fr);
    }

    .split-grid-top {
      align-items: start;
    }

    .right-stack {
      display: grid;
      gap: 1rem;
    }

    .compare-preview {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 0.75rem;
      margin-bottom: 1rem;
    }

    .compare-chip {
      display: grid;
      gap: 0.35rem;
      padding: 0.95rem 1rem;
      border-radius: 18px;
      background: var(--surface-panel-subtle);
      border: 1px solid var(--line);
    }

    .compare-chip span {
      color: var(--muted);
    }

    .verification-form {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 0.65rem;
      margin-top: 1rem;
    }

    .verification-form input {
      width: 100%;
      padding: 0.8rem 0.9rem;
      border-radius: 16px;
      border: 1px solid var(--line);
      font: inherit;
      background: var(--surface-elevated);
    }

    .status-preview {
      margin-bottom: 1rem;
    }

    .action-row-wrap,
    .alert-head,
    .listing-head {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .panel-copy {
      max-width: 42rem;
    }

    .performance-strip {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 0.75rem;
      margin: 0.9rem 0 1rem;
    }

    .performance-chip {
      display: grid;
      gap: 0.2rem;
      padding: 0.85rem 0.9rem;
      border-radius: 16px;
      background: var(--accent-1);
      border: 1px solid rgba(15, 23, 42, 0.07);
    }

    .performance-chip strong {
      font-size: 1.1rem;
      letter-spacing: -0.03em;
    }

    .performance-chip span {
      color: var(--muted);
      font-size: 0.82rem;
    }

    .badge-text,
    .status-chip {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 1.9rem;
      padding: 0.2rem 0.65rem;
      border-radius: 999px;
      font-size: 0.78rem;
      font-weight: 700;
      background: var(--surface-soft);
      color: var(--accent-strong);
      text-transform: capitalize;
    }

    .freshness-row {
      display: inline-flex;
      align-items: center;
      width: fit-content;
      padding: 0.45rem 0.7rem;
      border-radius: 999px;
      background: var(--accent-1);
      color: var(--muted-strong);
      font-size: 0.82rem;
      font-weight: 700;
    }

    .freshness-hot {
      background: var(--success-bg);
      color: var(--success-text);
    }

    .listing-item,
    .list-item,
    .alert-item {
      border-radius: 22px;
      padding: 1rem;
      background: linear-gradient(180deg, var(--surface-elevated-strong), var(--surface-panel-muted));
      border: 1px solid var(--line);
    }

    .alert-warning {
      border-color: var(--warning-border);
      background: linear-gradient(180deg, rgba(255, 251, 235, 0.95), rgba(255, 255, 255, 0.98));
    }

    .alert-critical {
      border-color: var(--danger-border);
      background: linear-gradient(180deg, rgba(254, 242, 242, 0.95), rgba(255, 255, 255, 0.98));
    }

    .meta-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.5rem 1rem;
      color: var(--muted);
      font-size: 0.95rem;
    }

    .upload-form {
      display: grid;
      gap: 0.75rem;
      padding-top: 0.25rem;
    }

    .upload-form label {
      display: grid;
      gap: 0.45rem;
    }

    .upload-label {
      font-weight: 700;
    }

