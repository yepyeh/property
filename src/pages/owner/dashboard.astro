---
import Layout from "../../layouts/Layout.astro";
import { isBillingEnabled } from "../../lib/billing";
import { getDashboardData, getDB } from "../../lib/marketplace";

const owner = Astro.locals.owner;
const { listings, enquiries, payments, notifications, savedSearches, inboxNotifications, unreadNotificationCount } = owner
  ? await getDashboardData(owner.id, getDB(Astro.locals.runtime))
  : { listings: [], enquiries: [], payments: [], notifications: [], savedSearches: [], inboxNotifications: [], unreadNotificationCount: 0 };
const uploaded = Astro.url.searchParams.get("uploaded");
const updated = Astro.url.searchParams.get("updated");
const savedSearchDeleted = Astro.url.searchParams.get("savedSearchDeleted");
const billingEnabled = isBillingEnabled(Astro.locals.runtime);

function isFutureDate(value?: string | null) {
  return Boolean(value) && new Date(value as string).getTime() > Date.now();
}

function getStandardActionLabel(listing: {
  status?: string;
  paid_until?: string | null;
  promoted_until?: string | null;
}) {
  if (listing.status === "Expired listing") return "Republish for 30 days";
  if (isFutureDate(listing.promoted_until)) return "Extend paid period";
  if (isFutureDate(listing.paid_until)) return "Extend paid period";
  return "Activate 30-day standard";
}

function getPromotionActionLabel(listing: {
  status?: string;
  promoted_until?: string | null;
}) {
  if (listing.status === "Expired listing") return "Republish with promotion";
  if (isFutureDate(listing.promoted_until)) return "Extend promotion";
  return "Promote for 7 days";
}

function getImageCount(value: unknown) {
  if (typeof value !== "string" || !value) return 0;

  try {
    const parsed = JSON.parse(value);
    return Array.isArray(parsed) ? parsed.length : 0;
  } catch {
    return 0;
  }
}
---

<Layout title="Owner Dashboard | Property App 2026" description="Review submitted listings and enquiries from the marketplace backend.">
  <section class="page-hero card">
    <div class="hero-copy">
      <p class="eyebrow">Owner workspace</p>
      <h1 class="hero-title">Operate listings, billing, and follow-up from one surface.</h1>
      <p class="hero-text">
        Inventory health, enquiry flow, and monetization should stay visible without bouncing across scattered tools.
        This dashboard keeps the supply-side loop legible.
      </p>
    </div>
    <div class="hero-actions">
      <a class="button-primary" href="/submit-listing/">Post a listing</a>
      <a class="button-secondary" href="/account/inbox">Open inbox</a>
      <a class="button-secondary" href="/account/notifications">Notification settings</a>
    </div>
  </section>

  <section class="stats-grid">
    <article class="card stat-card">
      <span class="stat-label">Inventory</span>
      <strong>{listings.length}</strong>
      <span class="stat-copy">Database listings</span>
    </article>
    <article class="card stat-card">
      <span class="stat-label">Pipeline</span>
      <strong>{enquiries.length}</strong>
      <span class="stat-copy">Enquiries received</span>
    </article>
    <article class="card stat-card">
      <span class="stat-label">Inbox</span>
      <strong>{unreadNotificationCount}</strong>
      <span class="stat-copy">Unread notifications</span>
    </article>
  </section>

  <section class="card profile-panel">
    <div class="profile-block">
      <p class="eyebrow">Signed in as</p>
      <strong>{owner?.full_name}</strong>
      <span>{owner?.email}</span>
    </div>
    <div class="profile-block">
      <p class="eyebrow">Plan tier</p>
      <strong>{owner?.plan_tier ?? "starter"}</strong>
      <span>7-day free trial, paid listing upgrades, promoted placement</span>
    </div>
    <form method="POST" action="/api/auth/logout" class="profile-actions">
      <button class="button-secondary" type="submit">Log out</button>
    </form>
  </section>

  {uploaded && <div class="card flash-banner">Image uploaded for <code>{uploaded}</code>.</div>}
  {updated && <div class="card flash-banner">Billing state updated for <code>{updated}</code>.</div>}
  {savedSearchDeleted && <div class="card flash-banner">Saved search deleted.</div>}

  <section class="split-grid split-grid-top">
    <article class="card panel">
      <div class="panel-head">
        <div>
          <p class="eyebrow">Renewal</p>
          <h2>Expiry notifications</h2>
          <p class="panel-copy">Trial, paid, and promotion reminders are prioritized here first.</p>
        </div>
        <a class="panel-link" href="/account/notifications">Preferences</a>
      </div>
      {notifications.length === 0 ? <p class="empty-copy">No renewal alerts right now.</p> : (
        <ul class="stack-list alert-list">
          {notifications.map((notification) => (
            <li class={`alert-item alert-${notification.level}`}>
              <div class="alert-head">
                <strong>{notification.listingTitle}</strong>
                <span class="badge-text">{notification.category}</span>
              </div>
              <p>{notification.message}</p>
              <div class="meta-row">
                <span>Due {notification.dueAt}</span>
                <span>{notification.ctaLabel}</span>
              </div>
            </li>
          ))}
        </ul>
      )}
    </article>

    <article class="card panel">
      <div class="panel-head">
        <div>
          <p class="eyebrow">Recent activity</p>
          <h2>Notification inbox</h2>
          <p class="panel-copy">Unread account events stay visible without opening a separate admin flow.</p>
        </div>
        <a class="panel-link" href="/account/inbox">View all</a>
      </div>
      {inboxNotifications.length === 0 ? <p class="empty-copy">No inbox notifications yet.</p> : (
        <ul class="stack-list compact-list">
          {inboxNotifications.map((notification) => (
            <li class="list-item">
              <strong>{notification.title}</strong>
              <p>{notification.message}</p>
              <div class="meta-row">
                <span>{notification.category}</span>
                <span>{notification.created_at}</span>
              </div>
            </li>
          ))}
        </ul>
      )}
      <div class="action-row">
        <a class="button-secondary" href="/account/inbox">Open inbox</a>
        <a class="button-tertiary" href="/account/notifications">Manage settings</a>
      </div>
    </article>
  </section>

  <section class="card panel section-gap">
    <div class="panel-head">
      <div>
        <p class="eyebrow">Demand signals</p>
        <h2>Saved searches</h2>
        <p class="panel-copy">Buyer intent worth revisiting later or converting into alerts.</p>
      </div>
    </div>
    {savedSearches.length === 0 ? <p class="empty-copy">No saved searches yet. Save a filter from the listings page to build buyer alerts.</p> : (
      <ul class="stack-list compact-list">
        {savedSearches.map((search) => (
          <li class="list-item">
            <strong>{search.name}</strong>
            <p>{search.last_result_count} matching listings at last save</p>
            <div class="meta-row">
              <span>{search.route_query ? `/listings/?${search.route_query}` : "/listings/"}</span>
            </div>
            <div class="action-row">
              <a class="button-secondary" href={search.route_query ? `/listings/?${search.route_query}` : "/listings/"}>Open search</a>
              <form method="POST" action="/api/saved-searches/delete">
                <input type="hidden" name="id" value={search.id} />
                <button type="submit" class="button-tertiary">Delete</button>
              </form>
            </div>
          </li>
        ))}
      </ul>
    )}
  </section>

  <section class="split-grid section-gap">
    <article class="card panel">
      <div class="panel-head">
        <div>
          <p class="eyebrow">Supply</p>
          <h2>Submitted listings</h2>
          <p class="panel-copy">Each listing shows current plan state, media count, and next billing action.</p>
        </div>
      </div>
      {listings.length === 0 ? <p class="empty-copy">No database listings yet.</p> : (
        <ul class="stack-list listing-list">
          {listings.map((listing) => (
            <li class="listing-item">
              <div class="listing-head">
                <div>
                  <strong>{listing.title}</strong>
                  <p>{listing.city} · {listing.district} · {listing.intent}</p>
                </div>
                <span class="status-chip">{listing.plan_type}</span>
              </div>
              <div class="meta-grid">
                <span>{listing.enquiries} enquiries</span>
                <span>{getImageCount(listing.image_keys)} images</span>
                <span>Status: {listing.status}</span>
                {listing.trial_ends_at && <span>Trial ends: {listing.trial_ends_at}</span>}
                {listing.paid_until && <span>Paid until: {listing.paid_until}</span>}
                {listing.promoted_until && <span>Promoted until: {listing.promoted_until}</span>}
              </div>
              <div class="action-row action-row-wrap">
                {billingEnabled ? (
                  <>
                    <form method="POST" action="/api/billing/checkout">
                      <input type="hidden" name="listingSlug" value={listing.slug} />
                      <input type="hidden" name="planType" value="paid" />
                      <button type="submit" class="button-secondary">{getStandardActionLabel(listing)}</button>
                    </form>
                    <form method="POST" action="/api/billing/checkout">
                      <input type="hidden" name="listingSlug" value={listing.slug} />
                      <input type="hidden" name="planType" value="promoted" />
                      <button type="submit" class="button-tertiary">{getPromotionActionLabel(listing)}</button>
                    </form>
                  </>
                ) : (
                  <span class="helper-copy">Stripe is not configured yet. Admin can still change billing state manually.</span>
                )}
              </div>
              <form class="upload-form" method="POST" action="/api/upload-image" enctype="multipart/form-data">
                <input type="hidden" name="listingSlug" value={listing.slug} />
                <label>
                  <span class="upload-label">Add photo</span>
                  <input type="file" name="image" accept="image/png,image/jpeg,image/webp,image/avif" required />
                </label>
                <button type="submit" class="button-secondary">Upload</button>
              </form>
            </li>
          ))}
        </ul>
      )}
    </article>

    <div class="right-stack">
      <article class="card panel">
        <div class="panel-head">
          <div>
            <p class="eyebrow">Pipeline</p>
            <h2>Recent enquiries</h2>
            <p class="panel-copy">Most recent inbound demand on your listings.</p>
          </div>
        </div>
        {enquiries.length === 0 ? <p class="empty-copy">No enquiries yet.</p> : (
          <ul class="stack-list compact-list">
            {enquiries.map((enquiry) => (
              <li class="list-item">
                <strong>{enquiry.applicant_name}</strong>
                <p>{enquiry.listing_title}</p>
                <div class="meta-row"><span>{enquiry.contact}</span></div>
              </li>
            ))}
          </ul>
        )}
      </article>

      <article class="card panel">
        <div class="panel-head">
          <div>
            <p class="eyebrow">Revenue</p>
            <h2>Payment history</h2>
            <p class="panel-copy">Completed Stripe checkouts and plan changes recorded against this account.</p>
          </div>
        </div>
        {payments.length === 0 ? <p class="empty-copy">No payments recorded yet. New completed Stripe checkouts will appear here.</p> : (
          <ul class="stack-list compact-list">
            {payments.map((payment) => (
              <li class="list-item">
                <strong>{payment.plan_type} · {payment.amount} {String(payment.currency).toUpperCase()}</strong>
                <p>{payment.listing_slug}</p>
                <div class="meta-row">
                  <span>Status: {payment.status}</span>
                  <span>{payment.paid_at ? `Paid at: ${payment.paid_at}` : `Created: ${payment.created_at}`}</span>
                </div>
              </li>
            ))}
          </ul>
        )}
      </article>
    </div>
  </section>

  <style>
    .page-hero,
    .profile-panel,
    .panel,
    .stat-card,
    .flash-banner {
      padding: 1.5rem;
    }

    .page-hero,
    .profile-panel,
    .panel,
    .stat-card,
    .flash-banner {
      background: rgba(255, 255, 255, 0.88);
      box-shadow: 0 1px 2px rgba(16, 24, 40, 0.04), 0 16px 40px rgba(16, 24, 40, 0.06);
    }

    .page-hero,
    .profile-panel,
    .panel-head,
    .hero-actions,
    .action-row,
    .alert-head,
    .meta-row,
    .listing-head {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .section-gap,
    .profile-panel,
    .flash-banner {
      margin-top: 1rem;
    }

    .hero-copy {
      max-width: 46rem;
    }

    .hero-title {
      margin: 0;
      font-size: clamp(2rem, 4vw, 3.1rem);
      letter-spacing: -0.06em;
      line-height: 1;
    }

    .hero-text,
    .panel-copy,
    .list-item p,
    .listing-item p,
    .helper-copy,
    .empty-copy,
    .profile-block span,
    .meta-row,
    .stat-copy {
      color: var(--muted);
    }

    .hero-text,
    .panel-copy,
    .list-item p,
    .listing-item p,
    .helper-copy,
    .empty-copy {
      margin: 0;
      line-height: 1.65;
    }

    .eyebrow,
    .stat-label {
      margin: 0 0 0.45rem;
      font-size: 0.78rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--muted);
    }

    .hero-actions,
    .action-row {
      align-items: center;
    }

    .stats-grid,
    .split-grid {
      display: grid;
      gap: 1rem;
      margin-top: 1rem;
    }

    .stats-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .split-grid {
      grid-template-columns: minmax(0, 1.45fr) minmax(0, 1fr);
    }

    .split-grid-top {
      align-items: start;
    }

    .right-stack {
      display: grid;
      gap: 1rem;
    }

    .stat-card strong {
      display: block;
      margin-bottom: 0.35rem;
      font-size: 2.25rem;
      line-height: 1;
      letter-spacing: -0.06em;
    }

    .profile-panel {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1rem;
      align-items: end;
    }

    .profile-block,
    .profile-actions {
      min-width: 0;
    }

    .panel h2 {
      margin: 0;
      font-size: 1.3rem;
      letter-spacing: -0.03em;
    }

    .panel-link {
      text-decoration: none;
      font-weight: 700;
      color: var(--accent-strong);
    }

    .stack-list {
      list-style: none;
      margin: 0;
      padding: 0;
      display: grid;
      gap: 0.85rem;
    }

    .list-item,
    .listing-item,
    .alert-item {
      border: 1px solid var(--line);
      border-radius: 20px;
      padding: 1rem;
      background: linear-gradient(180deg, rgba(255,255,255,0.98), rgba(248,250,252,0.95));
    }

    .list-item,
    .alert-item {
      display: grid;
      gap: 0.45rem;
    }

    .listing-item {
      display: grid;
      gap: 0.85rem;
    }

    .badge-text,
    .status-chip {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 1.9rem;
      padding: 0.2rem 0.65rem;
      border-radius: 999px;
      font-size: 0.78rem;
      font-weight: 700;
      background: rgba(127, 86, 217, 0.12);
      color: var(--accent-strong);
      text-transform: capitalize;
    }

    .alert-warning {
      border-color: rgba(217, 119, 6, 0.18);
      background: linear-gradient(180deg, rgba(255, 251, 235, 0.95), rgba(255, 255, 255, 0.98));
    }

    .alert-critical {
      border-color: rgba(220, 38, 38, 0.18);
      background: linear-gradient(180deg, rgba(254, 242, 242, 0.95), rgba(255, 255, 255, 0.98));
    }

    .meta-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.5rem 1rem;
      color: var(--muted);
      font-size: 0.95rem;
    }

    .upload-form {
      display: grid;
      gap: 0.75rem;
      padding-top: 0.25rem;
    }

    .upload-form label {
      display: grid;
      gap: 0.45rem;
    }

    .upload-label {
      font-weight: 700;
      color: var(--text);
    }

    .upload-form input[type="file"] {
      width: 100%;
      border: 1px solid var(--line);
      border-radius: 14px;
      background: white;
      padding: 0.9rem 1rem;
      color: var(--muted);
    }

    .button-primary,
    .button-secondary,
    .button-tertiary {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 2.75rem;
      border-radius: 999px;
      padding: 0.82rem 1.05rem;
      font: inherit;
      font-weight: 700;
      text-decoration: none;
      cursor: pointer;
      transition: transform 0.16s ease, box-shadow 0.16s ease, border-color 0.16s ease;
    }

    .button-primary:hover,
    .button-secondary:hover,
    .button-tertiary:hover {
      transform: translateY(-1px);
    }

    .button-primary {
      border: none;
      background: linear-gradient(135deg, #12b76a, #079455);
      color: white;
      box-shadow: 0 12px 24px rgba(18, 183, 106, 0.2);
    }

    .button-secondary {
      border: 1px solid var(--line-strong);
      background: white;
      color: var(--text);
      box-shadow: 0 1px 2px rgba(16, 24, 40, 0.05);
    }

    .button-tertiary {
      border: 1px solid rgba(127, 86, 217, 0.18);
      background: rgba(127, 86, 217, 0.06);
      color: var(--accent-strong);
    }

    .flash-banner {
      border-left: 4px solid rgba(18, 183, 106, 0.35);
      color: #067647;
      font-weight: 700;
    }

    .listing-head strong,
    .list-item strong,
    .alert-item strong,
    .profile-block strong {
      display: block;
      margin-bottom: 0.2rem;
    }

    .action-row-wrap {
      align-items: stretch;
    }

    @media (max-width: 1100px) {
      .split-grid {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 820px) {
      .stats-grid,
      .profile-panel,
      .meta-grid {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 760px) {
      .page-hero,
      .profile-panel,
      .panel-head,
      .hero-actions,
      .action-row,
      .listing-head,
      .meta-row {
        display: grid;
      }

      .hero-actions,
      .action-row,
      .profile-actions {
        width: 100%;
      }

      .button-primary,
      .button-secondary,
      .button-tertiary {
        width: 100%;
      }
    }
  </style>
</Layout>
