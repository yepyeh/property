---
import Layout from "../../layouts/Layout.astro";
import { getDashboardData, getDB } from "../../lib/marketplace";

const { listings, enquiries } = await getDashboardData(getDB(Astro.locals.runtime));
---

<Layout title="Owner Dashboard | Property App 2026" description="Review submitted listings and enquiries from the marketplace backend.">
  <section class="page-head card">
    <div>
      <span class="pill">Owner dashboard</span>
      <h1 class="section-title">Listings and enquiries</h1>
      <p class="section-copy">This is the first operational backend surface: what got submitted, and who enquired about it.</p>
    </div>
    <div class="actions">
      <a class="primary" href="/submit-listing/">Post a listing</a>
      <form method="POST" action="/api/auth/logout">
        <button class="ghost" type="submit">Log out</button>
      </form>
    </div>
  </section>

  <section class="stats-grid">
    <article class="card stat"><strong>{listings.length}</strong><span>database listings</span></article>
    <article class="card stat"><strong>{enquiries.length}</strong><span>enquiries received</span></article>
  </section>

  <section class="panel-grid">
    <article class="card panel">
      <h2>Submitted listings</h2>
      {listings.length === 0 ? <p>No database listings yet.</p> : (
        <ul>
          {listings.map((listing) => (
            <li>
              <strong>{listing.title}</strong>
              <span>{listing.city} · {listing.district} · {listing.intent}</span>
              <span>{listing.enquiries} enquiries</span>
            </li>
          ))}
        </ul>
      )}
    </article>

    <article class="card panel">
      <h2>Recent enquiries</h2>
      {enquiries.length === 0 ? <p>No enquiries yet.</p> : (
        <ul>
          {enquiries.map((enquiry) => (
            <li>
              <strong>{enquiry.applicant_name}</strong>
              <span>{enquiry.listing_title}</span>
              <span>{enquiry.contact}</span>
            </li>
          ))}
        </ul>
      )}
    </article>
  </section>

  <style>
    .page-head, .panel { padding: 1.4rem; }
    .page-head {
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      align-items: flex-start;
      margin-bottom: 1rem;
    }
    .primary {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0.95rem 1.2rem;
      border-radius: 999px;
      background: linear-gradient(135deg, var(--accent), var(--accent-strong));
      color: white;
      font-weight: 700;
      text-decoration: none;
    }
    .ghost {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0.95rem 1.2rem;
      border-radius: 999px;
      border: 1px solid var(--line);
      background: rgba(255,255,255,0.72);
      color: var(--text);
      font-weight: 700;
      cursor: pointer;
    }
    .actions {
      display: flex;
      gap: 0.75rem;
      flex-wrap: wrap;
    }
    .stats-grid, .panel-grid {
      display: grid;
      gap: 1rem;
    }
    .stats-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); margin-bottom: 1rem; }
    .panel-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .stat { padding: 1.2rem; }
    .stat strong { display:block; font-size: 2rem; }
    .stat span, .panel p, .panel li span { color: var(--muted); }
    .panel ul { list-style: none; padding: 0; margin: 1rem 0 0; display: grid; gap: 0.9rem; }
    .panel li { display:grid; gap:0.2rem; padding: 0.9rem; border-radius: 18px; background: rgba(255,255,255,0.55); }
    @media (max-width: 960px) {
      .stats-grid, .panel-grid, .page-head { grid-template-columns: 1fr; display:grid; }
    }
  </style>
</Layout>
