---
import Layout from "../../layouts/Layout.astro";
import { getDashboardData, getDB } from "../../lib/marketplace";

const owner = Astro.locals.owner;
const { listings, enquiries } = owner
  ? await getDashboardData(owner.id, getDB(Astro.locals.runtime))
  : { listings: [], enquiries: [] };
const uploaded = Astro.url.searchParams.get("uploaded");

function getImageCount(value: unknown) {
  if (typeof value !== "string" || !value) return 0;

  try {
    const parsed = JSON.parse(value);
    return Array.isArray(parsed) ? parsed.length : 0;
  } catch {
    return 0;
  }
}
---

<Layout title="Owner Dashboard | Property App 2026" description="Review submitted listings and enquiries from the marketplace backend.">
  <section class="page-head card">
    <div>
      <span class="pill">Owner dashboard</span>
      <h1 class="section-title">Listings and enquiries</h1>
      <p class="section-copy">
        This dashboard is owner-scoped. Listings, images, and enquiries belong to the signed-in account, which is the
        baseline needed for trial windows, paid upgrades, and promoted inventory.
      </p>
    </div>
    <div class="actions">
      <a class="primary" href="/submit-listing/">Post a listing</a>
      <form method="POST" action="/api/auth/logout">
        <button class="ghost" type="submit">Log out</button>
      </form>
    </div>
  </section>

  <section class="stats-grid">
    <article class="card stat"><strong>{listings.length}</strong><span>database listings</span></article>
    <article class="card stat"><strong>{enquiries.length}</strong><span>enquiries received</span></article>
  </section>

  <section class="owner-card card">
    <strong>{owner?.full_name}</strong>
    <span>{owner?.email}</span>
    <span>Account tier: {owner?.plan_tier ?? "starter"}</span>
    <span>Monetization model: 7-day free trial, paid extension, promoted placement</span>
  </section>

  {uploaded && (
    <div class="card flash">
      Image uploaded for <code>{uploaded}</code>.
    </div>
  )}

  <section class="panel-grid">
    <article class="card panel">
      <h2>Submitted listings</h2>
      {listings.length === 0 ? <p>No database listings yet.</p> : (
        <ul>
          {listings.map((listing) => (
            <li>
              <strong>{listing.title}</strong>
              <span>{listing.city} · {listing.district} · {listing.intent}</span>
              <span>{listing.enquiries} enquiries</span>
              <span>{getImageCount(listing.image_keys)} images</span>
              <span>Plan: {listing.plan_type}</span>
              {listing.trial_ends_at && <span>Trial ends: {listing.trial_ends_at}</span>}
              {listing.promoted_until && <span>Promoted until: {listing.promoted_until}</span>}
              <form class="upload-form" method="POST" action="/api/upload-image" enctype="multipart/form-data">
                <input type="hidden" name="listingSlug" value={listing.slug} />
                <label>
                  Add photo
                  <input type="file" name="image" accept="image/png,image/jpeg,image/webp,image/avif" required />
                </label>
                <button type="submit">Upload</button>
              </form>
            </li>
          ))}
        </ul>
      )}
    </article>

    <article class="card panel">
      <h2>Recent enquiries</h2>
      {enquiries.length === 0 ? <p>No enquiries yet.</p> : (
        <ul>
          {enquiries.map((enquiry) => (
            <li>
              <strong>{enquiry.applicant_name}</strong>
              <span>{enquiry.listing_title}</span>
              <span>{enquiry.contact}</span>
            </li>
          ))}
        </ul>
      )}
    </article>
  </section>

  <style>
    .page-head, .panel { padding: 1.4rem; }
    .owner-card {
      display: grid;
      gap: 0.35rem;
      padding: 1.2rem;
      margin-bottom: 1rem;
    }
    .flash {
      padding: 1rem 1.2rem;
      margin-bottom: 1rem;
      color: var(--accent-strong);
      font-weight: 700;
    }
    .page-head {
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      align-items: flex-start;
      margin-bottom: 1rem;
    }
    .primary {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0.95rem 1.2rem;
      border-radius: 999px;
      background: linear-gradient(135deg, var(--accent), var(--accent-strong));
      color: white;
      font-weight: 700;
      text-decoration: none;
    }
    .ghost {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0.95rem 1.2rem;
      border-radius: 999px;
      border: 1px solid var(--line);
      background: rgba(255,255,255,0.72);
      color: var(--text);
      font-weight: 700;
      cursor: pointer;
    }
    .actions {
      display: flex;
      gap: 0.75rem;
      flex-wrap: wrap;
    }
    .stats-grid, .panel-grid {
      display: grid;
      gap: 1rem;
    }
    .stats-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); margin-bottom: 1rem; }
    .panel-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .stat { padding: 1.2rem; }
    .stat strong { display:block; font-size: 2rem; }
    .stat span, .panel p, .panel li span { color: var(--muted); }
    .panel ul { list-style: none; padding: 0; margin: 1rem 0 0; display: grid; gap: 0.9rem; }
    .panel li { display:grid; gap:0.2rem; padding: 0.9rem; border-radius: 18px; background: rgba(255,255,255,0.55); }
    .upload-form {
      display: grid;
      gap: 0.6rem;
      margin-top: 0.6rem;
    }
    .upload-form label {
      display: grid;
      gap: 0.35rem;
      color: var(--muted);
      font-size: 0.92rem;
      font-weight: 600;
    }
    .upload-form input[type="file"] {
      width: 100%;
      padding: 0.85rem 1rem;
      border-radius: 16px;
      border: 1px solid var(--line);
      background: rgba(255,255,255,0.8);
      font: inherit;
    }
    .upload-form button {
      justify-self: start;
      padding: 0.85rem 1rem;
      border: none;
      border-radius: 999px;
      background: var(--bg-deep);
      color: white;
      font-weight: 700;
      cursor: pointer;
    }
    @media (max-width: 960px) {
      .stats-grid, .panel-grid, .page-head { grid-template-columns: 1fr; display:grid; }
    }
  </style>
</Layout>
