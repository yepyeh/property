---
import Layout from "../../../layouts/Layout.astro";
import WorkspaceHero from "../../../components/workspace/WorkspaceHero.astro";
import WorkspaceStats from "../../../components/workspace/WorkspaceStats.astro";
import { Activity, Clock3, Users } from "lucide-react";
import { getOwnerListingDetail } from "../../../lib/dashboard";
import { getDB } from "../../../lib/runtime";

const owner = Astro.locals.owner;
const t = Astro.locals.t || ((value: string) => value);

if (!owner || !["owner", "admin"].includes(owner.role)) {
  return Astro.redirect("/login");
}

const slug = Astro.params.slug || "";
const { listing, enquiries, payments, insights, auctionEvents, auctionDemand } = await getOwnerListingDetail(owner.id, slug, getDB(Astro.locals.runtime));
const auctionEventAdded = Astro.url.searchParams.get("auctionEventAdded") === "1";

if (!listing) {
  return Astro.redirect("/owner/dashboard/");
}

function getImageUrls(value: unknown) {
  if (typeof value !== "string" || !value) return [] as string[];
  try {
    const parsed = JSON.parse(value);
    return Array.isArray(parsed) ? parsed.map((key) => `/media/${key}`) : [];
  } catch {
    return [] as string[];
  }
}

const imageUrls = getImageUrls(listing.image_keys);
---

<Layout title={`${listing.title} | ${t("Owner listing")}`} description={t("Review listing-specific demand, media, and payments.")}>
  <WorkspaceHero
    eyebrow={t("Listing drilldown")}
    title={listing.title}
    text={t("Use this view to evaluate one listing instead of scanning the whole dashboard. Demand, media, and paid visibility are easier to judge at listing scope.")}
    actions={[
      { href: "/owner/dashboard/", label: t("Back to dashboard"), kind: "secondary" },
      { href: `/listings/${listing.slug}/`, label: t("Open public page"), kind: "secondary" },
    ]}
  />

  <WorkspaceStats
    items={[
      { label: "Views", value: listing.views_24h ?? 0, copy: "Last 24 hours" },
      { label: "Saves", value: listing.saves ?? 0, copy: "Buyer shortlists" },
      { label: "Enquiries", value: listing.enquiries ?? 0, copy: "Total enquiries" },
      { label: listing.sale_mode === "auction" ? "Watchers" : "Payments", value: listing.sale_mode === "auction" ? (auctionDemand?.watcherCount ?? 0) : payments.length, copy: listing.sale_mode === "auction" ? "Auction interest" : "Recorded upgrades" },
    ]}
  />

  {auctionEventAdded && <p class="auction-banner">{t("Auction update published. Watchers and registered bidders can now see the new event.")}</p>}

  <section class="split-grid section-gap">
    <article class="card panel">
      <div class="panel-head">
        <div>
          <p class="eyebrow">Listing health</p>
          <h2>Visibility snapshot</h2>
          <p class="panel-copy">This is the fastest way to judge whether the listing is presentation-ready and commercially active.</p>
        </div>
      </div>
      <div class="meta-grid">
        <span>Plan: {listing.plan_type}</span>
        <span>Status: {listing.status}</span>
        <span>{listing.city} · {listing.district} · {listing.ward}</span>
        <span>{listing.intent}</span>
        {listing.trial_ends_at && <span>Trial ends: {listing.trial_ends_at}</span>}
        {listing.paid_until && <span>Paid until: {listing.paid_until}</span>}
        {listing.promoted_until && <span>Promoted until: {listing.promoted_until}</span>}
      </div>
      <div class="performance-strip">
        <div class="performance-chip"><strong>{imageUrls.length}</strong><span>Gallery images</span></div>
        <div class="performance-chip"><strong>{listing.views_24h ?? 0}</strong><span>Views / 24h</span></div>
        <div class="performance-chip"><strong>{listing.saves ?? 0}</strong><span>Saves</span></div>
        <div class="performance-chip"><strong>{listing.enquiries ?? 0}</strong><span>Enquiries</span></div>
      </div>
      {imageUrls.length === 0 ? <p class="empty-copy">No images uploaded yet.</p> : (
        <div class="gallery-grid">
          {imageUrls.map((imageUrl) => (
            <div class="gallery-tile" style={`background-image:url(${imageUrl})`}></div>
          ))}
        </div>
      )}
    </article>

    <div class="right-stack">
      {insights && (
        <article class="card panel">
          <div class="panel-head">
            <div>
              <p class="eyebrow">Owner insights</p>
              <h2>What the market is telling you</h2>
              <p class="panel-copy">This is the operator layer: how the listing sits in its district and what the next move should probably be.</p>
            </div>
          </div>
          <div class="insight-stack">
            <div class="insight-box">
              <strong>Visible district band</strong>
              <span>{insights.marketBand}</span>
            </div>
            <div class="insight-box">
              <strong>Market pace</strong>
              <span>{insights.marketPace}</span>
            </div>
            <div class="insight-box">
              <strong>Demand signal</strong>
              <span>{insights.demandLabel}</span>
            </div>
            <div class="insight-box">
              <strong>Listing response</strong>
              <span>{insights.performanceLabel}</span>
            </div>
          </div>
          <div class="operator-note">
            <strong>Pricing context</strong>
            <p>{insights.pricingPositionLabel}</p>
          </div>
          <div class="operator-note next-action">
            <strong>Recommended next action</strong>
            <p>{insights.nextAction}</p>
          </div>
          <div class="chip-row">
            {insights.bestFor.map((item) => <span>{item}</span>)}
          </div>
        </article>
      )}

      {listing.sale_mode === "auction" && (
        <article class="card panel">
          <div class="panel-head">
            <div>
              <p class="eyebrow">Auction operations</p>
              <h2>Watchers, bidders, and live updates</h2>
              <p class="panel-copy">This is the owner-side control layer. Publish meaningful auction events so serious buyers feel looked after before a full live bidding engine exists.</p>
            </div>
          </div>
          <div class="performance-strip">
            <div class="performance-chip"><strong>{auctionDemand?.watcherCount ?? 0}</strong><span>Watching</span></div>
            <div class="performance-chip"><strong>{auctionDemand?.bidderCount ?? 0}</strong><span>Registered bidders</span></div>
            <div class="performance-chip"><strong>{listing.auction_starting_price_label ?? "Set"}</strong><span>Opening guide</span></div>
            <div class="performance-chip"><strong>{listing.auction_reserve_price_label ?? "Private"}</strong><span>Reserve</span></div>
          </div>
          <form class="auction-event-form" method="POST" action="/api/owner/auction-events">
            <input type="hidden" name="listingSlug" value={listing.slug} />
            <input type="hidden" name="redirectTo" value={`/owner/listings/${listing.slug}/`} />
            <label>
              <span>Event type</span>
              <select name="eventType">
                <option value="registration_open">Registration open</option>
                <option value="starting_soon">Starting soon</option>
                <option value="bid_placed">Bid placed</option>
                <option value="reserve_met">Reserve met</option>
                <option value="extended">Extended</option>
                <option value="ending_soon">Ending soon</option>
                <option value="sold">Sold</option>
                <option value="passed_in">Passed in</option>
                <option value="status_update">Status update</option>
              </select>
            </label>
            <label>
              <span>Short title</span>
              <input type="text" name="title" placeholder="Reserve met" />
            </label>
            <label>
              <span>Message</span>
              <textarea name="message" rows="3" placeholder="Explain what changed and what a watcher or bidder should expect next."></textarea>
            </label>
            <div class="meta-grid">
              <label>
                <span>Value label</span>
                <input type="text" name="valueLabel" placeholder="Current bid 6.2B VND" />
              </label>
              <label>
                <span>Numeric value</span>
                <input type="number" name="numericValue" min="0" step="0.01" placeholder="6200000000" />
              </label>
            </div>
            <button type="submit" class="button-secondary">Publish auction update</button>
          </form>
          {auctionEvents.length === 0 ? <p class="empty-copy">No auction events published yet.</p> : (
            <ul class="stack-list compact-list">
              {auctionEvents.map((event) => (
                <li class="list-item">
                  <div class="item-title">
                    <Activity className="h-5 w-5 item-icon accent-icon" strokeWidth={1.5} />
                    <strong>{event.title}</strong>
                  </div>
                  <p>{event.message}</p>
                  <div class="meta-row">
                    <span>{event.event_type}</span>
                    {event.value_label && <span>{event.value_label}</span>}
                    <span class="meta-with-icon"><Clock3 className="h-5 w-5 item-icon" strokeWidth={1.5} />{event.created_at}</span>
                  </div>
                </li>
              ))}
            </ul>
          )}
        </article>
      )}

      <article class="card panel">
        <div class="panel-head">
          <div>
            <p class="eyebrow">Demand</p>
            <h2>Enquiry thread</h2>
            <p class="panel-copy">Keep one listing’s pipeline visible instead of mixing it into the full owner inbox.</p>
          </div>
        </div>
        {enquiries.length === 0 ? <p class="empty-copy">No enquiries for this listing yet.</p> : (
          <ul class="stack-list compact-list">
            {enquiries.map((enquiry) => (
              <li class="list-item">
                <div class="item-title">
                  <Users className="h-5 w-5 item-icon accent-icon" strokeWidth={1.5} />
                  <strong>{enquiry.applicant_name}</strong>
                </div>
                <div class="meta-row">
                  <span>{enquiry.contact}</span>
                  <span>Status: {enquiry.response_status ?? "new"}</span>
                </div>
                <p>{enquiry.message}</p>
                {enquiry.owner_note && <p class="inline-note">Owner note: {enquiry.owner_note}</p>}
                <div class="meta-row">
                  <span>{enquiry.preferred_time || "No preferred time"}</span>
                  <span class="meta-with-icon"><Clock3 className="h-5 w-5 item-icon" strokeWidth={1.5} />{enquiry.responded_at ? `Updated ${enquiry.responded_at}` : enquiry.created_at}</span>
                </div>
              </li>
            ))}
          </ul>
        )}
      </article>

      <article class="card panel">
        <div class="panel-head">
          <div>
            <p class="eyebrow">Billing</p>
            <h2>Upgrade history</h2>
            <p class="panel-copy">Recorded plan changes tied to this one listing.</p>
          </div>
        </div>
        {payments.length === 0 ? <p class="empty-copy">No payments recorded for this listing yet.</p> : (
          <ul class="stack-list compact-list">
            {payments.map((payment) => (
              <li class="list-item">
                <div class="item-title">
                  <Activity className="h-5 w-5 item-icon" strokeWidth={1.5} />
                  <strong>{payment.plan_type} · {payment.amount} {String(payment.currency).toUpperCase()}</strong>
                </div>
                <div class="meta-row">
                  <span>Status: {payment.status}</span>
                  <span class="meta-with-icon"><Clock3 className="h-5 w-5 item-icon" strokeWidth={1.5} />{payment.paid_at ? `Paid at ${payment.paid_at}` : payment.created_at}</span>
                </div>
                <p>{payment.stripe_session_id}</p>
              </li>
            ))}
          </ul>
        )}
      </article>
    </div>
  </section>

  <style is:inline>
    .auction-banner {
      margin: 0 0 var(--space-m);
      padding: var(--space-s) var(--space-m);
      border-radius: var(--radius-lg);
      background: color-mix(in srgb, var(--brand-soft) 65%, var(--surface-elevated-strong));
      border: 1px solid color-mix(in srgb, var(--brand) 18%, var(--line));
      color: var(--text);
      font-weight: 600;
    }
    .split-grid {
      display: grid;
      grid-template-columns: minmax(0, 1.3fr) minmax(0, 1fr);
      gap: var(--space-m);
    }
    .right-stack {
      display: grid;
      gap: var(--space-m);
    }
    .meta-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: var(--space-s);
      margin-bottom: var(--space-m);
    }
    .meta-grid span {
      padding: var(--space-s) var(--space-m);
      border-radius: var(--radius-lg);
      background: var(--accent-1);
      color: var(--muted-strong);
      font-weight: 600;
    }
    .performance-strip {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: var(--space-s);
      margin-bottom: var(--space-m);
    }
    .performance-chip {
      display: grid;
      gap: calc(var(--space-2xs) * 1.1);
      padding: var(--space-s) 0;
      border-radius: 0;
      background: transparent;
    }
    .performance-chip strong {
      font-size: var(--text-lg);
      letter-spacing: -0.03em;
      color: var(--text);
    }
    .performance-chip span,
    .panel-copy,
    .list-item p,
    .inline-note {
      color: var(--muted);
    }
    .insight-stack {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: var(--space-s);
      margin-bottom: var(--space-m);
    }
    .insight-box,
    .operator-note {
      display: grid;
      gap: calc(var(--space-2xs) * 1.1);
      padding: var(--space-m);
      border-radius: var(--radius-lg);
      background: color-mix(in srgb, var(--surface-panel-subtle) 72%, transparent);
    }
    .insight-box strong,
    .operator-note strong {
      font-size: var(--text-sm);
      letter-spacing: -0.02em;
      color: var(--text);
    }
    .insight-box span,
    .operator-note p {
      color: var(--muted);
      margin: 0;
      line-height: 1.65;
    }
    .next-action {
      background: linear-gradient(180deg, color-mix(in srgb, var(--accent-strong) 10%, transparent), var(--surface-elevated-strong));
    }
    .auction-event-form {
      display: grid;
      gap: var(--space-s);
      margin-bottom: var(--space-m);
    }
    .auction-event-form label {
      display: grid;
      gap: var(--space-2xs);
    }
    .auction-event-form input,
    .auction-event-form select,
    .auction-event-form textarea {
      width: 100%;
      border-radius: var(--radius-lg);
      border: 1px solid color-mix(in srgb, var(--line) 55%, transparent);
      background: color-mix(in srgb, var(--surface-input-strong) 82%, transparent);
      color: var(--text);
      padding: var(--space-s) var(--space-m);
      font: inherit;
    }
    .chip-row {
      display: flex;
      flex-wrap: wrap;
      gap: var(--space-xs);
      margin-top: var(--space-m);
    }
    .chip-row span {
      display: inline-flex;
      align-items: center;
      min-height: calc(var(--space-l) * 0.95);
      padding: calc(var(--space-2xs) * 0.8) var(--space-s);
      border-radius: var(--radius-full);
      background: var(--brand-soft);
      color: var(--muted-strong);
      font-size: var(--text-xs);
      font-weight: 700;
    }
    .gallery-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: var(--space-s);
    }
    .gallery-tile {
      min-height: 12rem;
      border-radius: var(--radius-lg);
      background-size: cover;
      background-position: center;
      background-color: var(--accent-1);
    }
    .list-item {
      padding: 0;
      border-radius: 0;
      background: transparent;
      border: 0;
      display: grid;
      gap: 0.5rem;
    }
    .compact-list {
      gap: var(--space-l);
    }
    .compact-list .list-item strong {
      font-size: var(--text-base);
      line-height: 1.35;
      letter-spacing: -0.03em;
      color: var(--text);
      font-weight: 650;
    }
    .item-title {
      display: flex;
      align-items: center;
      gap: var(--space-s);
    }
    .item-icon {
      flex: 0 0 auto;
      color: var(--muted);
    }
    .accent-icon {
      color: var(--accent-strong);
    }
    .compact-list .list-item p {
      font-size: var(--text-sm);
      line-height: 1.7;
      margin: 0;
      max-width: 62ch;
    }
    .compact-list .meta-row {
      gap: var(--space-s);
      font-size: var(--text-xs);
      line-height: 1.4;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--muted);
    }
    .compact-list .inline-note {
      font-size: var(--text-sm);
      color: var(--muted-strong);
    }
    .meta-with-icon {
      display: inline-flex;
      align-items: center;
      gap: var(--space-2xs);
    }
    .compact-list .list-item + .list-item {
      margin-top: 0.1rem;
    }
    @media (max-width: 920px) {
      .split-grid,
      .meta-grid,
      .insight-stack,
      .performance-strip,
      .gallery-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</Layout>
