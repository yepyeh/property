---
import Layout from "../layouts/Layout.astro";

const error = Astro.url.searchParams.get("error");
const exists = Astro.url.searchParams.get("exists");
const role = Astro.url.searchParams.get("role") === "buyer" ? "buyer" : "owner";
const isBuyer = role === "buyer";
const t = Astro.locals.t || ((value: string) => value);
---

<Layout title={`${t("Create account")} | Property App 2026`} description={t("Create an owner or buyer account to use the marketplace with the right workflow.")}>
  <section class="auth-shell">
    <div class="story-panel card">
      <span class="pill">{isBuyer ? t("Buyer onboarding") : t("Owner onboarding")}</span>
      <h1>{isBuyer ? t("Create a buyer account that helps you decide, not just browse.") : t("Create an owner account built to publish, manage, and convert.")}</h1>
      <p>
        {isBuyer
          ? "Use one account to shortlist, compare, mark finalists, and track enquiry follow-up without losing context between visits."
          : "Use one account to publish listings, manage galleries, monitor enquiries, and convert free-trial inventory into paid or promoted visibility."}
      </p>

      <div class="role-switch">
        <a class:list-active={!isBuyer} href="/signup?role=owner">Owner account</a>
        <a class:list-active={isBuyer} href="/signup?role=buyer">Buyer account</a>
      </div>

      <div class="story-stack">
        <article>
          <strong>{isBuyer ? "What you unlock" : "What you unlock"}</strong>
          <ul>
            {isBuyer ? (
              <>
                <li>Save searches and see what is new since your last visit.</li>
                <li>Shortlist homes into collections, compare them, and mark finalists.</li>
                <li>Track enquiries, follow-up plans, and buyer-side decisions in one workspace.</li>
              </>
            ) : (
              <>
                <li>Every listing starts with a 7-day free trial to get live quickly.</li>
                <li>Upload galleries, respond to enquiries, and manage billing from one dashboard.</li>
                <li>Run paid, promoted, and auction-ready inventory without leaving the platform.</li>
              </>
            )}
          </ul>
        </article>

        <article class="soft-card">
          <strong>{isBuyer ? "How to use it well" : "How to use it well"}</strong>
          <p>
            {isBuyer
              ? "Keep the shortlist tight. Save a few serious options, compare trade-offs, then move the strongest one into finalist state before you enquire."
              : "Treat publishing like a launch sequence. Strong facts, strong gallery, strong trust context first. Promotion works best once the listing itself is credible."}
          </p>
        </article>
      </div>
    </div>

    <section class="form-panel card">
      <div class="panel-head">
        <div>
          <span class="eyebrow">{t("Create account")}</span>
          <h2>{isBuyer ? t("Buyer account") : t("Owner account")}</h2>
        </div>
        <p>
          {isBuyer
            ? "Set up the account once, then keep your search, shortlist, compare, and enquiry workflow attached to it."
            : "Set up the account once, then keep listings, billing, trust signals, and owner communication attached to it."}
        </p>
      </div>

      {(error || exists) && (
        <p class="error">
          {exists ? t("That email already has an account.") : t("Use a valid email and a password with at least 8 characters.")}
        </p>
      )}

      <form class="signup-form" method="POST" action="/api/auth/register">
        <input type="hidden" name="role" value={role} />

        <div class="grid two">
          <label class="field">
            <span>{t("Full name")}</span>
            <input class="input-luxury" type="text" name="fullName" required placeholder="Nguyen Anh" />
          </label>
          <label class="field">
            <span>{t("Phone")}</span>
            <input class="input-luxury" type="text" name="phone" placeholder="+84 ..." />
          </label>
        </div>

        <label class="field">
          <span>{t("Email")}</span>
          <input class="input-luxury" type="email" name="email" required placeholder={isBuyer ? "buyer@example.com" : "owner@example.com"} />
        </label>

        <label class="field">
          <span>{t("Password")}</span>
          <input class="input-luxury" type="password" name="password" required minlength="8" placeholder="At least 8 characters" />
        </label>

        <button class="btn-primary" type="submit">{isBuyer ? t("Create buyer account") : t("Create owner account")}</button>
      </form>

      <div class="plan-card">
        <strong>{isBuyer ? "Buyer workflow" : "Owner monetization model"}</strong>
        <ul>
          {isBuyer ? (
            <>
              <li>Save promising searches from the results page.</li>
              <li>Use shortlist state to mark finalists and follow-up plans.</li>
              <li>Compare a few credible options before you contact the owner.</li>
            </>
          ) : (
            <>
              <li>Every new listing starts as a 7-day free trial.</li>
              <li>Paid listings extend visibility beyond the trial window.</li>
              <li>Promoted and auction-ready listings get stronger presentation and routing.</li>
            </>
          )}
        </ul>
      </div>

      <p class="switch-link">{t("Already have an account?")} <a href="/login">{t("Sign in")}</a>.</p>
    </section>
  </section>

  <style is:inline>
    .auth-shell {
      display: grid;
      grid-template-columns: minmax(0, 1.05fr) minmax(22rem, 0.95fr);
      gap: var(--space-m);
      align-items: stretch;
    }
    .story-panel,
    .form-panel {
      padding: var(--space-l);
    }
    .story-panel {
      display: grid;
      gap: var(--space-m);
      background:
        radial-gradient(circle at top left, color-mix(in srgb, var(--hero-glow) 42%, transparent), transparent 28rem),
        linear-gradient(180deg, var(--surface-overlay-strong), var(--surface-panel-muted));
    }
    .story-panel h1,
    .panel-head h2 {
      margin: 0;
      font-size: var(--text-5xl);
      line-height: 0.95;
      letter-spacing: -0.06em;
    }
    .story-panel p,
    .panel-head p,
    .soft-card p,
    .story-stack li {
      margin: 0;
      color: var(--muted);
      line-height: 1.7;
    }
    .role-switch {
      display: inline-flex;
      gap: var(--space-s);
      flex-wrap: wrap;
    }
    .role-switch a {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: var(--space-s) var(--space-m);
      border-radius: var(--radius-full);
      border: 1px solid var(--line);
      text-decoration: none;
      color: var(--text);
      font-weight: 700;
      background: color-mix(in srgb, var(--surface-input) 86%, transparent);
      box-shadow: inset 0 1px 0 color-mix(in srgb, var(--surface-overlay-strong) 88%, transparent);
    }
    .role-switch a.list-active {
      background: linear-gradient(180deg, color-mix(in srgb, var(--brand) 94%, white), var(--brand));
      border-color: color-mix(in srgb, var(--brand) 80%, transparent);
      color: var(--surface-canvas);
    }
    .story-stack {
      display: grid;
      gap: var(--space-s);
    }
    .story-stack article {
      padding: var(--space-m);
      border-radius: var(--radius-panel);
      background: color-mix(in srgb, var(--surface-input) 84%, transparent);
      border: 1px solid var(--line);
      display: grid;
      gap: var(--space-2xs);
      box-shadow: inset 0 1px 0 color-mix(in srgb, var(--surface-overlay-strong) 88%, transparent);
    }
    .story-stack strong,
    .plan-card strong {
      font-size: var(--text-base);
      letter-spacing: -0.02em;
    }
    .story-stack ul,
    .plan-card ul {
      margin: 0;
      padding-left: var(--space-m);
      display: grid;
      gap: var(--space-2xs);
    }
    .form-panel {
      display: grid;
      gap: var(--space-m);
      background: linear-gradient(180deg, var(--surface-elevated-strong), var(--surface-panel-muted));
    }
    .panel-head {
      display: grid;
      gap: var(--space-xs);
    }
    .eyebrow {
      display: inline-flex;
      font-size: var(--text-xs);
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--muted);
    }
    .error {
      margin: 0;
      padding: var(--space-s) var(--space-m);
      border-radius: var(--radius-lg);
      background: var(--danger-bg);
      color: var(--danger-text);
      font-weight: 600;
      border: 1px solid var(--danger-border);
    }
    .signup-form {
      display: grid;
      gap: var(--space-s);
    }
    .grid {
      display: grid;
      gap: var(--space-s);
    }
    .grid.two {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
    .field {
      display: grid;
      gap: var(--space-2xs);
      color: var(--muted);
      font-size: var(--text-sm);
      font-weight: 600;
    }
    .plan-card {
      padding: var(--space-m);
      border-radius: var(--radius-panel);
      background: color-mix(in srgb, var(--accent-1) 70%, var(--surface-elevated-strong));
      border: 1px solid color-mix(in srgb, var(--accent-9) 18%, var(--line));
      display: grid;
      gap: var(--space-2xs);
    }
    .switch-link {
      margin: 0;
      color: var(--muted);
    }
    .switch-link a {
      color: var(--accent-strong);
      font-weight: 700;
      text-decoration: none;
    }
    @media (max-width: 960px) {
      .auth-shell,
      .grid.two {
        grid-template-columns: 1fr;
      }
      .story-panel h1,
      .panel-head h2 {
        font-size: var(--text-4xl);
      }
    }
  </style>
</Layout>
