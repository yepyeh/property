---
import Layout from "../layouts/Layout.astro";

const error = Astro.url.searchParams.get("error");
const exists = Astro.url.searchParams.get("exists");
const role = Astro.url.searchParams.get("role") === "buyer" ? "buyer" : "owner";
const isBuyer = role === "buyer";
---

<Layout title="Create Account | Property App 2026" description="Create an owner or buyer account to use the marketplace with the right workflow.">
  <section class="signup-shell card">
    <div>
      <span class="pill">Marketplace accounts</span>
      <h1 class="section-title">Create your {isBuyer ? "buyer" : "owner"} account</h1>
      <p class="section-copy">
        {isBuyer
          ? "Buyer accounts are for search, saved filters, and future alerting. They do not have access to listing publishing or owner billing flows."
          : "Owner accounts start on a starter plan: every listing gets a 7-day free trial. After that you can convert a listing to a paid placement or pay extra for promoted visibility."}
      </p>
    </div>

    <div class="role-switch">
      <a class:list-active={!isBuyer} href="/signup?role=owner">Owner account</a>
      <a class:list-active={isBuyer} href="/signup?role=buyer">Buyer account</a>
    </div>

    {(error || exists) && (
      <p class="error">
        {exists ? "That email already has an account." : "Use a valid email and a password with at least 8 characters."}
      </p>
    )}

    <form class="signup-form" method="POST" action="/api/auth/register">
      <input type="hidden" name="role" value={role} />
      <label>Full name<input type="text" name="fullName" required placeholder="Nguyen Anh" /></label>
      <label>Email<input type="email" name="email" required placeholder="owner@example.com" /></label>
      <label>Phone<input type="text" name="phone" placeholder="+84 ..." /></label>
      <label>Password<input type="password" name="password" required minlength="8" placeholder="At least 8 characters" /></label>
      <button type="submit">Create {isBuyer ? "buyer" : "owner"} account</button>
    </form>

    <div class="plan-card">
      <strong>{isBuyer ? "Buyer workflow" : "Owner monetization model"}</strong>
      <ul>
        {isBuyer ? (
          <>
            <li>Save searches from the listings page.</li>
            <li>Return to your buyer dashboard to reopen them quickly.</li>
            <li>Future buyer alerts will build on these saved searches.</li>
          </>
        ) : (
          <>
            <li>Every new listing starts as a 7-day free trial.</li>
            <li>Paid listings can run beyond the trial window.</li>
            <li>Promoted listings are prioritized above standard inventory.</li>
          </>
        )}
      </ul>
    </div>

    <p class="switch-link">Already have an account? <a href="/login">Sign in</a>.</p>
  </section>

  <style is:inline>
    .signup-shell {
      max-width: 38rem;
      margin: 4rem auto 0;
      padding: 1.5rem;
    }
    .error {
      padding: 0.9rem 1rem;
      border-radius: 18px;
      background: rgba(185, 28, 28, 0.08);
      color: #991b1b;
      font-weight: 600;
    }
    .signup-form {
      display: grid;
      gap: 1rem;
      margin-top: 1rem;
    }
    .role-switch {
      display: flex;
      gap: 0.75rem;
      flex-wrap: wrap;
      margin-top: 1rem;
    }
    .role-switch a {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0.85rem 1rem;
      border-radius: 999px;
      border: 1px solid var(--line);
      text-decoration: none;
      color: var(--text);
      font-weight: 700;
      background: rgba(255,255,255,0.72);
    }
    .role-switch a.list-active {
      background: var(--bg-deep);
      border-color: var(--bg-deep);
      color: white;
    }
    label {
      display: block;
      color: var(--muted);
      font-size: 0.92rem;
      font-weight: 600;
    }
    input {
      width: 100%;
      margin-top: 0.4rem;
      padding: 0.95rem 1rem;
      border-radius: 18px;
      border: 1px solid var(--line);
      background: rgba(255,255,255,0.8);
      font: inherit;
    }
    button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0.95rem 1.2rem;
      border: none;
      border-radius: 999px;
      background: linear-gradient(135deg, var(--accent), var(--accent-strong));
      color: white;
      font-weight: 700;
      cursor: pointer;
    }
    .plan-card {
      margin-top: 1rem;
      padding: 1rem;
      border-radius: 22px;
      background: rgba(15, 118, 110, 0.08);
    }
    .plan-card ul {
      margin: 0.6rem 0 0;
      padding-left: 1.1rem;
      color: var(--muted);
      line-height: 1.7;
    }
    .switch-link {
      margin: 1rem 0 0;
      color: var(--muted);
    }
    .switch-link a {
      color: var(--accent-strong);
      font-weight: 700;
      text-decoration: none;
    }
  </style>
</Layout>
