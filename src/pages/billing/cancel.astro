---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Payment Cancelled | Property App 2026" description="You cancelled checkout before paying for the listing upgrade.">
  <section class="card shell">
    <span class="pill">Checkout cancelled</span>
    <h1 class="section-title">No payment was made.</h1>
    <p class="section-copy">
      Your listing remains on its current plan. You can return to the owner dashboard and try the upgrade again later.
    </p>
    <div class="actions">
      <a class="primary btn-primary" href="/owner/dashboard/">Back to dashboard</a>
      <a class="ghost button-secondary" href="/submit-listing/">Post another listing</a>
    </div>
  </section>

  <style is:inline>
    .shell {
      max-width: 40rem;
      margin: var(--space-2xl) auto 0;
      padding: var(--space-l);
    }
    .actions {
      display: flex;
      gap: var(--space-s);
      flex-wrap: wrap;
      margin-top: var(--space-m);
    }
    .primary,
    .ghost {
      text-decoration: none;
    }
  </style>
</Layout>
