---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Payment Success | Property App 2026" description="Your payment was accepted and the listing upgrade is being applied.">
  <section class="card shell">
    <span class="pill">Payment received</span>
    <h1 class="section-title">Checkout completed.</h1>
    <p class="section-copy">
      Stripe has accepted the payment. Your listing upgrade will appear after the webhook is processed. Return to the
      owner dashboard to confirm the updated plan state.
    </p>
    <div class="actions">
      <a class="primary btn-primary" href="/owner/dashboard/">Go to dashboard</a>
      <a class="ghost button-secondary" href="/listings/">Browse listings</a>
    </div>
  </section>

  <style is:inline>
    .shell {
      max-width: 40rem;
      margin: var(--space-2xl) auto 0;
      padding: var(--space-l);
    }
    .actions {
      display: flex;
      gap: var(--space-s);
      flex-wrap: wrap;
      margin-top: var(--space-m);
    }
    .primary,
    .ghost {
      text-decoration: none;
    }
  </style>
</Layout>
