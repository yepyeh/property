---
import Layout from "../../layouts/Layout.astro";
import ListingCard from "../../components/ListingCard.astro";
import { buildSavedSearchQuery, getDB, searchListings } from "../../lib/marketplace";

const params = Astro.url.searchParams;
const filters = {
  intent: params.get("intent") || "buy",
  city: params.get("city") || "",
  district: params.get("district") || "",
  propertyType: params.get("propertyType") || "",
  minPrice: Number(params.get("minPrice") || "") || undefined,
  maxPrice: Number(params.get("maxPrice") || "") || undefined,
  minBeds: Number(params.get("minBeds") || "") || undefined,
  sort: params.get("sort") || "newest",
};

const listings = await searchListings(filters, getDB(Astro.locals.runtime));
const owner = Astro.locals.owner;
const allCities = Array.from(new Set(listings.map((listing) => listing.city))).sort();
const allDistricts = Array.from(new Set(listings.map((listing) => listing.district))).sort();
const saved = Astro.url.searchParams.get("saved");
const activeFilters = [
  filters.intent && filters.intent !== "buy" ? `Intent: ${filters.intent}` : filters.intent === "buy" ? "Intent: buy" : "",
  filters.city ? `City: ${filters.city}` : "",
  filters.district ? `District: ${filters.district}` : "",
  filters.propertyType ? `Type: ${filters.propertyType}` : "",
  typeof filters.minPrice === "number" ? `Min price: ${filters.minPrice}` : "",
  typeof filters.maxPrice === "number" ? `Max price: ${filters.maxPrice}` : "",
  typeof filters.minBeds === "number" ? `Beds: ${filters.minBeds}+` : "",
].filter(Boolean);

const resultSummary = {
  total: listings.length,
  cities: Array.from(new Set(listings.map((listing) => listing.city))).length,
  forRent: listings.filter((listing) => listing.intent === "rent").length,
};

const selectedIntent = filters.intent === "rent" ? "rent" : "buy";
const selectedSort = filters.sort || "newest";
const hasFilters =
  filters.city ||
  filters.district ||
  filters.propertyType ||
  typeof filters.minPrice === "number" ||
  typeof filters.maxPrice === "number" ||
  typeof filters.minBeds === "number" ||
  selectedIntent !== "buy" ||
  selectedSort !== "newest";
const currentSearchQuery = buildSavedSearchQuery(filters);
---

<Layout
  title="Search Listings | Property App 2026"
  description="Search properties to buy or rent with real filterable results and a cleaner, portal-style search experience."
>
  <header class="search-header card">
    <div class="header-copy">
      <span class="pill">Results page</span>
      <h1 class="section-title">Search properties to buy or rent.</h1>
      <p class="section-copy">
        The results surface now uses real query-string filters, not static demo controls. The URL is shareable, the
        filters are stateful, and submitted D1 listings are included in the result set.
      </p>
    </div>
    <div class="header-actions">
      <a class="ghost" href="/">Home</a>
      <a class="primary" href="#results">View results</a>
    </div>
  </header>

  <form class="search-shell card" method="GET" action="/listings/">
    <div class="intent-tabs">
      <label class:list-active={selectedIntent === "buy"}>
        <input type="radio" name="intent" value="buy" checked={selectedIntent === "buy"} />
        <span>Buy</span>
      </label>
      <label class:list-active={selectedIntent === "rent"}>
        <input type="radio" name="intent" value="rent" checked={selectedIntent === "rent"} />
        <span>Rent</span>
      </label>
    </div>

    <div class="query-grid">
      <label>
        City
        <input type="text" name="city" value={filters.city} placeholder="Ho Chi Minh City" />
      </label>
      <label>
        District
        <input type="text" name="district" value={filters.district} placeholder="Thu Duc City" />
      </label>
      <label>
        Type
        <select name="propertyType">
          <option value="">Any property</option>
          <option value="Condo" selected={filters.propertyType === "Condo"}>Condo</option>
          <option value="Villa" selected={filters.propertyType === "Villa"}>Villa</option>
          <option value="Townhouse" selected={filters.propertyType === "Townhouse"}>Townhouse</option>
          <option value="Apartment" selected={filters.propertyType === "Apartment"}>Apartment</option>
          <option value="House" selected={filters.propertyType === "House"}>House</option>
          <option value="Land" selected={filters.propertyType === "Land"}>Land</option>
        </select>
      </label>
      <label>
        Minimum beds
        <select name="minBeds">
          <option value="">Any beds</option>
          <option value="1" selected={filters.minBeds === 1}>1+</option>
          <option value="2" selected={filters.minBeds === 2}>2+</option>
          <option value="3" selected={filters.minBeds === 3}>3+</option>
          <option value="4" selected={filters.minBeds === 4}>4+</option>
        </select>
      </label>
      <label>
        Minimum price
        <input type="number" min="0" step="0.01" name="minPrice" value={filters.minPrice ?? ""} placeholder="0" />
      </label>
      <label>
        Maximum price
        <input type="number" min="0" step="0.01" name="maxPrice" value={filters.maxPrice ?? ""} placeholder="10" />
      </label>
      <label>
        Sort
        <select name="sort">
          <option value="newest" selected={selectedSort === "newest"}>Newest</option>
          <option value="price-asc" selected={selectedSort === "price-asc"}>Price: low to high</option>
          <option value="price-desc" selected={selectedSort === "price-desc"}>Price: high to low</option>
          <option value="beds-desc" selected={selectedSort === "beds-desc"}>Beds</option>
        </select>
      </label>
      <div class="query-actions">
        <button class="primary" type="submit">Search</button>
        <a class="ghost" href="/listings/">Clear</a>
      </div>
    </div>

    <div class="utility-row">
      <div class="filter-chips">
        {activeFilters.length > 0 ? activeFilters.map((filter) => <span>{filter}</span>) : <span>No extra filters applied</span>}
      </div>
      <div class="utility-links">
        <a href="/owner/dashboard/">Track enquiries</a>
        <a href="/submit-listing/">Post listing</a>
      </div>
    </div>
  </form>

  {saved && (
    <div class="card flash">
      Search saved. You can manage it from your dashboard.
    </div>
  )}

  <section class="results-meta card" id="results">
    <div>
      <strong>{resultSummary.total} listings</strong>
      <span>
        across {resultSummary.cities} cities · {resultSummary.forRent} rentals live
        {hasFilters ? " · filtered results" : " · full inventory"}
      </span>
    </div>
    <div class="sort-row">
      <span>Popular cities:</span>
      {allCities.slice(0, 3).map((city) => <a href={`/listings/?intent=${selectedIntent}&city=${encodeURIComponent(city)}`}>{city}</a>)}
    </div>
  </section>

  <section class="card saved-search-panel">
    <div>
      <span class="pill">Buyer alerts</span>
      <h2>Save this search</h2>
      <p>
        Persist the current result set and come back to it later. This gives buyers a reusable shortlist before email
        alerts are layered on top.
      </p>
    </div>
    {owner ? (
      <form method="POST" action="/api/saved-searches" class="saved-search-form">
        <input type="hidden" name="intent" value={filters.intent} />
        <input type="hidden" name="city" value={filters.city} />
        <input type="hidden" name="district" value={filters.district} />
        <input type="hidden" name="propertyType" value={filters.propertyType} />
        <input type="hidden" name="minPrice" value={filters.minPrice ?? ""} />
        <input type="hidden" name="maxPrice" value={filters.maxPrice ?? ""} />
        <input type="hidden" name="minBeds" value={filters.minBeds ?? ""} />
        <input type="hidden" name="sort" value={filters.sort} />
        <label>
          Search name
          <input type="text" name="name" value={`Saved search · ${filters.intent === "rent" ? "Rent" : "Buy"} · ${filters.city || "All cities"}`} />
        </label>
        <div class="saved-search-actions">
          <button type="submit" class="primary">Save search</button>
          <a class="ghost" href="/owner/dashboard/">Manage saved searches</a>
        </div>
      </form>
    ) : (
      <div class="saved-search-auth">
        <p>Sign in to save this filter set and turn it into a reusable buyer alert.</p>
        <a class="primary" href={`/login?redirect=${encodeURIComponent(`/listings/?${currentSearchQuery}`)}`}>Sign in to save</a>
      </div>
    )}
  </section>

  <section class="results-layout">
    <aside class="map-panel card">
      <span class="pill">Market context</span>
      <h2>Where people are searching</h2>
      <p>
        This side panel is still a placeholder for the eventual map, but the context is now tied to the live result
        set instead of fixed demo copy.
      </p>
      <div class="map-box">
        {(allDistricts.length > 0 ? allDistricts : ["No matching districts"]).slice(0, 5).map((district) => <b>{district}</b>)}
      </div>
    </aside>

    <div class="results-list">
      {listings.length > 0 ? (
        listings.map((listing) => <ListingCard listing={listing} />)
      ) : (
        <article class="empty-state card">
          <span class="pill">No matches</span>
          <h2>There are no listings for this filter set yet.</h2>
          <p>
            Broaden the city or district, lower the bed count requirement, or clear the price range. If you are testing
            owner supply, you can also add a new listing from the dashboard.
          </p>
          <div class="empty-actions">
            <a class="primary" href="/listings/">Clear filters</a>
            <a class="ghost" href="/submit-listing/">Post a listing</a>
          </div>
        </article>
      )}
    </div>
  </section>

  <style>
    .search-header,
    .search-shell,
    .results-meta,
    .saved-search-panel,
    .flash {
      padding: 1.4rem;
      margin-bottom: 1rem;
    }

    .search-header,
    .utility-row,
    .results-meta {
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      align-items: flex-start;
    }

    .header-actions,
    .utility-links,
    .sort-row,
    .filter-chips,
    .intent-tabs,
    .empty-actions,
    .saved-search-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.7rem;
    }

    .primary,
    .ghost,
    .sort-row a,
    .intent-tabs label span {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0.9rem 1.1rem;
      border-radius: 999px;
      font-weight: 700;
      text-decoration: none;
      border: 1px solid var(--line);
    }

    .primary {
      background: linear-gradient(135deg, var(--accent), var(--accent-strong));
      color: white;
      border: none;
      cursor: pointer;
    }

    .flash {
      color: var(--accent-strong);
      font-weight: 700;
    }

    .ghost,
    .sort-row a,
    .intent-tabs label span {
      background: rgba(255, 255, 255, 0.72);
      color: var(--text);
    }

    .intent-tabs input {
      position: absolute;
      opacity: 0;
      pointer-events: none;
    }

    .intent-tabs label {
      position: relative;
      cursor: pointer;
    }

    .intent-tabs label.list-active span {
      background: var(--bg-deep);
      border-color: var(--bg-deep);
      color: white;
    }

    .query-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 0.8rem;
      margin-top: 1rem;
    }

    .query-actions {
      display: grid;
      gap: 0.8rem;
      align-content: end;
    }

    .saved-search-panel {
      display: grid;
      grid-template-columns: 1.1fr 1fr;
      gap: 1rem;
      align-items: start;
    }

    .saved-search-form,
    .saved-search-auth {
      display: grid;
      gap: 0.8rem;
    }

    label {
      display: block;
      color: var(--muted);
      font-size: 0.9rem;
      font-weight: 600;
    }

    input,
    select {
      width: 100%;
      margin-top: 0.4rem;
      padding: 0.95rem 1rem;
      border-radius: 18px;
      border: 1px solid var(--line);
      background: rgba(255, 255, 255, 0.72);
      font: inherit;
    }

    .utility-row {
      margin-top: 1rem;
      align-items: center;
    }

    .filter-chips span {
      padding: 0.7rem 0.95rem;
      border-radius: 999px;
      background: rgba(15, 118, 110, 0.08);
      color: var(--accent-strong);
      font-weight: 700;
    }

    .utility-links a {
      color: var(--muted);
      text-decoration: none;
      font-weight: 600;
    }

    .results-meta strong {
      display: block;
      font-size: 1.25rem;
    }

    .results-meta span {
      color: var(--muted);
      line-height: 1.6;
    }

    .sort-row {
      align-items: center;
    }

    .sort-row span {
      color: var(--muted);
      font-weight: 600;
    }

    .results-layout {
      display: grid;
      grid-template-columns: 0.8fr 1.2fr;
      gap: 1rem;
    }

    .map-panel {
      padding: 1.4rem;
      position: sticky;
      top: 1rem;
      align-self: start;
    }

    .map-panel h2 {
      margin: 1rem 0 0.6rem;
      font-size: 1.5rem;
    }

    .map-panel p,
    .empty-state p {
      color: var(--muted);
      line-height: 1.7;
    }

    .map-box {
      display: grid;
      place-items: center;
      gap: 0.8rem;
      min-height: 22rem;
      margin-top: 1rem;
      padding: 1.2rem;
      border-radius: 24px;
      background:
        radial-gradient(circle at top, rgba(15, 118, 110, 0.22), transparent 30%),
        linear-gradient(180deg, rgba(14, 22, 40, 0.04), rgba(14, 22, 40, 0.1));
      border: 1px solid var(--line);
    }

    .map-box b {
      display: inline-flex;
      padding: 0.65rem 0.9rem;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.75);
    }

    .results-list {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
    }

    .empty-state {
      padding: 1.4rem;
      grid-column: 1 / -1;
    }

    .empty-state h2 {
      margin: 1rem 0 0.65rem;
      font-size: 1.5rem;
    }

    @media (max-width: 960px) {
      .query-grid,
      .results-layout,
      .results-list,
      .saved-search-panel {
        grid-template-columns: 1fr;
      }

      .map-panel {
        position: static;
      }
    }

    @media (max-width: 760px) {
      .search-header,
      .utility-row,
      .results-meta {
        flex-direction: column;
        align-items: flex-start;
      }
    }
  </style>
</Layout>
