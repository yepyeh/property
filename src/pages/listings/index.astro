---
import Layout from "../../layouts/Layout.astro";
import PremiumSearchResultsPage from "../../components/search/PremiumSearchResultsPage";
import { getAllListings, searchListings } from "../../lib/listings";
import { getDB } from "../../lib/runtime";

const params = Astro.url.searchParams;
const mapSaleModeQueryToLabel = (value: string) =>
  value
    .split(",")
    .map((entry) => entry.trim())
    .filter(Boolean)
    .map((entry) => (entry === "auction" ? "Auction" : entry === "private-sale" ? "Private sale" : ""))
    .filter(Boolean)
    .join(",");

const filters = {
  intent: params.get("intent") || "buy",
  country: params.get("country") || "",
  city: params.get("city") || "",
  district: params.get("district") || "",
  propertyType: params.get("propertyType") || "",
  saleMode: params.get("saleMode") || "",
  beds: params.get("beds") || "",
  minPrice: Number(params.get("minPrice") || "") || undefined,
  maxPrice: Number(params.get("maxPrice") || "") || undefined,
  minBeds: Number(params.get("minBeds") || "") || undefined,
  sort: params.get("sort") || "newest",
};

const db = getDB(Astro.locals.runtime);
const listings = await searchListings(filters, db);
const allListings = await getAllListings(db);
const owner = Astro.locals.owner;
const allCountries = Array.from(new Set(allListings.map((listing) => listing.country))).sort();
const allCities = Array.from(new Set(allListings.map((listing) => listing.city))).sort();
const allDistricts = Array.from(new Set(allListings.map((listing) => listing.district))).sort();

const initialFilters = {
  intent: filters.intent === "rent" ? "rent" : "buy",
  country: filters.country || "",
  city: filters.city || "",
  district: filters.district || "",
  propertyType: filters.propertyType || "",
  saleMode: mapSaleModeQueryToLabel(filters.saleMode || ""),
  beds: filters.beds || (typeof filters.minBeds === "number" ? String(filters.minBeds) : ""),
  minPrice: typeof filters.minPrice === "number" ? String(filters.minPrice) : "",
  maxPrice: typeof filters.maxPrice === "number" ? String(filters.maxPrice) : "",
};
---

<Layout
  title="Search listings | Property App 2026"
  description="Search properties to buy or rent with a cleaner premium results experience."
  inlineShellCss={true}
>
  <PremiumSearchResultsPage
    client:load
    initialListings={listings}
    initialFilters={initialFilters}
    countries={allCountries}
    cities={allCities}
    districts={allDistricts}
    isSignedIn={Boolean(owner)}
  />
</Layout>
