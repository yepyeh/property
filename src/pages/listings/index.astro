---
import Layout from "../../layouts/Layout.astro";
import ListingCard from "../../components/ListingCard.astro";
import { buildSavedSearchQuery, getDB, searchListings } from "../../lib/marketplace";

const params = Astro.url.searchParams;
const filters = {
  intent: params.get("intent") || "buy",
  city: params.get("city") || "",
  district: params.get("district") || "",
  propertyType: params.get("propertyType") || "",
  minPrice: Number(params.get("minPrice") || "") || undefined,
  maxPrice: Number(params.get("maxPrice") || "") || undefined,
  minBeds: Number(params.get("minBeds") || "") || undefined,
  sort: params.get("sort") || "newest",
};

const listings = await searchListings(filters, getDB(Astro.locals.runtime));
const owner = Astro.locals.owner;
const dashboardHref = owner?.role === "buyer" ? "/buyer/dashboard/" : "/owner/dashboard/";
const allCities = Array.from(new Set(listings.map((listing) => listing.city))).sort();
const allDistricts = Array.from(new Set(listings.map((listing) => listing.district))).sort();
const saved = Astro.url.searchParams.get("saved");
const activeFilters = [
  filters.intent ? `Intent: ${filters.intent}` : "",
  filters.city ? `City: ${filters.city}` : "",
  filters.district ? `District: ${filters.district}` : "",
  filters.propertyType ? `Type: ${filters.propertyType}` : "",
  typeof filters.minPrice === "number" ? `Min price: ${filters.minPrice}` : "",
  typeof filters.maxPrice === "number" ? `Max price: ${filters.maxPrice}` : "",
  typeof filters.minBeds === "number" ? `Beds: ${filters.minBeds}+` : "",
].filter(Boolean);

const resultSummary = {
  total: listings.length,
  cities: Array.from(new Set(listings.map((listing) => listing.city))).length,
  forRent: listings.filter((listing) => listing.intent === "rent").length,
};
const mappableListings = listings
  .filter((listing) => listing.location)
  .map((listing) => ({
    slug: listing.slug,
    title: listing.title,
    priceLabel: listing.priceLabel,
    ward: listing.ward,
    district: listing.district,
    city: listing.city,
    lat: listing.location?.lat ?? 0,
    lng: listing.location?.lng ?? 0,
  }));
const topNeighborhoods = Array.from(
  new Set(
    listings
      .flatMap((listing) => [listing.ward ? `${listing.ward}, ${listing.district}` : "", listing.district])
      .filter(Boolean)
  )
).slice(0, 5);

const selectedIntent = filters.intent === "rent" ? "rent" : "buy";
const selectedSort = filters.sort || "newest";
const hasFilters =
  filters.city ||
  filters.district ||
  filters.propertyType ||
  typeof filters.minPrice === "number" ||
  typeof filters.maxPrice === "number" ||
  typeof filters.minBeds === "number" ||
  selectedIntent !== "buy" ||
  selectedSort !== "newest";
const currentSearchQuery = buildSavedSearchQuery(filters);
---

<Layout
  title="Search Listings | Property App 2026"
  description="Search properties to buy or rent with real filterable results and a cleaner, portal-style search experience."
>
  <section class="results-hero card">
    <div class="hero-copy">
      <span class="section-kicker">Search results</span>
      <h1>Search property with less noise and stronger buyer signals.</h1>
      <p>
        The results surface should feel decisive: clear filters, stable URLs, visible result counts, and cleaner cards
        that help a buyer compare quickly.
      </p>
    </div>
    <div class="hero-actions">
      <a class="button-secondary" href="/">Home</a>
      <a class="button-dark" href="#results">Jump to results</a>
    </div>
  </section>

  <form class="search-frame card" method="GET" action="/listings/">
    <div class="intent-tabs">
      <label class:list-active={selectedIntent === "buy"}>
        <input type="radio" name="intent" value="buy" checked={selectedIntent === "buy"} />
        <span>Buy</span>
      </label>
      <label class:list-active={selectedIntent === "rent"}>
        <input type="radio" name="intent" value="rent" checked={selectedIntent === "rent"} />
        <span>Rent</span>
      </label>
    </div>

    <div class="filter-grid">
      <label class="field">
        <span>City</span>
        <input type="text" name="city" value={filters.city} placeholder="Ho Chi Minh City" />
      </label>
      <label class="field">
        <span>District</span>
        <input type="text" name="district" value={filters.district} placeholder="Thu Duc City" />
      </label>
      <label class="field">
        <span>Property type</span>
        <select name="propertyType">
          <option value="">Any property</option>
          <option value="Condo" selected={filters.propertyType === "Condo"}>Condo</option>
          <option value="Villa" selected={filters.propertyType === "Villa"}>Villa</option>
          <option value="Townhouse" selected={filters.propertyType === "Townhouse"}>Townhouse</option>
          <option value="Apartment" selected={filters.propertyType === "Apartment"}>Apartment</option>
          <option value="House" selected={filters.propertyType === "House"}>House</option>
          <option value="Land" selected={filters.propertyType === "Land"}>Land</option>
        </select>
      </label>
      <label class="field">
        <span>Minimum beds</span>
        <select name="minBeds">
          <option value="">Any beds</option>
          <option value="1" selected={filters.minBeds === 1}>1+</option>
          <option value="2" selected={filters.minBeds === 2}>2+</option>
          <option value="3" selected={filters.minBeds === 3}>3+</option>
          <option value="4" selected={filters.minBeds === 4}>4+</option>
        </select>
      </label>
      <label class="field">
        <span>Minimum price</span>
        <input type="number" min="0" step="0.01" name="minPrice" value={filters.minPrice ?? ""} placeholder="0" />
      </label>
      <label class="field">
        <span>Maximum price</span>
        <input type="number" min="0" step="0.01" name="maxPrice" value={filters.maxPrice ?? ""} placeholder="10" />
      </label>
      <label class="field">
        <span>Sort</span>
        <select name="sort">
          <option value="newest" selected={selectedSort === "newest"}>Newest</option>
          <option value="price-asc" selected={selectedSort === "price-asc"}>Price: low to high</option>
          <option value="price-desc" selected={selectedSort === "price-desc"}>Price: high to low</option>
          <option value="beds-desc" selected={selectedSort === "beds-desc"}>Beds</option>
        </select>
      </label>
      <div class="filter-actions">
        <button class="button-dark" type="submit">Search</button>
        <a class="button-secondary" href="/listings/">Clear</a>
      </div>
    </div>

    <div class="utility-row">
      <div class="filter-chips">
        {activeFilters.length > 0 ? activeFilters.map((filter) => <span>{filter}</span>) : <span>All live inventory</span>}
      </div>
      <div class="utility-links">
        <a href={dashboardHref}>{owner?.role === "buyer" ? "Saved searches" : "Track enquiries"}</a>
        <a href={owner?.role === "buyer" ? "/signup?role=owner" : "/submit-listing/"}>{owner?.role === "buyer" ? "Create owner account" : "Post listing"}</a>
      </div>
    </div>
  </form>

  {saved && <div class="card flash-banner">Search saved. You can manage it from your dashboard.</div>}

  <section class="results-summary card" id="results">
    <div>
      <strong>{resultSummary.total} listings</strong>
      <p>
        across {resultSummary.cities} cities · {resultSummary.forRent} rentals live
        {hasFilters ? " · filtered results" : " · full inventory"}
      </p>
    </div>
    <div class="summary-links">
      <span>Popular cities</span>
      {allCities.slice(0, 3).map((city) => <a href={`/listings/?intent=${selectedIntent}&city=${encodeURIComponent(city)}`}>{city}</a>)}
    </div>
  </section>

  <section class="save-search card">
    <div>
      <span class="section-kicker">Buyer alerts</span>
      <h2>Save this search</h2>
      <p>Keep the current filter set as a reusable shortlist and turn it into an alert workflow later.</p>
    </div>
    {owner ? (
      <form method="POST" action="/api/saved-searches" class="save-form">
        <input type="hidden" name="intent" value={filters.intent} />
        <input type="hidden" name="city" value={filters.city} />
        <input type="hidden" name="district" value={filters.district} />
        <input type="hidden" name="propertyType" value={filters.propertyType} />
        <input type="hidden" name="minPrice" value={filters.minPrice ?? ""} />
        <input type="hidden" name="maxPrice" value={filters.maxPrice ?? ""} />
        <input type="hidden" name="minBeds" value={filters.minBeds ?? ""} />
        <input type="hidden" name="sort" value={filters.sort} />
        <label class="field">
          <span>Search name</span>
          <input type="text" name="name" value={`Saved search · ${filters.intent === "rent" ? "Rent" : "Buy"} · ${filters.city || "All cities"}`} />
        </label>
        <div class="save-actions">
          <button type="submit" class="button-dark">Save search</button>
          <a class="button-secondary" href={dashboardHref}>Manage saved searches</a>
        </div>
      </form>
    ) : (
      <div class="save-auth">
        <p>Sign in to save this filter set and turn it into a reusable buyer alert.</p>
        <a class="button-dark" href={`/login?redirect=${encodeURIComponent(`/listings/?${currentSearchQuery}`)}`}>Sign in to save</a>
      </div>
    )}
  </section>

  <div class="mobile-view-toggle" data-default-view="list">
    <button type="button" class="toggle-chip is-active" data-results-view-trigger="list">List</button>
    <button
      type="button"
      class="toggle-chip"
      data-results-view-trigger="map"
      disabled={mappableListings.length === 0}
      aria-disabled={mappableListings.length === 0 ? "true" : "false"}
    >
      Map
    </button>
  </div>

  <section class="results-layout" data-results-view="list">
    <aside class="market-panel card">
      <span class="section-kicker">Map view</span>
      <h2>See the filtered listings on a live map</h2>
      <p>Search by filters first, then use the map to validate coverage and cluster patterns instead of guessing where the inventory sits.</p>
      {mappableListings.length > 0 ? (
        <div
          id="results-map"
          class="results-map"
          data-listings={JSON.stringify(mappableListings)}
        ></div>
      ) : (
        <div class="map-empty">
          <strong>No map coordinates for this result set yet.</strong>
          <span>Try a broader filter set or add owner coordinates when posting listings.</span>
        </div>
      )}
      <div class="district-list">
        {(allDistricts.length > 0 ? allDistricts : ["No matching districts"]).slice(0, 5).map((district) => <b>{district}</b>)}
      </div>
      {topNeighborhoods.length > 0 && (
        <div class="neighborhood-list">
          {topNeighborhoods.map((place) => <span>{place}</span>)}
        </div>
      )}
    </aside>

    <div class="results-list">
      {listings.length > 0 ? (
        listings.map((listing) => (
          <div
            class="listing-card-shell"
            data-listing-card={listing.slug}
            data-has-map={listing.location ? "true" : "false"}
            tabindex={listing.location ? 0 : -1}
          >
            <ListingCard listing={listing} />
          </div>
        ))
      ) : (
        <article class="empty-state card">
          <span class="section-kicker">No matches</span>
          <h2>There are no listings for this filter set yet.</h2>
          <p>
            Broaden the city or district, lower the bed count requirement, or clear the price range. If you are testing
            owner supply, you can also add a new listing from the dashboard.
          </p>
          <div class="empty-actions">
            <a class="button-dark" href="/listings/">Clear filters</a>
            <a class="button-secondary" href="/submit-listing/">Post a listing</a>
          </div>
        </article>
      )}
    </div>
  </section>

  <script is:inline>
    const layoutNode = document.querySelector("[data-results-view]");
    const viewTriggerNodes = Array.from(document.querySelectorAll("[data-results-view-trigger]"));
    const mapNode = document.getElementById("results-map");
    const cardNodes = Array.from(document.querySelectorAll("[data-listing-card]"));
    const markerBySlug = new Map();

    function setResultsView(nextView) {
      if (!layoutNode) return;
      layoutNode.setAttribute("data-results-view", nextView);

      viewTriggerNodes.forEach((node) => {
        const active = node.getAttribute("data-results-view-trigger") === nextView;
        node.classList.toggle("is-active", active);
        node.setAttribute("aria-pressed", active ? "true" : "false");
      });
    }

    function setActiveListing(slug, options = {}) {
      const { openMarker = false, centerMap = false, scrollCard = false } = options;

      cardNodes.forEach((node) => {
        node.classList.toggle("is-active", node.getAttribute("data-listing-card") === slug);
      });

      const markerEntry = markerBySlug.get(slug);
      if (markerEntry) {
        markerBySlug.forEach((entry, entrySlug) => {
          entry.marker.setStyle({
            radius: entrySlug === slug ? 11 : 9,
            weight: entrySlug === slug ? 3 : 2,
            fillOpacity: entrySlug === slug ? 1 : 0.88,
          });
        });

        if (centerMap) {
          markerEntry.map.setView(markerEntry.marker.getLatLng(), Math.max(markerEntry.map.getZoom(), 13), {
            animate: true,
          });
        }

        if (openMarker) {
          markerEntry.marker.openPopup();
        }
      }

      if (scrollCard) {
        const activeCard = document.querySelector(`[data-listing-card="${slug}"]`);
        if (activeCard) {
          activeCard.scrollIntoView({ behavior: "smooth", block: "center" });
        }
      }
    }

    async function loadLeaflet() {
      if (window.L) return window.L;

      if (!document.querySelector('link[data-leaflet="true"]')) {
        const link = document.createElement("link");
        link.rel = "stylesheet";
        link.href = "https://unpkg.com/leaflet@1.9.4/dist/leaflet.css";
        link.dataset.leaflet = "true";
        document.head.appendChild(link);
      }

      await new Promise((resolve, reject) => {
        const existing = document.querySelector('script[data-leaflet="true"]');
        if (existing && window.L) {
          resolve(window.L);
          return;
        }

        if (existing) {
          existing.addEventListener("load", () => resolve(window.L), { once: true });
          existing.addEventListener("error", reject, { once: true });
          return;
        }

        const script = document.createElement("script");
        script.src = "https://unpkg.com/leaflet@1.9.4/dist/leaflet.js";
        script.dataset.leaflet = "true";
        script.onload = () => resolve(window.L);
        script.onerror = reject;
        document.head.appendChild(script);
      });

      return window.L;
    }

    async function initResultsMap() {
      if (!mapNode) return;

      const payload = mapNode.getAttribute("data-listings");
      const listings = payload ? JSON.parse(payload) : [];
      if (!Array.isArray(listings) || listings.length === 0) return;

      const L = await loadLeaflet();
      const map = L.map(mapNode, {
        scrollWheelZoom: false,
        zoomControl: true,
      });

      L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
        attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
      }).addTo(map);

      const bounds = [];

      listings.forEach((listing) => {
        const marker = L.circleMarker([listing.lat, listing.lng], {
          radius: 9,
          color: "#0f172a",
          weight: 2,
          fillColor: "#0f766e",
          fillOpacity: 0.88,
        }).addTo(map);

        marker.bindPopup(`
          <div style="min-width: 180px; font-family: 'Plus Jakarta Sans', sans-serif;">
            <strong style="display:block; margin-bottom:6px;">${listing.title}</strong>
            <span style="display:block; margin-bottom:6px; color:#475467;">${listing.priceLabel}</span>
            <span style="display:block; margin-bottom:10px; color:#667085;">${listing.ward}, ${listing.district}</span>
            <a href="/listings/${listing.slug}/" style="color:#0f766e; font-weight:700; text-decoration:none;">Open listing</a>
          </div>
        `);

        marker.on("click", () => {
          setActiveListing(listing.slug, {
            openMarker: true,
            scrollCard: true,
          });
        });

        markerBySlug.set(listing.slug, { marker, map });

        bounds.push([listing.lat, listing.lng]);
      });

      if (bounds.length === 1) {
        map.setView(bounds[0], 13);
      } else {
        map.fitBounds(bounds, { padding: [24, 24] });
      }

      if (listings[0]?.slug) {
        setActiveListing(listings[0].slug);
      }
    }

    viewTriggerNodes.forEach((node) => {
      node.addEventListener("click", () => {
        if (node.hasAttribute("disabled")) return;
        setResultsView(node.getAttribute("data-results-view-trigger") || "list");
      });
    });

    cardNodes.forEach((node) => {
      const slug = node.getAttribute("data-listing-card");
      const hasMap = node.getAttribute("data-has-map") === "true";
      if (!slug || !hasMap) return;

      node.addEventListener("mouseenter", () => {
        setActiveListing(slug, { centerMap: false, openMarker: false, scrollCard: false });
      });

      node.addEventListener("focusin", () => {
        setActiveListing(slug, { centerMap: true, openMarker: true, scrollCard: false });
      });

      node.addEventListener("click", (event) => {
        const target = event.target;
        if (!(target instanceof Element)) return;
        if (target.closest("a, button, input, textarea, select, form")) return;
        setActiveListing(slug, { centerMap: true, openMarker: true, scrollCard: false });
      });
    });

    setResultsView("list");

    initResultsMap().catch((error) => {
      console.error("Failed to initialize listings map", error);
    });
  </script>

  <style>
    .results-hero,
    .search-frame,
    .results-summary,
    .save-search,
    .market-panel,
    .flash-banner,
    .empty-state {
      padding: 1.4rem;
      background: rgba(255, 255, 255, 0.9);
      box-shadow: 0 1px 2px rgba(16, 24, 40, 0.04), 0 16px 36px rgba(16, 24, 40, 0.06);
    }

    .results-hero,
    .hero-actions,
    .utility-row,
    .results-summary,
    .summary-links,
    .save-actions,
    .empty-actions {
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      align-items: flex-start;
      flex-wrap: wrap;
    }

    .results-hero,
    .search-frame,
    .results-summary,
    .save-search,
    .mobile-view-toggle,
    .flash-banner,
    .results-layout {
      margin-bottom: 1rem;
    }

    .hero-copy h1,
    .save-search h2,
    .market-panel h2,
    .empty-state h2 {
      margin: 0.8rem 0 0;
      font-size: clamp(2rem, 4vw, 3.2rem);
      letter-spacing: -0.06em;
      line-height: 1;
    }

    .save-search h2,
    .market-panel h2,
    .empty-state h2 {
      font-size: clamp(1.5rem, 3vw, 2.1rem);
    }

    .hero-copy p,
    .results-summary p,
    .save-search p,
    .market-panel p,
    .empty-state p {
      color: var(--muted);
      line-height: 1.7;
      margin: 0.8rem 0 0;
    }

    .section-kicker {
      display: inline-flex;
      align-items: center;
      min-height: 2rem;
      padding: 0.22rem 0.75rem;
      border-radius: 999px;
      background: var(--brand-soft);
      color: var(--accent-strong);
      font-size: 0.78rem;
      font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .button-dark,
    .button-secondary,
    .toggle-chip,
    .summary-links a,
    .utility-links a,
    .filter-chips span,
    .intent-tabs label span {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 2.75rem;
      border-radius: 999px;
      padding: 0.82rem 1rem;
      font-weight: 700;
      text-decoration: none;
      font: inherit;
      border: 1px solid var(--line);
    }

    .button-dark {
      background: var(--brand);
      color: white;
      border-color: var(--brand);
      cursor: pointer;
    }

    .button-secondary,
    .toggle-chip,
    .summary-links a,
    .utility-links a,
    .filter-chips span,
    .intent-tabs label span {
      background: white;
      color: var(--text);
    }

    .flash-banner {
      border-left: 4px solid rgba(18, 183, 106, 0.35);
      color: #067647;
      font-weight: 700;
    }

    .intent-tabs,
    .filter-grid,
    .district-list {
      display: grid;
      gap: 1rem;
    }

    .intent-tabs {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      margin-bottom: 1rem;
    }

    .intent-tabs label {
      position: relative;
      cursor: pointer;
    }

    .intent-tabs input {
      position: absolute;
      opacity: 0;
      pointer-events: none;
    }

    .intent-tabs label.list-active span {
      background: var(--brand);
      color: white;
      border-color: var(--brand);
    }

    .filter-grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .field,
    .save-form {
      display: grid;
      gap: 0.45rem;
    }

    .field span {
      font-size: 0.9rem;
      font-weight: 700;
      color: var(--text);
    }

    .field input,
    .field select {
      width: 100%;
      min-height: 3.1rem;
      border-radius: 16px;
      border: 1px solid var(--line);
      background: white;
      padding: 0.92rem 1rem;
      color: var(--text);
      font: inherit;
    }

    .filter-actions,
    .utility-links,
    .filter-chips,
    .save-actions,
    .neighborhood-list {
      display: flex;
      gap: 0.75rem;
      flex-wrap: wrap;
    }

    .filter-actions {
      align-items: end;
    }

    .utility-row {
      margin-top: 1rem;
      padding-top: 1rem;
      border-top: 1px solid var(--line);
    }

    .filter-chips span {
      min-height: 2.3rem;
      padding: 0.56rem 0.85rem;
      font-size: 0.84rem;
      background: #f8fafc;
    }

    .results-summary strong {
      display: block;
      font-size: 2rem;
      letter-spacing: -0.04em;
    }

    .summary-links {
      align-items: center;
    }

    .summary-links span {
      color: var(--muted);
      font-weight: 700;
    }

    .save-search {
      display: grid;
      grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
      gap: 1rem;
      align-items: center;
    }

    .mobile-view-toggle {
      display: none;
      gap: 0.75rem;
      padding: 0.35rem;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.92);
      border: 1px solid var(--line);
      box-shadow: var(--shadow-soft);
    }

    .toggle-chip {
      flex: 1 1 0;
      min-height: 2.9rem;
      background: transparent;
      color: var(--text);
      cursor: pointer;
    }

    .toggle-chip.is-active {
      background: var(--brand);
      color: white;
      border-color: var(--brand);
    }

    .toggle-chip[disabled] {
      opacity: 0.45;
      cursor: not-allowed;
    }

    .results-layout {
      display: grid;
      grid-template-columns: minmax(20rem, 0.42fr) minmax(0, 1fr);
      gap: 1rem;
      align-items: start;
    }

    .market-panel {
      position: sticky;
      top: 6rem;
    }

    .results-map {
      min-height: 22rem;
      margin-top: 1rem;
      border-radius: 22px;
      overflow: hidden;
      border: 1px solid var(--line);
      background: linear-gradient(180deg, #f8fafc, #e5edf6);
    }

    .map-empty {
      display: grid;
      gap: 0.45rem;
      margin-top: 1rem;
      padding: 1rem;
      border-radius: 22px;
      background: #f8fafc;
      border: 1px solid var(--line);
    }

    .map-empty strong {
      font-size: 0.98rem;
