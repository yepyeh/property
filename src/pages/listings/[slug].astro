---
import Layout from "../../layouts/Layout.astro";
import ListingCard from "../../components/ListingCard.astro";
import { getAllListings, getListingBySlug, isListingSavedByUser } from "../../lib/listings";
import { getDB } from "../../lib/runtime";

const { slug } = Astro.params;
const db = getDB(Astro.locals.runtime);
const viewer = Astro.locals.owner;
const listing = await getListingBySlug(slug ?? "", db);
const enquirySent = Astro.url.searchParams.get("enquiry") === "sent";
const savedListing = Astro.url.searchParams.get("savedListing") === "1";
const heroImage = listing?.imageUrls?.[0];
const isBuyer = viewer?.role === "buyer" || viewer?.role === "admin";
const isSaved = listing ? await isListingSavedByUser(db, viewer?.id, listing.slug) : false;

if (!listing) {
  throw new Error(`Listing not found: ${slug}`);
}

const allListings = await getAllListings(db);
const similarListings = allListings
  .filter((candidate) => candidate.slug !== listing.slug)
  .sort((a, b) => {
    const aScore = Number(a.city === listing.city) + Number(a.intent === listing.intent) + Number(a.type === listing.type);
    const bScore = Number(b.city === listing.city) + Number(b.intent === listing.intent) + Number(b.type === listing.type);
    return bScore - aScore;
  })
  .slice(0, 3);

const intentLabel = listing.intent === "buy" ? "For sale" : "For rent";
const ownerTrustLabel = listing.owner.verified ? "Verified owner" : "Owner listed";
const neighborhood = listing.neighborhood;
const location = listing.location;
const mapQuery = encodeURIComponent(`${listing.ward}, ${listing.district}, ${listing.city}`);
const mapHref = location
  ? `https://www.google.com/maps/search/?api=1&query=${location.lat},${location.lng}`
  : `https://www.google.com/maps/search/?api=1&query=${mapQuery}`;
const mapEmbedHref = location
  ? `https://www.openstreetmap.org/export/embed.html?bbox=${location.lng - 0.01}%2C${location.lat - 0.01}%2C${location.lng + 0.01}%2C${location.lat + 0.01}&layer=mapnik&marker=${location.lat}%2C${location.lng}`
  : undefined;
---

<Layout
  title={`${listing.title} | Property App 2026`}
  description={listing.summary}
>
  <section class="detail-hero card">
    <div class="hero-media">
      <div class={`hero-image ${listing.tone}`} style={heroImage ? `background-image: linear-gradient(180deg, rgba(15, 23, 42, 0.08), rgba(15, 23, 42, 0.42)), url(${heroImage})` : undefined}>
        <div class="hero-badges">
          <span class="badge-primary">{intentLabel}</span>
          <span class="badge-secondary">{listing.status}</span>
        </div>
      </div>
      {listing.imageUrls && listing.imageUrls.length > 1 && (
        <div class="gallery-strip">
          {listing.imageUrls.slice(0, 4).map((imageUrl) => (
            <img src={imageUrl} alt={listing.title} loading="lazy" />
          ))}
        </div>
      )}
    </div>

    <div class="hero-panel">
      <a class="back-link" href="/listings/">All listings</a>
      <p class="eyebrow">{listing.type} · {listing.district}, {listing.city}</p>
      <h1>{listing.title}</h1>
      <p class="price">{listing.priceLabel}</p>
      <p class="summary">{listing.summary}</p>

      <div class="fact-grid">
        <article>
          <strong>{listing.beds}</strong>
          <span>Bedrooms</span>
        </article>
        <article>
          <strong>{listing.baths}</strong>
          <span>Bathrooms</span>
        </article>
        <article>
          <strong>{listing.area}</strong>
          <span>Square meters</span>
        </article>
      </div>

      <div class="trust-bar">
        <span>{ownerTrustLabel}</span>
        <span>{listing.owner.role}</span>
        <span>Replies in {listing.owner.responseTime}</span>
      </div>

      <div class="hero-actions">
        {isBuyer ? (
          <form method="POST" action={isSaved ? "/api/saved-listings/delete" : "/api/saved-listings"}>
            <input type="hidden" name="listingSlug" value={listing.slug} />
            <input type="hidden" name="redirectTo" value={`/listings/${listing.slug}/`} />
            <button type="submit" class="button-secondary">{isSaved ? "Saved to favorites" : "Save listing"}</button>
          </form>
        ) : (
          <a class="button-secondary" href={`/login?redirect=${encodeURIComponent(`/listings/${listing.slug}/`)}`}>Sign in to save</a>
        )}
        <a class="button-dark" href="#enquiry-panel">Enquire now</a>
      </div>
      {savedListing && <p class="flash-inline">Listing saved to your buyer dashboard.</p>}
    </div>
  </section>

  <section class="detail-grid">
    <article class="content-panel card">
      <div class="panel-section">
        <span class="section-kicker">Overview</span>
        <h2>Property overview</h2>
        <p>{listing.description}</p>
      </div>

      <div class="panel-section">
        <span class="section-kicker">Highlights</span>
        <div class="tag-row">
          {listing.tags.map((tag) => <span>{tag}</span>)}
        </div>
      </div>

      <div class="panel-section">
        <span class="section-kicker">Included features</span>
        <div class="feature-grid">
          {listing.features.map((feature) => (
            <div class="feature-item">
              <span class="feature-dot"></span>
              <span>{feature}</span>
            </div>
          ))}
        </div>
      </div>

      {neighborhood && (
        <div class="panel-section">
          <span class="section-kicker">Neighborhood context</span>
          <h2>What this location adds beyond the unit itself</h2>
          <p>{neighborhood.headline}</p>
          <div class="context-grid">
            <article>
              <strong>Commute and access</strong>
              <p>{neighborhood.commute}</p>
            </article>
            <article>
              <strong>Nearby anchors</strong>
              <ul>
                {neighborhood.nearby.map((item) => <li>{item}</li>)}
              </ul>
            </article>
            <article>
              <strong>Trust signals</strong>
              <ul>
                {neighborhood.trustSignals.map((item) => <li>{item}</li>)}
              </ul>
            </article>
          </div>
        </div>
      )}

      <div class="panel-section">
        <span class="section-kicker">Map and access</span>
        <h2>Location view</h2>
        <p>
          Use the map as orientation, not as a promise of exact door-level precision. For marketplace trust, approximate
          neighborhood placement is usually the right balance until the owner chooses to reveal more.
        </p>
        <div class="map-panel">
          {mapEmbedHref ? (
            <iframe
              title={`Map for ${listing.title}`}
              src={mapEmbedHref}
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
            ></iframe>
          ) : (
            <div class="map-fallback">
              <strong>{listing.ward}, {listing.district}</strong>
              <span>{listing.city}</span>
            </div>
          )}
          <div class="map-meta">
            <strong>{location?.precisionLabel || "Approximate neighborhood view"}</strong>
            <span>{listing.ward}, {listing.district}, {listing.city}</span>
            <div class="map-actions">
              <a class="button-dark" href={mapHref} target="_blank" rel="noreferrer">Open map</a>
            </div>
          </div>
        </div>
      </div>

      {listing.imageUrls && listing.imageUrls.length > 0 && (
        <div class="panel-section">
          <span class="section-kicker">Photo gallery</span>
          <div class="gallery-grid">
            {listing.imageUrls.map((imageUrl) => (
              <img src={imageUrl} alt={listing.title} loading="lazy" />
            ))}
          </div>
        </div>
      )}
    </article>

    <aside class="sidebar-stack">
      <section class="enquiry-panel card" id="enquiry-panel">
        <span class="section-kicker">Enquiry panel</span>
        <h2>Contact the owner</h2>
        <p class="enquiry-copy">
          Structured enquiries are the conversion layer. Buyers should know who they are contacting and owners should
          receive clean intent data, not vague messages.
        </p>
        {enquirySent && <p class="success-banner">Enquiry sent successfully. The owner can now see it in the dashboard.</p>}

        <div class="owner-card">
          <strong>{listing.owner.name}</strong>
          <span>{listing.owner.role}</span>
          <span>{ownerTrustLabel} · Replies in {listing.owner.responseTime}</span>
        </div>

        <form class="enquiry-form" method="POST" action="/api/enquiries">
          <input type="hidden" name="listingSlug" value={listing.slug} />
          <input type="hidden" name="listingTitle" value={listing.title} />
          <label>
            <span>Your name</span>
            <input type="text" name="applicantName" required placeholder="Enter your name" />
          </label>
          <label>
            <span>Contact</span>
            <input type="text" name="contact" required placeholder="Email or phone number" />
          </label>
          <label>
            <span>Preferred viewing time</span>
            <input type="text" name="preferredTime" placeholder="Saturday morning" />
          </label>
          <label>
            <span>Message</span>
            <textarea name="message" rows="5" required placeholder={`Hi, I'm interested in ${listing.title}. Is it still available?`}></textarea>
          </label>
          <button type="submit" class="button-dark full-width">Send enquiry</button>
        </form>
      </section>

      <section class="stats-panel card">
        <span class="section-kicker">Demand signals</span>
        <div class="stats-grid">
          <article>
            <strong>{listing.stats.views24h}</strong>
            <span>Views in the last 24 hours</span>
          </article>
          <article>
            <strong>{listing.stats.saves}</strong>
            <span>Buyers saved this listing</span>
          </article>
          <article>
            <strong>{listing.stats.enquiries}</strong>
            <span>Open conversations</span>
          </article>
        </div>
      </section>
    </aside>
  </section>

  {similarListings.length > 0 && (
    <section class="similar-section">
      <div class="section-head">
        <span class="section-kicker">Similar listings</span>
        <h2>Nearby alternatives worth comparing</h2>
        <p>Good detail pages should recover the browse journey instead of trapping the user on one listing.</p>
      </div>
      <div class="similar-grid">
        {similarListings.map((similarListing) => <ListingCard listing={similarListing} />)}
      </div>
    </section>
  )}

  <style>
    .detail-hero,
    .content-panel,
    .enquiry-panel,
    .stats-panel {
      padding: 1.1rem;
      background: rgba(255, 255, 255, 0.92);
      box-shadow: 0 1px 2px rgba(16, 24, 40, 0.04), 0 18px 40px rgba(16, 24, 40, 0.06);
    }

    .detail-hero {
      display: grid;
      grid-template-columns: minmax(0, 1.05fr) minmax(20rem, 0.95fr);
      gap: 1rem;
      overflow: hidden;
      background:
        radial-gradient(circle at 14% 14%, rgba(15, 118, 110, 0.08), transparent 22%),
        linear-gradient(180deg, rgba(255,255,255,0.96), rgba(255,255,255,0.9));
    }

    .hero-media,
    .sidebar-stack,
    .gallery-strip,
    .gallery-grid,
    .stats-grid,
    .similar-grid,
    .feature-grid {
      display: grid;
      gap: 1rem;
    }

    .hero-image {
      min-height: 25rem;
      padding: 1rem;
      border-radius: 22px;
      background-size: cover;
      background-position: center;
      display: flex;
      align-items: flex-start;
      justify-content: flex-start;
    }

    .sea:not([style]),
    .sun:not([style]),
    .forest:not([style]),
    .night:not([style]),
    .clay:not([style]),
    .sky:not([style]) {
      background-position: center;
    }

    .sea:not([style]) { background-image: linear-gradient(180deg, rgba(15,23,42,0.08), rgba(15,23,42,0.42)), linear-gradient(135deg, #98d4d5, #2f6f89); }
    .sun:not([style]) { background-image: linear-gradient(180deg, rgba(15,23,42,0.08), rgba(15,23,42,0.42)), linear-gradient(135deg, #f4c78d, #cf6f46); }
    .forest:not([style]) { background-image: linear-gradient(180deg, rgba(15,23,42,0.08), rgba(15,23,42,0.42)), linear-gradient(135deg, #a7d4b0, #255a4a); }
    .night:not([style]) { background-image: linear-gradient(180deg, rgba(15,23,42,0.08), rgba(15,23,42,0.45)), linear-gradient(135deg, #9ca8e6, #212c58); }
    .clay:not([style]) { background-image: linear-gradient(180deg, rgba(15,23,42,0.08), rgba(15,23,42,0.45)), linear-gradient(135deg, #deb28d, #996347); }
    .sky:not([style]) { background-image: linear-gradient(180deg, rgba(15,23,42,0.08), rgba(15,23,42,0.45)), linear-gradient(135deg, #c2dff6, #4f7cab); }

    .hero-badges,
    .hero-actions,
    .trust-bar,
    .tag-row,
    .section-head {
      display: flex;
      gap: 0.75rem;
      flex-wrap: wrap;
      align-items: center;
    }

    .badge-primary,
    .badge-secondary,
    .section-kicker,
    .tag-row span,
    .trust-bar span {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 2rem;
      padding: 0.22rem 0.75rem;
      border-radius: 999px;
      font-size: 0.78rem;
      font-weight: 800;
      letter-spacing: 0.04em;
    }

    .badge-primary,
    .badge-secondary {
      background: rgba(255,255,255,0.92);
      color: var(--brand);
    }

    .hero-panel {
      display: grid;
      gap: 1rem;
      padding: 0.35rem 0.3rem 0.3rem;
      align-content: start;
    }

    .back-link {
      color: var(--muted);
      text-decoration: none;
      font-weight: 700;
    }

    .eyebrow,
    .section-kicker {
      color: var(--accent-strong);
      text-transform: uppercase;
    }

    .eyebrow {
      margin: 0;
      font-size: 0.82rem;
      font-weight: 800;
      letter-spacing: 0.08em;
    }

    h1,
    .section-head h2 {
      margin: 0;
      font-size: clamp(2.4rem, 4.8vw, 4.35rem);
      letter-spacing: -0.08em;
      line-height: 0.96;
    }

    .section-head h2 {
      margin-top: 0.75rem;
      font-size: clamp(1.8rem, 3vw, 2.4rem);
    }

    .price {
      margin: 0;
      font-size: 1.75rem;
      font-weight: 800;
      letter-spacing: -0.05em;
    }

    .summary,
    .panel-section p,
    .enquiry-copy,
    .section-head p,
    .feature-item,
    .owner-card span,
    .stats-grid span,
    .flash-inline {
      color: var(--muted);
      line-height: 1.7;
      margin: 0;
    }

    .fact-grid,
    .detail-grid {
      display: grid;
      gap: 1rem;
    }

    .fact-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .fact-grid article,
    .stats-grid article,
    .context-grid article {
      padding: 1rem;
      border-radius: 22px;
      background: linear-gradient(180deg, #ffffff, #f8fafc);
      border: 1px solid rgba(208, 213, 221, 0.74);
    }

    .fact-grid strong,
    .stats-grid strong {
      display: block;
      margin-bottom: 0.35rem;
      font-size: 1.4rem;
      letter-spacing: -0.04em;
    }

    .trust-bar span,
    .tag-row span {
      background: rgba(248,250,252,0.96);
      border: 1px solid rgba(208, 213, 221, 0.74);
      color: var(--text);
      font-weight: 700;
    }

    .button-dark,
    .button-secondary {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 2.8rem;
      padding: 0.85rem 1rem;
      border-radius: 999px;
      font: inherit;
      font-weight: 700;
      text-decoration: none;
      cursor: pointer;
    }

    .button-dark {
      border: none;
      background: var(--brand);
      color: white;
      box-shadow: 0 14px 28px rgba(16, 24, 40, 0.16);
    }

    .button-secondary {
      border: 1px solid var(--line-strong);
      background: white;
      color: var(--text);
    }

    .flash-inline {
      color: #067647;
      font-weight: 700;
    }

    .detail-grid {
      grid-template-columns: minmax(0, 1.1fr) minmax(20rem, 0.9fr);
      margin-top: 1rem;
      align-items: start;
    }

    .panel-section + .panel-section {
      margin-top: 1.25rem;
      padding-top: 1.25rem;
      border-top: 1px solid var(--line);
    }

    .panel-section h2,
    .enquiry-panel h2 {
      margin: 0.7rem 0 0;
      font-size: 1.55rem;
      letter-spacing: -0.03em;
    }

    .feature-grid,
    .map-actions {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      margin-top: 1rem;
    }

    .map-panel {
      display: grid;
      grid-template-columns: minmax(0, 1.2fr) minmax(16rem, 0.8fr);
      gap: 1rem;
      margin-top: 1rem;
    }

    .map-panel iframe,
    .map-fallback {
      width: 100%;
      min-height: 20rem;
      border: 0;
      border-radius: 22px;
      background:
        linear-gradient(180deg, rgba(15, 23, 42, 0.05), rgba(15, 23, 42, 0.12)),
        radial-gradient(circle at 22% 20%, rgba(15, 118, 110, 0.16), transparent 18%),
        linear-gradient(135deg, #f8fafc, #e5edf6);
    }

    .map-fallback {
      display: grid;
      place-content: center;
      gap: 0.35rem;
      padding: 1.2rem;
      text-align: center;
    }

    .map-fallback strong {
      font-size: 1.1rem;
      letter-spacing: -0.03em;
    }

    .map-fallback span,
    .map-meta span {
      color: var(--muted);
    }

    .map-meta {
      display: grid;
      gap: 0.9rem;
      align-content: start;
      padding: 1rem;
      border-radius: 24px;
      background: linear-gradient(180deg, #ffffff, #f8fafc);
      border: 1px solid rgba(208, 213, 221, 0.74);
    }

    .map-meta strong {
      font-size: 1rem;
      letter-spacing: -0.02em;
    }

    .map-actions {
      display: flex;
      gap: 0.75rem;
      flex-wrap: wrap;
      margin-top: 0.25rem;
    }

    .context-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1rem;
      margin-top: 1rem;
    }

    .context-grid strong {
      display: block;
      margin-bottom: 0.55rem;
      font-size: 1rem;
      letter-spacing: -0.02em;
    }

    .context-grid p,
    .context-grid ul {
      margin: 0;
      color: var(--muted);
      line-height: 1.65;
    }

    .context-grid ul {
      padding-left: 1.1rem;
    }

    .feature-item {
      display: flex;
      gap: 0.7rem;
      align-items: center;
      padding: 0.9rem 1rem;
      border-radius: 20px;
      background: linear-gradient(180deg, #ffffff, #f8fafc);
      border: 1px solid rgba(208, 213, 221, 0.74);
    }

    .feature-dot {
      width: 0.65rem;
      height: 0.65rem;
      border-radius: 999px;
      background: linear-gradient(135deg, var(--brand), #23314d);
      flex: none;
    }

    .gallery-strip {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .gallery-strip img,
    .gallery-grid img {
      width: 100%;
      border-radius: 18px;
      object-fit: cover;
      background: rgba(14, 22, 40, 0.08);
    }

    .gallery-strip img {
      height: 7rem;
    }

    .gallery-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      margin-top: 1rem;
    }

    .gallery-grid img {
      height: 15rem;
    }

    .sidebar-stack {
      display: grid;
      gap: 1rem;
      position: sticky;
      top: 6rem;
    }

    .success-banner {
      padding: 0.9rem 1rem;
      border-radius: 18px;
      background: rgba(18, 183, 106, 0.08);
      color: #067647;
      font-weight: 700;
    }

    .owner-card {
      display: grid;
      gap: 0.2rem;
      padding: 1rem;
      border-radius: 22px;
      background: linear-gradient(180deg, #ffffff, #f8fafc);
      border: 1px solid rgba(208, 213, 221, 0.74);
    }

    .owner-card strong {
      display: block;
      font-size: 1.05rem;
      margin-bottom: 0.15rem;
    }

    .enquiry-form {
      display: grid;
      gap: 0.85rem;
      margin-top: 1rem;
    }

    .enquiry-form label {
      display: grid;
      gap: 0.4rem;
    }

    .enquiry-form label span {
      font-size: 0.9rem;
      font-weight: 700;
      color: var(--text);
    }

    .enquiry-form input,
    .enquiry-form textarea {
      width: 100%;
      border: 1px solid var(--line);
      border-radius: 16px;
      background: white;
      padding: 0.95rem 1rem;
      color: var(--text);
      font: inherit;
    }

    .full-width {
      width: 100%;
    }

    .stats-grid {
      grid-template-columns: 1fr;
    }

    .similar-section {
      margin-top: 1.15rem;
    }

    .section-head {
      margin-bottom: 1rem;
    }

    .similar-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    @media (max-width: 1100px) {
      .detail-hero,
      .detail-grid,
      .similar-grid,
      .context-grid,
      .map-panel {
        grid-template-columns: 1fr;
      }

      .sidebar-stack {
        position: static;
      }
    }

    @media (max-width: 760px) {
      .fact-grid,
      .feature-grid,
      .gallery-strip,
      .gallery-grid {
        grid-template-columns: 1fr;
      }

      .button-dark,
      .button-secondary {
        width: 100%;
      }

      .hero-actions,
      .trust-bar,
      .tag-row,
      .section-head {
        display: grid;
      }
    }
  </style>
</Layout>
