---
import Layout from "../../layouts/Layout.astro";
import DetailHero from "../../components/listing-detail/DetailHero.astro";
import DetailContent from "../../components/listing-detail/DetailContent.astro";
import DetailSidebar from "../../components/listing-detail/DetailSidebar.astro";
import SimilarListingsSection from "../../components/listing-detail/SimilarListingsSection.astro";
import { buildAuctionTimeline } from "../../data/listings";
import { buildListingInsights, hasPremiumInsightsAccess } from "../../lib/insights";
import { getAllListings, getAuctionBidderRegistrationRecord, getAuctionEventRecords, getAuctionWatchRecord, getListingBySlug, isListingSavedByUser, recordRecentlyViewedListing } from "../../lib/listings";
import { getDB } from "../../lib/runtime";

const t = Astro.locals.t || ((value: string) => value);
const { slug } = Astro.params;
const db = getDB(Astro.locals.runtime);
const viewer = Astro.locals.owner;
const listing = await getListingBySlug(slug ?? "", db);
const enquirySent = Astro.url.searchParams.get("enquiry") === "sent";
const savedListing = Astro.url.searchParams.get("savedListing") === "1";
const reportSent = Astro.url.searchParams.get("report") === "sent";
const protectedFlow = Astro.url.searchParams.get("protected") === "1";
const auctionWatchUpdated = Astro.url.searchParams.get("auctionWatchUpdated") === "1";
const auctionWatchRemoved = Astro.url.searchParams.get("auctionWatchRemoved") === "1";
const auctionRegistered = Astro.url.searchParams.get("auctionRegistered") === "1";
const auctionRegistrationRemoved = Astro.url.searchParams.get("auctionRegistrationRemoved") === "1";
const isBuyer = viewer?.role === "buyer" || viewer?.role === "admin";
const isSaved = listing ? await isListingSavedByUser(db, viewer?.id, listing.slug) : false;

if (!listing) {
  throw new Error(`Listing not found: ${slug}`);
}

if ((viewer?.role === "buyer" || viewer?.role === "admin") && db) {
  await recordRecentlyViewedListing(db, viewer.id, listing.slug);
}

const allListings = await getAllListings(db);
const similarListings = allListings
  .filter((candidate) => candidate.slug !== listing.slug)
  .sort((a, b) => {
    const aScore = Number(a.city === listing.city) + Number(a.intent === listing.intent) + Number(a.type === listing.type);
    const bScore = Number(b.city === listing.city) + Number(b.intent === listing.intent) + Number(b.type === listing.type);
    return bScore - aScore;
  })
  .slice(0, 3);
const insights = buildListingInsights(listing, allListings);
const hasPremiumInsights = hasPremiumInsightsAccess(viewer);

const intentLabel = listing.saleMode === "auction" ? t("Auction") : listing.intent === "buy" ? t("For sale") : t("For rent");
const ownerTrustLabel = listing.owner.verified ? t("Verified owner") : t("Owner listed");
const location = listing.location;
const mapQuery = encodeURIComponent(`${listing.ward}, ${listing.district}, ${listing.city}, ${listing.country}`);
const mapHref = location
  ? `https://www.google.com/maps/search/?api=1&query=${location.lat},${location.lng}`
  : `https://www.google.com/maps/search/?api=1&query=${mapQuery}`;
const mapEmbedHref = location
  ? `https://www.openstreetmap.org/export/embed.html?bbox=${location.lng - 0.01}%2C${location.lat - 0.01}%2C${location.lng + 0.01}%2C${location.lat + 0.01}&layer=mapnik&marker=${location.lat}%2C${location.lng}`
  : undefined;
const auctionWatch = listing.saleMode === "auction" ? await getAuctionWatchRecord(db, viewer?.id, listing.slug) : null;
const auctionRegistration = listing.saleMode === "auction" ? await getAuctionBidderRegistrationRecord(db, viewer?.id, listing.slug) : null;
const auctionTimeline = listing.saleMode === "auction" ? buildAuctionTimeline(listing.auction) : [];
const auctionEvents = listing.saleMode === "auction" ? await getAuctionEventRecords(db, listing.slug, 12) : [];
---

<Layout title={`${listing.title} | Property App 2026`} description={listing.summary}>
  <DetailHero
    listing={listing}
    intentLabel={intentLabel}
    ownerTrustLabel={ownerTrustLabel}
    isBuyer={isBuyer}
    isSaved={isSaved}
    savedListing={savedListing}
    t={t}
  />

  <section class="detail-grid">
    <DetailContent listing={listing} mapHref={mapHref} mapEmbedHref={mapEmbedHref} insights={insights} hasPremiumInsights={hasPremiumInsights} auctionTimeline={auctionTimeline} auctionEvents={auctionEvents} t={t} />
    <DetailSidebar
      listing={listing}
      ownerTrustLabel={ownerTrustLabel}
      enquirySent={enquirySent}
      isBuyer={isBuyer}
      reportSent={reportSent}
      protectedFlow={protectedFlow}
      auctionWatch={auctionWatch}
      auctionRegistration={auctionRegistration}
      auctionWatchUpdated={auctionWatchUpdated}
      auctionWatchRemoved={auctionWatchRemoved}
      auctionRegistered={auctionRegistered}
      auctionRegistrationRemoved={auctionRegistrationRemoved}
      t={t}
    />
  </section>

  <SimilarListingsSection similarListings={similarListings} t={t} />

  <style is:inline>
    .detail-grid {
      display: grid;
      grid-template-columns: minmax(0, 1.1fr) minmax(20rem, 0.9fr);
      gap: 1rem;
      margin-top: 1rem;
      align-items: start;
    }

    @media (max-width: 1100px) {
      .detail-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</Layout>
