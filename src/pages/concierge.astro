---
import Layout from "../layouts/Layout.astro";

const sent = Astro.url.searchParams.get("sent");
const error = Astro.url.searchParams.get("error");
const owner = Astro.locals.owner;
---

<Layout title="Property Concierge | Property App 2026" description="A high-touch service layer for buyers, renters, owners, and auction sellers who need help beyond standard listings.">
  <section class="hero-shell glass-card">
    <div class="hero-copy">
      <span class="pill">Property concierge</span>
      <h1>If the right place is not advertised yet, or the right listing strategy is not obvious, our team can help.</h1>
      <p>
        We want the product to run smoothly with as much automation as possible, but we also want the service layer to feel personal. If you need help sourcing, narrowing, preparing, or positioning something that the standard workflow does not fully cover, send a request and we will pick it up.
      </p>
      <div class="signal-grid">
        <span>Buyer sourcing help beyond current inventory</span>
        <span>Owner listing strategy and launch support</span>
        <span>Auction and high-attention inventory coordination</span>
        <span>High-touch service layered on top of structured workflows</span>
      </div>
    </div>
  </section>

  <section class="split-grid section-space">
    <article class="glass-card service-card">
      <strong>For buyers and renters</strong>
      <ul>
        <li>Help narrowing the shortlist when inventory feels noisy.</li>
        <li>Help sourcing options that are not yet clearly represented in the public inventory.</li>
        <li>Help making sense of trade-offs across price, location, timing, and trust.</li>
      </ul>
    </article>
    <article class="glass-card service-card">
      <strong>For owners and landlords</strong>
      <ul>
        <li>Help improving listing quality before paying for visibility.</li>
        <li>Help deciding whether a listing should run as standard, promoted, or auction inventory.</li>
        <li>Help coordinating a stronger listing launch and follow-through path.</li>
      </ul>
    </article>
  </section>

  {(sent || error) && (
    <section class={`glass-card flash ${error ? "error-flash" : ""}`}>
      {sent ? "Your service request was submitted. The team can now review it from the admin queue." : "The request could not be submitted. Check the form and try again."}
    </section>
  )}

  <section class="glass-card request-shell section-space">
    <div class="request-copy">
      <span class="pill">Request support</span>
      <h2>Ask for human help where the standard workflow stops.</h2>
      <p>
        This is for cases where the product should still feel personal: off-market sourcing, listing strategy, auction preparation, or a buyer journey that needs more guidance than a standard search form can provide.
      </p>
    </div>

    <form class="request-form" method="POST" action="/api/service-request">
      <div class="form-grid form-two">
        <label class="field">
          <span>Name</span>
          <input class="input-luxury" name="name" required placeholder="Nguyen Anh" value={owner?.full_name ?? ""} />
        </label>
        <label class="field">
          <span>Email</span>
          <input class="input-luxury" type="email" name="email" required placeholder="name@example.com" value={owner?.email ?? ""} />
        </label>
      </div>

      <div class="form-grid form-three">
        <label class="field">
          <span>Phone</span>
          <input class="input-luxury" name="phone" placeholder="+84 ..." value={owner?.phone ?? ""} />
        </label>
        <label class="field">
          <span>You are</span>
          <select class="input-luxury" name="role">
            <option value="buyer">Buyer</option>
            <option value="renter">Renter</option>
            <option value="owner">Owner</option>
            <option value="landlord">Landlord</option>
            <option value="developer">Developer</option>
            <option value="agent">Agent</option>
          </select>
        </label>
        <label class="field">
          <span>Request type</span>
          <select class="input-luxury" name="requestType">
            <option value="sourcing-help">Find me options</option>
            <option value="listing-strategy">Help with listing strategy</option>
            <option value="auction-support">Auction support</option>
            <option value="pricing-guidance">Pricing guidance</option>
            <option value="general-support">General support</option>
          </select>
        </label>
      </div>

      <div class="form-grid form-three">
        <label class="field">
          <span>Market intent</span>
          <select class="input-luxury" name="marketIntent">
            <option value="">Not sure yet</option>
            <option value="buy">Buy</option>
            <option value="rent">Rent</option>
            <option value="sell">Sell</option>
            <option value="let">Let</option>
            <option value="auction">Auction</option>
          </select>
        </label>
        <label class="field">
          <span>City or area</span>
          <input class="input-luxury" name="city" placeholder="Ho Chi Minh City, Binh Thanh, Da Nang..." />
        </label>
        <label class="field">
          <span>Budget or price context</span>
          <input class="input-luxury" name="budgetLabel" placeholder="Up to 6B VND, 45M VND / month, reserve not fixed..." />
        </label>
      </div>

      <label class="field">
        <span>Timeline</span>
        <input class="input-luxury" name="timelineLabel" placeholder="Need options this month, launch in two weeks, auction next quarter..." />
      </label>

      <label class="field">
        <span>What do you need help with?</span>
        <textarea class="input-luxury area-input" name="message" rows="6" required placeholder="Explain what is missing from the normal workflow, what you have already seen, and where you want human help from the team."></textarea>
      </label>

      <button type="submit" class="btn-primary">Send request</button>
    </form>
  </section>

  <style is:inline>
    .hero-shell,
    .service-card,
    .request-shell,
    .flash {
      padding: var(--space-xl);
    }

    .hero-shell {
      display: grid;
      gap: var(--space-m);
      background:
        radial-gradient(circle at top left, color-mix(in srgb, var(--accent) 10%, transparent), transparent 28rem),
        linear-gradient(180deg, color-mix(in srgb, var(--card) 94%, transparent), color-mix(in srgb, var(--card) 82%, transparent));
    }

    .hero-copy,
    .request-shell,
    .request-copy,
    .service-card,
    .request-form,
    .field {
      display: grid;
      gap: var(--space-m);
    }

    .hero-copy h1,
    .request-copy h2 {
      margin: 0;
      font-size: var(--text-5xl);
      line-height: 0.94;
      letter-spacing: -0.06em;
      max-width: 14ch;
    }

    .hero-copy p,
    .service-card li,
    .request-copy p {
      margin: 0;
      color: var(--muted);
      line-height: 1.72;
    }

    .signal-grid,
    .split-grid,
    .form-grid {
      display: grid;
      gap: var(--space-m);
    }

    .signal-grid,
    .split-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .signal-grid span {
      padding: var(--space-l);
      border-radius: var(--radius-lg);
      border: 1px solid var(--border);
      background: color-mix(in srgb, var(--card) 78%, transparent);
      color: var(--muted);
      font-size: var(--text-sm);
      font-weight: 600;
    }

    .service-card ul {
      margin: 0;
      padding-left: var(--space-m);
      display: grid;
      gap: var(--space-xs);
    }

    .form-two {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .form-three {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .field span {
      color: var(--muted);
      font-size: var(--text-sm);
      font-weight: 600;
    }

    .area-input {
      min-height: calc(var(--space-xl) * 4);
    }

    .flash {
      margin-top: var(--space-m);
    }

    .error-flash {
      border-color: color-mix(in srgb, var(--accent) 18%, var(--border));
      background: color-mix(in srgb, var(--card) 82%, transparent);
      color: var(--text);
    }

    @media (max-width: 900px) {
      .signal-grid,
      .split-grid,
      .form-two,
      .form-three {
        grid-template-columns: 1fr;
      }
    }
  </style>
</Layout>
