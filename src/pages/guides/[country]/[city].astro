---
import Layout from "../../../layouts/Layout.astro";
import { getAllListings } from "../../../lib/listings";
import { getDB } from "../../../lib/runtime";
import { buildAreaGuideInsights, getGuideMarkets, hasPremiumInsightsAccess, matchGuideCity } from "../../../lib/insights";

const listings = await getAllListings(getDB(Astro.locals.runtime));
const viewer = Astro.locals.owner;
const hasPremiumInsights = hasPremiumInsightsAccess(viewer);
const t = Astro.locals.t || ((value: string) => value);
const match = matchGuideCity(Astro.params.country ?? "", Astro.params.city ?? "", listings);

if (!match) {
  return Astro.redirect("/listings/");
}

const insights = buildAreaGuideInsights(match.country, match.city, listings);
const cityListings = listings.filter((listing) => listing.country === match.country && listing.city === match.city).slice(0, 6);
const relatedDistricts = getGuideMarkets(listings).districts.filter((entry) => entry.country === match.country && entry.city === match.city).slice(0, 6);
---

<Layout title={`${match.city} guide | Property App 2026`} description={`Area guide, market signals, and listing context for ${match.city}, ${match.country}.`}>
  <section class="guide-hero card">
    <div class="hero-copy">
      <span class="pill">City guide</span>
      <h1>{match.city} should feel easier to read than a raw directory page.</h1>
      <p>{match.city} is one of the live search markets on the platform. This guide translates the inventory into quick public signals first, then deeper insight for logged-in and premium users.</p>
      <div class="hero-actions">
        <a class="button-primary" href={`/listings/?city=${encodeURIComponent(match.city)}`}>Browse {match.city} listings</a>
        <a class="button-secondary" href="/concierge">Ask for local help</a>
      </div>
    </div>
    <div class="hero-panel">
      <strong>Free signals</strong>
      <ul>
        <li>{insights.free.priceBandLabel}</li>
        <li>{insights.free.marketPaceLabel}</li>
        <li>{insights.free.demandLabel}</li>
      </ul>
    </div>
  </section>

  <section class="guide-grid section-gap">
    <article class="guide-card card">
      <span class="pill">Free insight</span>
      <strong>Useful before login</strong>
      <ul>
        <li>Typical visible price band: {insights.free.priceBandLabel}</li>
        <li>Market pace: {insights.free.marketPaceLabel}</li>
        <li>Demand signal: {insights.free.demandLabel}</li>
        <li>Best for: {insights.free.bestFor.join(", ")}</li>
      </ul>
    </article>
    <article class={`guide-card card premium-card ${hasPremiumInsights ? "open" : "locked"}`}>
      <span class="pill">Premium insight</span>
      <strong>{hasPremiumInsights ? "Deeper market read" : "Advanced signals for serious users"}</strong>
      {hasPremiumInsights ? (
        <>
          <p>{insights.premium.pricingNarrative}</p>
          <p>{insights.premium.renterVsBuyerLabel}</p>
        </>
      ) : (
        <p>Premium users unlock deeper market reads, stronger pricing context, and better area comparison tools without leaving the product.</p>
      )}
    </article>
  </section>

  <section class="guide-grid section-gap">
    <article class="guide-card card">
      <span class="pill">Area fit</span>
      <strong>What this city looks strongest for</strong>
      <div class="chip-row">
        {insights.free.bestFor.map((item) => <span>{item}</span>)}
      </div>
      <p>{match.city} is strongest when users need a quick read on which districts to search first and which market lane they should be in before comparing individual listings.</p>
    </article>
    <article class="guide-card card">
      <span class="pill">Property mix</span>
      <strong>What shows up most often</strong>
      <div class="chip-row">
        {insights.free.topPropertyTypes.map((item) => <span>{item}</span>)}
      </div>
      <p>The visible mix matters because casual users usually want to know whether a city is fundamentally condo-led, house-led, or a broader mixed supply market.</p>
    </article>
  </section>

  {relatedDistricts.length > 0 && (
    <section class="district-panel card section-gap">
      <div class="panel-head">
        <div>
          <span class="pill">District guides</span>
          <h2>Best districts to open next</h2>
        </div>
        <p>Go one level deeper when the city is still too broad.</p>
      </div>
      <div class="district-grid">
        {relatedDistricts.map((entry) => (
          <a class="district-card" href={`/guides/${encodeURIComponent(entry.country.toLowerCase().replace(/\s+/g, "-"))}/${encodeURIComponent(entry.city.toLowerCase().replace(/\s+/g, "-"))}/${encodeURIComponent(entry.district.toLowerCase().replace(/\s+/g, "-"))}/`}>
            <strong>{entry.district}</strong>
            <span>{entry.city}, {entry.country}</span>
          </a>
        ))}
      </div>
    </section>
  )}

  <section class="listing-panel card section-gap">
    <div class="panel-head">
      <div>
        <span class="pill">Live inventory</span>
        <h2>Current listings in {match.city}</h2>
      </div>
      <p>{cityListings.length} examples pulled from the live inventory layer.</p>
    </div>
    <div class="listing-grid">
      {cityListings.map((listing) => (
        <a class="listing-card" href={`/listings/${listing.slug}/`}>
          <strong>{listing.title}</strong>
          <span>{listing.priceLabel}</span>
          <span>{listing.ward}, {listing.district}</span>
        </a>
      ))}
    </div>
  </section>

  <style is:inline>
    .guide-hero,
    .guide-card,
    .district-panel,
    .listing-panel { padding: 1.4rem; }
    .guide-hero {
      display: grid;
      grid-template-columns: minmax(0, 1.2fr) minmax(18rem, 0.8fr);
      gap: 1rem;
      align-items: start;
      background: linear-gradient(180deg, var(--surface-overlay-strong), var(--surface-panel-muted));
    }
    .hero-copy,
    .hero-panel,
    .guide-card,
    .panel-head { display: grid; gap: 0.8rem; }
    .hero-copy h1,
    .panel-head h2 { margin: 0; font-size: clamp(2rem, 5vw, 3.5rem); line-height: 0.95; letter-spacing: -0.08em; }
    .guide-card strong,
    .district-card strong,
    .listing-card strong { font-size: 1rem; letter-spacing: -0.03em; }
    .hero-copy p,
    .hero-panel li,
    .guide-card p,
    .guide-card li,
    .district-card span,
    .listing-card span,
    .panel-head p { margin: 0; color: var(--muted); line-height: 1.7; }
    .hero-actions,
    .chip-row { display: flex; gap: 0.7rem; flex-wrap: wrap; }
    .button-primary,
    .button-secondary {
      display: inline-flex; align-items: center; justify-content: center; min-height: 2.85rem; padding: 0.85rem 1.05rem;
      border-radius: 999px; font-weight: 700; text-decoration: none;
    }
    .button-primary { background: linear-gradient(135deg, var(--brand), color-mix(in srgb, var(--brand) 82%, var(--surface-soft))); color: var(--surface-canvas); }
    .button-secondary { background: var(--surface-elevated-strong); border: 1px solid var(--line); color: var(--text); }
    .hero-panel,
    .district-card,
    .listing-card { padding: 1rem; border-radius: 20px; background: linear-gradient(180deg, var(--surface-elevated-strong), var(--surface-panel-muted)); border: 1px solid var(--line); }
    .guide-grid,
    .district-grid,
    .listing-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 1rem; }
    .premium-card.locked { background: linear-gradient(180deg, color-mix(in srgb, var(--accent-strong) 10%, transparent), var(--surface-elevated-strong)); }
    .chip-row span { display: inline-flex; align-items: center; min-height: 1.9rem; padding: 0.2rem 0.7rem; border-radius: 999px; background: var(--brand-soft); color: var(--muted-strong); font-size: 0.78rem; font-weight: 700; }
    .guide-card ul,
    .hero-panel ul { margin: 0; padding-left: 1rem; display: grid; gap: 0.35rem; }
    .district-card,
    .listing-card { display: grid; gap: 0.3rem; text-decoration: none; color: inherit; }
    @media (max-width: 960px) {
      .guide-hero,
      .guide-grid,
      .district-grid,
      .listing-grid { grid-template-columns: 1fr; }
    }
  </style>
</Layout>
