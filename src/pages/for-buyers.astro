---
import Layout from "../layouts/Layout.astro";

const buyerBenefits = [
  {
    title: "Search with less clutter",
    body: "The browse flow is designed around clear intent, practical filters, and neighborhood context instead of noisy portal patterns.",
  },
  {
    title: "Save what matters",
    body: "Buyers can save searches, save listings, and return to a cleaner shortlist without starting from scratch.",
  },
  {
    title: "Track follow-through",
    body: "The useful part is not just discovery. It is moving from shortlist to enquiry without losing track of what you contacted.",
  },
  {
    title: "Ask for human help when needed",
    body: "If the right option is not visible yet, or you need help narrowing a serious shortlist, the concierge flow gives you a direct path to the team.",
  },
];
---

<Layout
  title="For Buyers | Property App 2026"
  description="Search listings, save homes, and manage buyer workflows with a cleaner marketplace experience."
>
  <section class="landing-hero card">
    <div class="hero-copy">
      <span class="section-kicker">For buyers</span>
      <h1>Search, shortlist, and enquire without the usual marketplace noise.</h1>
      <p>
        This page explains the buyer side clearly: search, save, revisit, and act. The product is more usable when the
        buyer workflow is explicit instead of buried across several screens.
      </p>
      <div class="hero-actions">
        <a class="button-primary" href="/listings/?intent=buy">Browse homes</a>
        <a class="button-secondary" href="/signup?role=buyer">Create buyer account</a>
        <a class="button-secondary" href="/concierge">Ask for help</a>
      </div>
    </div>
    <div class="hero-panel">
      <strong>Buyer workflow</strong>
      <ul>
        <li>Search by city, district, type, beds, and budget</li>
        <li>Save listings and searches to revisit later</li>
        <li>Open maps, compare contexts, and enquire directly</li>
        <li>Escalate to concierge help if the shortlist is still not right</li>
      </ul>
    </div>
  </section>

  <section class="benefits-grid">
    {buyerBenefits.map((benefit) => (
      <article class="benefit-card card">
        <span class="section-kicker">Buyer benefit</span>
        <h2>{benefit.title}</h2>
        <p>{benefit.body}</p>
      </article>
    ))}
  </section>

  <section class="cta-band card">
    <div>
      <span class="section-kicker">Buyer tools</span>
      <h2>Good buyer UX is mostly about reducing friction between search and action.</h2>
      <p>
        That is why saved searches, saved listings, map context, and enquiry flow matter more than decorative feature lists.
      </p>
    </div>
    <a class="button-primary" href="/buyer/dashboard/">Go to buyer dashboard</a>
  </section>

  <style is:inline>
    .landing-hero,
    .cta-band,
    .benefit-card {
      padding: 1.4rem;
      background: var(--surface-elevated);
      box-shadow: 0 1px 2px rgba(16, 24, 40, 0.04), 0 16px 36px rgba(16, 24, 40, 0.06);
    }

    .landing-hero,
    .cta-band {
      display: grid;
      grid-template-columns: minmax(0, 1.15fr) minmax(18rem, 0.85fr);
      gap: 1rem;
      align-items: start;
    }

    .hero-copy h1,
    .benefit-card h2,
    .cta-band h2 {
      margin: 0.8rem 0 0;
      font-size: clamp(2.1rem, 4vw, 3.8rem);
      letter-spacing: -0.08em;
      line-height: 0.96;
    }

    .benefit-card h2,
    .cta-band h2 {
      font-size: clamp(1.4rem, 2.4vw, 2rem);
    }

    .hero-copy p,
    .benefit-card p,
    .cta-band p,
    .hero-panel,
    .hero-panel li {
      color: var(--muted);
      line-height: 1.7;
    }

    .hero-actions {
      display: flex;
      gap: 0.75rem;
      flex-wrap: wrap;
      margin-top: 1.35rem;
    }

    .button-primary,
    .button-secondary {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 2.9rem;
      padding: 0.88rem 1.1rem;
      border-radius: 999px;
      font-weight: 700;
      text-decoration: none;
    }

    .button-primary {
      background: linear-gradient(135deg, var(--brand), #23314d);
      color: var(--surface-canvas);
    }

    .button-secondary {
      border: 1px solid var(--line);
      background: var(--surface-elevated-strong);
      color: var(--text);
    }

    .hero-panel {
      padding: 1.1rem;
      border-radius: 24px;
      background: linear-gradient(180deg, var(--surface-elevated-strong), var(--surface-panel-muted));
      border: 1px solid var(--line);
    }

    .hero-panel strong {
      display: block;
      margin-bottom: 0.8rem;
      font-size: 1.05rem;
      letter-spacing: -0.03em;
      color: var(--text);
    }

    .hero-panel ul {
      margin: 0;
      padding-left: 1.1rem;
    }

    .benefits-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1rem;
      margin-top: 1rem;
    }

    .cta-band {
      margin-top: 1rem;
    }

    @media (max-width: 980px) {
      .landing-hero,
      .cta-band,
      .benefits-grid {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 760px) {
      .hero-actions {
        display: grid;
      }

      .button-primary,
      .button-secondary {
        width: 100%;
      }
    }
  </style>
</Layout>
