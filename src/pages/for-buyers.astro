---
import Layout from "../layouts/Layout.astro";

const buyerBenefits = [
  {
    title: "Search with less clutter",
    body: "The browse flow is designed around clear intent, practical filters, and neighborhood context instead of noisy portal patterns.",
  },
  {
    title: "Save what matters",
    body: "Buyers can save searches, save listings, and return to a cleaner shortlist without starting from scratch.",
  },
  {
    title: "Track follow-through",
    body: "The useful part is not just discovery. It is moving from shortlist to enquiry without losing track of what you contacted.",
  },
  {
    title: "Ask for human help when needed",
    body: "If the right option is not visible yet, or you need help narrowing a serious shortlist, the concierge flow gives you a direct path to the team.",
  },
];

const buyerComparison = [
  {
    title: "What typical portals do",
    body: "Large operators in the region usually do breadth well: lots of listings, lots of categories, and basic search controls.",
  },
  {
    title: "Where they often fall short",
    body: "The buyer still has to do too much alone: compare manually, remember what they saw, and manage follow-up outside the product.",
  },
  {
    title: "What we do better",
    body: "Shortlist state, collections, compare, finalists, enquiry history, market insights, and concierge support all work together as one decision flow.",
  },
];
---

<Layout
  title="For Buyers | Property App 2026"
  description="Search listings, save homes, and manage buyer workflows with a cleaner marketplace experience."
>
  <section class="hero-shell glass-card">
    <div class="hero-copy">
      <span class="pill">For buyers</span>
      <h1>Search, shortlist, and enquire without the usual marketplace noise.</h1>
      <p>
        This page explains the buyer side clearly: search, save, revisit, and act. The product is more usable when the buyer workflow is explicit instead of buried across several screens.
      </p>
      <div class="hero-actions">
        <a class="btn-primary" href="/listings/?intent=buy">Browse homes</a>
        <a class="button-shell" href="/signup?role=buyer">Create buyer account</a>
        <a class="button-shell" href="/concierge">Ask for help</a>
      </div>
    </div>
    <div class="surface-card hero-panel">
      <strong>Buyer workflow</strong>
      <ul>
        <li>Search by city, district, type, beds, and budget</li>
        <li>Save listings and searches to revisit later</li>
        <li>Open maps, compare contexts, and enquire directly</li>
        <li>Escalate to concierge help if the shortlist is still not right</li>
      </ul>
    </div>
  </section>

  <section class="card-grid section-space">
    {buyerBenefits.map((benefit) => (
      <article class="glass-card benefit-card">
        <span class="pill">Buyer benefit</span>
        <h2>{benefit.title}</h2>
        <p>{benefit.body}</p>
      </article>
    ))}
  </section>

  <section class="card-grid section-space">
    {buyerComparison.map((item) => (
      <article class="glass-card benefit-card">
        <span class="pill">Buyer comparison</span>
        <h2>{item.title}</h2>
        <p>{item.body}</p>
      </article>
    ))}
  </section>

  <section class="glass-card note-shell section-space">
    <div class="note-copy">
      <span class="pill">Buyer tools</span>
      <h2>Good buyer UX is mostly about reducing friction between search and action.</h2>
      <p>
        That is why saved searches, saved listings, map context, and enquiry flow matter more than decorative feature lists.
      </p>
    </div>
    <a class="btn-primary" href="/buyer/dashboard/">Go to buyer dashboard</a>
  </section>

  <style is:inline>
    .hero-shell,
    .benefit-card,
    .note-shell {
      padding: var(--space-xl);
    }

    .hero-shell,
    .note-shell {
      display: grid;
      grid-template-columns: minmax(0, 1.15fr) minmax(0, 0.85fr);
      gap: var(--space-m);
      align-items: start;
    }

    .hero-copy,
    .benefit-card,
    .note-copy,
    .hero-panel {
      display: grid;
      gap: var(--space-m);
    }

    .hero-copy h1,
    .benefit-card h2,
    .note-copy h2 {
      margin: 0;
      font-size: var(--text-5xl);
      line-height: 0.94;
      letter-spacing: -0.06em;
    }

    .benefit-card h2,
    .note-copy h2 {
      font-size: var(--text-2xl);
    }

    .hero-copy p,
    .benefit-card p,
    .note-copy p,
    .hero-panel,
    .hero-panel li {
      margin: 0;
      color: var(--muted);
      line-height: 1.72;
    }

    .hero-shell {
      background:
        radial-gradient(circle at top left, color-mix(in srgb, var(--accent) 10%, transparent), transparent 26rem),
        linear-gradient(180deg, color-mix(in srgb, var(--card) 94%, transparent), color-mix(in srgb, var(--card) 82%, transparent));
    }

    .hero-actions {
      display: flex;
      gap: var(--space-s);
      flex-wrap: wrap;
    }

    .button-shell {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: calc(var(--space-xl) + var(--space-s));
      padding: var(--space-s) var(--space-m);
      border-radius: var(--radius-full);
      border: 1px solid var(--border);
      background: color-mix(in srgb, var(--card) 78%, transparent);
      color: inherit;
      text-decoration: none;
      font-weight: 700;
      transition: all var(--duration-fast) var(--transition-luxury);
    }

    .button-shell:hover {
      border-color: color-mix(in srgb, var(--accent) 22%, var(--border));
      color: var(--accent);
    }

    .hero-panel ul {
      margin: 0;
      padding-left: var(--space-m);
      display: grid;
      gap: var(--space-xs);
    }

    .card-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: var(--space-m);
    }

    @media (max-width: 980px) {
      .hero-shell,
      .note-shell,
      .card-grid {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 760px) {
      .hero-actions {
        display: grid;
      }

      .btn-primary,
      .button-shell {
        width: 100%;
      }
    }
  </style>
</Layout>
