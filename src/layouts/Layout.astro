---
import { getUnreadInboxNotificationCount } from "../lib/notifications";
import { getDB } from "../lib/runtime";

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Property App 2026",
  description = "A clean property marketplace for searching homes, posting listings, and handling enquiries across mobile and desktop.",
} = Astro.props;

const viewer = Astro.locals.owner;
const pathname = Astro.url.pathname;
const isBuyer = viewer?.role === "buyer";
const isOwner = viewer?.role === "owner" || viewer?.role === "admin";
const isAdmin = viewer?.role === "admin";
const dashboardHref = isBuyer ? "/buyer/dashboard/" : "/owner/dashboard/";
const unreadCount = viewer ? await getUnreadInboxNotificationCount(getDB(Astro.locals.runtime), viewer.id) : 0;
const viewerLabel = viewer?.full_name || viewer?.email || "Account";
const viewerRoleLabel = isAdmin ? "Platform admin" : isBuyer ? "Buyer account" : viewer ? "Owner account" : "";

function getInitials(value?: string) {
  if (!value) return "PA";
  const parts = value.trim().split(/\s+/).filter(Boolean);
  if (parts.length === 1) return parts[0].slice(0, 2).toUpperCase();
  return `${parts[0][0] || ""}${parts[1][0] || ""}`.toUpperCase();
}

const viewerInitials = getInitials(viewer?.full_name || viewer?.email);

const primaryNav = [
  { label: "Buy", href: "/listings/?intent=buy", active: pathname === "/listings/" || pathname.startsWith("/listings/") },
  { label: "Rent", href: "/listings/?intent=rent", active: pathname === "/listings/" || pathname.startsWith("/listings/") },
  { label: "For buyers", href: "/for-buyers", active: pathname === "/for-buyers" },
  { label: "For owners", href: "/for-owners", active: pathname === "/for-owners" },
  { label: "Pricing", href: "/pricing", active: pathname === "/pricing" },
  ...(isOwner ? [{ label: "Post", href: "/submit-listing/", active: pathname === "/submit-listing/" }] : []),
  ...(viewer ? [{ label: "Inbox", href: "/account/inbox", active: pathname.startsWith("/account/inbox"), count: unreadCount }] : []),
];

const accountMenu = [
  ...(viewer ? [{ label: "Settings", href: "/account/notifications", active: pathname.startsWith("/account/notifications") }] : []),
  ...(viewer ? [{ label: isBuyer ? "Buyer" : "Dashboard", href: dashboardHref, active: pathname.startsWith("/buyer/") || pathname.startsWith("/owner/") }] : []),
  ...(isAdmin ? [{ label: "Billing", href: "/admin/billing/", active: pathname.startsWith("/admin/") }] : []),
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0e1628" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Property App" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="icon" href="/icons/icon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/icons/icon-192.svg" />
    <title>{title}</title>
    <style is:global>
      @import url("https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap");

      :root {
        color-scheme: light;
        --bg: #f5f7fb;
        --bg-deep: #0f172a;
        --panel: rgba(255, 255, 255, 0.9);
        --panel-strong: rgba(255, 255, 255, 0.97);
        --surface-alt: #eef2f8;
        --text: #0f172a;
        --muted: #667085;
        --accent: #0f766e;
        --accent-strong: #115e59;
        --brand: #0f172a;
        --brand-strong: #111827;
        --brand-soft: #e8eef8;
        --warm: #b76e27;
        --success: #17b26a;
        --line: #eaecf0;
        --line-strong: #d0d5dd;
        --shadow: 0 24px 48px rgba(15, 23, 42, 0.08);
        --shadow-soft: 0 10px 28px rgba(15, 23, 42, 0.06);
        font-family: "Plus Jakarta Sans", sans-serif;
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        min-height: 100vh;
        color: var(--text);
        background:
          radial-gradient(circle at 8% 10%, rgba(17, 24, 39, 0.05), transparent 22%),
          radial-gradient(circle at 78% 12%, rgba(15, 118, 110, 0.08), transparent 18%),
          linear-gradient(180deg, #fcfdff 0%, var(--bg) 100%);
      }

      main {
        max-width: 80rem;
        margin: 0 auto;
        padding: 1rem 1.25rem 5rem;
      }

      .shell {
        max-width: 80rem;
        margin: 0 auto;
        padding: 1rem 1.25rem 0;
      }

      .global-nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding: 0.9rem 1.05rem;
        position: sticky;
        top: 0.75rem;
        z-index: 20;
        background: rgba(255, 255, 255, 0.9);
        border-color: rgba(208, 213, 221, 0.7);
        box-shadow: var(--shadow-soft);
      }

      .brand-link {
        display: inline-flex;
        align-items: center;
        gap: 0.75rem;
        text-decoration: none;
        font-weight: 800;
      }

      .brand-mark {
        width: 2.4rem;
        height: 2.4rem;
        border-radius: 16px;
        display: grid;
        place-items: center;
        background: linear-gradient(135deg, var(--brand), #23314d);
        color: white;
        box-shadow: 0 12px 30px rgba(15, 23, 42, 0.22);
      }

      .brand-copy {
        display: grid;
        gap: 0.1rem;
      }

      .brand-copy small {
        color: var(--muted);
        font-size: 0.78rem;
      }

      .nav-cluster,
      .nav-links,
      .utility-links {
        display: flex;
        align-items: center;
        gap: 0.65rem;
        flex-wrap: wrap;
      }

      .nav-link,
      .utility-link,
      .auth-link,
      .nav-button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 2.75rem;
        padding: 0.8rem 1rem;
        border-radius: 999px;
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.82);
        color: var(--text);
        font-weight: 700;
        text-decoration: none;
        box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04);
      }

      .nav-link.active,
      .utility-link.active {
        background: var(--brand-soft);
        border-color: rgba(15, 23, 42, 0.12);
        color: var(--brand);
      }

      .auth-link.primary {
        border: none;
        background: linear-gradient(135deg, var(--brand), #23314d);
        color: white;
      }

      .link-with-count {
        gap: 0.55rem;
      }

      .count-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 1.35rem;
        height: 1.35rem;
        padding: 0 0.35rem;
        border-radius: 999px;
        background: rgba(15, 23, 42, 0.08);
        color: var(--brand);
        font-size: 0.74rem;
        font-weight: 800;
        line-height: 1;
      }

      .nav-link.active .count-badge,
      .utility-link.active .count-badge {
        background: rgba(15, 23, 42, 0.12);
      }

      .nav-button {
        cursor: pointer;
        font: inherit;
      }

      .account-menu {
        position: relative;
      }

      .account-summary {
        list-style: none;
        display: inline-flex;
        align-items: center;
        gap: 0.8rem;
        min-height: 3rem;
        padding: 0.45rem 0.55rem 0.45rem 0.45rem;
        border-radius: 999px;
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.9);
        cursor: pointer;
        box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04);
      }

      .account-summary::-webkit-details-marker {
        display: none;
      }

      .account-summary::marker {
        content: "";
      }

      .avatar-badge {
        width: 2.25rem;
        height: 2.25rem;
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, var(--brand), #23314d);
        color: white;
        font-size: 0.82rem;
        font-weight: 800;
        letter-spacing: 0.04em;
      }

      .account-copy {
        display: grid;
        gap: 0.1rem;
        min-width: 0;
      }

      .account-copy strong,
      .account-copy small {
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }

      .account-copy small {
        color: var(--muted);
        font-size: 0.76rem;
      }

      .chevron {
        color: var(--muted);
        font-size: 0.88rem;
        line-height: 1;
      }

      .account-menu[open] .chevron {
        transform: rotate(180deg);
      }

      .account-panel {
        position: absolute;
        right: 0;
        top: calc(100% + 0.6rem);
        width: min(18rem, 90vw);
        padding: 0.7rem;
        border-radius: 24px;
        border: 1px solid rgba(208, 213, 221, 0.78);
        background: rgba(255, 255, 255, 0.97);
        box-shadow: 0 24px 48px rgba(15, 23, 42, 0.12);
        display: grid;
        gap: 0.45rem;
        z-index: 40;
      }

      .account-panel-head {
        display: grid;
        gap: 0.15rem;
        padding: 0.55rem 0.7rem 0.65rem;
        border-bottom: 1px solid var(--line);
      }

      .account-panel-head strong {
        font-size: 0.96rem;
        letter-spacing: -0.02em;
      }

      .account-panel-head small {
        color: var(--muted);
        font-size: 0.8rem;
      }

      .account-item,
      .account-logout {
        width: 100%;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        min-height: 3rem;
        padding: 0.75rem 0.8rem;
        border-radius: 18px;
        border: 1px solid transparent;
        background: transparent;
        color: var(--text);
        font: inherit;
        font-weight: 700;
        text-decoration: none;
        text-align: left;
        cursor: pointer;
      }

      .account-item.active,
      .account-item:hover,
      .account-logout:hover {
        background: var(--brand-soft);
        border-color: rgba(15, 23, 42, 0.08);
      }

      .account-icon {
        width: 2rem;
        height: 2rem;
        border-radius: 14px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: rgba(15, 23, 42, 0.06);
        color: var(--brand);
        flex: none;
      }

      .account-icon svg {
        width: 1rem;
        height: 1rem;
      }

      .mobile-utility {
        display: none;
      }

      .mobile-spacer {
        display: none;
      }

      .card {
        background: var(--panel);
        backdrop-filter: blur(18px);
        border: 1px solid rgba(234, 236, 240, 0.92);
        border-radius: 28px;
        box-shadow: var(--shadow);
      }

      a {
        color: inherit;
      }

      .section-title {
        margin: 0 0 0.75rem;
        font-size: clamp(2rem, 4vw, 3.4rem);
        line-height: 0.98;
        letter-spacing: -0.05em;
      }

      .section-copy {
        margin: 0;
        color: var(--muted);
        font-size: 1.02rem;
        line-height: 1.7;
      }

      .pill {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        padding: 0.55rem 0.85rem;
        border-radius: 999px;
        border: 1px solid rgba(15, 23, 42, 0.08);
        background: var(--brand-soft);
        color: var(--brand);
        font-size: 0.82rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      @media (max-width: 760px) {
        .shell {
          padding: 0.9rem 0.9rem 0;
        }

        main {
          padding: 0.9rem 0.9rem 6rem;
        }

        .global-nav {
          display: grid;
          gap: 0.85rem;
          top: 0.5rem;
        }

        .nav-cluster {
          display: none;
        }

        .mobile-utility {
          position: fixed;
          left: 0.9rem;
          right: 0.9rem;
          bottom: 0.9rem;
          z-index: 30;
          display: grid;
          grid-template-columns: repeat(4, minmax(0, 1fr));
          gap: 0.6rem;
          padding: 0.7rem;
          background: rgba(255, 255, 255, 0.9);
          backdrop-filter: blur(18px);
          border: 1px solid var(--line);
          border-radius: 24px;
          box-shadow: var(--shadow);
        }

        .mobile-utility a {
          display: inline-flex;
          align-items: center;
          justify-content: center;
          min-height: 2.8rem;
          padding: 0.7rem 0.6rem;
          border-radius: 16px;
          text-decoration: none;
          color: var(--text);
          font-weight: 700;
          font-size: 0.88rem;
          background: rgba(16, 24, 40, 0.04);
        }

        .mobile-utility a.active {
          background: rgba(127, 86, 217, 0.08);
          color: var(--accent-strong);
        }

        .mobile-spacer {
          display: block;
          height: 4.5rem;
        }
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <header class="global-nav card">
        <a class="brand-link" href="/">
          <span class="brand-mark">P</span>
          <span class="brand-copy">
            <strong>Property App</strong>
            <small>SE Asia property marketplace</small>
          </span>
        </a>

        <div class="nav-cluster">
          <nav class="nav-links">
            {primaryNav.map((item) => (
              <a class:list={["nav-link", "link-with-count", item.active && "active"]} href={item.href}>
                <span>{item.label}</span>
                {item.count ? <span class="count-badge">{item.count > 9 ? "9+" : item.count}</span> : null}
              </a>
            ))}
          </nav>

          <div class="utility-links">
            {viewer ? (
              <details class="account-menu">
                <summary class="account-summary">
                  <span class="avatar-badge">{viewerInitials}</span>
                  <span class="account-copy">
                    <strong>{viewerLabel}</strong>
                    <small>{viewerRoleLabel}</small>
                  </span>
                  <span class="chevron">▾</span>
                </summary>
                <div class="account-panel">
                  <div class="account-panel-head">
                    <strong>{viewerLabel}</strong>
                    <small>{viewerRoleLabel}</small>
                  </div>

                  {accountMenu.map((item) => (
                    <a class:list={["account-item", item.active && "active"]} href={item.href}>
                      <span class="account-icon" aria-hidden="true">
                        {item.label === "Settings" ? (
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="3"></circle>
                            <path d="M19.4 15a1.7 1.7 0 0 0 .34 1.87l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06A1.7 1.7 0 0 0 15 19.4a1.7 1.7 0 0 0-1 .6 1.7 1.7 0 0 0-.33 1V21a2 2 0 1 1-4 0v-.09a1.7 1.7 0 0 0-.33-1 1.7 1.7 0 0 0-1-.6 1.7 1.7 0 0 0-1.87.34l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06A1.7 1.7 0 0 0 4.6 15a1.7 1.7 0 0 0-.6-1 1.7 1.7 0 0 0-1-.33H3a2 2 0 1 1 0-4h.09a1.7 1.7 0 0 0 1-.33 1.7 1.7 0 0 0 .6-1 1.7 1.7 0 0 0-.34-1.87l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06A1.7 1.7 0 0 0 9 4.6a1.7 1.7 0 0 0 1-.6 1.7 1.7 0 0 0 .33-1V3a2 2 0 1 1 4 0v.09a1.7 1.7 0 0 0 .33 1 1.7 1.7 0 0 0 1 .6 1.7 1.7 0 0 0 1.87-.34l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06A1.7 1.7 0 0 0 19.4 9c.27.3.48.64.6 1 .08.32.2.66.39.94.2.29.5.5.84.58H21a2 2 0 1 1 0 4h-.09a1.7 1.7 0 0 0-.94.39c-.29.2-.5.5-.58.84-.12.36-.33.7-.6 1Z"></path>
                          </svg>
                        ) : item.label === "Billing" ? (
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <rect x="3" y="5" width="18" height="14" rx="2"></rect>
                            <path d="M3 10h18"></path>
                            <path d="M7 15h3"></path>
                            <path d="M14 15h3"></path>
                          </svg>
                        ) : (
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                            <circle cx="12" cy="7" r="4"></circle>
                          </svg>
                        )}
                      </span>
                      <span>{item.label}</span>
                    </a>
                  ))}

                  <form method="POST" action="/api/auth/logout">
                    <button class="account-logout" type="submit">
                      <span class="account-icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                          <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
                          <path d="M16 17l5-5-5-5"></path>
                          <path d="M21 12H9"></path>
                        </svg>
                      </span>
                      <span>Log out</span>
                    </button>
                  </form>
                </div>
              </details>
            ) : (
              <>
                <a class="auth-link" href="/login">Sign in</a>
                <a class="auth-link primary" href="/signup?role=buyer">Create account</a>
              </>
            )}
          </div>
        </div>
      </header>
    </div>
    <main>
      <slot />
      <div class="mobile-spacer"></div>
    </main>
    <nav class="mobile-utility" aria-label="Mobile navigation">
      <a class:list-active={pathname.startsWith("/listings") || pathname === "/"} href="/listings/?intent=buy">Search</a>
      <a class:list-active={pathname.startsWith("/account/inbox")} href={viewer ? "/account/inbox" : "/login"}>
        {viewer && unreadCount > 0 ? `Inbox (${unreadCount > 9 ? "9+" : unreadCount})` : "Inbox"}
      </a>
      <a class:list-active={pathname.startsWith("/account/notifications")} href={viewer ? "/account/notifications" : "/login"}>Settings</a>
      <a class:list-active={pathname.startsWith("/buyer/") || pathname.startsWith("/owner/") || pathname.startsWith("/admin/")} href={viewer ? dashboardHref : "/login"}>{viewer ? "Account" : "Sign in"}</a>
    </nav>
    <script is:inline>
      if ("serviceWorker" in navigator) {
        window.addEventListener("load", async () => {
          try {
            const registrations = await navigator.serviceWorker.getRegistrations();
            await Promise.all(registrations.map((registration) => registration.unregister()));

            if ("caches" in window) {
              const keys = await caches.keys();
              await Promise.all(keys.map((key) => caches.delete(key)));
            }
          } catch {
            // Ignore cleanup failures while caching is intentionally disabled.
          }
        });
      }
    </script>
  </body>
</html>
