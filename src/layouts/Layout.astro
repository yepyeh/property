---
import { getDB, getUnreadInboxNotificationCount } from "../lib/marketplace";

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Property App 2026",
  description = "A clean property marketplace for searching homes, posting listings, and handling enquiries across mobile and desktop.",
} = Astro.props;

const viewer = Astro.locals.owner;
const pathname = Astro.url.pathname;
const isBuyer = viewer?.role === "buyer";
const isOwner = viewer?.role === "owner" || viewer?.role === "admin";
const isAdmin = viewer?.role === "admin";
const dashboardHref = isBuyer ? "/buyer/dashboard/" : "/owner/dashboard/";
const unreadCount = viewer ? await getUnreadInboxNotificationCount(getDB(Astro.locals.runtime), viewer.id) : 0;

const primaryNav = [
  { label: "Buy", href: "/listings/?intent=buy", active: pathname === "/listings/" || pathname.startsWith("/listings/") },
  { label: "Rent", href: "/listings/?intent=rent", active: pathname === "/listings/" || pathname.startsWith("/listings/") },
  ...(isOwner ? [{ label: "Post", href: "/submit-listing/", active: pathname === "/submit-listing/" }] : []),
  ...(viewer ? [{ label: "Inbox", href: "/account/inbox", active: pathname.startsWith("/account/inbox"), count: unreadCount }] : []),
];

const utilityNav = [
  ...(viewer ? [{ label: "Settings", href: "/account/notifications", active: pathname.startsWith("/account/notifications") }] : []),
  ...(viewer ? [{ label: isBuyer ? "Buyer" : "Dashboard", href: dashboardHref, active: pathname.startsWith("/buyer/") || pathname.startsWith("/owner/") }] : []),
  ...(isAdmin ? [{ label: "Billing", href: "/admin/billing/", active: pathname.startsWith("/admin/") }] : []),
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0e1628" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Property App" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="icon" href="/icons/icon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/icons/icon-192.svg" />
    <title>{title}</title>
    <style>
      @import url("https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Fraunces:opsz,wght@9..144,600;9..144,700&display=swap");

      :root {
        color-scheme: light;
        --bg: #f8fafc;
        --bg-deep: #101828;
        --panel: rgba(255, 255, 255, 0.88);
        --panel-strong: rgba(255, 255, 255, 0.96);
        --text: #101828;
        --muted: #667085;
        --accent: #7f56d9;
        --accent-strong: #6941c6;
        --warm: #f79009;
        --success: #17b26a;
        --line: #eaecf0;
        --line-strong: #d0d5dd;
        --shadow: 0 20px 40px rgba(16, 24, 40, 0.08);
        --shadow-soft: 0 8px 24px rgba(16, 24, 40, 0.06);
        font-family: "Plus Jakarta Sans", sans-serif;
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        min-height: 100vh;
        color: var(--text);
        background:
          radial-gradient(circle at 10% 10%, rgba(127, 86, 217, 0.12), transparent 24%),
          radial-gradient(circle at 80% 12%, rgba(23, 178, 106, 0.08), transparent 18%),
          linear-gradient(180deg, #fcfcfd 0%, var(--bg) 100%);
      }

      main {
        max-width: 80rem;
        margin: 0 auto;
        padding: 1rem 1.25rem 5rem;
      }

      .shell {
        max-width: 80rem;
        margin: 0 auto;
        padding: 1rem 1.25rem 0;
      }

      .global-nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding: 0.9rem 1.05rem;
        position: sticky;
        top: 0.75rem;
        z-index: 20;
        background: rgba(255, 255, 255, 0.82);
        border-color: rgba(208, 213, 221, 0.7);
        box-shadow: var(--shadow-soft);
      }

      .brand-link {
        display: inline-flex;
        align-items: center;
        gap: 0.75rem;
        text-decoration: none;
        font-weight: 800;
      }

      .brand-mark {
        width: 2.4rem;
        height: 2.4rem;
        border-radius: 16px;
        display: grid;
        place-items: center;
        background: linear-gradient(135deg, var(--accent), var(--accent-strong));
        color: white;
        box-shadow: 0 12px 30px rgba(127, 86, 217, 0.22);
      }

      .brand-copy {
        display: grid;
        gap: 0.1rem;
      }

      .brand-copy small {
        color: var(--muted);
        font-size: 0.78rem;
      }

      .nav-cluster,
      .nav-links,
      .utility-links {
        display: flex;
        align-items: center;
        gap: 0.65rem;
        flex-wrap: wrap;
      }

      .nav-link,
      .utility-link,
      .auth-link,
      .nav-button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 2.75rem;
        padding: 0.8rem 1rem;
        border-radius: 999px;
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.72);
        color: var(--text);
        font-weight: 700;
        text-decoration: none;
        box-shadow: 0 1px 2px rgba(16, 24, 40, 0.04);
      }

      .nav-link.active,
      .utility-link.active {
        background: rgba(127, 86, 217, 0.08);
        border-color: rgba(127, 86, 217, 0.22);
        color: var(--accent-strong);
      }

      .auth-link.primary {
        border: none;
        background: linear-gradient(135deg, var(--accent), var(--accent-strong));
        color: white;
      }

      .link-with-count {
        gap: 0.55rem;
      }

      .count-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 1.35rem;
        height: 1.35rem;
        padding: 0 0.35rem;
        border-radius: 999px;
        background: rgba(127, 86, 217, 0.12);
        color: var(--accent-strong);
        font-size: 0.74rem;
        font-weight: 800;
        line-height: 1;
      }

      .nav-link.active .count-badge,
      .utility-link.active .count-badge {
        background: rgba(127, 86, 217, 0.16);
      }

      .nav-button {
        cursor: pointer;
        font: inherit;
      }

      .mobile-utility {
        display: none;
      }

      .mobile-spacer {
        display: none;
      }

      .card {
        background: var(--panel);
        backdrop-filter: blur(18px);
        border: 1px solid rgba(234, 236, 240, 0.92);
        border-radius: 24px;
        box-shadow: var(--shadow);
      }

      a {
        color: inherit;
      }

      .section-title {
        margin: 0 0 0.75rem;
        font-family: "Fraunces", serif;
        font-size: clamp(2rem, 4vw, 3.4rem);
        line-height: 0.95;
        letter-spacing: -0.03em;
      }

      .section-copy {
        margin: 0;
        color: var(--muted);
        font-size: 1.02rem;
        line-height: 1.7;
      }

      .pill {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        padding: 0.55rem 0.85rem;
        border-radius: 999px;
        border: 1px solid rgba(127, 86, 217, 0.14);
        background: rgba(127, 86, 217, 0.08);
        color: var(--accent-strong);
        font-size: 0.82rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      @media (max-width: 760px) {
        .shell {
          padding: 0.9rem 0.9rem 0;
        }

        main {
          padding: 0.9rem 0.9rem 6rem;
        }

        .global-nav {
          display: grid;
          gap: 0.85rem;
          top: 0.5rem;
        }

        .nav-cluster {
          display: none;
        }

        .mobile-utility {
          position: fixed;
          left: 0.9rem;
          right: 0.9rem;
          bottom: 0.9rem;
          z-index: 30;
          display: grid;
          grid-template-columns: repeat(4, minmax(0, 1fr));
          gap: 0.6rem;
          padding: 0.7rem;
          background: rgba(255, 255, 255, 0.9);
          backdrop-filter: blur(18px);
          border: 1px solid var(--line);
          border-radius: 24px;
          box-shadow: var(--shadow);
        }

        .mobile-utility a {
          display: inline-flex;
          align-items: center;
          justify-content: center;
          min-height: 2.8rem;
          padding: 0.7rem 0.6rem;
          border-radius: 16px;
          text-decoration: none;
          color: var(--text);
          font-weight: 700;
          font-size: 0.88rem;
          background: rgba(16, 24, 40, 0.04);
        }

        .mobile-utility a.active {
          background: rgba(127, 86, 217, 0.08);
          color: var(--accent-strong);
        }

        .mobile-spacer {
          display: block;
          height: 4.5rem;
        }
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <header class="global-nav card">
        <a class="brand-link" href="/">
          <span class="brand-mark">P</span>
          <span class="brand-copy">
            <strong>Property App</strong>
            <small>SE Asia property marketplace</small>
          </span>
        </a>

        <div class="nav-cluster">
          <nav class="nav-links">
            {primaryNav.map((item) => (
              <a class:list={["nav-link", "link-with-count", item.active && "active"]} href={item.href}>
                <span>{item.label}</span>
                {item.count ? <span class="count-badge">{item.count > 9 ? "9+" : item.count}</span> : null}
              </a>
            ))}
          </nav>

          <div class="utility-links">
            {utilityNav.map((item) => (
              <a class:list={["utility-link", item.active && "active"]} href={item.href}>{item.label}</a>
            ))}

            {viewer ? (
              <form method="POST" action="/api/auth/logout">
                <button class="nav-button" type="submit">Log out</button>
              </form>
            ) : (
              <>
                <a class="auth-link" href="/login">Sign in</a>
                <a class="auth-link primary" href="/signup?role=buyer">Create account</a>
              </>
            )}
          </div>
        </div>
      </header>
    </div>
    <main>
      <slot />
      <div class="mobile-spacer"></div>
    </main>
    <nav class="mobile-utility" aria-label="Mobile navigation">
      <a class:list-active={pathname.startsWith("/listings") || pathname === "/"} href="/listings/?intent=buy">Search</a>
      <a class:list-active={pathname.startsWith("/account/inbox")} href={viewer ? "/account/inbox" : "/login"}>
        {viewer && unreadCount > 0 ? `Inbox (${unreadCount > 9 ? "9+" : unreadCount})` : "Inbox"}
      </a>
      <a class:list-active={pathname.startsWith("/account/notifications")} href={viewer ? "/account/notifications" : "/login"}>Settings</a>
      <a class:list-active={pathname.startsWith("/buyer/") || pathname.startsWith("/owner/") || pathname.startsWith("/admin/")} href={viewer ? dashboardHref : "/login"}>{viewer ? "Account" : "Sign in"}</a>
    </nav>
    <script is:inline>
      if ("serviceWorker" in navigator) {
        window.addEventListener("load", () => {
          navigator.serviceWorker.register("/sw.js").catch(() => {});
        });
      }
    </script>
  </body>
</html>
