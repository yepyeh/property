---
import appShellCss from "../styles/app-shell.css?raw";
import GlobalNav from "../components/shell/GlobalNav.astro";
import MobileNav from "../components/shell/MobileNav.astro";
import { getUnreadInboxNotificationCount } from "../lib/notifications";
import { getDB } from "../lib/runtime";

export interface Props {
  title?: string;
  description?: string;
  inlineShellCss?: boolean;
}

const {
  title = "Property App 2026",
  description = "A clean property marketplace for searching homes, posting listings, and handling enquiries across mobile and desktop.",
  inlineShellCss = true,
} = Astro.props;

const viewer = Astro.locals.owner;
const pathname = Astro.url.pathname;
const isBuyer = viewer?.role === "buyer";
const isOwner = viewer?.role === "owner" || viewer?.role === "admin";
const isAdmin = viewer?.role === "admin";
const dashboardHref = isBuyer ? "/buyer/dashboard/" : "/owner/dashboard/";
const unreadCount = viewer ? await getUnreadInboxNotificationCount(getDB(Astro.locals.runtime), viewer.id) : 0;
const viewerLabel = viewer?.full_name || viewer?.email || "Account";
const viewerRoleLabel = isAdmin ? "Platform admin" : isBuyer ? "Buyer account" : viewer ? "Owner account" : "";

function getInitials(value?: string) {
  if (!value) return "PA";
  const parts = value.trim().split(/\s+/).filter(Boolean);
  if (parts.length === 1) return parts[0].slice(0, 2).toUpperCase();
  return `${parts[0][0] || ""}${parts[1][0] || ""}`.toUpperCase();
}

const viewerInitials = getInitials(viewer?.full_name || viewer?.email);

const primaryNav = [
  { label: "Buy", href: "/listings/?intent=buy", active: pathname === "/listings/" || pathname.startsWith("/listings/") },
  { label: "Rent", href: "/listings/?intent=rent", active: pathname === "/listings/" || pathname.startsWith("/listings/") },
  { label: "For buyers", href: "/for-buyers", active: pathname === "/for-buyers" },
  { label: "For owners", href: "/for-owners", active: pathname === "/for-owners" },
  { label: "Pricing", href: "/pricing", active: pathname === "/pricing" },
  ...(isOwner ? [{ label: "Post", href: "/submit-listing/", active: pathname === "/submit-listing/" }] : []),
  ...(viewer ? [{ label: "Inbox", href: "/account/inbox", active: pathname.startsWith("/account/inbox"), count: unreadCount }] : []),
];

const accountMenu = [
  ...(viewer ? [{ label: "Settings", href: "/account/notifications", active: pathname.startsWith("/account/notifications") }] : []),
  ...(viewer ? [{ label: isBuyer ? "Buyer" : "Dashboard", href: dashboardHref, active: pathname.startsWith("/buyer/") || pathname.startsWith("/owner/") }] : []),
  ...(isAdmin ? [{ label: "Billing", href: "/admin/billing/", active: pathname.startsWith("/admin/") }] : []),
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0e1628" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Property App" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="icon" href="/icons/icon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/icons/icon-192.svg" />
    <title>{title}</title>
    {inlineShellCss && <style is:inline set:html={appShellCss}></style>}
  </head>
  <body>
    <div class="shell">
      <GlobalNav
        primaryNav={primaryNav}
        viewer={viewer}
        viewerLabel={viewerLabel}
        viewerRoleLabel={viewerRoleLabel}
        viewerInitials={viewerInitials}
        accountMenu={accountMenu}
      />
    </div>
    <main>
      <slot />
      <div class="mobile-spacer"></div>
    </main>
    <MobileNav pathname={pathname} viewer={viewer} unreadCount={unreadCount} dashboardHref={dashboardHref} />
    <script is:inline>
      if ("serviceWorker" in navigator) {
        window.addEventListener("load", async () => {
          try {
            const registrations = await navigator.serviceWorker.getRegistrations();
            await Promise.all(registrations.map((registration) => registration.unregister()));

            if ("caches" in window) {
              const keys = await caches.keys();
              await Promise.all(keys.map((key) => caches.delete(key)));
            }
          } catch {
            // Ignore cleanup failures while caching is intentionally disabled.
          }
        });
      }
    </script>
  </body>
</html>
